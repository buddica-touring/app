function toLD(dt){return dt.getFullYear()+"-"+String(dt.getMonth()+1).padStart(2,"0")+"-"+String(dt.getDate()).padStart(2,"0");}
function fmtD(d){if(!d)return"";const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);if(isNaN(dt))return d;const w=["日","月","火","水","木","金","土"];return`${dt.getMonth()+1}/${dt.getDate()}(${w[dt.getDay()]})`;}
function fmtFull(d){if(!d)return"";const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);if(isNaN(dt))return d;const w=["日","月","火","水","木","金","土"];return`${dt.getFullYear()}年${dt.getMonth()+1}月${dt.getDate()}日(${w[dt.getDay()]})`;}
function dOff(b,n){const d=new Date(b+"T00:00:00");d.setDate(d.getDate()+n);return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");}
function norm(d){if(!d)return"";const s=String(d).replace(/\//g,"-");if(s.length<=10)return s;const dt=new Date(s);if(isNaN(dt))return s.substring(0,10);return toLD(dt);}
function sD(a,b){return norm(a)===norm(b);}
// 車両重複チェック: targetVcに対してresIdの期間と1日でもかぶる予約orメンテがあるか
function checkVehicleConflict(targetVc,resId,data,fleet,maintenance){
  const res=data.find(r=>r.id===resId);if(!res)return null;
  const ld=norm(res.lendDate),rd=norm(res.returnDate);
  // 予約重複チェック
  const conflict=data.find(r=>r.id!==resId&&r.status!=="cancelled"&&fleet[r.id]===targetVc&&norm(r.lendDate)<=rd&&norm(r.returnDate)>=ld);
  if(conflict)return conflict;
  // メンテナンス重複チェック
  if(maintenance&&maintenance.length){
    const maintConflict=maintenance.find(m=>m.vehicleCode===targetVc&&norm(m.startDate)<=rd&&norm(m.endDate)>=ld);
    if(maintConflict)return{_isMaint:true,name:"メンテナンス("+maintConflict.label+")",lendDate:maintConflict.startDate,returnDate:maintConflict.endDate};
  }
  return null;
}
function toYM(d){const s=String(d);const dt=new Date(s.length===10?s+"T00:00:00":s);return`${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,"0")}`;}
function daysInMonth(ym){const[y,m]=ym.split("-").map(Number);return new Date(y,m,0).getDate();}
function ymLabel(ym){const[y,m]=ym.split("-").map(Number);return`${y}年${m}月`;}
function ymOff(ym,n){const[y,m]=ym.split("-").map(Number);const d=new Date(y,m-1+n,1);return`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`;}
let _id=0;function uid(){return"t"+(++_id);}
let _vid=100;function vuid(){return"v"+(++_vid);}

/* ===== Googleスプレッドシートから場所データ取得 ===== */
const PLACE_SHEET_CSV="https://docs.google.com/spreadsheets/d/e/2PACX-1vSBbORCPCGuadh3deGcfP1jFxO4aYJkxUnD5M0SH7Uu6-JCACjAE0Lg2fBdF39LGZvQNXOJ5JElP2ND/pub?gid=914474197&single=true&output=csv";
function parsePlaceCSV(text){
  const lines=[];let cur="";let inQ=false;
  for(let i=0;i<text.length;i++){
    const c=text[i];
    if(c==='"'){if(inQ&&text[i+1]==='"'){cur+='"';i++;}else{inQ=!inQ;}}
    else if(c===","&&!inQ){lines.length===0?lines.push([cur]):lines[lines.length-1].push(cur);cur="";}
    else if((c==="\n"||(c==="\r"&&text[i+1]==="\n"))&&!inQ){
      if(c==="\r")i++;
      if(lines.length===0){lines.push([cur]);lines.push([]);}else{lines[lines.length-1].push(cur);lines.push([]);}
      cur="";
    }else{cur+=c;}
  }
  if(cur||lines.length>0){if(lines.length===0)lines.push([cur]);else lines[lines.length-1].push(cur);}
  return lines.filter(r=>r.some(c=>c.trim()));
}
async function fetchPlaceData(targetResIds,onIncomplete){
  const resp=await fetch(PLACE_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  // ★ ヘッダー行を自動検出（空行をスキップ）
  let headerIdx=-1;
  for(let i=0;i<Math.min(20,rows.length);i++){
    const textCells=rows[i].filter(c=>c.trim()&&!/^\d{4}\//.test(c.trim()));
    if(textCells.length>=5){headerIdx=i;break;}
  }
  if(headerIdx<0)throw new Error("ヘッダー行が見つかりません");
  const header=rows[headerIdx];
  // ★ 予約番号列を自動検出
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(headerIdx+1,Math.min(headerIdx+6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  // ★ 場所列を自動検出（H列=DEL場所, Y列=返却・送迎場所=COL場所）
  let delPlaceCol=-1,colPlaceCol=-1;
  header.forEach((h,i)=>{
    const t=h.trim();
    if(t==="場所"&&delPlaceCol<0)delPlaceCol=i;
    if(t.includes("返却")&&t.includes("場所"))colPlaceCol=i;
  });
  if(delPlaceCol<0)delPlaceCol=7; // fallback: H列
  if(colPlaceCol<0)colPlaceCol=24; // fallback: Y列
  // ★ 2026-04-24 記入漏れ検出用: 予約者列・貸出日列を特定
  let nameCol=-1,lendDateCol=-1,returnDateCol=-1;
  header.forEach((h,i)=>{
    const t=(h||"").trim();
    if(t==="予約者"&&nameCol<0)nameCol=i;
    if(t==="貸出日"&&lendDateCol<0)lendDateCol=i;
    if(t==="返却日"&&returnDateCol<0)returnDateCol=i;
  });
  const targetSet=new Set(targetResIds);
  const result={};
  const incomplete=[]; // ★ 予約者名あり・予約番号なしの行を収集
  rows.slice(headerIdx+1).forEach((r,idx)=>{
    const rid=(r[resCol]||"").trim();
    // ★ SS記入漏れ検出: 予約者名あり・予約番号なし
    if(!rid&&nameCol>=0){
      const nm=(r[nameCol]||"").trim();
      const ld=lendDateCol>=0?(r[lendDateCol]||"").trim():"";
      const rd=returnDateCol>=0?(r[returnDateCol]||"").trim():"";
      const del=(r[delPlaceCol]||"").trim();
      const col=(r[colPlaceCol]||"").trim();
      // 予約者名があり、場所情報が入っている行のみ警告対象
      if(nm&&(del||col)){
        incomplete.push({row:headerIdx+1+idx+1,name:nm,lendDate:ld,returnDate:rd,delPlace:del,colPlace:col,kind:"place"});
      }
    }
    if(!rid||!targetSet.has(rid))return;
    const del=(r[delPlaceCol]||"").trim();
    const col=(r[colPlaceCol]||"").trim();
    if(result[rid]){
      if(del&&!result[rid].delPlace)result[rid].delPlace=del;
      if(col&&!result[rid].colPlace)result[rid].colPlace=col;
    }else{
      result[rid]={delPlace:del,colPlace:col};
    }
  });
  if(onIncomplete&&incomplete.length)onIncomplete(incomplete);
  return result;
}

/* ===== スプレッドシートからDEL/COL時間データ取得 ===== */
async function fetchTimeData(targetResIds,onIncomplete){
  const resp=await fetch(PLACE_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  // ★ ヘッダー行を自動検出（空行をスキップ）
  let headerIdx=-1;
  for(let i=0;i<Math.min(20,rows.length);i++){
    const textCells=rows[i].filter(c=>c.trim()&&!/^\d{4}\//.test(c.trim()));
    if(textCells.length>=5){headerIdx=i;break;}
  }
  if(headerIdx<0)throw new Error("ヘッダー行が見つかりません");
  const header=rows[headerIdx];
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(headerIdx+1,Math.min(headerIdx+6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  // ★ 時間列を自動検出（C列=DEL時間, W列=返却時間=COL時間）
  let delTimeCol=-1,colTimeCol=-1;
  header.forEach((h,i)=>{
    const t=h.trim();
    if(t==="時間"&&delTimeCol<0)delTimeCol=i;
    if(t==="返却時間")colTimeCol=i;
  });
  if(delTimeCol<0)delTimeCol=2; // fallback: C列
  if(colTimeCol<0)colTimeCol=22; // fallback: W列
  // ★ 2026-04-24 記入漏れ検出用: 予約者列・貸出日列・返却日列を特定
  let nameCol=-1,lendDateCol=-1,returnDateCol=-1;
  header.forEach((h,i)=>{
    const t=(h||"").trim();
    if(t==="予約者"&&nameCol<0)nameCol=i;
    if(t==="貸出日"&&lendDateCol<0)lendDateCol=i;
    if(t==="返却日"&&returnDateCol<0)returnDateCol=i;
  });
  const targetSet=new Set(targetResIds);
  const result={};
  const incomplete=[]; // ★ 予約者名あり・予約番号なしの行を収集
  rows.slice(headerIdx+1).forEach((r,idx)=>{
    const rid=(r[resCol]||"").trim();
    // ★ SS記入漏れ検出: 予約者名あり・予約番号なし・時間あり
    if(!rid&&nameCol>=0){
      const nm=(r[nameCol]||"").trim();
      const ld=lendDateCol>=0?(r[lendDateCol]||"").trim():"";
      const rd=returnDateCol>=0?(r[returnDateCol]||"").trim():"";
      const delT=(r[delTimeCol]||"").trim();
      const colT=(r[colTimeCol]||"").trim();
      // 予約者名があり、時間情報が入っている行のみ警告対象
      if(nm&&(delT||colT)){
        incomplete.push({row:headerIdx+1+idx+1,name:nm,lendDate:ld,returnDate:rd,delTime:delT,colTime:colT,kind:"time"});
      }
    }
    if(!rid||!targetSet.has(rid))return;
    const delT=(r[delTimeCol]||"").trim();
    const colT=(r[colTimeCol]||"").trim();
    if(result[rid]){
      if(delT&&!result[rid].delTime)result[rid].delTime=delT;
      if(colT&&!result[rid].colTime)result[rid].colTime=colT;
    }else{
      result[rid]={delTime:delT,colTime:colT};
    }
  });
  if(onIncomplete&&incomplete.length)onIncomplete(incomplete);
  return result;
}

/* ===== じゃらん決済スプレッドシートから支払データ取得 ===== */
const JALAN_PAY_SHEET_CSV="";  // ← 高松店用じゃらん決済スプレッドシートURLをここに設定
async function fetchJalanPaySheetData(targetResIds){
  if(!JALAN_PAY_SHEET_CSV)throw new Error("スプレッドシートURLが未設定です。\nJALAN_PAY_SHEET_CSV を設定してください。");
  const resp=await fetch(JALAN_PAY_SHEET_CSV);
  if(!resp.ok)throw new Error("CSV取得失敗: "+resp.status);
  const text=await resp.text();
  const rows=parsePlaceCSV(text);
  if(rows.length<2)throw new Error("データが空です");
  // 予約番号列を自動検出
  const header=rows[0];
  let resCol=-1;
  header.forEach((h,i)=>{if(h.includes("予約番号")||h.includes("予約ID")||h.includes("Reservation"))resCol=i;});
  if(resCol<0){
    for(let ci=0;ci<header.length;ci++){
      const sample=rows.slice(1,Math.min(6,rows.length)).map(r=>r[ci]||"");
      if(sample.some(s=>/^[A-Z0-9]{8,}$/.test(s.trim()))){resCol=ci;break;}
    }
  }
  if(resCol<0)throw new Error("予約番号の列が見つかりません");
  const payDateCol=3; // D列(index3) = 支払日
  const amountCol=5;  // F列(index5) = 金額
  const targetSet=new Set(targetResIds);
  const result={};
  rows.slice(1).forEach(r=>{
    const rid=(r[resCol]||"").trim();
    if(!rid||!targetSet.has(rid))return;
    const payDate=(r[payDateCol]||"").trim();
    const amount=(r[amountCol]||"").trim().replace(/[,¥￥\s]/g,"");
    // D列に日付が入っていれば支払済み
    if(payDate){
      result[rid]={adjustedPrice:amount||"0",payStatus:"完了",payDate:payDate};
    }
  });
  return result;
}

/* ===== タスク生成 ===== */
function generateTasks(reservations,date,fleet,vehicles){
  const tasks=[];
  const tomorrow=dOff(date,1);
  // 翌日出発の配車済み車両を収集（洗車タスク用）
  const tomorrowDELVehicles=new Set();
  reservations.forEach(r=>{
    if(r.status==="cancelled")return; // キャンセル済み除外
    if(sD(r.lendDate,tomorrow)&&fleet[r.id]){tomorrowDELVehicles.add(fleet[r.id]);}
  });
  reservations.forEach(r=>{
    if(r.status==="cancelled")return; // ★ キャンセル済みはタスク生成しない
    const fv=fleet[r.id];const veh=fv?vehicles.find(v=>v.code===fv):null;
    const base={reservationId:r.id,ota:r.ota,tel:r.tel||"",mail:r.mail||"",done:false,assignee:"",memo:"",assignedVehicle:fv||"",plateNo:veh?veh.no:"",insuranceChange:"",opts:{b:+(r.optB||0),c:+(r.optC||0),j:+(r.optJ||0),usb:+(r.optUSB||0)},yakkan:false,line:false,payment:false,_taskDate:norm(date)};
    // ★ TKM: DEL/PU判定 = visitType OR お届け場所の有無（Step2 CSV含む）
    // ★ 2026-05-02 v3.4.29: 仕様統一
    //   visit_type/return_type 明示値（来店/返却/PU/BD/DEL/COL）→ そのまま尊重
    //   ※ PUB/BDB は旧仕様の値。バス運用廃止により PU/BD に降格して扱う
    //   空のときだけ place から推論（送迎/空港 → PU/BD、それ以外 → DEL/COL）
    const isAirportOrBus=(p)=>p&&/送迎バス|14番のりば|11番|レンタカー送迎バス|高松空港|空港/.test(p);
    const dpOk=r.delPlace&&r.delPlace.trim()&&!/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し|FALSE|false|0)$/.test(r.delPlace.trim());
    const cpOk=r.colPlace&&r.colPlace.trim()&&!/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し|FALSE|false|0)$/.test(r.colPlace.trim());
    let lendType;
    if(r.visitType==="来店")lendType="来店";
    else if(["PU","BD","DEL","COL"].indexOf(r.visitType)>=0)lendType=r.visitType;
    else if(["PUB","BDB"].indexOf(r.visitType)>=0)lendType="PU";  // ★ バス廃止: PUBはPUに降格
    else if(isAirportOrBus(r.delPlace))lendType="PU";  // ハイエース送迎
    else if(dpOk)lendType="DEL";
    else lendType="PU";
    let retType;
    if(r.returnType==="返却")retType="返却";
    else if(["PU","BD","DEL","COL"].indexOf(r.returnType)>=0)retType=r.returnType;
    else if(["PUB","BDB"].indexOf(r.returnType)>=0)retType="BD";  // ★ バス廃止: BDBはBDに降格
    else if(isAirportOrBus(r.colPlace))retType="BD";  // ハイエース送迎
    else if(cpOk)retType="COL";
    else retType="BD";
    if(sD(r.lendDate,date)){const lTask={...base,_id:"d-"+r.id,type:lendType,time:r.delTime||r.lendTime,name:r.name,people:r.people,place:r.delPlace||"",vehicle:r.vehicle,insurance:r.insurance,flight:r.flight,returnDate:r.returnDate,returnTime:r.returnTime,returnType:retType,colPlace:r.colPlace||""};tasks.push(lTask);}
    if(sD(r.returnDate,date)){const place=r.colPlace||"";const rTask={...base,_id:"c-"+r.id,type:retType,time:r.colTime||r.returnTime,name:r.name,people:r.people,place,vehicle:r.vehicle,insurance:r.insurance,flight:""};tasks.push(rTask);}
  });
  // 洗車タスク: 翌日DELの配車済み車両のみ（未配車分はloadTasks内で追加管理）
  tomorrowDELVehicles.forEach(vc=>{
    const veh=vehicles.find(v=>v.code===vc);
    const tRes=reservations.find(r=>sD(r.lendDate,tomorrow)&&fleet[r.id]===vc);
    if(!veh)return;
    if(tasks.find(t=>t.type==="洗車"&&t.assignedVehicle===vc))return;
    const wType=tRes?(tRes.visitType==="DEL"?"DEL":"PU"):"DEL";
    tasks.push({_id:tRes?("w-"+tRes.id):uid(),type:"洗車",time:"",name:`翌日出発: ${tRes?tRes.name:""}`,people:0,place:"",vehicle:veh.type,insurance:"",flight:"",reservationId:tRes?tRes.id:"",ota:tRes?tRes.ota:"",tel:"",mail:"",done:false,assignee:"",memo:`${fmtD(tomorrow)} ${wType} ${tRes?tRes.lendTime:""} ${tRes?tRes.name:""}`,assignedVehicle:vc,plateNo:veh.no,insuranceChange:"",opts:{b:+(tRes&&tRes.optB||0),c:+(tRes&&tRes.optC||0),j:+(tRes&&tRes.optJ||0),usb:+(tRes&&tRes.optUSB||0)},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:"",_taskDate:norm(date)});
  });
  return tasks.sort((a,b)=>{
    // 洗車は最後にまとめる
    if(a.type==="洗車"&&b.type!=="洗車")return 1;
    if(a.type!=="洗車"&&b.type==="洗車")return -1;
    return(a.time||"").localeCompare(b.time||"");
  });
}

/* ===== 自動配車ロジック ===== */
function autoAssign(reservations,vehicles,existingFleet,maintenance){
  const fleet={...existingFleet};
  const maints=maintenance||[];
  // キャンセル済み除外
  // オフィシャル/直予約(HP)を最優先、次に貸出日順
  const sorted=[...reservations].filter(r=>r.status!=="cancelled").sort((a,b)=>{
    const aO=a.ota==="HP"?0:1,bO=b.ota==="HP"?0:1;
    if(aO!==bO)return aO-bO;
    return norm(a.lendDate).localeCompare(norm(b.lendDate));
  });
  const _reasons={};
  // 各車両の割当回数カウンタ（均等配車用）
  const usageCount={};
  vehicles.forEach(v=>{usageCount[v.code]=0;});
  // 既存割当をカウント
  Object.values(existingFleet).forEach(vc=>{if(vc&&typeof vc==="string")usageCount[vc]=(usageCount[vc]||0)+1;});

  // 車両が期間中に空いているか判定（washBuffer=trueで前日も確保）
  function isAvailable(v,rL,rR,rId,washBuffer){
    const checkL=washBuffer?dOff(rL,-1):rL;
    const inMaint=maints.some(m=>{
      if(m.vehicleCode!==v.code)return false;
      const mL=norm(m.startDate),mR=norm(m.endDate);
      return checkL<=mR&&rR>=mL;
    });
    if(inMaint)return{ok:false,reason:`${v.code}:メンテ中`};
    const conflictRes=sorted.find(other=>{
      if(other.id===rId)return false;
      if(fleet[other.id]!==v.code)return false;
      const oL=norm(other.lendDate),oR=norm(other.returnDate);
      return checkL<=oR&&rR>=oL;
    });
    if(conflictRes)return{ok:false,reason:`${v.code}:${conflictRes.name||conflictRes.id}と重複`};
    return{ok:true};
  }

  // 候補リストを使用回数昇順にソート（均等配車）
  function sortByUsage(list){
    return[...list].sort((a,b)=>(usageCount[a.code]||0)-(usageCount[b.code]||0));
  }

  // 候補リストから空き車両を探す（washBuffer付き→なしのフォールバック）
  function tryAssign(list,rL,rR,rId){
    const sorted1=sortByUsage(list);
    // Pass 1: 洗車バッファ（前日空き）付きで探す
    for(const v of sorted1){
      const chk=isAvailable(v,rL,rR,rId,true);
      if(chk.ok)return{v,tried:[]};
    }
    // Pass 2: バッファなし（詰め配車）で探す
    let tried=[];
    for(const v of sorted1){
      const chk=isAvailable(v,rL,rR,rId,false);
      if(!chk.ok){tried.push(chk.reason);continue;}
      return{v,tried};
    }
    return{v:null,tried};
  }

  sorted.forEach(r=>{
    if(fleet[r.id])return;
    const cls=r.vehicle;
    const pvc=r.preferVc||"";
    const rL=norm(r.lendDate),rR=norm(r.returnDate);
    // ★ サブクラスフォールバック: A2→A, B2→B（車両未登録時）
    const SUBCLASS_FB={"A2":"A","B2":"B"};
    let candidates=vehicles.filter(v=>v.type===cls&&!v.insuranceVeh);
    let usedCls=cls;
    if(candidates.length===0&&SUBCLASS_FB[cls]){usedCls=SUBCLASS_FB[cls];candidates=vehicles.filter(v=>v.type===usedCls&&!v.insuranceVeh);}
    if(candidates.length===0){
      _reasons[r.id]=`クラス"${cls}"の車両が登録されていません`;
      return;
    }
    let allTried=[];
    // ① preferVcがある場合: 指定車種を最優先
    if(pvc){
      const preferred=candidates.filter(v=>v.code.startsWith(pvc));
      if(preferred.length>0){
        const res=tryAssign(preferred,rL,rR,r.id);
        if(res.v){fleet[r.id]=res.v.code;usageCount[res.v.code]=(usageCount[res.v.code]||0)+1;return;}
        allTried=allTried.concat(res.tried);
      }
    }
    // ② 同クラスの他車種（or preferVcなしの場合は全候補）
    const fallback=pvc?candidates.filter(v=>!v.code.startsWith(pvc)):candidates;
    if(fallback.length>0){
      const res=tryAssign(fallback,rL,rR,r.id);
      if(res.v){fleet[r.id]=res.v.code;usageCount[res.v.code]=(usageCount[res.v.code]||0)+1;return;}
      allTried=allTried.concat(res.tried);
    }
    _reasons[r.id]=pvc
      ?`${cls}クラス(車種指定:${pvc})全${candidates.length}台が使用中(${allTried.join(", ")})`
      :`${cls}クラス全${candidates.length}台が使用中(${allTried.join(", ")})`;
  });
  fleet._unassignedReasons=_reasons;
  return fleet;
}

function OBadge({ota}){const o=OTA[ota];if(!o)return null;return <span style={{background:o.bg,color:o.c,padding:"1px 6px",borderRadius:4,fontSize:10,fontWeight:700,border:`1px solid ${o.c}22`}}>{o.key}</span>;}

/* Google Maps リンク生成 */
function mapsUrl(place){if(!place)return "";return "https://www.google.com/maps/search/?api=1&query="+encodeURIComponent(place+" 高松");}
function PlaceLink({place,style}){if(!place||place==="—"||place==="-")return <span style={style}>{place||""}</span>;const skip=!place.trim()||place.trim().length<2||/^(なし|無し|無|ー+|-+|FALSE|false|0)$/.test(place.trim());if(skip)return <span style={style}>{place}</span>;return <a href={mapsUrl(place)} target="_blank" rel="noopener noreferrer" style={{...style,color:"#2563eb",textDecoration:"underline",cursor:"pointer"}} title={`Googleマップで「${place}」を検索`}>{place}</a>;}
function EditablePlace({value,field,mark:markFn,task,updFn,getResChanges}){
  const[editing,setEditing]=React.useState(false);
  const[customMode,setCustomMode]=React.useState(false);
  const[modalVal,setModalVal]=React.useState(value||"");
  const isMobile=window.innerWidth<=768;
  const hasLink=value&&value.trim()&&value.trim().length>=2&&!/^(なし|無し|無|ー+|-+|FALSE|false|0|—)$/.test(value.trim());
  const isPreset=NHA_PLACE_OPTIONS.includes(value);
  // ★ スマホ: モーダル風の場所編集
  if(editing&&isMobile)return <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.4)",display:"flex",alignItems:"flex-end",justifyContent:"center",zIndex:9999}} onClick={e=>{if(e.target===e.currentTarget){setEditing(false);setCustomMode(false);}}}>
    <div style={{width:"100%",maxWidth:500,background:"#fff",borderRadius:"16px 16px 0 0",padding:"16px 16px env(safe-area-inset-bottom,16px)"}} onClick={e=>e.stopPropagation()}>
      <div style={{fontSize:13,fontWeight:700,color:"#1e293b",marginBottom:10}}>📍 {field==="colPlace"?"回収場所":"送迎場所"}を編集</div>
      <div style={{display:"flex",flexDirection:"column",gap:8}}>
        <select value={isPreset?value:customMode?"__custom":""} onChange={e=>{const v=e.target.value;if(v==="__custom"){setCustomMode(true);setModalVal("");return;}setCustomMode(false);updFn(task._id,markFn({...task,[field]:v},field),getResChanges?getResChanges(v):undefined);setEditing(false);}} style={{border:"1px solid #d1d5db",borderRadius:8,padding:"10px 12px",fontSize:14,width:"100%"}}>
          <option value="">選択してください</option>{NHA_PLACE_OPTIONS.map(p=><option key={p} value={p}>{p}</option>)}<option value="__custom">その他(手入力)...</option>{value&&!isPreset&&<option value={value}>{value}</option>}
        </select>
        {customMode&&<input autoFocus value={modalVal} onChange={e=>setModalVal(e.target.value)} placeholder="場所を入力" style={{border:"1px solid #3b82f6",borderRadius:8,padding:"10px 12px",fontSize:14,width:"100%",outline:"none"}}/>}
        <div style={{display:"flex",gap:8}}>
          <button onClick={()=>{setEditing(false);setCustomMode(false);}} style={{flex:1,padding:"10px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",fontSize:13,cursor:"pointer"}}>キャンセル</button>
          {customMode&&<button onClick={()=>{updFn(task._id,markFn({...task,[field]:modalVal},field),getResChanges?getResChanges(modalVal):undefined);setEditing(false);setCustomMode(false);}} style={{flex:1,padding:"10px",borderRadius:8,border:"none",background:"#2563eb",color:"#fff",fontSize:13,fontWeight:700,cursor:"pointer"}}>保存</button>}
        </div>
      </div>
    </div>
  </div>;
  // PC: 従来のインライン編集
  if(editing&&customMode)return <input autoFocus value={value||""} onChange={e=>{const nv=e.target.value;updFn(task._id,markFn({...task,[field]:nv},field),getResChanges?getResChanges(nv):undefined);}} onBlur={()=>{setEditing(false);setCustomMode(false);}} onKeyDown={e=>{if(e.key==="Enter")e.target.blur();}} style={{border:"1px solid #3b82f6",background:"#eff6ff",fontSize:9,width:"100%",padding:"1px 3px",borderRadius:3,outline:"none"}} placeholder="場所を入力"/>;
  if(editing)return <select autoFocus value={isPreset?value:"__custom"} onChange={e=>{const v=e.target.value;if(v==="__custom"){setCustomMode(true);return;}updFn(task._id,markFn({...task,[field]:v},field),getResChanges?getResChanges(v):undefined);setEditing(false);}} onBlur={()=>setEditing(false)} style={{border:"1px solid #3b82f6",background:"#eff6ff",fontSize:8,width:"100%",padding:"1px 2px",borderRadius:3,outline:"none"}}><option value="">-</option>{NHA_PLACE_OPTIONS.map(p=><option key={p} value={p}>{p}</option>)}<option value="__custom">その他(手入力)...</option>{value&&!isPreset&&value!=="__custom"&&<option value={value}>{value}</option>}</select>;
  return <div style={{display:"flex",alignItems:"center",gap:2,width:"100%",minHeight:18}}>
    {hasLink?<><a href={mapsUrl(value)} target="_blank" rel="noopener noreferrer" style={{fontSize:9,color:"#2563eb",textDecoration:"underline",cursor:"pointer",flex:1,minWidth:0,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}} title={`Googleマップで「${value}」を検索`}>{value}</a><button onClick={()=>setEditing(true)} style={{background:"none",border:"none",cursor:"pointer",fontSize:9,color:"#94a3b8",padding:0,lineHeight:1,flexShrink:0}}>✏️</button></>:<span style={{fontSize:9,color:value?"#334155":"#ccc",flex:1,cursor:"text"}} onClick={()=>setEditing(true)}>{value||"-"}</span>}
  </div>;
}

/* ==========================================
   CSV取込
   ========================================== */
function CSVPanel({onImport,onUpdatePlaces,dataCount,pendingPlaces,onSetPendingPlaces,files,setFiles,logs,setLogs,placeLogs,setPlaceLogs}){
  const handle=(e,k)=>{const f=e.target.files?.[0];if(!f)return;readFile(f,text=>{const rows=parseCSV(text);let res;if(k){const cfg=OTA[k];if(cfg){const skipStoreFilter=!!cfg.skipStoreFilter;for(let i=0;i<Math.min(rows.length,10);i++){if(cfg.det(rows[i])){const hd=rows[i],data=[];let totalValid=0,skippedOther=0;for(let j=i+1;j<rows.length;j++){if(rows[j].length<3||!rows[j][0])continue;try{const p=cfg.parse(rows[j],hd);if(p&&p.lendDate&&p.status!=="cancelled"){totalValid++;if(!skipStoreFilter){const rowText=rows[j].join(",").toUpperCase();if(!rowText.includes("高松")){skippedOther++;continue;}}p.delTime=p.delTime||p.lendTime;p.colTime=p.colTime||p.returnTime;p.delPlace=p.delPlace||"";p.colPlace=p.colPlace||"";data.push(p);}}catch(e){}}res={ota:k,data,totalValid,skippedOther};break;}}}}if(!res)res=detectParse(rows);if(!res){setLogs(p=>[...p,{t:"err",m:`${f.name}: 検出失敗`}]);return;}const now=new Date();const ts=`${now.getMonth()+1}/${now.getDate()} ${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;setFiles(p=>({...p,[res.ota]:{name:f.name,data:res.data,importedAt:ts}}));const isOfficial=OTA[res.ota]?.skipStoreFilter;const skipMsg=res.skippedOther>0?` (他店舗${res.skippedOther}件除外)`:"";const countLabel=isOfficial?`${res.data.length}件 (OTA${res.totalValid-res.data.length}件除外)`:`高松${res.data.length}件${skipMsg}`;
    // 月別内訳を生成
    const monthBreak={};let totalPrice=0;res.data.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"不明";monthBreak[ym]=(monthBreak[ym]||0)+1;totalPrice+=(r.price||0);});
    const monthStr=Object.entries(monthBreak).sort(([a],[b])=>a.localeCompare(b)).map(([ym,cnt])=>`${ym.replace("-","/")}:${cnt}件`).join(" / ");
    setLogs(p=>[...p,{t:"ok",m:`[${ts}] ${f.name} → ${OTA[res.ota].name} ${countLabel} ¥${totalPrice.toLocaleString()} 【全期間】${monthStr}`}]);});};
  const total=Object.values(files).reduce((s,f)=>s+f.data.length,0);
  return <div style={{maxWidth:960,margin:"0 auto"}}>
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4">
      <h3 className="text-base font-bold mb-1">Step 1: CSVアップロード</h3>
      <p className="text-xs text-gray-500 mb-3">各OTAのCSVを選択（Shift_JIS / UTF-8 自動判別）</p>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(100px,1fr))",gap:8}}>
        {Object.entries(OTA).map(([k,cfg])=>{const up=files[k];return <label key={k} className="flex flex-col items-center p-3 rounded-xl border-2 border-dashed cursor-pointer transition hover:shadow-md" style={{borderColor:up?cfg.c:"#d1d5db",background:up?cfg.bg:"#fff"}}>
          <div className="w-8 h-8 rounded-full text-white flex items-center justify-center text-sm font-bold mb-1" style={{background:cfg.c}}>{k}</div>
          <span className="font-semibold text-xs">{cfg.name}</span>
          {up?<><div className="text-xs font-bold mt-1" style={{color:cfg.c}}>{up.data.length}件</div><div style={{fontSize:8,color:"#64748b",marginTop:1}}>{up.importedAt}</div></>:<span className="text-xs text-gray-400 mt-1">選択</span>}
          <input type="file" accept=".csv,.txt" className="hidden" onChange={e=>handle(e,k)} />
        </label>;})}
      </div>
    </div>
    {logs.length>0&&<div className="bg-white rounded-xl shadow-sm border border-gray-200 p-3 mb-4">{logs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}</div>}
    {total>0&&(()=>{
      const rawD=Object.values(files).flatMap(f=>f.data);
      // ★ 重複ID解消: price>0の予約を優先（楽天price=0 vs RC正しいprice の問題対策）
      const dmap=new Map();let dupCnt=0;
      rawD.forEach(r=>{const ex=dmap.get(r.id);if(ex){dupCnt++;if((Number(r.price)||0)>(Number(ex.price)||0))dmap.set(r.id,r);}else dmap.set(r.id,r);});
      const allD=[...dmap.values()];
      const mBreak={};let tPrice=0;
      allD.forEach(r=>{const ym=r.returnDate?r.returnDate.substring(0,7):"不明";mBreak[ym]=(mBreak[ym]||{cnt:0,sum:0});mBreak[ym].cnt++;mBreak[ym].sum+=(r.price||0);tPrice+=(r.price||0);});
      const sortedM=Object.entries(mBreak).sort(([a],[b])=>a.localeCompare(b));
      return <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div className="flex items-center gap-2 mb-3 flex-wrap">{Object.entries(files).map(([k,f])=><div key={k} className="flex items-center gap-1"><OBadge ota={k}/><span className="text-xs font-bold">{f.data.length}件</span></div>)}<span className="text-gray-400">→</span><span className="text-base font-black text-blue-700">合計 {allD.length}件 / ¥{tPrice.toLocaleString()}</span>{dupCnt>0&&<span className="text-xs text-amber-600 font-bold">（重複{dupCnt}件→price優先で統合）</span>}</div>
      <div style={{fontSize:10,color:"#475569",marginBottom:8,padding:"6px 8px",background:"#f8fafc",borderRadius:6}}>📅 返却月別: {sortedM.map(([ym,d])=><span key={ym} style={{marginRight:8}}><b>{ym.replace("-","/")}</b>:{d.cnt}件(¥{d.sum.toLocaleString()})</span>)}</div>
      <button onClick={()=>onImport(allD)} className="btn-primary" style={{padding:"10px 24px",fontSize:14}}>統合してタスクを生成 →</button>
    </div>;})()}
    <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mt-4">
      <h3 className="text-base font-bold mb-1" style={{display:"flex",alignItems:"center",gap:8}}><span style={{background:"#4f46e5",color:"#fff",borderRadius:"50%",width:24,height:24,display:"inline-flex",alignItems:"center",justifyContent:"center",fontSize:12,fontWeight:700}}>2</span>場所CSV取込</h3>
      <p className="text-xs text-gray-500 mb-3">予約番号でお届け場所・回収場所を一括更新 → OPシートにGoogleマップリンク付きで表示されます<br/>CSVフォーマット: 予約番号, お届け場所, 回収場所{dataCount===0&&<span style={{color:"#b45309",fontWeight:600}}><br/>※ Step 1のCSV取込後にマッチングされます（先に読み込みも可能）</span>}</p>
      <div className="flex items-center gap-3 flex-wrap">
        <label className="px-4 py-2 rounded-lg text-xs font-semibold border-2 border-dashed border-indigo-300 bg-indigo-50 text-indigo-700 cursor-pointer hover:bg-indigo-100"><span>📍 場所CSVを選択</span><input type="file" accept=".csv,.txt,.tsv" className="hidden" onChange={e=>{
          const f=e.target.files?.[0];if(!f)return;
          readFile(f,text=>{
            const rows=parseCSV(text);if(rows.length<2){setPlaceLogs([{t:"err",m:"CSVが空です"}]);return;}
            // ヘッダー行を自動検出（最初の10行以内で「予約番号」を含む行を探す）
            let hdIdx=-1,hd=null;
            for(let hi=0;hi<Math.min(rows.length,10);hi++){
              if(rows[hi].some(h=>h&&(h.includes("予約番号")||h==="ID"||h==="id"))){hdIdx=hi;hd=rows[hi];break;}
            }
            if(!hd){setPlaceLogs([{t:"err",m:"「予約番号」列が見つかりません"}]);return;}
            const idxId=hd.findIndex(h=>h.includes("予約番号")||h==="ID"||h==="id");
            const idxDel=hd.findIndex(h=>h.includes("届け")||(h.includes("場所")&&!h.includes("回収")&&!h.includes("返却")));
            const idxCol=hd.findIndex(h=>h.includes("回収")||h.includes("返却場所"));
            if(idxId<0){setPlaceLogs([{t:"err",m:"「予約番号」列が見つかりません"}]);return;}
            const places={};let cnt=0;
            for(let i=hdIdx+1;i<rows.length;i++){
              const r=rows[i];const rid=r[idxId]?.trim();if(!rid)continue;
              const del=idxDel>=0?r[idxDel]?.trim()||"":"";
              const col=idxCol>=0?r[idxCol]?.trim()||"":"";
              if(del||col){places[rid]={delPlace:del,colPlace:col};cnt++;}
            }
            if(cnt===0){setPlaceLogs([{t:"err",m:"有効なデータがありません"}]);return;}
            const now2=new Date();const ts2=`${now2.getMonth()+1}/${now2.getDate()} ${String(now2.getHours()).padStart(2,"0")}:${String(now2.getMinutes()).padStart(2,"0")}`;
            onSetPendingPlaces(places);
            if(dataCount>0){const result=onUpdatePlaces(places);setPlaceLogs([{t:"ok",m:`[${ts2}] ${f.name}: ${cnt}件読込 → ${result.matched}件マッチ, ${result.unmatched}件未マッチ`}]);}
            else{setPlaceLogs([{t:"ok",m:`[${ts2}] ${f.name}: ${cnt}件読込済み（Step 1のCSV取込後に自動マッチングされます）`}]);}
          });
        }}/></label>
        <span className="text-xs text-gray-400">予約番号 + お届け場所 + 回収場所</span>
      </div>
      {placeLogs.length>0&&<div className="mt-2">{placeLogs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}</div>}
      {pendingPlaces&&Object.keys(pendingPlaces).length>0&&dataCount===0&&<div className="mt-2 px-2 py-1 rounded text-xs" style={{background:"#fef3c7",color:"#92400e"}}>📍 場所データ {Object.keys(pendingPlaces).length}件 読込済み — Step 1のインポート待ち</div>}
    </div>
  </div>;
}

/* ==========================================
   車両管理画面
   ========================================== */
function VehDetailList({vehicles,vehicleClasses,maintenance,onEdit}){
  const rows=useMemo(()=>{
    const out=[];const seen={};
    (vehicleClasses||[]).forEach(vc=>{(vehicles||[]).filter(v=>v.type===vc.type).forEach(v=>{out.push(v);seen[v.id]=1;});});
    (vehicles||[]).forEach(v=>{if(!seen[v.id])out.push(v);});
    return out;
  },[vehicles,vehicleClasses]);
  const maintCost=(code)=>(maintenance||[]).filter(m=>(m.vehicleCode||m.vehicle_code)===code).reduce((s,m)=>s+Number(m.actualCost||m.cost||0),0);
  const monthlyCost=(v)=>Number(v.insuranceAnnual||0)+(v.leaseMonthly||0)+Math.round((v.shakenCost||0)/12)+Math.round((v.tenkenCost||0)/6)+Math.round((v.carTax||0)/12);
  const S=v=>(v&&typeof v.specs==="object")?v.specs:{};
  const Chk=on=>on?<span style={{color:"#16a34a",fontWeight:900}}>✓</span>:<span style={{color:"#cbd5e1"}}>−</span>;
  const th={padding:"6px 8px",fontSize:10,fontWeight:800,color:"#475569",borderBottom:"2px solid #cbd5e1",whiteSpace:"nowrap",textAlign:"center",background:"#f1f5f9",position:"sticky",top:0,zIndex:2};
  const td={padding:"5px 8px",fontSize:11,borderBottom:"1px solid #eef2f7",whiteSpace:"nowrap",textAlign:"center"};
  const stickyTh={...th,left:0,zIndex:3,textAlign:"left",boxShadow:"2px 0 0 #e2e8f0"};
  const stickyTd=(bg)=>({...td,position:"sticky",left:0,background:bg,textAlign:"left",zIndex:1,boxShadow:"2px 0 0 #e2e8f0"});
  const cols=["グレード","油種","タイヤ","ETC位置","ドラレコ","USB","BT","バックカメラ","リアモニター","ナビ言語","ハンドル","AT/MT","定員","年式","カラー","型式","車体番号","車検満了","車検予定","点検期限","点検予定","保険/月","リース/月","整備実費","月次原価"];
  return <div style={{border:"1px solid #e2e8f0",borderRadius:10,overflow:"auto",maxHeight:"72vh"}}>
    <table style={{borderCollapse:"collapse",fontSize:11,minWidth:1400,width:"100%"}}>
      <thead><tr>
        <th style={stickyTh}>車両（クラス / 略称 / ナンバー）</th>
        {cols.map((c,i)=><th key={i} style={th}>{c}</th>)}
        <th style={th}>編集</th>
      </tr></thead>
      <tbody>{rows.map((v,i)=>{const s=S(v);const bg=i%2===0?"#fff":"#fafbfc";const langs=[s.nav_en&&"EN",s.nav_zh&&"中",s.nav_ko&&"韓"].filter(Boolean).join(" ");return <tr key={v.id} style={{background:bg}} onClick={()=>onEdit&&onEdit(v)} title="タップで編集">
        <td style={stickyTd(bg)}>
          <div style={{display:"flex",alignItems:"center",gap:6}}>
            <span style={{fontSize:10,fontWeight:900,padding:"1px 6px",borderRadius:5,background:v.type==="AA"?"#fef3c7":"#dbeafe",color:v.type==="AA"?"#92400e":"#1e40af"}}>{v.type}</span>
            <div><div style={{fontWeight:700,color:"#1e293b"}}>{s.abbr||v.name}</div><div style={{fontSize:10,color:"#2563eb",fontFamily:"monospace",fontWeight:700}}>{v.no}{v.insuranceVeh?" 🛡️":""}{v.active===false?" ⏸":""}</div></div>
          </div>
        </td>
        <td style={{...td,textAlign:"left"}}>{v.grade||"−"}</td>
        <td style={td}>{s.fuel||"−"}</td>
        <td style={td}>{s.tire||"−"}</td>
        <td style={{...td,textAlign:"left",maxWidth:180,overflow:"hidden",textOverflow:"ellipsis"}}>{s.etc_image?<span title="画像あり">📷 </span>:null}{s.etc_location||<span style={{color:"#cbd5e1"}}>−</span>}</td>
        <td style={td}>{Chk(s.dashcam)}</td>
        <td style={td}>{Chk(s.usb)}</td>
        <td style={td}>{Chk(s.bluetooth)}</td>
        <td style={td}>{Chk(s.backcam)}</td>
        <td style={td}>{Chk(s.rearmonitor)}</td>
        <td style={td}>{langs?<span style={{fontWeight:700,color:"#2563eb"}}>{langs}</span>:<span style={{color:"#cbd5e1"}}>−</span>}</td>
        <td style={td}>{s.handle||"−"}</td>
        <td style={td}>{s.transmission||"−"}</td>
        <td style={td}>{v.seats}</td>
        <td style={td}>{v.year||"−"}</td>
        <td style={{...td,textAlign:"left"}}>{v.color||"−"}</td>
        <td style={{...td,textAlign:"left"}}>{s.model_code||"−"}</td>
        <td style={{...td,textAlign:"left"}}>{s.shatai_no||"−"}</td>
        <td style={td}>{v.inspectionDueDate||"−"}</td>
        <td style={td}>{v.inspectionNextDate||"−"}</td>
        <td style={td}>{v.tenkenDueDate||"−"}</td>
        <td style={td}>{v.tenkenNextDate||"−"}</td>
        <td style={{...td,textAlign:"right"}}>{Number(v.insuranceAnnual)?"¥"+Number(v.insuranceAnnual).toLocaleString():"−"}</td>
        <td style={{...td,textAlign:"right"}}>{Number(v.leaseMonthly)?"¥"+Number(v.leaseMonthly).toLocaleString():"−"}</td>
        <td style={{...td,textAlign:"right"}}>{(()=>{const mc=maintCost(v.code);return mc?"¥"+mc.toLocaleString():"−";})()}</td>
        <td style={{...td,textAlign:"right",fontWeight:700,color:"#d97706"}}>{(()=>{const m=monthlyCost(v);return m?"¥"+m.toLocaleString():"−";})()}</td>
        <td style={td}><button onClick={e=>{e.stopPropagation();onEdit&&onEdit(v);}} style={{fontSize:10,color:"#2563eb",background:"none",border:"none",cursor:"pointer",fontWeight:700}}>編集</button></td>
      </tr>;})}</tbody>
    </table>
    <div style={{padding:"8px 12px",fontSize:10,color:"#94a3b8",borderTop:"1px solid #eef2f7"}}>{rows.length}台 ／ 横スクロールで全項目 ／ 行タップで編集 ／ 🛡️保険事業車 ⏸未稼働 ／ 保険・リースは月額 ／ 月次原価＝保険+リース+車検/12+点検/6+税/12</div>
  </div>;
}
function VehicleManager({vehicles,onVehiclesChange,vehicleClasses,onDeleteVehicle,highlightVehicle,maintenance}){
  const EMPTY={name:"",no:"",type:"A",grade:"",brand:"",seats:5,insuranceVeh:false,year:"",color:"",equip:"",insPrice:"",memo:"",insuranceAnnual:0,leaseMonthly:0,shakenCost:0,tenkenCost:0,carTax:0,oilIntervalKm:5000,inspectionDueDate:"",inspectionNextDate:"",tenkenDueDate:"",tenkenNextDate:"",specs:{}};
  const[modal,setModal]=useState(null);
  const[form,setForm]=useState(EMPTY);
  const[mTab,setMTab]=useState("basic");
  const[maintRecs,setMaintRecs]=useState([]);
  const[kpiFlags,setKpiFlags]=useState({});
  const[vehSaving,setVehSaving]=useState(false);
  const[vehSaveMsg,setVehSaveMsg]=useState(null); // null|"ok"|"err"
  // メンテナンス更新フォーム
  const[updType,setUpdType]=useState(null); // どのカテゴリを更新中か
  const[updForm,setUpdForm]=useState({completed_date:"",cost:"",invoice_no:"",notes:"",odometer_km:""});
  // 整備管理追加フォーム
  const[addingService,setAddingService]=useState(false);
  const[svcForm,setSvcForm]=useState({checkin_date:"",checkout_date:"",workshop:"",notes:"",cost:"",invoice_no:""});
  const upF=(k,v)=>setForm(p=>({...p,[k]:v}));
  const upS=(k,v)=>setForm(p=>({...p,specs:{...(p.specs||{}),[k]:v}}));
  const[etcUploading,setEtcUploading]=useState(false);
  const[vehListView,setVehListView]=useState(false);
  const onEtcImg=async(file)=>{if(!file)return;setEtcUploading(true);try{const url=await DB.uploadMemoImage(file);upS("etc_image",url);}catch(e){alert("画像アップロード失敗: "+(e.message||"不明"));}setEtcUploading(false);};
  const today=new Date().toISOString().slice(0,10);
  const MAINT_CATS=["車検","半年点検","オイル交換"]; // 走行距離は「距離管理」タブに移動 / オイル交換は距離管理から入力・ここで自動表示

  useEffect(()=>{
    if(!sb)return;
    const n=new Date();const ym=n.getFullYear()+"-"+String(n.getMonth()+1).padStart(2,"0");
    sb.from("bt_vehicle_monthly_kpi").select("vehicle_code,active").eq("year_month",ym)
      .then(({data})=>{const f={};(data||[]).forEach(r=>f[r.vehicle_code]=r.active);setKpiFlags(f);});
  },[]);

  const loadMaint=async(code)=>{
    if(!sb||!code)return;
    const{data}=await sb.from("bt_vehicle_maintenance").select("*").eq("vehicle_code",code).order("completed_date",{ascending:false}).order("created_at",{ascending:false});
    setMaintRecs(data||[]);
  };

  const getKpiStatus=(code)=>{
    if(kpiFlags[code]===false)return{label:"未稼働",color:"#dc2626",bg:"#fee2e2"};
    return{label:"稼働",color:"#059669",bg:"#dcfce7"};
  };

  const openAdd=()=>{setForm(EMPTY);setModal({mode:"add",v:null});setMTab("basic");setMaintRecs([]);setUpdType(null);setAddingService(false);};
  const openEdit=(v)=>{
    setForm({name:v.name||"",no:v.no||"",type:v.type||"A",grade:v.grade||"",brand:v.brand||"",seats:v.seats||5,insuranceVeh:!!v.insuranceVeh,year:v.year||"",color:v.color||"",equip:v.equip||"",insPrice:v.insPrice||"",memo:v.memo||"",insuranceAnnual:Number(v.insuranceAnnual)||0,leaseMonthly:Number(v.leaseMonthly)||0,shakenCost:Number(v.shakenCost)||0,tenkenCost:Number(v.tenkenCost)||0,carTax:Number(v.carTax)||0,inspectionDueDate:v.inspectionDueDate||"",inspectionNextDate:v.inspectionNextDate||"",tenkenDueDate:v.tenkenDueDate||"",tenkenNextDate:v.tenkenNextDate||"",specs:(v.specs&&typeof v.specs==="object")?{...v.specs}:{}});
    setModal({mode:"edit",v});setMTab("basic");setUpdType(null);setAddingService(false);
    loadMaint(v.code);
  };
  const closeModal=()=>setModal(null);

  const saveVehicle=async()=>{
    if(!window.confirm(modal.mode==="add"?"新規車両を登録しますか？":"車両情報を保存しますか？"))return;
    setVehSaving(true);setVehSaveMsg(null);
    try{
      let vToSave=null;
      if(modal.mode==="edit"){
        const next=vehicles.map(v=>v.id===modal.v.id?{...v,...form,seats:+form.seats}:v);
        vToSave=next.find(v=>v.id===modal.v.id);
        onVehiclesChange(next);
      }else{
        const prefix=form.name.replace(/[\s-]/g,"").substring(0,3).toUpperCase()||"NEW";
        const noStr=(form.no||"").replace(/[^0-9a-zA-Z]/g,"");
        const code=prefix+(noStr||Date.now().toString(36).slice(-4));
        if(vehicles.some(v=>v.code===code)){alert("同じ車種・ナンバーが既に登録されています");setVehSaving(false);return;}
        vToSave={id:code,code,...form,seats:+form.seats};
        onVehiclesChange([...vehicles,vToSave]);
      }
      // 直接DBに保存して成否を確認
      if(sb&&vToSave){
        const row={code:vToSave.code,name:vToSave.name,plate_no:vToSave.no,type:vToSave.type,grade:vToSave.grade||"",brand:vToSave.brand||"",seats:vToSave.seats,insurance_veh:!!vToSave.insuranceVeh,year:vToSave.year||"",color:vToSave.color||"",equip:vToSave.equip||"",ins_price:vToSave.insPrice||"",memo:vToSave.memo||"",insurance_annual:Number(vToSave.insuranceAnnual)||0,lease_monthly:Number(vToSave.leaseMonthly)||0,shaken_cost:Number(vToSave.shakenCost)||0,tenken_cost:Number(vToSave.tenkenCost)||0,car_tax:Number(vToSave.carTax)||0,oil_interval_km:Number(vToSave.oilIntervalKm)||5000,inspection_due_date:vToSave.inspectionDueDate||null,inspection_next_date:vToSave.inspectionNextDate||null,tenken_due_date:vToSave.tenkenDueDate||null,tenken_next_date:vToSave.tenkenNextDate||null,active:vToSave.active!==false,specs:(vToSave.specs&&typeof vToSave.specs==="object")?vToSave.specs:{}};
        const{error}=await sb.from("bt_vehicles").upsert(row,{onConflict:"code"});
        if(error)throw new Error(error.message);
        // ★ 保存成功後にDBから再取得してローカルstateを確実に更新
        const refreshed=await DB.fetchVehicles();
        if(refreshed&&refreshed.length>0)onVehiclesChange(refreshed);
      }
      setVehSaveMsg("ok");
      setTimeout(()=>{setVehSaveMsg(null);closeModal();setVehSaving(false);},600);
    }catch(e){
      console.error("Vehicle save error:",e);
      setVehSaveMsg("err");
      setVehSaving(false);
      alert("保存に失敗しました: "+(e.message||"不明なエラー")+"\nもう一度お試しください。");
    }
  };

  const remove=(id)=>{if(!window.confirm("この車両を削除しますか？"))return;const v=vehicles.find(x=>x.id===id);onVehiclesChange(vehicles.filter(x=>x.id!==id));if(v&&onDeleteVehicle)onDeleteVehicle(v.code);};

  // メンテナンス更新保存
  const saveMaintUpd=async()=>{
    if(!sb||!modal?.v?.code)return;
    const isOdo=updType==="走行距離";
    const row={vehicle_code:modal.v.code,type:updType,completed_date:updForm.completed_date||today,cost:isOdo?0:Number(updForm.cost)||0,invoice_no:isOdo?"":updForm.invoice_no||"",notes:updForm.notes||"",odometer_km:Number(updForm.odometer_km)||0};
    await sb.from("bt_vehicle_maintenance").insert(row);
    setUpdType(null);setUpdForm({completed_date:"",cost:"",invoice_no:"",notes:"",odometer_km:""});
    loadMaint(modal.v.code);
  };

  // 整備管理保存
  const saveSvc=async()=>{
    if(!sb||!modal?.v?.code)return;
    const row={vehicle_code:modal.v.code,type:"整備管理",completed_date:svcForm.checkout_date||svcForm.checkin_date||today,checkin_date:svcForm.checkin_date||null,checkout_date:svcForm.checkout_date||null,workshop:svcForm.workshop||"",notes:svcForm.notes||"",cost:Number(svcForm.cost)||0,invoice_no:svcForm.invoice_no||""};
    await sb.from("bt_vehicle_maintenance").insert(row);
    setAddingService(false);setSvcForm({checkin_date:"",checkout_date:"",workshop:"",notes:"",cost:"",invoice_no:""});
    loadMaint(modal.v.code);
  };

  const deleteMaint=async(id)=>{if(!window.confirm("削除しますか？"))return;await sb.from("bt_vehicle_maintenance").delete().eq("id",id);loadMaint(modal.v.code);};

  const grouped=useMemo(()=>vehicleClasses.map(vc=>({...vc,items:vehicles.filter(v=>v.type===vc.type)})),[vehicles,vehicleClasses]);
  const[openCls,setOpenCls]=useState({}); // デフォルト折りたたみ
  const toggleCls=(tp)=>setOpenCls(p=>({...p,[tp]:!p[tp]}));
  const isMob=useMobile();
  const fS={padding:"7px 10px",fontSize:13,border:"1px solid #d1d5db",borderRadius:8,width:"100%"};
  const lS={fontSize:11,fontWeight:700,color:"#64748b",marginBottom:4,display:"block"};
  const secH=(t)=><div style={{fontSize:11,fontWeight:800,color:"#2563eb",marginBottom:10,paddingBottom:4,borderBottom:"1px solid #e2e8f0",marginTop:4}}>{t}</div>;
  const tabBtn=(id,label)=><button key={id} onClick={()=>setMTab(id)} style={{padding:"8px 14px",fontSize:12,fontWeight:mTab===id?700:500,color:mTab===id?"#2563eb":"#64748b",background:"none",border:"none",borderBottom:mTab===id?"2px solid #2563eb":"2px solid transparent",cursor:"pointer",whiteSpace:"nowrap"}}>{label}</button>;
  const fmtYen=(n)=>n>0?"¥"+Number(n).toLocaleString():"-";

  return <div style={{maxWidth:vehListView?1440:960,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16,gap:8,flexWrap:"wrap"}}>
      <h3 style={{fontSize:15,fontWeight:800,margin:0}}>車両登録管理</h3>
      <div style={{display:"flex",gap:8,alignItems:"center"}}>
        <div style={{display:"flex",border:"1px solid #cbd5e1",borderRadius:8,overflow:"hidden"}}>
          <button onClick={()=>setVehListView(false)} style={{padding:"6px 12px",fontSize:12,fontWeight:700,border:"none",cursor:"pointer",background:vehListView?"#fff":"#2563eb",color:vehListView?"#64748b":"#fff"}}>📇 登録管理</button>
          <button onClick={()=>setVehListView(true)} style={{padding:"6px 12px",fontSize:12,fontWeight:700,border:"none",cursor:"pointer",background:vehListView?"#2563eb":"#fff",color:vehListView?"#fff":"#64748b"}}>📋 詳細一覧</button>
        </div>
        <button onClick={openAdd} style={{padding:"7px 18px",background:"#2563eb",color:"#fff",border:"none",borderRadius:8,fontSize:12,fontWeight:700,cursor:"pointer"}}>＋ 車両追加</button>
      </div>
    </div>

    {vehListView&&<VehDetailList vehicles={vehicles} vehicleClasses={vehicleClasses} maintenance={maintenance} onEdit={openEdit}/>}
    {!vehListView&&grouped.map(g=>{
      const isOpen=!!openCls[g.type];
      const mc=g.items.reduce((s,v)=>s+Number(v.insuranceAnnual||0)+(v.leaseMonthly||0)+Math.round((v.shakenCost||0)/12)+Math.round((v.tenkenCost||0)/6)+Math.round((v.carTax||0)/12),0);
      return<div key={g.type} style={{marginBottom:8}}>
        {/* アコーディオンヘッダー */}
        <div onClick={()=>toggleCls(g.type)} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:isOpen?"8px 8px 0 0":"8px",cursor:"pointer",userSelect:"none"}}>
          <span style={{padding:"2px 10px",background:"#2563eb",color:"#fff",borderRadius:4,fontSize:11,fontWeight:800}}>{g.type}</span>
          <span style={{fontSize:12,color:"#374151",fontWeight:700,flex:1}}>{g.label}</span>
          <span style={{fontSize:11,color:"#94a3b8"}}>{g.items.length}台</span>
          {mc>0&&<span style={{fontSize:11,fontWeight:700,color:"#d97706"}}>原価¥{mc.toLocaleString()}/月</span>}
          <span style={{fontSize:12,color:"#94a3b8"}}>{isOpen?"▲":"▼"}</span>
        </div>
        {/* 展開時のみ表示 */}
        {isOpen&&(g.items.length===0
          ?<div style={{fontSize:11,color:"#94a3b8",padding:"10px 16px",border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",background:"#fff"}}>未登録</div>
          :isMob
          // ===== モバイル =====
          ?<div style={{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"hidden"}}>
            {g.items.map((v,i)=>{const ks=getKpiStatus(v.code);const mc2=Number(v.insuranceAnnual||0)+(v.leaseMonthly||0)+Math.round((v.shakenCost||0)/12)+Math.round((v.tenkenCost||0)/6)+Math.round((v.carTax||0)/12);return<div key={v.id} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 12px",borderBottom:"1px solid #f1f5f9",background:i%2===0?"#fff":"#fafafa",outline:highlightVehicle===v.code?"2px solid #fbbf24":"none"}}>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>{v.name}</div>
                <div style={{display:"flex",gap:6,alignItems:"center",marginTop:3,flexWrap:"wrap"}}>
                  <span style={{fontSize:12,fontFamily:"monospace",color:"#2563eb",fontWeight:700}}>{v.no}</span>
                  {v.year&&<span style={{fontSize:10,color:"#94a3b8"}}>{v.year}年式</span>}
                  {v.insuranceVeh&&<span style={{fontSize:9,padding:"1px 5px",borderRadius:3,background:"#fef3c7",color:"#d97706",fontWeight:700}}>保険</span>}
                </div>
              </div>
              <div style={{textAlign:"center",flexShrink:0}}>
                <span style={{fontSize:10,fontWeight:700,padding:"3px 8px",borderRadius:6,background:ks.bg,color:ks.color}}>{ks.label}</span>
                {mc2>0&&<div style={{fontSize:9,color:"#d97706",fontWeight:700,marginTop:2}}>¥{mc2.toLocaleString()}</div>}
              </div>
              <div style={{display:"flex",gap:6,flexShrink:0}}>
                <button onClick={()=>openEdit(v)} style={{fontSize:11,padding:"5px 12px",background:"#eff6ff",color:"#2563eb",border:"1px solid #bfdbfe",borderRadius:6,cursor:"pointer",fontWeight:600}}>編集</button>
                <button onClick={()=>remove(v.id)} style={{fontSize:11,padding:"5px 10px",background:"#fff",color:"#ef4444",border:"1px solid #fecaca",borderRadius:6,cursor:"pointer",fontWeight:600}}>削除</button>
              </div>
            </div>;})}
          </div>
          // ===== デスクトップ =====
          :<div style={{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"hidden"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
              <thead><tr style={{background:"#f8fafc"}}>
                {["クラス","車種名","グレード","ナンバー","定員","年式","稼働","保険","月次原価",""].map((h,i)=><th key={i} style={{padding:"6px 10px",textAlign:i>5?"center":"left",fontSize:10,fontWeight:700,color:i===8?"#d97706":"#64748b",borderBottom:"1px solid #e2e8f0"}}>{h}</th>)}
              </tr></thead>
              <tbody>{g.items.map((v,i)=>{const ks=getKpiStatus(v.code);return<tr key={v.id} style={{background:i%2===0?"#fff":"#fafafa",outline:highlightVehicle===v.code?"2px solid #fbbf24":"none"}}>
                <td style={{padding:"7px 10px",textAlign:"center"}}><span style={{fontSize:11,fontWeight:900,padding:"2px 8px",borderRadius:6,background:v.type==="AA"?"#fef3c7":"#dbeafe",color:v.type==="AA"?"#92400e":"#1e40af"}}>{v.type}</span></td>
                <td style={{padding:"7px 10px",fontWeight:600}}>{v.name}</td>
                <td style={{padding:"7px 10px",color:"#64748b",fontSize:11}}>{v.grade||"-"}</td>
                <td style={{padding:"7px 10px",fontFamily:"monospace",color:"#2563eb",fontWeight:700}}>{v.no}</td>
                <td style={{padding:"7px 10px"}}>{v.seats}名</td>
                <td style={{padding:"7px 10px",color:"#64748b"}}>{v.year||"-"}</td>
                <td style={{padding:"7px 10px",textAlign:"center"}}><span style={{fontSize:10,fontWeight:700,padding:"1px 6px",borderRadius:4,background:ks.bg,color:ks.color}}>{ks.label}</span></td>
                <td style={{padding:"7px 10px",textAlign:"center"}}>{v.insuranceVeh?<span style={{fontSize:10,fontWeight:700,padding:"1px 6px",borderRadius:4,background:"#fef3c7",color:"#d97706"}}>保険</span>:<span style={{color:"#cbd5e1"}}>-</span>}</td>
                <td style={{padding:"7px 10px",textAlign:"right"}}>{(()=>{const mc2=Number(v.insuranceAnnual||0)+(v.leaseMonthly||0)+Math.round((v.shakenCost||0)/12)+Math.round((v.tenkenCost||0)/6)+Math.round((v.carTax||0)/12);return mc2>0?<span style={{fontSize:11,fontWeight:700,color:"#d97706"}}>¥{mc2.toLocaleString()}</span>:<span style={{color:"#cbd5e1",fontSize:10}}>-</span>;})()}</td>
                <td style={{padding:"7px 10px",textAlign:"right",whiteSpace:"nowrap"}}>
                  <button onClick={()=>openEdit(v)} style={{fontSize:10,color:"#2563eb",background:"none",border:"none",cursor:"pointer",marginRight:8,fontWeight:600}}>編集</button>
                  <button onClick={()=>remove(v.id)} style={{fontSize:10,color:"#ef4444",background:"none",border:"none",cursor:"pointer",fontWeight:600}}>削除</button>
                </td>
              </tr>;})}</tbody>
            </table>
          </div>)}
      </div>;
    })}
    {!vehListView&&<div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginTop:8}}>
      <div style={{fontSize:11,color:"#94a3b8"}}>合計: {vehicles.length}台</div>
      {(()=>{const total=vehicles.reduce((s,v)=>s+Number(v.insuranceAnnual||0)+(v.leaseMonthly||0)+Math.round((v.shakenCost||0)/12)+Math.round((v.tenkenCost||0)/6)+Math.round((v.carTax||0)/12),0);return total>0&&<div style={{fontSize:12,fontWeight:700,color:"#d97706"}}>月次原価 合計: ¥{total.toLocaleString()}/月</div>;})()}
    </div>}

    {modal&&<div style={{position:"fixed",inset:0,background:"rgba(15,23,42,.55)",zIndex:9000,display:"flex",alignItems:"flex-start",justifyContent:"center",padding:"20px 16px",overflowY:"auto"}}>
      <div style={{background:"#fff",borderRadius:16,width:"100%",maxWidth:680,boxShadow:"0 20px 60px rgba(0,0,0,.2)"}}>
        <div style={{padding:"16px 20px",borderBottom:"1px solid #e2e8f0",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
          <h3 style={{fontSize:15,fontWeight:800,margin:0}}>{modal.mode==="add"?"🚗 車両追加":`✏️ ${modal.v?.name||""} ${modal.v?.no||""}`}</h3>
          <button onClick={closeModal} style={{background:"none",border:"none",fontSize:22,cursor:"pointer",color:"#94a3b8"}}>✕</button>
        </div>
        <div style={{display:"flex",gap:0,borderBottom:"1px solid #e2e8f0",paddingLeft:12,overflowX:"auto"}}>
          {tabBtn("basic","基本情報")}
          {tabBtn("ins","保険事業")}
          {tabBtn("cost","ランニングコスト")}
          {tabBtn("maint","メンテナンス")}
          {tabBtn("svc","整備管理")}
          {tabBtn("inspect","🚗 車検/点検/修理")}
        </div>
        <div style={{padding:"20px 24px",maxHeight:"62vh",overflowY:"auto"}}>

          {/* ===== 基本情報 ===== */}
          {mTab==="basic"&&<div>
            {secH("基本スペック")}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:12}}>
              <div><label style={lS}>クラス</label><select value={form.type} onChange={e=>upF("type",e.target.value)} style={fS}>{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type} — {c.label}</option>)}</select></div>
              <div><label style={lS}>車種名</label><input value={form.name} onChange={e=>upF("name",e.target.value)} style={fS} placeholder={form.type==="AA"?"例: Mercedes GL500 / Lamborghini Urus":"アルファード①"}/></div>
              <div><label style={lS}>略称</label><input value={(form.specs&&form.specs.abbr)||""} onChange={e=>upS("abbr",e.target.value)} style={fS} placeholder="アル①"/></div>
              <div><label style={lS}>グレード</label><input value={form.grade} onChange={e=>upF("grade",e.target.value)} style={fS} placeholder="2.5S Cパッケージ"/></div>
              <div><label style={lS}>ナンバー</label><input value={form.no} onChange={e=>upF("no",e.target.value)} style={fS} placeholder="2340"/></div>
              <div><label style={lS}>定員</label><input type="number" value={form.seats} onChange={e=>upF("seats",e.target.value)} style={fS}/></div>
              <div><label style={lS}>年式</label><input value={form.year} onChange={e=>upF("year",e.target.value)} style={fS} placeholder="2022"/></div>
              <div><label style={lS}>油種</label><select value={(form.specs&&form.specs.fuel)||""} onChange={e=>upS("fuel",e.target.value)} style={fS}><option value="">未設定</option>{["レギュラー","ハイオク","軽油","ハイブリッド","EV"].map(o=><option key={o} value={o}>{o}</option>)}</select></div>
              <div style={{gridColumn:"1/-1"}}><label style={lS}>カラー</label><input value={form.color} onChange={e=>upF("color",e.target.value)} style={fS} placeholder="ホワイトパールクリスタルシャイン"/></div>
              <div><label style={lS}>型式</label><input value={(form.specs&&form.specs.model_code)||""} onChange={e=>upS("model_code",e.target.value)} style={fS} placeholder="3BA-AGH30W"/></div>
              <div><label style={lS}>車体番号</label><input value={(form.specs&&form.specs.shatai_no)||""} onChange={e=>upS("shatai_no",e.target.value)} style={fS} placeholder="AGH30-0123456"/></div>
            </div>
            {secH("走行・操作情報")}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:12}}>
              <div><label style={lS}>ハンドル</label><select value={(form.specs&&form.specs.handle)||""} onChange={e=>upS("handle",e.target.value)} style={fS}><option value="">未設定</option><option value="右">右</option><option value="左">左</option></select></div>
              <div><label style={lS}>AT / MT</label><select value={(form.specs&&form.specs.transmission)||""} onChange={e=>upS("transmission",e.target.value)} style={fS}><option value="">未設定</option><option value="AT">AT</option><option value="MT">MT</option></select></div>
              <div><label style={lS}>タイヤ</label><select value={(form.specs&&form.specs.tire)||""} onChange={e=>upS("tire",e.target.value)} style={fS}><option value="">未設定</option>{["ノーマル","スタッドレス","オールシーズン"].map(o=><option key={o} value={o}>{o}</option>)}</select></div>
              <div>
                <label style={lS}>ナビ言語</label>
                <div style={{display:"flex",gap:14,flexWrap:"wrap",padding:"7px 0"}}>
                  {[["nav_en","英語"],["nav_zh","中国語"],["nav_ko","韓国語"]].map(([k,l])=><label key={k} style={{display:"flex",alignItems:"center",gap:5,cursor:"pointer",fontSize:12,fontWeight:600,color:(form.specs&&form.specs[k])?"#2563eb":"#64748b"}}><input type="checkbox" checked={!!(form.specs&&form.specs[k])} onChange={e=>upS(k,e.target.checked)}/>{l}</label>)}
                </div>
              </div>
            </div>
            {secH("装備")}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:10}}>
              <div><label style={lS}>ETC位置</label><input value={(form.specs&&form.specs.etc_location)||""} onChange={e=>upS("etc_location",e.target.value)} style={fS} placeholder="グローブボックス内 など"/></div>
              <div>
                <label style={lS}>ETC画像</label>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  {form.specs&&form.specs.etc_image?<a href={form.specs.etc_image} target="_blank" rel="noreferrer"><img src={form.specs.etc_image} alt="ETC" style={{width:44,height:44,objectFit:"cover",borderRadius:6,border:"1px solid #cbd5e1"}}/></a>:<div style={{width:44,height:44,borderRadius:6,border:"1px dashed #cbd5e1",display:"flex",alignItems:"center",justifyContent:"center",fontSize:16,color:"#cbd5e1"}}>📷</div>}
                  <label style={{fontSize:11,padding:"5px 10px",background:"#eff6ff",color:"#2563eb",border:"1px solid #bfdbfe",borderRadius:6,cursor:"pointer",fontWeight:600}}>{etcUploading?"アップロード中…":(form.specs&&form.specs.etc_image?"変更":"画像を選択")}<input type="file" accept="image/*" style={{display:"none"}} disabled={etcUploading} onChange={e=>onEtcImg(e.target.files&&e.target.files[0])}/></label>
                  {form.specs&&form.specs.etc_image&&<button type="button" onClick={()=>upS("etc_image","")} style={{fontSize:10,color:"#ef4444",background:"none",border:"none",cursor:"pointer"}}>削除</button>}
                </div>
              </div>
            </div>
            <div style={{display:"flex",gap:10,flexWrap:"wrap",marginBottom:14}}>
              {[["dashcam","🎥 ドラレコ"],["usb","🔌 USB"],["bluetooth","📶 Bluetooth"],["backcam","📹 バックカメラ"],["rearmonitor","🖥️ リアモニター"]].map(([k,l])=>{const on=!!(form.specs&&form.specs[k]);return <label key={k} style={{display:"flex",alignItems:"center",gap:6,cursor:"pointer",fontSize:12,fontWeight:700,padding:"6px 12px",borderRadius:8,border:"1px solid "+(on?"#86efac":"#e2e8f0"),background:on?"#f0fdf4":"#f8fafc",color:on?"#15803d":"#94a3b8"}}><input type="checkbox" checked={on} onChange={e=>upS(k,e.target.checked)}/>{l}</label>;})}
            </div>
            {secH("補足（自由記述）")}
            <div style={{display:"grid",gridTemplateColumns:"1fr",gap:12,marginBottom:12}}>
              <div><label style={lS}>装備・オプション（自由記述・上記トグル以外の補足）</label><input value={form.equip} onChange={e=>upF("equip",e.target.value)} style={fS} placeholder="フリップダウンモニター など"/></div>
              <div><label style={lS}>メモ</label><textarea value={form.memo} onChange={e=>upF("memo",e.target.value)} rows={2} style={{...fS,resize:"vertical"}} placeholder="備考"/></div>
            </div>
          </div>}

          {/* ===== 保険事業 ===== */}
          {mTab==="ins"&&<div>
            {secH("保険事業情報")}
            <div style={{marginBottom:16}}>
              <label style={lS}>保険事業価格（月額）</label>
              <input value={form.insPrice} onChange={e=>upF("insPrice",e.target.value)} style={{...fS,maxWidth:200}} placeholder="¥15,000"/>
            </div>
            <label style={{display:"flex",alignItems:"center",gap:12,cursor:"pointer",padding:"16px",background:form.insuranceVeh?"#fffbeb":"#f8fafc",border:"2px solid "+(form.insuranceVeh?"#fde68a":"#e2e8f0"),borderRadius:12}}>
              <input type="checkbox" checked={form.insuranceVeh} onChange={e=>upF("insuranceVeh",e.target.checked)} style={{width:20,height:20,cursor:"pointer"}}/>
              <div>
                <div style={{fontWeight:700,fontSize:14,color:form.insuranceVeh?"#d97706":"#475569"}}>保険車両</div>
                <div style={{fontSize:11,color:"#94a3b8",marginTop:2}}>ONにすると自動配車から除外されます</div>
              </div>
            </label>
          </div>}

          {/* ===== ランニングコスト ===== */}
          {mTab==="cost"&&(()=>{
            // 車検/半年点検: 配車表(bt_maintenance)の最新概算予算から自動算出
            const vCode=modal?.v?.code;
            const latestShaken=(maintenance||[]).filter(m=>m.vehicleCode===vCode&&m.label==="車検"&&m.cost>0).sort((a,b)=>(b.startDate||"").localeCompare(a.startDate||""))[0];
            const latestTenken=(maintenance||[]).filter(m=>m.vehicleCode===vCode&&m.label==="半年点検"&&m.cost>0).sort((a,b)=>(b.startDate||"").localeCompare(a.startDate||""))[0];
            // 確定金額(actualCost)があればそちらを優先、なければ概算予算(cost)を使用
            const shakenActual=latestShaken?(latestShaken.actualCost>0?latestShaken.actualCost:latestShaken.cost):0;
            const tenkenActual=latestTenken?(latestTenken.actualCost>0?latestTenken.actualCost:latestTenken.cost):0;
            const shakenM=shakenActual?Math.round(shakenActual/12):0; // 1年車検 → ÷12ヶ月
            const tenkenM=tenkenActual?Math.round(tenkenActual/6):0; // 年2回 → 1回÷6ヶ月
            const carTaxM=form.carTax?Math.round(form.carTax/12):0; // 年税 → ÷12ヶ月
            const autoBoxS={padding:"10px 12px",background:"#f0f9ff",border:"1px solid #bae6fd",borderRadius:8};
            const total=Number(form.insuranceAnnual||0)+Number(form.leaseMonthly||0)+shakenM+tenkenM+carTaxM;
            return <div>
              {secH("ランニングコスト情報")}
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:16}}>
                <div>
                  <label style={lS}>保険料（月額）</label>
                  <input type="number" value={form.insuranceAnnual||""} onChange={e=>upF("insuranceAnnual",+e.target.value||0)} style={fS} placeholder="例: 10000"/>
                </div>
                <div>
                  <label style={lS}>リース代（月額）</label>
                  <input type="number" value={form.leaseMonthly||""} onChange={e=>upF("leaseMonthly",+e.target.value||0)} style={fS} placeholder="例: 55000"/>
                </div>
                {/* 車税 */}
                <div>
                  <label style={lS}>自動車税（年額）</label>
                  <input type="number" value={form.carTax||""} onChange={e=>upF("carTax",+e.target.value||0)} style={fS} placeholder="例: 45000"/>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6,marginTop:6}}>
                    <div style={{background:"#fefce8",border:"1px solid #fde68a",borderRadius:6,padding:"5px 8px"}}>
                      <div style={{fontSize:9,color:"#92400e",fontWeight:700}}>年額</div>
                      <div style={{fontSize:13,fontWeight:900,color:"#b45309"}}>{form.carTax>0?"¥"+Number(form.carTax).toLocaleString():"-"}</div>
                    </div>
                    <div style={{background:"#fefce8",border:"1px solid #fde68a",borderRadius:6,padding:"5px 8px"}}>
                      <div style={{fontSize:9,color:"#92400e",fontWeight:700}}>月額（÷12）</div>
                      <div style={{fontSize:13,fontWeight:900,color:"#d97706"}}>{carTaxM>0?"¥"+carTaxM.toLocaleString():"-"}</div>
                    </div>
                  </div>
                </div>
                {/* 車検代: 配車表から自動算出 */}
                <div style={autoBoxS}>
                  <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    <label style={{...lS,margin:0,color:"#0369a1"}}>車検代（自動算出）</label>
                    <span style={{fontSize:9,background:"#bae6fd",color:"#0369a1",padding:"1px 6px",borderRadius:4,fontWeight:700}}>配車表連動</span>
                  </div>
                  {latestShaken?<>
                    <div style={{fontSize:11,color:"#64748b",marginBottom:4}}>最新: ¥{latestShaken.cost.toLocaleString()} ({latestShaken.startDate})</div>
                    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                      <div style={{background:"#fff",borderRadius:6,padding:"6px 10px",border:"1px solid #dbeafe"}}>
                        <div style={{fontSize:9,color:"#64748b",fontWeight:700}}>年額（1年）</div>
                        <div style={{fontSize:14,fontWeight:900,color:"#0369a1"}}>¥{latestShaken.cost.toLocaleString()}</div>
                      </div>
                      <div style={{background:"#fff",borderRadius:6,padding:"6px 10px",border:"1px solid #dbeafe"}}>
                        <div style={{fontSize:9,color:"#64748b",fontWeight:700}}>月額（÷12ヶ月）</div>
                        <div style={{fontSize:14,fontWeight:900,color:"#2563eb"}}>¥{shakenM.toLocaleString()}</div>
                      </div>
                    </div>
                  </>:<div style={{fontSize:11,color:"#94a3b8"}}>配車表に車検を登録すると自動算出されます</div>}
                </div>
                {/* 半年点検代: 配車表から自動算出 */}
                <div style={autoBoxS}>
                  <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    <label style={{...lS,margin:0,color:"#0369a1"}}>半年点検代（自動算出）</label>
                    <span style={{fontSize:9,background:"#bae6fd",color:"#0369a1",padding:"1px 6px",borderRadius:4,fontWeight:700}}>配車表連動</span>
                  </div>
                  {latestTenken?<>
                    <div style={{fontSize:11,color:"#64748b",marginBottom:4}}>最新: ¥{latestTenken.cost.toLocaleString()} ({latestTenken.startDate})</div>
                    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                      <div style={{background:"#fff",borderRadius:6,padding:"6px 10px",border:"1px solid #dbeafe"}}>
                        <div style={{fontSize:9,color:"#64748b",fontWeight:700}}>年額（×2回）</div>
                        <div style={{fontSize:14,fontWeight:900,color:"#0369a1"}}>¥{(latestTenken.cost*2).toLocaleString()}</div>
                      </div>
                      <div style={{background:"#fff",borderRadius:6,padding:"6px 10px",border:"1px solid #dbeafe"}}>
                        <div style={{fontSize:9,color:"#64748b",fontWeight:700}}>月額（÷6ヶ月）</div>
                        <div style={{fontSize:14,fontWeight:900,color:"#2563eb"}}>¥{tenkenM.toLocaleString()}</div>
                      </div>
                    </div>
                  </>:<div style={{fontSize:11,color:"#94a3b8"}}>配車表に半年点検を登録すると自動算出されます</div>}
                </div>
              </div>
              {total>0&&<div style={{padding:"14px 18px",background:"#f0fdf4",borderRadius:10,border:"1px solid #bbf7d0"}}>
                <div style={{fontSize:11,fontWeight:800,color:"#166534",marginBottom:4}}>月額合計（概算）</div>
                <div style={{fontSize:22,fontWeight:900,color:"#059669"}}>¥{total.toLocaleString()}<span style={{fontSize:12,color:"#64748b",fontWeight:600}}>/月</span></div>
                <div style={{display:"flex",flexWrap:"wrap",gap:"4px 12px",marginTop:6}}>
                  {[["保険",Number(form.insuranceAnnual)],["リース",Number(form.leaseMonthly)],["自動車税",carTaxM],["車検",shakenM],["半年点検",tenkenM]].map(([k,v])=>v>0&&<span key={k} style={{fontSize:10,color:"#64748b"}}>{k} <b style={{color:"#1e293b"}}>¥{v.toLocaleString()}</b></span>)}
                </div>
              </div>}
            </div>;
          })()}

          {/* ===== メンテナンス ===== */}
          {mTab==="maint"&&<div>
            {modal.mode==="add"?<div style={{textAlign:"center",padding:32,color:"#94a3b8"}}>車両登録後に記録できます</div>:<div>
              {MAINT_CATS.map(cat=>{
                // 車検/半年点検 → 配車表(bt_maintenance)から取得
                const isFleetCat=cat==="車検"||cat==="半年点検";
                const recs=isFleetCat
                  ?(maintenance||[]).filter(m=>m.vehicleCode===(modal?.v?.code)&&m.label===cat).map(m=>({id:m.id,type:m.label,completed_date:m.endDate,scheduled_date:m.startDate,cost:m.cost||0,invoice_no:m.invoiceNo||"",notes:m.maintNotes||"",workshop:m.workshop||"",_fleetRec:m})).sort((a,b)=>(b.completed_date||"").localeCompare(a.completed_date||""))
                  :maintRecs.filter(r=>r.type===cat);
                const latest=recs[0];
                const prev=recs[1];
                const isOdo=cat==="走行距離";
                const isOil=cat==="オイル交換";
                const isUpd=updType===cat;
                return <div key={cat} style={{border:"1px solid #e2e8f0",borderRadius:12,marginBottom:14,overflow:"hidden"}}>
                  {/* カテゴリヘッダー */}
                  <div style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:10}}>
                    <span style={{fontSize:12,fontWeight:800,color:"#1e293b",flex:1}}>{cat}</span>
                    {!isUpd&&(isFleetCat||isOil
                      ?<span style={{fontSize:10,color:"#64748b",padding:"3px 10px",background:"#f1f5f9",borderRadius:6,border:"1px solid #e2e8f0"}}>{isOil?"距離管理から入力":"配車表から登録"}</span>
                      :<button onClick={()=>{setUpdType(cat);setUpdForm({completed_date:isOdo?today:"",cost:"",invoice_no:"",notes:"",odometer_km:""});}} style={{fontSize:11,padding:"4px 12px",background:"#2563eb",color:"#fff",border:"none",borderRadius:6,cursor:"pointer",fontWeight:700}}>{isOdo?"記録":"更新"}</button>)}
                  </div>
                  {/* 最新情報 */}
                  <div style={{padding:"10px 14px",display:"flex",gap:20,flexWrap:"wrap",background:"#fff",borderBottom:recs.length>0||isUpd?"1px solid #f1f5f9":"none"}}>
                    {isOdo?(
                      <div style={{display:"flex",gap:24,flexWrap:"wrap"}}>
                        <div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>前回記録日</div><div style={{fontSize:13,fontWeight:700}}>{prev?.completed_date||"-"}</div>{prev&&<div style={{fontSize:11,color:"#2563eb",fontWeight:700}}>{prev.odometer_km?.toLocaleString()||"-"} km</div>}</div>
                        <div style={{width:1,background:"#e2e8f0"}}/>
                        <div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>今回記録日</div><div style={{fontSize:13,fontWeight:700,color:"#059669"}}>{latest?.completed_date||"-"}</div>{latest&&<div style={{fontSize:11,color:"#2563eb",fontWeight:700}}>{latest.odometer_km?.toLocaleString()||"-"} km</div>}</div>
                      </div>
                    ):(
                      latest?<div style={{display:"flex",gap:20,flexWrap:"wrap"}}>
                        {isFleetCat&&<div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>入庫日</div><div style={{fontSize:13,fontWeight:700,color:"#2563eb"}}>{latest.scheduled_date||"-"}</div></div>}
                        <div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>{isFleetCat?"出庫日":"最終実施日"}</div><div style={{fontSize:13,fontWeight:700,color:"#059669"}}>{latest.completed_date||"-"}</div></div>
                        {latest.workshop&&<div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>業者</div><div style={{fontSize:13,fontWeight:600}}>{latest.workshop}</div></div>}
                        <div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>累計費用</div><div style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>{fmtYen(recs.reduce((s,r)=>s+(r.cost||0),0))}</div></div>
                        <div><div style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>実施回数</div><div style={{fontSize:13,fontWeight:700}}>{recs.length}回</div></div>
                      </div>:<div style={{fontSize:11,color:"#94a3b8"}}>記録なし</div>
                    )}
                  </div>
                  {/* 更新フォーム */}
                  {isUpd&&<div style={{padding:"12px 14px",background:"#eff6ff",borderBottom:"1px solid #dbeafe"}}>
                    <div style={{display:"grid",gridTemplateColumns:isOdo?"1fr 1fr":"1fr 1fr 1fr",gap:8,marginBottom:8}}>
                      {!isOdo&&<div><label style={lS}>実施日</label><input type="date" value={updForm.completed_date} onChange={e=>setUpdForm(p=>({...p,completed_date:e.target.value}))} style={fS}/></div>}
                      {isOdo&&<div><label style={lS}>記録日（自動）</label><input type="date" value={updForm.completed_date||today} onChange={e=>setUpdForm(p=>({...p,completed_date:e.target.value}))} style={fS}/></div>}
                      {isOdo&&<div><label style={lS}>走行距離（km）</label><input type="number" value={updForm.odometer_km} onChange={e=>setUpdForm(p=>({...p,odometer_km:e.target.value}))} style={fS} placeholder="例: 45000"/></div>}
                      {cat==="オイル交換"&&<div><label style={lS}>走行距離（km）</label><input type="number" value={updForm.odometer_km} onChange={e=>setUpdForm(p=>({...p,odometer_km:e.target.value}))} style={fS}/></div>}
                      {!isOdo&&<div><label style={lS}>費用（円）</label><input type="number" value={updForm.cost} onChange={e=>setUpdForm(p=>({...p,cost:e.target.value}))} style={fS} placeholder="0"/></div>}
                      {!isOdo&&<div><label style={lS}>請求書番号</label><input value={updForm.invoice_no} onChange={e=>setUpdForm(p=>({...p,invoice_no:e.target.value}))} style={fS} placeholder="INV-001"/></div>}
                    </div>
                    {!isOdo&&<div style={{marginBottom:8}}><label style={lS}>メモ</label><input value={updForm.notes} onChange={e=>setUpdForm(p=>({...p,notes:e.target.value}))} style={fS}/></div>}
                    <div style={{display:"flex",gap:8}}>
                      <button onClick={saveMaintUpd} style={{padding:"6px 18px",background:"#2563eb",color:"#fff",border:"none",borderRadius:6,fontSize:12,fontWeight:700,cursor:"pointer"}}>保存</button>
                      <button onClick={()=>setUpdType(null)} style={{padding:"6px 12px",border:"1px solid #d1d5db",borderRadius:6,background:"#fff",fontSize:12,cursor:"pointer"}}>キャンセル</button>
                    </div>
                  </div>}
                  {/* 履歴 */}
                  {recs.length>0&&<div style={{maxHeight:160,overflowY:"auto"}}>
                    <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                      <thead><tr style={{background:"#fafafa"}}>{(isOdo?["日付","距離(km)"]:["実施日","費用","請求書番号","メモ",""]).map((h,i)=><th key={i} style={{padding:"5px 10px",textAlign:i===1&&!isOdo?"right":"left",fontSize:9,fontWeight:700,color:"#94a3b8",borderBottom:"1px solid #f1f5f9"}}>{h}</th>)}</tr></thead>
                      <tbody>{recs.map((r,i)=><tr key={r.id} style={{borderBottom:"1px solid #f8fafc",background:i===0?"#f0fdf4":"#fff"}}>
                        {isOdo?<><td style={{padding:"5px 10px",fontWeight:i===0?700:400}}>{r.completed_date||"-"}{i===0&&<span style={{marginLeft:6,fontSize:9,color:"#059669",fontWeight:700}}>最新</span>}</td><td style={{padding:"5px 10px",fontWeight:700,color:"#2563eb"}}>{r.odometer_km?.toLocaleString()||"-"} km</td></>
                        :<><td style={{padding:"5px 10px",fontWeight:i===0?700:400}}>{r.completed_date||"-"}{i===0&&<span style={{marginLeft:6,fontSize:9,color:"#059669",fontWeight:700}}>最新</span>}</td><td style={{padding:"5px 10px",textAlign:"right",fontWeight:700}}>{fmtYen(r.cost||0)}</td><td style={{padding:"5px 10px",fontFamily:"monospace",fontSize:10}}>{r.invoice_no||"-"}</td><td style={{padding:"5px 10px",color:"#64748b",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.notes||"-"}</td><td style={{padding:"5px 10px",textAlign:"right"}}><button onClick={()=>deleteMaint(r.id)} style={{fontSize:9,color:"#ef4444",background:"none",border:"none",cursor:"pointer"}}>削除</button></td></>}
                      </tr>)}</tbody>
                    </table>
                  </div>}
                </div>;
              })}
            </div>}
          </div>}

          {/* ===== 整備管理 ===== */}
          {mTab==="svc"&&<div>
            {secH("整備管理（修理・入庫記録）")}
            {modal.mode==="add"?<div style={{textAlign:"center",padding:32,color:"#94a3b8"}}>車両登録後に記録できます</div>:<div>
              {!addingService&&<button onClick={()=>setAddingService(true)} style={{padding:"6px 16px",background:"#7c3aed",color:"#fff",border:"none",borderRadius:8,fontSize:12,fontWeight:700,cursor:"pointer",marginBottom:12}}>＋ 整備記録追加</button>}
              {addingService&&<div style={{background:"#faf5ff",border:"1px solid #e9d5ff",borderRadius:12,padding:14,marginBottom:14}}>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
                  <div><label style={lS}>入庫日</label><input type="date" value={svcForm.checkin_date} onChange={e=>setSvcForm(p=>({...p,checkin_date:e.target.value}))} style={fS}/></div>
                  <div><label style={lS}>出庫日</label><input type="date" value={svcForm.checkout_date} onChange={e=>setSvcForm(p=>({...p,checkout_date:e.target.value}))} style={fS}/></div>
                  <div style={{gridColumn:"1/-1"}}><label style={lS}>業者名</label><input value={svcForm.workshop} onChange={e=>setSvcForm(p=>({...p,workshop:e.target.value}))} style={fS} placeholder="〇〇自動車整備"/></div>
                  <div style={{gridColumn:"1/-1"}}><label style={lS}>整備内容</label><input value={svcForm.notes} onChange={e=>setSvcForm(p=>({...p,notes:e.target.value}))} style={fS} placeholder="エンジンオイル交換、ブレーキパッド交換"/></div>
                  <div><label style={lS}>費用（円）</label><input type="number" value={svcForm.cost} onChange={e=>setSvcForm(p=>({...p,cost:e.target.value}))} style={fS} placeholder="0"/></div>
                  <div><label style={lS}>請求書番号</label><input value={svcForm.invoice_no} onChange={e=>setSvcForm(p=>({...p,invoice_no:e.target.value}))} style={fS} placeholder="INV-2024-001"/></div>
                </div>
                <div style={{display:"flex",gap:8}}>
                  <button onClick={saveSvc} style={{padding:"6px 18px",background:"#7c3aed",color:"#fff",border:"none",borderRadius:6,fontSize:12,fontWeight:700,cursor:"pointer"}}>保存</button>
                  <button onClick={()=>setAddingService(false)} style={{padding:"6px 12px",border:"1px solid #d1d5db",borderRadius:6,background:"#fff",fontSize:12,cursor:"pointer"}}>キャンセル</button>
                </div>
              </div>}
              {(()=>{const svcRecs=maintRecs.filter(r=>r.type==="整備管理");const totalCost=svcRecs.reduce((s,r)=>s+(r.cost||0),0);return svcRecs.length===0?<div style={{textAlign:"center",padding:24,color:"#94a3b8",fontSize:12}}>整備記録なし</div>:<div>
                {totalCost>0&&<div style={{textAlign:"right",marginBottom:8,fontSize:12,fontWeight:700}}>累計費用: <span style={{color:"#7c3aed"}}>¥{totalCost.toLocaleString()}</span> ({svcRecs.length}件)</div>}
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                  <thead><tr style={{background:"#faf5ff"}}>{["入庫日","出庫日","業者","整備内容","費用","請求書",""].map((h,i)=><th key={i} style={{padding:"6px 8px",textAlign:i===4?"right":"left",fontSize:10,fontWeight:700,color:"#7c3aed",borderBottom:"1px solid #e9d5ff"}}>{h}</th>)}</tr></thead>
                  <tbody>{svcRecs.map((r,i)=><tr key={r.id} style={{borderBottom:"1px solid #f5f3ff",background:i%2===0?"#fff":"#fafafa"}}>
                    <td style={{padding:"7px 8px",color:"#64748b"}}>{r.checkin_date||r.completed_date||"-"}</td>
                    <td style={{padding:"7px 8px",color:"#64748b"}}>{r.checkout_date||"-"}</td>
                    <td style={{padding:"7px 8px",fontWeight:600}}>{r.workshop||"-"}</td>
                    <td style={{padding:"7px 8px",maxWidth:160,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.notes||"-"}</td>
                    <td style={{padding:"7px 8px",textAlign:"right",fontWeight:700}}>{fmtYen(r.cost||0)}</td>
                    <td style={{padding:"7px 8px",fontFamily:"monospace",fontSize:10}}>{r.invoice_no||"-"}</td>
                    <td style={{padding:"7px 8px",textAlign:"right"}}><button onClick={()=>deleteMaint(r.id)} style={{fontSize:10,color:"#ef4444",background:"none",border:"none",cursor:"pointer"}}>削除</button></td>
                  </tr>)}</tbody>
                </table>
              </div>;})()}
            </div>}
          </div>}

          {/* ===== 🚗 車検/点検 ===== */}
          {mTab==="inspect"&&(()=>{
            // 残日数と信号色判定ヘルパー
            const calcDays=(d)=>{if(!d)return null;const t=new Date();t.setHours(0,0,0,0);const x=new Date(d);x.setHours(0,0,0,0);return Math.round((x-t)/86400000);};
            const sigColor=(days)=>{if(days===null)return{bg:"#f1f5f9",fg:"#64748b",label:"未登録"};if(days<0)return{bg:"#1e293b",fg:"#fff",label:"⚫切れ"};if(days<14)return{bg:"#fef2f2",fg:"#dc2626",label:"🔴緊急"};if(days<30)return{bg:"#fff7ed",fg:"#ea580c",label:"🟠注意"};if(days<60)return{bg:"#fefce8",fg:"#ca8a04",label:"🟡近日"};return{bg:"#f0fdf4",fg:"#16a34a",label:"🟢余裕"};};
            const dueDays=calcDays(form.inspectionDueDate);
            const nextDays=calcDays(form.inspectionNextDate);
            const tenkenDueDays=calcDays(form.tenkenDueDate);
            const tenkenNextDays=calcDays(form.tenkenNextDate);
            // ★ 2026-05-07 日付入力をプルダウン3つに変更（input type=date エラー対応）
            const DateSelect=({value,onChange})=>{
              const parts=(value||"").split("-");
              const y=parts[0]||""; const m=parts[1]||""; const d=parts[2]||"";
              const buildDate=(yy,mm,dd)=>{
                if(!yy&&!mm&&!dd)return"";
                const Y=yy||String(new Date().getFullYear());
                const M=(mm||"01").padStart(2,"0");
                const D=(dd||"01").padStart(2,"0");
                return Y+"-"+M+"-"+D;
              };
              const ss={padding:"6px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:12,background:"#fff"};
              const yearOptions=[];const curY=new Date().getFullYear();
              for(let yr=curY-2;yr<=curY+10;yr++)yearOptions.push(yr);
              return <div style={{display:"flex",gap:6,alignItems:"center",flexWrap:"wrap"}}>
                <select value={y} onChange={e=>onChange({target:{value:buildDate(e.target.value,m,d)}})} style={ss}>
                  <option value="">年</option>
                  {yearOptions.map(yr=><option key={yr} value={String(yr)}>{yr}年</option>)}
                </select>
                <select value={m} onChange={e=>onChange({target:{value:buildDate(y,e.target.value,d)}})} style={ss}>
                  <option value="">月</option>
                  {Array.from({length:12},(_,i)=>String(i+1).padStart(2,"0")).map(mo=><option key={mo} value={mo}>{parseInt(mo)}月</option>)}
                </select>
                <select value={d} onChange={e=>onChange({target:{value:buildDate(y,m,e.target.value)}})} style={ss}>
                  <option value="">日</option>
                  {Array.from({length:31},(_,i)=>String(i+1).padStart(2,"0")).map(da=><option key={da} value={da}>{parseInt(da)}日</option>)}
                </select>
                {value&&<button type="button" onClick={()=>onChange({target:{value:""}})} style={{fontSize:10,padding:"4px 8px",background:"#fee2e2",color:"#991b1b",border:"none",borderRadius:4,cursor:"pointer"}}>クリア</button>}
              </div>;
            };
            const Card=({label,value,onChange,days,note})=>{
              const c=sigColor(days);
              return <div style={{background:c.bg,border:"1px solid #e2e8f0",borderRadius:10,padding:14,marginBottom:10}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6,flexWrap:"wrap",gap:6}}>
                  <label style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>{label}</label>
                  {days!==null&&<span style={{fontSize:11,fontWeight:800,color:c.fg,padding:"2px 8px",borderRadius:6,background:"rgba(255,255,255,.6)"}}>{c.label} 残{days>=0?"+":""}{days}日</span>}
                </div>
                <DateSelect value={value} onChange={onChange}/>
                {note&&<div style={{fontSize:10,color:"#64748b",marginTop:4}}>{note}</div>}
              </div>;
            };
            return <div>
              {modal.mode==="add"?<div style={{textAlign:"center",padding:32,color:"#94a3b8",fontSize:13}}>車両登録後に入力できます</div>:<div>
                {secH("🚗 車検満了日")}
                <Card label="車検満了日（車検証記載・法的期限）" value={form.inspectionDueDate} onChange={e=>upF("inspectionDueDate",e.target.value)} days={dueDays} note="※ 車検証に印字されている正確な日付を入力してください"/>
                <div style={{height:16}}></div>
                {secH("🔧 半年点検期限")}
                <Card label="半年点検期限" value={form.tenkenDueDate} onChange={e=>upF("tenkenDueDate",e.target.value)} days={tenkenDueDays} note="※ 前回点検 + 6ヶ月の期限日"/>
                <div style={{padding:"10px 14px",background:"#eef2ff",border:"1px solid #c7d2fe",borderRadius:8,marginTop:14}}>
                  <div style={{fontSize:11,fontWeight:800,color:"#4338ca",marginBottom:4}}>💡 次回予定日について</div>
                  <div style={{fontSize:11,color:"#3730a3",lineHeight:1.5}}>
                    次回車検予定日 / 次回半年点検予定日は、<b>配車表のメンテナンスブロック</b>として登録された日付が「車検/点検 → スケジュール」画面に自動反映されます。<br/>
                    配車表で「メンテナンス追加」→ ラベル「車検」または「半年点検」+ 予定日を登録してください。
                  </div>
                </div>
                <div style={{padding:"10px 14px",background:"#fef2f2",border:"1px solid #fca5a5",borderRadius:8,marginTop:10}}>
                  <div style={{fontSize:11,fontWeight:800,color:"#991b1b",marginBottom:4}}>⚠️ 重要</div>
                  <div style={{fontSize:11,color:"#7f1d1d",lineHeight:1.5}}>
                    車検満了日を超えた車両を貸し出すと法令違反（道路運送車両法）+ 任意保険無効。<br/>
                    車検証の現物を確認して正確な日付を入力してください。
                  </div>
                </div>
              </div>}
            </div>;
          })()}

        </div>
        {/* フッター（基本3タブ + 車検/点検タブ で保存） */}
        {["basic","ins","cost","inspect"].includes(mTab)&&<div style={{padding:"12px 24px",borderTop:"1px solid #e2e8f0",display:"flex",justifyContent:"flex-end",gap:8}}>
          <button onClick={closeModal} style={{padding:"8px 20px",border:"1px solid #d1d5db",borderRadius:8,background:"#fff",fontSize:13,cursor:"pointer"}}>キャンセル</button>
          <button onClick={saveVehicle} disabled={vehSaving} style={{padding:"8px 24px",background:vehSaveMsg==="ok"?"#059669":vehSaveMsg==="err"?"#dc2626":"#2563eb",color:"#fff",border:"none",borderRadius:8,fontSize:13,fontWeight:700,cursor:vehSaving?"not-allowed":"pointer",display:"flex",alignItems:"center",gap:6}}>
            {vehSaving?<span style={{fontSize:11}}>保存中...</span>:vehSaveMsg==="ok"?<span>✅ 保存完了</span>:vehSaveMsg==="err"?<span>❌ 失敗</span>:(modal.mode==="add"?"登録":"保存")}
          </button>
        </div>}
      </div>
    </div>}
  </div>;
}

/* ==========================================
   車検/点検/修理（3サブタブ: 車両マスター / スケジュール / 資金繰り）
   ========================================== */
function InspectionCalendar({vehicles,maintenance,onMaintenanceChange,hmLogs}){
  const nowY=new Date().getFullYear();
  const isMob=useMobile();
  const[icTab,setIcTab]=useState("master"); // "master"|"budget"|"inspection"
  const[year,setYear]=useState(nowY);
  const MONTHS=Array.from({length:12},(_,i)=>i+1);
  const TYPES=["車検","半年点検","修理"];
  const TC={"車検":{bg:"#dbeafe",color:"#1e40af",bar:"#2563eb"},"半年点検":{bg:"#dcfce7",color:"#166534",bar:"#16a34a"},"修理":{bg:"#fef2f2",color:"#991b1b",bar:"#dc2626"}};
  const getVeh=(code)=>vehicles.find(v=>v.code===code);
  const thS={padding:"8px 10px",fontSize:11,fontWeight:700,color:"#64748b",borderBottom:"2px solid #e2e8f0",textAlign:"left",background:"#f8fafc",whiteSpace:"nowrap"};
  const tdS={padding:"6px 10px",fontSize:11,verticalAlign:"middle",borderBottom:"1px solid #f1f5f9"};

  // 月別データ（スケジュール/資金繰り共通）
  const byMonth=useMemo(()=>{
    const m={};MONTHS.forEach(mo=>m[mo]=[]);
    (maintenance||[]).filter(r=>TYPES.includes(r.label)).forEach(r=>{
      const d=r.startDate||r.endDate;if(!d)return;
      const y=parseInt(d.slice(0,4));const mo=parseInt(d.slice(5,7));
      if(y===year&&m[mo])m[mo].push(r);
    });
    return m;
  },[maintenance,year]);

  const costByMonth=useMemo(()=>{
    const m={};MONTHS.forEach(mo=>m[mo]={車検:0,半年点検:0,修理:0,total:0,cnt:0,budget:0,actual:0,actualCnt:0});
    // 予算 = bt_maintenance.cost
    (maintenance||[]).filter(r=>TYPES.includes(r.label)).forEach(r=>{
      const d=r.startDate||r.endDate;if(!d)return;
      const y=parseInt(d.slice(0,4));const mo=parseInt(d.slice(5,7));
      if(y!==year||!m[mo])return;
      const budget=r.cost||0;
      if(budget>0){m[mo].budget+=budget;m[mo].cnt++;}
    });
    // 実績 = bt_logs (整備記録) type='inspection'|'semi_annual'|'repair'
    (hmLogs||[]).forEach(l=>{
      const t=l.type||"";
      if(t!=="inspection"&&t!=="semi_annual"&&t!=="repair")return;
      const d=l.date;if(!d)return;
      const y=parseInt(d.slice(0,4));const mo=parseInt(d.slice(5,7));
      if(y!==year||!m[mo])return;
      const c=Number(l.cost||0);if(c<=0)return;
      const lbl=t==="inspection"?"車検":t==="semi_annual"?"半年点検":"修理";
      m[mo].actual+=c;m[mo].actualCnt++;
      m[mo][lbl]=(m[mo][lbl]||0)+c;m[mo].total+=c;
    });
    return m;
  },[maintenance,hmLogs,year]);

  const annualBudget=Object.values(costByMonth).reduce((s,m)=>s+m.budget,0);
  const annualActual=Object.values(costByMonth).reduce((s,m)=>s+m.actual,0);
  const annualTotal=Object.values(costByMonth).reduce((s,m)=>s+m.total,0);
  const maxCost=Math.max(...Object.values(costByMonth).map(m=>m.total),1);

  // ★ 個別レコードの実費 = bt_logs から (車両 + 種別 + 月) で引く
  const findActualForMaint=(r)=>{
    if(!r||!r.startDate)return 0;
    const ym=r.startDate.slice(0,7);
    const targetType=r.label==="車検"?"inspection":r.label==="半年点検"?"semi_annual":null;
    if(!targetType)return 0;
    return (hmLogs||[]).filter(l=>l.car_id===r.vehicleCode&&l.type===targetType&&(l.date||"").slice(0,7)===ym)
      .reduce((s,l)=>s+Number(l.cost||0),0);
  };
  const[openMonths,setOpenMonths]=useState({});
  const toggleMonth=(mo)=>setOpenMonths(p=>({...p,[mo]:!p[mo]}));

  // ===== タブボタン =====
  const tabBtn=(id,icon,label)=><button onClick={()=>setIcTab(id)} style={{padding:"6px 14px",fontSize:12,fontWeight:icTab===id?700:500,color:icTab===id?"#2563eb":"#64748b",background:icTab===id?"#eff6ff":"none",border:"none",borderRadius:8,cursor:"pointer",display:"flex",alignItems:"center",gap:4}}><span>{icon}</span>{label}</button>;

  // ===== 年セレクター（共通） =====
  const YearSel=()=><div style={{display:"flex",alignItems:"center",gap:6,marginLeft:"auto"}}>
    <button onClick={()=>setYear(y=>y-1)} style={{padding:"3px 8px",border:"1px solid #e2e8f0",borderRadius:6,background:"#fff",cursor:"pointer",fontSize:12}}>◀</button>
    <span style={{fontSize:13,fontWeight:700,minWidth:52,textAlign:"center"}}>{year}年</span>
    <button onClick={()=>setYear(y=>y+1)} style={{padding:"3px 8px",border:"1px solid #e2e8f0",borderRadius:6,background:"#fff",cursor:"pointer",fontSize:12}}>▶</button>
    {year!==nowY&&<button onClick={()=>setYear(nowY)} style={{fontSize:10,padding:"2px 8px",border:"1px solid #bfdbfe",borderRadius:6,background:"#eff6ff",color:"#2563eb",cursor:"pointer"}}>今年</button>}
  </div>;

  return <div style={{maxWidth:960,margin:"0 auto"}}>
    {/* サブタブ */}
    <div style={{display:"flex",gap:4,marginBottom:16,borderBottom:"1px solid #e2e8f0",paddingBottom:8}}>
      {tabBtn("master","📋","車両マスター")}
      {tabBtn("budget","📅","予算スケジュール")}
      {tabBtn("inspection","🚗","車検/点検/修理 スケジュール")}
    </div>

    {/* ========== 📋 車両マスター ========== */}
    {icTab==="master"&&<InspectionMasterView vehicles={vehicles} maintenance={maintenance} onMaintenanceChange={onMaintenanceChange} thS={thS} tdS={tdS} TC={TC}/>}

    {/* ========== 📅 予算スケジュール ========== */}
    {icTab==="budget"&&<div>
      <div style={{display:"flex",alignItems:"center",marginBottom:16}}>
        <h3 style={{fontSize:14,fontWeight:800,margin:0}}>📅 年間スケジュール（予算 vs 実績）</h3>
        <YearSel/>
      </div>
      {/* 年間コストサマリー */}
      <div style={{background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:12,padding:"14px 18px",marginBottom:16}}>
        <div style={{display:"flex",alignItems:"baseline",gap:10,marginBottom:6,flexWrap:"wrap"}}>
          <span style={{fontSize:12,fontWeight:800,color:"#1e293b"}}>{year}年 年間</span>
          <div style={{display:"flex",gap:12,flexWrap:"wrap",alignItems:"baseline"}}>
            <span style={{fontSize:11,color:"#64748b"}}>予算 <span style={{fontSize:18,fontWeight:900,color:"#475569"}}>¥{annualBudget.toLocaleString()}</span></span>
            {annualActual>0&&<>
              <span style={{fontSize:11,color:"#64748b"}}>実績 <span style={{fontSize:18,fontWeight:900,color:"#059669"}}>¥{annualActual.toLocaleString()}</span></span>
              <span style={{fontSize:11,color:"#64748b"}}>差異 <span style={{fontSize:14,fontWeight:700,color:annualActual>annualBudget?"#dc2626":"#059669"}}>{annualActual>annualBudget?"+":""}{(annualActual-annualBudget).toLocaleString()}</span></span>
            </>}
          </div>
          <div style={{display:"flex",gap:8,marginLeft:"auto",flexWrap:"wrap"}}>
            {TYPES.map(t=><span key={t} style={{fontSize:10,padding:"2px 8px",borderRadius:4,background:TC[t].bg,color:TC[t].color,fontWeight:700}}>{t}: ¥{Object.values(costByMonth).reduce((s,m)=>s+(m[t]||0),0).toLocaleString()}</span>)}
          </div>
        </div>
        <div style={{display:"flex",gap:3,alignItems:"flex-end",height:52}}>
          {MONTHS.map(mo=>{
            const c=costByMonth[mo];const isNow=year===nowY&&mo===new Date().getMonth()+1;
            return <div key={mo} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:2}}>
              <div style={{width:"100%",display:"flex",flexDirection:"column",gap:1,height:44,justifyContent:"flex-end"}}>
                {c["修理"]>0&&<div style={{width:"100%",height:Math.max(2,Math.round(c["修理"]/maxCost*44)),background:TC["修理"].bar,borderRadius:"2px 2px 0 0"}}/>}
                {c["車検"]>0&&<div style={{width:"100%",height:Math.max(2,Math.round(c["車検"]/maxCost*44)),background:TC["車検"].bar}}/>}
                {c["半年点検"]>0&&<div style={{width:"100%",height:Math.max(2,Math.round(c["半年点検"]/maxCost*44)),background:TC["半年点検"].bar}}/>}
              </div>
              <div style={{fontSize:9,fontWeight:isNow?800:400,color:isNow?"#2563eb":"#94a3b8"}}>{mo}月</div>
            </div>;
          })}
        </div>
      </div>
      {/* 月別一覧 */}
      {isMob
        // ===== モバイル: カード形式 =====
        ?<div style={{borderRadius:12,overflow:"hidden",border:"1px solid #e2e8f0"}}>
          {MONTHS.map(mo=>{
            const recs=byMonth[mo];const moData=costByMonth[mo]||{};
            const isNow=year===nowY&&mo===new Date().getMonth()+1;
            const isOpen=!!openMonths[mo];const hasRecs=recs.length>0;
            const moBudget=moData.budget||0;const moActual=moData.actual||0;const moActualCnt=moData.actualCnt||0;
            return<div key={mo} style={{borderBottom:"1px solid #f1f5f9"}}>
              {/* ヘッダー行（常時表示） */}
              <div onClick={()=>hasRecs&&toggleMonth(mo)} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:isNow?"#dbeafe":"#f8fafc",cursor:hasRecs?"pointer":"default",flexWrap:"wrap"}}>
                <span style={{fontSize:13,fontWeight:800,color:isNow?"#2563eb":hasRecs?"#1e293b":"#94a3b8",minWidth:28}}>{mo}月</span>
                {hasRecs?<>
                  <span style={{fontSize:11,color:"#64748b"}}>{recs.length}件</span>
                  {TYPES.map(t=>{const cnt=recs.filter(r=>r.label===t).length;return cnt>0?<span key={t} style={{fontSize:10,padding:"1px 6px",borderRadius:4,background:TC[t].bg,color:TC[t].color}}>{t}{cnt}</span>:null;})}
                  {moBudget>0&&<span style={{fontSize:10,color:"#64748b"}}>予算 <b style={{color:"#475569"}}>¥{moBudget.toLocaleString()}</b></span>}
                  {moActual>0&&<span style={{fontSize:10,color:"#64748b"}}>実績 <b style={{color:"#059669"}}>¥{moActual.toLocaleString()}</b></span>}
                  {moActual>0&&moBudget>0&&<span style={{fontSize:10,fontWeight:700,color:moActual>moBudget?"#dc2626":"#059669"}}>{moActual>moBudget?"↑":"↓"}¥{Math.abs(moActual-moBudget).toLocaleString()}</span>}
                  <span style={{marginLeft:"auto",fontSize:10,color:"#94a3b8"}}>{isOpen?"▼":"▶"}</span>
                </>:<span style={{fontSize:11,color:"#cbd5e1"}}>登録なし</span>}
              </div>
              {/* 詳細（展開時のみ） */}
              {isOpen&&hasRecs&&TYPES.map(t=>{
                const tRecs=recs.filter(r=>r.label===t);
                if(tRecs.length===0)return null;
                const tc=TC[t];
                const icon=t==="車検"?"🛡️":"🔧";
                const tBudget=tRecs.reduce((s,r)=>s+(r.cost||0),0);
                const tActual=tRecs.reduce((s,r)=>s+findActualForMaint(r),0);
                const tDiff=tActual>0&&tBudget>0?tActual-tBudget:null;
                return<div key={"g"+mo+t}>
                  {/* 種別サブヘッダー */}
                  <div style={{display:"flex",alignItems:"center",gap:8,padding:"8px 14px",background:tc.bg,borderTop:"2px solid "+tc.bar,flexWrap:"wrap"}}>
                    <span style={{fontSize:12,fontWeight:800,color:tc.color}}>{icon} {t}</span>
                    <span style={{fontSize:10,fontWeight:700,padding:"1px 6px",borderRadius:4,background:"#fff",color:tc.color}}>{tRecs.length}件</span>
                    <span style={{fontSize:10,color:"#64748b"}}>予算 <b>¥{tBudget.toLocaleString()}</b></span>
                    <span style={{fontSize:11,fontWeight:800,color:tActual>0?tc.color:"#94a3b8"}}>実績 ¥{tActual.toLocaleString()}</span>
                    {tDiff!==null&&<span style={{fontSize:10,fontWeight:700,color:tDiff>0?"#dc2626":"#059669"}}>{tDiff>0?"+":""}{tDiff.toLocaleString()}</span>}
                  </div>
                  {tRecs.map(r=>{
                    const v=getVeh(r.vehicleCode);
                    const actual=findActualForMaint(r);
                    const diff=actual>0&&r.cost>0?actual-r.cost:null;
                    return<div key={r.id} style={{display:"flex",alignItems:"flex-start",gap:10,padding:"10px 14px",borderTop:"1px dashed #f1f5f9",background:isNow?"#eff6ff":"#fff"}}>
                      <span style={{minWidth:28,color:tc.color,fontSize:12}}>↳</span>
                      <div style={{flex:1}}>
                        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                          <span style={{fontSize:12,fontWeight:700}}>{v?v.name:r.vehicleCode}</span>
                        </div>
                        <div style={{fontSize:10,color:"#64748b",display:"flex",gap:8,flexWrap:"wrap",marginBottom:4}}>
                          {r.startDate&&<span>入庫 <b style={{color:"#2563eb"}}>{r.startDate.slice(5)}</b></span>}
                          {r.endDate&&<span>出庫 <b style={{color:"#059669"}}>{r.endDate.slice(5)}</b></span>}
                          {r.workshop&&<span>{r.workshop}</span>}
                        </div>
                        <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
                          {r.cost>0&&<span style={{fontSize:10,color:"#64748b"}}>予算 <b>¥{r.cost.toLocaleString()}</b></span>}
                          {actual>0?<span style={{fontSize:10,color:tc.color,fontWeight:700}}>実績 ¥{actual.toLocaleString()}</span>:<span style={{fontSize:10,color:"#cbd5e1"}}>実績 未入力</span>}
                          {diff!==null&&<span style={{fontSize:10,fontWeight:700,color:diff>0?"#dc2626":"#059669"}}>{diff>0?"+":""}{diff.toLocaleString()}</span>}
                        </div>
                      </div>
                    </div>;
                  })}
                </div>;
              })}
            </div>;
          })}
          <div style={{background:"#1e293b",padding:"10px 14px",display:"flex",justifyContent:"space-between"}}>
            <span style={{fontSize:12,fontWeight:900,color:"#fff"}}>年間合計</span>
            <span style={{fontSize:14,fontWeight:900,color:"#4ade80"}}>¥{annualTotal.toLocaleString()}</span>
          </div>
        </div>
        // ===== デスクトップ: テーブル =====
        :<div style={{border:"1px solid #e2e8f0",borderRadius:12,overflow:"hidden"}}>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr>
              <th style={{...thS,width:46}}>月</th>
              <th style={thS}>車両</th>
              <th style={thS}>種別</th>
              <th style={thS}>入庫日</th>
              <th style={thS}>出庫日</th>
              <th style={{...thS,textAlign:"right"}}>予算</th>
              <th style={{...thS,textAlign:"right",color:"#059669",background:"#f0fdf4"}}>実績</th>
              <th style={{...thS,textAlign:"right",color:"#7c3aed",background:"#faf5ff"}}>差異</th>
              <th style={thS}>業者</th>
            </tr></thead>
            <tbody>
              {MONTHS.map(mo=>{
                const recs=byMonth[mo];const moData=costByMonth[mo]||{};
                const isNow=year===nowY&&mo===new Date().getMonth()+1;
                const isOpen=!!openMonths[mo];const hasRecs=recs.length>0;
                const moBudget=moData.budget||0;const moActual=moData.actual||0;const moActualCnt=moData.actualCnt||0;
                const rows=[];
                // ヘッダー行（常時表示・クリックで開閉）
                rows.push(<tr key={"h"+mo} onClick={()=>hasRecs&&toggleMonth(mo)} style={{background:isNow?"#dbeafe":"#f8fafc",cursor:hasRecs?"pointer":"default",userSelect:"none"}}>
                  <td style={{...tdS,fontWeight:800,color:isNow?"#2563eb":hasRecs?"#1e293b":"#94a3b8",fontSize:13,textAlign:"center",borderRight:"2px solid #e2e8f0"}}>
                    {hasRecs&&<span style={{fontSize:9,marginRight:3,color:"#94a3b8"}}>{isOpen?"▼":"▶"}</span>}{mo}月
                  </td>
                  <td colSpan={7} style={{...tdS,color:hasRecs?"#475569":"#cbd5e1",fontSize:11}}>
                    {hasRecs?<div style={{display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}}>
                      <span>{recs.length}件{TYPES.map(t=>{const cnt=recs.filter(r=>r.label===t).length;return cnt>0?<span key={t} style={{marginLeft:6,fontSize:10,padding:"1px 6px",borderRadius:4,background:TC[t].bg,color:TC[t].color}}>{t} {cnt}件</span>:null;})}</span>
                      {moBudget>0&&<span style={{fontSize:10,color:"#64748b"}}>予算 <b style={{color:"#475569"}}>¥{moBudget.toLocaleString()}</b></span>}
                      {moActual>0&&<span style={{fontSize:10,color:"#064748b"}}>実績 <b style={{color:"#059669"}}>¥{moActual.toLocaleString()}</b>{moActualCnt<recs.length&&<span style={{color:"#94a3b8",marginLeft:3}}>{moActualCnt}/{recs.length}件</span>}</span>}
                      {moActual>0&&moBudget>0&&<span style={{fontSize:10,fontWeight:700,color:moActual>moBudget?"#dc2626":"#059669"}}>{moActual>moBudget?"↑超過":"↓節約"} ¥{Math.abs(moActual-moBudget).toLocaleString()}</span>}
                    </div>:"登録なし"}
                  </td>
                  <td style={{...tdS,textAlign:"right",background:"#fffbeb",borderLeft:"1px solid #fde68a",padding:"4px 10px"}}>
                    {moActual>0?<>
                      <div style={{fontSize:8,color:"#92400e",fontWeight:700}}>{mo}月 実績計</div>
                      <div style={{fontSize:13,fontWeight:900,color:"#059669"}}>¥{moActual.toLocaleString()}</div>
                    </>:moBudget>0?<>
                      <div style={{fontSize:8,color:"#94a3b8",fontWeight:700}}>{mo}月 予算計</div>
                      <div style={{fontSize:11,fontWeight:700,color:"#94a3b8"}}>¥{moBudget.toLocaleString()}</div>
                    </>:<span style={{color:"#94a3b8",fontSize:11}}>-</span>}
                  </td>
                </tr>);
                // 詳細行（展開時のみ）
                if(isOpen&&hasRecs){
                  // 案A: 種別ごとにグループ化（🛡️車検 / 🔧半年点検）
                  TYPES.forEach(t=>{
                    const tRecs=recs.filter(r=>r.label===t);
                    if(tRecs.length===0)return;
                    const tc=TC[t];
                    const icon=t==="車検"?"🛡️":"🔧";
                    const tBudget=tRecs.reduce((s,r)=>s+(r.cost||0),0);
                    const tActual=tRecs.reduce((s,r)=>s+findActualForMaint(r),0);
                    const tDiff=tActual>0&&tBudget>0?tActual-tBudget:null;
                    // 種別サブヘッダー行（ラベル付き）
                    rows.push(<tr key={"sh"+mo+t} style={{background:tc.bg,borderTop:"2px solid "+tc.bar}}>
                      <td style={{...tdS,borderRight:"2px solid #e2e8f0",background:isNow?"#dbeafe":"#f8fafc"}}></td>
                      <td colSpan={4} style={{...tdS,fontSize:12,fontWeight:800,color:tc.color}}>
                        {icon} {t} <span style={{fontSize:10,fontWeight:700,marginLeft:8,padding:"2px 8px",background:"#fff",borderRadius:4,color:tc.color}}>{tRecs.length}件</span>
                        <span style={{fontSize:9,fontWeight:600,marginLeft:8,color:"#64748b"}}>↓ {t}の小計</span>
                      </td>
                      <td style={{...tdS,textAlign:"right",padding:"4px 10px"}}>
                        <div style={{fontSize:8,color:"#94a3b8",fontWeight:700}}>予算計</div>
                        <div style={{fontSize:11,fontWeight:700,color:"#475569"}}>¥{tBudget.toLocaleString()}</div>
                      </td>
                      <td style={{...tdS,textAlign:"right",background:"#f0fdf4",padding:"4px 10px"}}>
                        <div style={{fontSize:8,color:tc.color,fontWeight:700}}>実績計</div>
                        <div style={{fontSize:13,fontWeight:900,color:tActual>0?tc.color:"#94a3b8"}}>{tActual>0?"¥"+tActual.toLocaleString():"-"}</div>
                      </td>
                      <td style={{...tdS,textAlign:"right",background:"#faf5ff",padding:"4px 10px"}}>
                        <div style={{fontSize:8,color:"#7c3aed",fontWeight:700}}>差異</div>
                        <div style={{fontSize:11,fontWeight:800,color:tDiff===null?"#cbd5e1":tDiff>0?"#dc2626":"#059669"}}>{tDiff===null?"-":(tDiff>0?"↑+":"↓")+Math.abs(tDiff).toLocaleString()}</div>
                      </td>
                      <td style={tdS}></td>
                    </tr>);
                    // 各レコード行（インデント表示）
                    tRecs.forEach(r=>{
                      const v=getVeh(r.vehicleCode);
                      const actual=findActualForMaint(r);
                      const diff=actual>0&&r.cost>0?actual-r.cost:null;
                      rows.push(<tr key={r.id} style={{background:isNow?"#eff6ff":"#fff"}}>
                        <td style={{...tdS,borderRight:"2px solid #e2e8f0",background:isNow?"#dbeafe":"#f8fafc"}}></td>
                        <td style={{...tdS,paddingLeft:24}}>
                          <span style={{color:tc.color,marginRight:6,fontSize:10}}>↳</span>
                          <span style={{fontWeight:700,fontSize:11}}>{v?v.name:r.vehicleCode}</span>
                          {v&&<span style={{fontSize:10,color:"#94a3b8",marginLeft:6}}>{v.no}</span>}
                        </td>
                        <td style={{...tdS,fontSize:9,color:"#94a3b8"}}>{t}</td>
                        <td style={{...tdS,color:"#2563eb",fontSize:10}}>{r.startDate||"-"}</td>
                        <td style={{...tdS,color:"#059669",fontSize:10}}>{r.endDate||"-"}</td>
                        <td style={{...tdS,textAlign:"right",fontSize:10,color:"#64748b"}}>{r.cost>0?"¥"+r.cost.toLocaleString():"-"}</td>
                        <td style={{...tdS,textAlign:"right",fontWeight:700,color:actual>0?tc.color:"#cbd5e1",background:"#f0fdf4"}}>{actual>0?"¥"+actual.toLocaleString():<span style={{fontSize:9}}>未入力</span>}</td>
                        <td style={{...tdS,textAlign:"right",fontWeight:700,fontSize:10,background:"#faf5ff",color:diff===null?"#cbd5e1":diff>0?"#dc2626":"#059669"}}>{diff===null?"-":(diff>0?"+":"")+diff.toLocaleString()}</td>
                        <td style={{...tdS,color:"#64748b",fontSize:10}}>{r.workshop||"-"}</td>
                      </tr>);
                    });
                  });
                }
                return rows;
              })}
            </tbody>
            <tfoot><tr style={{background:"#1e293b"}}>
              <td colSpan={8} style={{padding:"8px 10px",fontSize:12,fontWeight:900,color:"#fff"}}>年間合計</td>
              <td style={{padding:"8px 10px",textAlign:"right",fontSize:13,fontWeight:900,color:"#4ade80"}}>¥{annualTotal.toLocaleString()}</td>
            </tr></tfoot>
          </table>
        </div>}

    </div>}

    {/* ========== 🚗 車検/点検 スケジュール (2026-05-07 別タブ化) ========== */}
    {icTab==="inspection"&&<div>
      {/* 全車両 車検/点検 次回予定一覧
          - 車検満了日 / 半年点検期限 = 車両マスター（編集モーダル）入力値
          - 次回車検予定 / 次回点検予定 = 配車表のメンテブロック (maintenance.label) から自動取得 */}
      {(()=>{
        const today=new Date();today.setHours(0,0,0,0);
        const todayStr=today.toISOString().slice(0,10);
        const calcDays=(d)=>{if(!d)return null;const x=new Date(d);x.setHours(0,0,0,0);return Math.round((x-today)/86400000);};
        const sigStyle=(days)=>{
          if(days===null)return{bg:"#f8fafc",fg:"#94a3b8",label:"未登録",border:"#e2e8f0"};
          if(days<0)return{bg:"#1e293b",fg:"#fff",label:"⚫切れ",border:"#0f172a"};
          if(days<14)return{bg:"#fef2f2",fg:"#dc2626",label:"🔴緊急",border:"#fca5a5"};
          if(days<30)return{bg:"#fff7ed",fg:"#ea580c",label:"🟠注意",border:"#fdba74"};
          if(days<60)return{bg:"#fefce8",fg:"#ca8a04",label:"🟡近日",border:"#fde047"};
          return{bg:"#f0fdf4",fg:"#16a34a",label:"🟢余裕",border:"#bbf7d0"};
        };
        // 配車表のメンテブロックから「次回車検予定」「次回点検予定」を計算（未来日の最早）
        const nextShakenMap={};const nextTenkenMap={};
        (maintenance||[]).forEach(m=>{
          const sd=m.startDate||m.start_date;
          const vc=m.vehicleCode||m.vehicle_code;
          if(!sd||!vc||sd<todayStr)return;
          if(m.label==="車検"){if(!nextShakenMap[vc]||sd<nextShakenMap[vc])nextShakenMap[vc]=sd;}
          if(m.label==="半年点検"){if(!nextTenkenMap[vc]||sd<nextTenkenMap[vc])nextTenkenMap[vc]=sd;}
        });
        const rows=(vehicles||[]).filter(v=>v.active!==false).map(v=>{
          const insDueDate=v.inspectionDueDate||"";
          const tenDueDate=v.tenkenDueDate||"";
          const insNextDate=nextShakenMap[v.code]||"";
          const tenNextDate=nextTenkenMap[v.code]||"";
          const insDue=calcDays(insDueDate);
          const insNext=calcDays(insNextDate);
          const tenDue=calcDays(tenDueDate);
          const tenNext=calcDays(tenNextDate);
          const urgs=[insDue,insNext,tenDue,tenNext].filter(x=>x!==null);
          const urgency=urgs.length?Math.min(...urgs):999;
          return{v,insDueDate,insNextDate,tenDueDate,tenNextDate,insDue,insNext,tenDue,tenNext,urgency};
        }).sort((a,b)=>a.urgency-b.urgency);
        const summary={expired:0,critical:0,warning:0,notRegistered:0};
        rows.forEach(r=>{
          if([r.insDue,r.tenDue].some(d=>d!==null&&d<0))summary.expired++;
          else if([r.insDue,r.tenDue].some(d=>d!==null&&d<14))summary.critical++;
          else if([r.insDue,r.tenDue].some(d=>d!==null&&d<30))summary.warning++;
          if(r.insDue===null||r.tenDue===null)summary.notRegistered++;
        });
        const Cell=({date,days})=>{
          if(!date)return <div style={{color:"#cbd5e1",fontSize:11}}>未登録</div>;
          const s=sigStyle(days);
          return <div style={{display:"flex",flexDirection:"column",gap:2}}>
            <div style={{fontSize:11,fontWeight:700,color:"#1e293b"}}>{date}</div>
            <span style={{fontSize:9,fontWeight:800,color:s.fg,background:s.bg,padding:"1px 6px",borderRadius:4,border:"1px solid "+s.border,alignSelf:"flex-start"}}>{s.label} {days>=0?"+":""}{days}日</span>
          </div>;
        };
        return <div style={{marginTop:32}}>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12,flexWrap:"wrap",gap:8}}>
            <h3 style={{fontSize:14,fontWeight:800,margin:0}}>📋 全車両 車検/点検 次回予定</h3>
            <span style={{fontSize:11,color:"#64748b"}}>{rows.length}台 — 残日数順 / 満了日=マスター入力 / 次回予定=配車表メンテブロック</span>
          </div>
          <div style={{display:"flex",gap:8,marginBottom:12,flexWrap:"wrap"}}>
            <div style={{padding:"8px 14px",background:summary.expired>0?"#1e293b":"#f8fafc",color:summary.expired>0?"#fff":"#94a3b8",borderRadius:8,fontSize:11,fontWeight:700}}>⚫ 切れ {summary.expired}台</div>
            <div style={{padding:"8px 14px",background:summary.critical>0?"#fef2f2":"#f8fafc",color:summary.critical>0?"#dc2626":"#94a3b8",border:"1px solid "+(summary.critical>0?"#fca5a5":"#e2e8f0"),borderRadius:8,fontSize:11,fontWeight:700}}>🔴 14日以内 {summary.critical}台</div>
            <div style={{padding:"8px 14px",background:summary.warning>0?"#fff7ed":"#f8fafc",color:summary.warning>0?"#ea580c":"#94a3b8",border:"1px solid "+(summary.warning>0?"#fdba74":"#e2e8f0"),borderRadius:8,fontSize:11,fontWeight:700}}>🟠 30日以内 {summary.warning}台</div>
            <div style={{padding:"8px 14px",background:summary.notRegistered>0?"#fffbeb":"#f0fdf4",color:summary.notRegistered>0?"#92400e":"#16a34a",border:"1px solid "+(summary.notRegistered>0?"#fde68a":"#bbf7d0"),borderRadius:8,fontSize:11,fontWeight:700}}>{summary.notRegistered>0?"⚠️ 未登録":"✅ 登録完備"} {summary.notRegistered}台</div>
          </div>
          <div style={{border:"1px solid #e2e8f0",borderRadius:10,overflow:"auto"}}>
            <table style={{width:"100%",minWidth:920,borderCollapse:"collapse",fontSize:11}}>
              <thead><tr style={{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}}>
                <th style={{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b",position:"sticky",left:0,background:"#f8fafc",zIndex:2}}>車両</th>
                <th style={{padding:"8px 10px",textAlign:"center",fontSize:10,fontWeight:700,color:"#64748b",width:60}}>クラス</th>
                <th style={{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#dc2626",borderLeft:"3px solid #fee2e2"}}>🚗 車検満了日</th>
                <th style={{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b"}}>次回車検予定<br/><span style={{fontSize:8,fontWeight:400}}>(配車表)</span></th>
                <th style={{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#16a34a",borderLeft:"3px solid #dcfce7"}}>🔧 半年点検期限</th>
                <th style={{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b"}}>次回点検予定<br/><span style={{fontSize:8,fontWeight:400}}>(配車表)</span></th>
              </tr></thead>
              <tbody>
                {rows.map((r,i)=>{
                  const v=r.v;
                  const rowBg=r.urgency<0?"#fef2f2":r.urgency<14?"#fff7ed":i%2===0?"#fff":"#fafafa";
                  return <tr key={v.code} style={{borderBottom:"1px solid #f1f5f9",background:rowBg}}>
                    <td style={{padding:"10px",fontWeight:700,position:"sticky",left:0,background:rowBg,zIndex:1}}>
                      <div>{v.name}</div>
                      <div style={{fontSize:9,color:"#94a3b8",marginTop:2}}>{v.code} / {v.no||""}</div>
                    </td>
                    <td style={{padding:"10px",textAlign:"center"}}>
                      <span style={{fontSize:10,fontWeight:700,padding:"2px 6px",background:"#e0e7ff",color:"#4338ca",borderRadius:4}}>{v.type}</span>
                    </td>
                    <td style={{padding:"10px",borderLeft:"3px solid #fee2e2"}}><Cell date={r.insDueDate} days={r.insDue}/></td>
                    <td style={{padding:"10px"}}><Cell date={r.insNextDate} days={r.insNext}/></td>
                    <td style={{padding:"10px",borderLeft:"3px solid #dcfce7"}}><Cell date={r.tenDueDate} days={r.tenDue}/></td>
                    <td style={{padding:"10px"}}><Cell date={r.tenNextDate} days={r.tenNext}/></td>
                  </tr>;
                })}
              </tbody>
            </table>
          </div>
          <div style={{fontSize:10,color:"#94a3b8",marginTop:8,padding:"8px 12px",background:"#f8fafc",borderRadius:6}}>
            💡 車検満了日・半年点検期限 → <b style={{color:"#2563eb"}}>マスター</b>タブから車両編集 → 「🚗 車検/点検」タブで入力<br/>
            💡 次回車検予定・次回点検予定 → <b style={{color:"#7c3aed"}}>配車表</b>でメンテナンスブロック登録（label=車検/半年点検）した未来日が自動反映
          </div>
        </div>;
      })()}

    </div>}

  </div>;
}

/* 📋 車両マスター（車両ごとの車検/点検サマリー + 確定金額入力） */
function InspectionMasterView({vehicles,maintenance,onMaintenanceChange,thS,tdS,TC}){
  const[editId,setEditId]=useState(null);
  const[editVal,setEditVal]=useState("");
  const[saving,setSaving]=useState(false);
  const[openCls,setOpenCls]=useState({}); // デフォルト折りたたみ
  const toggleCls=(tp)=>setOpenCls(p=>({...p,[tp]:!p[tp]}));
  const today=new Date().toISOString().slice(0,10);

  // 車両ごとに最新の車検/半年点検レコードをまとめる
  const vehRows=useMemo(()=>{
    return (vehicles||[]).map(v=>{
      const recs=(maintenance||[]).filter(m=>m.vehicleCode===v.code&&(m.label==="車検"||m.label==="半年点検"))
        .sort((a,b)=>(b.startDate||"").localeCompare(a.startDate||""));
      const shaken=recs.filter(r=>r.label==="車検");
      const tenken=recs.filter(r=>r.label==="半年点検");
      const nextShaken=shaken.find(r=>(r.startDate||r.endDate||"")>=today)||shaken[0];
      const nextTenken=tenken.find(r=>(r.startDate||r.endDate||"")>=today)||tenken[0];
      return{v,nextShaken,nextTenken,shakenCnt:shaken.length,tenkenCnt:tenken.length};
    });
  },[vehicles,maintenance,today]);

  // クラス別グループ
  const grouped=useMemo(()=>{
    const m={};const order=[];
    vehRows.forEach(row=>{const tp=row.v.type||"?";if(!m[tp]){m[tp]=[];order.push(tp);}m[tp].push(row);});
    return order.map(tp=>({type:tp,rows:m[tp]}));
  },[vehRows]);

  const dateStatus=(d)=>{
    if(!d)return null;
    const diff=Math.ceil((new Date(d)-new Date())/(1000*60*60*24));
    if(diff<0)return{color:"#dc2626",bg:"#fee2e2",label:"期限超過"};
    if(diff<=30)return{color:"#d97706",bg:"#fffbeb",label:diff+"日後"};
    return{color:"#059669",bg:"#f0fdf4",label:diff+"日後"};
  };

  const saveActual=async(rec)=>{
    const v=Number(editVal);
    if(isNaN(v)||v<0)return;
    setSaving(true);
    // maintenanceリストを更新
    const next=(maintenance||[]).map(m=>m.id===rec.id?{...m,actualCost:v}:m);
    if(onMaintenanceChange)onMaintenanceChange(next);
    await DB.updateMaintenanceActualCost(rec.id,v);
    setSaving(false);
    setEditId(null);setEditVal("");
  };

  const costDisp=(rec)=>{
    if(!rec)return<span style={{color:"#cbd5e1",fontSize:10}}>未登録</span>;
    const eff=rec.actualCost>0?rec.actualCost:rec.cost;
    return<div style={{textAlign:"right"}}>
      <div style={{fontSize:11,fontWeight:700,color:rec.actualCost>0?"#059669":"#64748b"}}>
        {eff>0?"¥"+eff.toLocaleString():"-"}
        {rec.actualCost>0&&<span style={{fontSize:9,marginLeft:3,color:"#059669",fontWeight:600}}>確定</span>}
      </div>
      {rec.cost>0&&rec.actualCost===0&&<div style={{fontSize:9,color:"#94a3b8"}}>概算: ¥{rec.cost.toLocaleString()}</div>}
    </div>;
  };

  return<div>
    <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12}}>
      <h3 style={{fontSize:14,fontWeight:800,margin:0}}>📋 車両マスター</h3>
      <span style={{fontSize:11,color:"#64748b"}}>{vehRows.length}台 — 車検/点検の直近予定と確定金額を管理</span>
    </div>
    {grouped.map(({type:tp,rows})=>{
      const isOpen=!!openCls[tp];
      return<div key={tp} style={{marginBottom:8}}>
        {/* アコーディオンヘッダー */}
        <div onClick={()=>toggleCls(tp)} style={{display:"flex",alignItems:"center",gap:8,padding:"9px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:isOpen?"8px 8px 0 0":"8px",cursor:"pointer",userSelect:"none"}}>
          <span style={{padding:"2px 9px",background:"#2563eb",color:"#fff",borderRadius:4,fontSize:11,fontWeight:800}}>{tp}</span>
          <span style={{fontSize:12,fontWeight:700,color:"#374151",flex:1}}>{tp}クラス</span>
          <span style={{fontSize:11,color:"#94a3b8"}}>{rows.length}台</span>
          <span style={{fontSize:12,color:"#94a3b8"}}>{isOpen?"▲":"▼"}</span>
        </div>
        {isOpen&&<div style={{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",minWidth:680}}>
            <thead><tr>
              <th style={thS}>車両</th>
              <th style={{...thS,background:"#dbeafe",color:"#1e40af"}}>🔵 車検（直近）</th>
              <th style={{...thS,background:"#dbeafe",color:"#1e40af",textAlign:"right"}}>車検費用</th>
              <th style={{...thS,background:"#dcfce7",color:"#166534"}}>🟢 半年点検（直近）</th>
              <th style={{...thS,background:"#dcfce7",color:"#166534",textAlign:"right"}}>点検費用</th>
            </tr></thead>
            <tbody>
              {rows.map(({v,nextShaken,nextTenken})=>{
                const shakenDate=nextShaken?.startDate||nextShaken?.endDate;
                const tenkenDate=nextTenken?.startDate||nextTenken?.endDate;
                const ss=dateStatus(shakenDate);const ts=dateStatus(tenkenDate);
                return<tr key={v.code} style={{background:"#fff"}}>
                  <td style={tdS}><div style={{fontWeight:700,fontSize:12}}>{v.name}</div><div style={{fontSize:10,color:"#94a3b8"}}>{v.no}</div></td>
                  <td style={{...tdS,background:"#eff6ff"}}>
                    {nextShaken?<div><div style={{display:"flex",alignItems:"center",gap:6}}><span style={{fontSize:11,fontWeight:700,color:"#1e40af"}}>{shakenDate||"-"}</span>{ss&&<span style={{fontSize:9,padding:"1px 6px",borderRadius:8,background:ss.bg,color:ss.color,fontWeight:700}}>{ss.label}</span>}</div>{nextShaken.workshop&&<div style={{fontSize:10,color:"#64748b",marginTop:1}}>{nextShaken.workshop}</div>}</div>:<span style={{fontSize:10,color:"#cbd5e1"}}>未登録</span>}
                  </td>
                  <td style={{...tdS,background:"#eff6ff"}}>
                    {editId===nextShaken?.id
                      ?<div style={{display:"flex",gap:4,alignItems:"center"}}><input type="number" value={editVal} onChange={e=>setEditVal(e.target.value)} style={{width:80,border:"1px solid #93c5fd",borderRadius:6,padding:"3px 6px",fontSize:11}} placeholder="確定金額" autoFocus/><button onClick={()=>saveActual(nextShaken)} disabled={saving} style={{fontSize:10,padding:"3px 8px",background:"#2563eb",color:"#fff",border:"none",borderRadius:6,cursor:"pointer",fontWeight:700}}>{saving?"…":"保存"}</button><button onClick={()=>{setEditId(null);setEditVal("");}} style={{fontSize:10,padding:"3px 7px",background:"none",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer"}}>✕</button></div>
                      :<div style={{display:"flex",alignItems:"center",gap:6,justifyContent:"flex-end"}}>{costDisp(nextShaken)}{nextShaken&&<button onClick={()=>{setEditId(nextShaken.id);setEditVal(nextShaken.actualCost>0?String(nextShaken.actualCost):String(nextShaken.cost||""));}} style={{fontSize:9,padding:"2px 7px",background:"#eff6ff",border:"1px solid #93c5fd",borderRadius:5,cursor:"pointer",color:"#2563eb",fontWeight:700,whiteSpace:"nowrap"}}>確定入力</button>}</div>}
                  </td>
                  <td style={{...tdS,background:"#f0fdf4"}}>
                    {nextTenken?<div><div style={{display:"flex",alignItems:"center",gap:6}}><span style={{fontSize:11,fontWeight:700,color:"#166534"}}>{tenkenDate||"-"}</span>{ts&&<span style={{fontSize:9,padding:"1px 6px",borderRadius:8,background:ts.bg,color:ts.color,fontWeight:700}}>{ts.label}</span>}</div>{nextTenken.workshop&&<div style={{fontSize:10,color:"#64748b",marginTop:1}}>{nextTenken.workshop}</div>}</div>:<span style={{fontSize:10,color:"#cbd5e1"}}>未登録</span>}
                  </td>
                  <td style={{...tdS,background:"#f0fdf4"}}>
                    {editId===nextTenken?.id
                      ?<div style={{display:"flex",gap:4,alignItems:"center"}}><input type="number" value={editVal} onChange={e=>setEditVal(e.target.value)} style={{width:80,border:"1px solid #86efac",borderRadius:6,padding:"3px 6px",fontSize:11}} placeholder="確定金額" autoFocus/><button onClick={()=>saveActual(nextTenken)} disabled={saving} style={{fontSize:10,padding:"3px 8px",background:"#16a34a",color:"#fff",border:"none",borderRadius:6,cursor:"pointer",fontWeight:700}}>{saving?"…":"保存"}</button><button onClick={()=>{setEditId(null);setEditVal("");}} style={{fontSize:10,padding:"3px 7px",background:"none",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer"}}>✕</button></div>
                      :<div style={{display:"flex",alignItems:"center",gap:6,justifyContent:"flex-end"}}>{costDisp(nextTenken)}{nextTenken&&<button onClick={()=>{setEditId(nextTenken.id);setEditVal(nextTenken.actualCost>0?String(nextTenken.actualCost):String(nextTenken.cost||""));}} style={{fontSize:9,padding:"2px 7px",background:"#f0fdf4",border:"1px solid #86efac",borderRadius:5,cursor:"pointer",color:"#16a34a",fontWeight:700,whiteSpace:"nowrap"}}>確定入力</button>}</div>}
                  </td>
                </tr>;
              })}
            </tbody>
          </table>
        </div>}
      </div>;
    })}
  </div>;
}


function VehicleMaintenanceBook({vehicles}){
  // === 保守データはlocalStorageで管理（車両リストはマスターから生成） ===
  const LS_KEY="bt_vmt_maint";
  const loadMaint=()=>{try{const s=localStorage.getItem(LS_KEY);return s?JSON.parse(s):{};}catch(e){return{};}};
  const saveMaint=(d)=>{try{localStorage.setItem(LS_KEY,JSON.stringify(d));}catch(e){}};
  const VMT_VERSION="bt_vmt_v2"; // バージョン変更で旧データ強制クリア
  const[maintData,setMaintData]=useState(()=>{
    // バージョンチェック: 旧データがあればクリアしてブランク初期化
    const ver=localStorage.getItem("bt_vmt_version")||"";
    if(ver!==VMT_VERSION){
      localStorage.removeItem(LS_KEY);
      localStorage.removeItem("bt_vmt_data");
      localStorage.setItem("bt_vmt_version",VMT_VERSION);
      // INIT_VMTからブランク初期化
      if(typeof INIT_VMT!=="undefined"){const m={};INIT_VMT.forEach(r=>{m[r.plate]={inspectionDate:"",oilChangeDate:"",oilChangeKm:0,currentOdo:0,alert:0,odoMonthEnd:{},oilExchange:"",batteryExchange:"",tireExchange:"",tireCost:0,coolant:"",seatClean:"",glassCoat:"",bodyCoat:"",repairs:[{place:"",date:""},{place:"",date:""},{place:"",date:""}]};});saveMaint(m);return m;}
      return {};
    }
    const ls=loadMaint();
    if(!Object.keys(ls).length){
      // INIT_VMTからの初期化
      if(typeof INIT_VMT!=="undefined"){const m={};INIT_VMT.forEach(r=>{m[r.plate]={inspectionDate:r.inspectionDate||"",oilChangeDate:r.oilChangeDate||"",oilChangeKm:r.oilChangeKm||0,currentOdo:r.currentOdo||0,alert:r.alert||0,odoMonthEnd:r.odoMonthEnd||{},oilExchange:r.oilExchange||"",batteryExchange:r.batteryExchange||"",tireExchange:r.tireExchange||"",tireCost:r.tireCost||0,coolant:r.coolant||"",seatClean:r.seatClean||"",glassCoat:r.glassCoat||"",bodyCoat:r.bodyCoat||"",repairs:r.repairs||[{place:"",date:""},{place:"",date:""},{place:"",date:""}]};});saveMaint(m);return m;}
    }
    return ls;
  });
  const persistMaint=(next)=>{setMaintData(next);saveMaint(next);};
  const getMaint=(plate)=>maintData[plate]||{inspectionDate:"",oilChangeDate:"",oilChangeKm:0,currentOdo:0,alert:0,odoMonthEnd:{},oilExchange:"",batteryExchange:"",tireExchange:"",tireCost:0,coolant:"",seatClean:"",glassCoat:"",bodyCoat:"",repairs:[{place:"",date:""},{place:"",date:""},{place:"",date:""}]};
  const updateMaint=(plate,updates)=>{const cur=getMaint(plate);const next={...maintData,[plate]:{...cur,...updates}};persistMaint(next);};

  // v1.0.40-BT: NHA固有の送迎車定義は撤去。BTはマスター車両（bt_vehicles）のみ
  const rows=useMemo(()=>{
    const list=[...(vehicles||[])];
    return list.map(v=>{const m=getMaint(v.no);return{...v,plate:v.no,classCode:v.type,vehicleCode:v.code?.replace(/\d+$/,"")||v.name,...m};});
  },[vehicles,maintData]);

  const[editPlate,setEditPlate]=useState(null);
  const[editRow,setEditRow]=useState(null);
  const[filterClass,setFilterClass]=useState("all");
  const[search,setSearch]=useState("");

  const classTypes=useMemo(()=>{const s=new Set();rows.forEach(r=>r.classCode&&s.add(r.classCode));return["all",...[...s].sort()];},[rows]);
  const filtered=useMemo(()=>{
    let list=rows;
    if(filterClass!=="all")list=list.filter(r=>r.classCode===filterClass);
    if(search){const s=search.toLowerCase();list=list.filter(r=>(r.code||"").toLowerCase().includes(s)||(r.name||"").toLowerCase().includes(s)||(r.no||"").includes(s));}
    return list;
  },[rows,filterClass,search]);

  const getAlert=(r)=>{
    const alerts=[];const today=new Date();
    if(r.inspectionDate){const d=new Date(r.inspectionDate);const diff=Math.floor((d-today)/(1000*60*60*24));if(diff<0)alerts.push({type:"danger",msg:"車検切れ"});else if(diff<30)alerts.push({type:"warning",msg:"車検残"+diff+"日"});}
    if(r.oilChangeKm&&r.currentOdo){const next=Number(r.oilChangeKm)+5000;const rem=next-Number(r.currentOdo);if(rem<0)alerts.push({type:"danger",msg:"オイル超過"+Math.abs(rem)+"km"});else if(rem<1000)alerts.push({type:"warning",msg:"オイル残"+rem+"km"});}
    return alerts;
  };

  // 編集保存
  const saveRow=()=>{
    if(!editRow||!editPlate)return;
    const{classCode,vehicleCode,plate,code,name,no,type,seats,...maint}=editRow;
    updateMaint(editPlate,maint);
    setEditPlate(null);setEditRow(null);
  };

  // 月末ODO
  const[odoMonth,setOdoMonth]=useState(new Date().toISOString().slice(0,7));
  const[odoInput,setOdoInput]=useState("");
  const[odoPlate,setOdoPlate]=useState(null);
  const saveOdo=()=>{
    if(!odoPlate||!odoInput)return;
    const cur=getMaint(odoPlate);
    updateMaint(odoPlate,{odoMonthEnd:{...cur.odoMonthEnd,[odoMonth]:Number(odoInput)},currentOdo:Number(odoInput)});
    setOdoInput("");setOdoPlate(null);
  };

  const inputSt={padding:"5px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11,width:"100%"};
  const labelSt={fontSize:10,fontWeight:600,color:"#64748b",marginBottom:2,display:"block"};

  // 編集モーダル（車両情報は読取専用、保守データのみ編集）
  const editModal=editRow&&<div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:12}} onClick={()=>{setEditPlate(null);setEditRow(null);}}>
    <div style={{background:"#fff",borderRadius:12,maxWidth:700,width:"100%",maxHeight:"90vh",overflow:"auto",padding:20}} onClick={e=>e.stopPropagation()}>
      <div style={{fontSize:16,fontWeight:800,marginBottom:8}}>保守データ編集</div>
      <div style={{fontSize:12,color:"#64748b",marginBottom:16,background:"#f8fafc",padding:"8px 12px",borderRadius:6}}>
        <span style={{fontWeight:700,color:"#1e40af"}}>{editRow.classCode}</span> {editRow.name||editRow.vehicleCode} <span style={{fontWeight:700}}>{editRow.plate}</span>
        <span style={{fontSize:10,color:"#94a3b8",marginLeft:8}}>※車両情報の変更はマスタータブで行ってください</span>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#1e40af"}}>車検・点検</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>車検期限</label><input type="date" value={editRow.inspectionDate||""} onChange={e=>setEditRow({...editRow,inspectionDate:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>オイル交換日</label><input type="date" value={editRow.oilChangeDate||""} onChange={e=>setEditRow({...editRow,oilChangeDate:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>オイル交換時km</label><input type="number" value={editRow.oilChangeKm||""} onChange={e=>setEditRow({...editRow,oilChangeKm:Number(e.target.value)})} style={inputSt}/></div>
        <div><label style={labelSt}>現在ODO</label><input type="number" value={editRow.currentOdo||""} onChange={e=>setEditRow({...editRow,currentOdo:Number(e.target.value)})} style={inputSt}/></div>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#059669"}}>消耗パーツ</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>オイル交換実施日</label><input type="date" value={editRow.oilExchange||""} onChange={e=>setEditRow({...editRow,oilExchange:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>バッテリー交換</label><input type="date" value={editRow.batteryExchange||""} onChange={e=>setEditRow({...editRow,batteryExchange:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>タイヤ交換</label><input type="date" value={editRow.tireExchange||""} onChange={e=>setEditRow({...editRow,tireExchange:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>タイヤ料金</label><input type="number" value={editRow.tireCost||""} onChange={e=>setEditRow({...editRow,tireCost:Number(e.target.value)})} style={inputSt}/></div>
        <div><label style={labelSt}>クーラント液</label><input type="date" value={editRow.coolant||""} onChange={e=>setEditRow({...editRow,coolant:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#7c3aed"}}>メンテナンス</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:12}}>
        <div><label style={labelSt}>シート洗浄</label><input type="date" value={editRow.seatClean||""} onChange={e=>setEditRow({...editRow,seatClean:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>ガラスコーティング</label><input type="date" value={editRow.glassCoat||""} onChange={e=>setEditRow({...editRow,glassCoat:e.target.value})} style={inputSt}/></div>
        <div><label style={labelSt}>ボディコーティング</label><input type="date" value={editRow.bodyCoat||""} onChange={e=>setEditRow({...editRow,bodyCoat:e.target.value})} style={inputSt}/></div>
      </div>
      <div style={{fontSize:13,fontWeight:700,marginBottom:8,color:"#ea580c"}}>外装自社修復</div>
      {[0,1,2].map(i=><div key={i} style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:10,marginBottom:6}}>
        <div><label style={labelSt}>修復箇所{i+1}</label><input value={(editRow.repairs||[])[i]?.place||""} onChange={e=>{const rp=[...(editRow.repairs||[{place:"",date:""},{place:"",date:""},{place:"",date:""}])];rp[i]={...rp[i],place:e.target.value};setEditRow({...editRow,repairs:rp});}} style={inputSt} placeholder="例: 塗装割れ"/></div>
        <div><label style={labelSt}>実施日{i+1}</label><input type="date" value={(editRow.repairs||[])[i]?.date||""} onChange={e=>{const rp=[...(editRow.repairs||[{place:"",date:""},{place:"",date:""},{place:"",date:""}])];rp[i]={...rp[i],date:e.target.value};setEditRow({...editRow,repairs:rp});}} style={inputSt}/></div>
      </div>)}
      <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:16}}>
        <button onClick={()=>{setEditPlate(null);setEditRow(null);}} style={{padding:"8px 16px",fontSize:12,border:"1px solid #d1d5db",borderRadius:6,background:"#fff",cursor:"pointer"}}>キャンセル</button>
        <button onClick={saveRow} style={{padding:"8px 16px",fontSize:12,border:"none",borderRadius:6,background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
      </div>
    </div>
  </div>;

  const odoModal=odoPlate&&<div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,.5)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:12}} onClick={()=>setOdoPlate(null)}>
    <div style={{background:"#fff",borderRadius:12,maxWidth:360,width:"100%",padding:20}} onClick={e=>e.stopPropagation()}>
      <div style={{fontSize:14,fontWeight:800,marginBottom:12}}>月末ODO入力</div>
      <div style={{marginBottom:8}}><label style={labelSt}>対象月</label><input type="month" value={odoMonth} onChange={e=>setOdoMonth(e.target.value)} style={inputSt}/></div>
      <div style={{marginBottom:12}}><label style={labelSt}>ODO値(km)</label><input type="number" value={odoInput} onChange={e=>setOdoInput(e.target.value)} style={inputSt} placeholder="例: 125000"/></div>
      <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
        <button onClick={()=>setOdoPlate(null)} style={{padding:"6px 14px",fontSize:12,border:"1px solid #d1d5db",borderRadius:6,background:"#fff",cursor:"pointer"}}>閉じる</button>
        <button onClick={saveOdo} style={{padding:"6px 14px",fontSize:12,border:"none",borderRadius:6,background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
      </div>
    </div>
  </div>;

  const allAlerts=filtered.flatMap(r=>getAlert(r).map(a=>({...a,vehicle:(r.name||r.code||"")+" "+r.no})));
  const dangerCount=allAlerts.filter(a=>a.type==="danger").length;
  const warnCount=allAlerts.filter(a=>a.type==="warning").length;

  return <div>
    {editModal}{odoModal}
    <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:12}}>
      <div style={{flex:"1 1 130px",background:"linear-gradient(135deg,#2563eb,#1d4ed8)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>管理台数（マスター連動）</div>
        <div style={{fontSize:24,fontWeight:800}}>{rows.length}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>台</span></div>
      </div>
      {dangerCount>0&&<div style={{flex:"1 1 130px",background:"linear-gradient(135deg,#ef4444,#dc2626)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>要対応</div>
        <div style={{fontSize:24,fontWeight:800}}>{dangerCount}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>件</span></div>
      </div>}
      {warnCount>0&&<div style={{flex:"1 1 130px",background:"linear-gradient(135deg,#f59e0b,#d97706)",borderRadius:10,padding:"12px 16px",color:"#fff"}}>
        <div style={{fontSize:10,opacity:0.8}}>注意</div>
        <div style={{fontSize:24,fontWeight:800}}>{warnCount}<span style={{fontSize:11,fontWeight:400,marginLeft:4}}>件</span></div>
      </div>}
    </div>
    {allAlerts.length>0&&<div style={{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:10,marginBottom:12}}>
      <div style={{fontSize:12,fontWeight:700,color:"#991b1b",marginBottom:6}}>⚠️ アラート</div>
      {allAlerts.slice(0,10).map((a,i)=><div key={i} style={{fontSize:11,color:a.type==="danger"?"#dc2626":"#d97706",padding:"2px 0"}}><span style={{fontWeight:700}}>{a.vehicle}</span>: {a.msg}</div>)}
    </div>}
    <div style={{display:"flex",gap:6,marginBottom:10,alignItems:"center",flexWrap:"wrap"}}>
      <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="車両名・ナンバーで検索" style={{flex:1,minWidth:140,padding:"6px 10px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11}}/>
      <select value={filterClass} onChange={e=>setFilterClass(e.target.value)} style={{padding:"6px 8px",border:"1px solid #d1d5db",borderRadius:6,fontSize:11}}>
        {classTypes.map(c=><option key={c} value={c}>{c==="all"?"全クラス":c+"クラス"}</option>)}
      </select>
      <span style={{fontSize:10,color:"#64748b"}}>{filtered.length}台</span>
    </div>
    <div style={{overflowX:"auto"}}>
      <table style={{width:"100%",fontSize:10,borderCollapse:"collapse",minWidth:900}}>
        <thead><tr style={{background:"#f1f5f9"}}>
          {["クラス","車両","No.","車検","オイル交換","ODO","アラート","消耗パーツ","メンテ","修復",""].map((h,i)=>
            <th key={i} style={{padding:"6px 6px",textAlign:"left",fontWeight:600,fontSize:9,borderBottom:"2px solid #e2e8f0",whiteSpace:"nowrap"}}>{h}</th>
          )}
        </tr></thead>
        <tbody>{filtered.map(r=>{
          const alerts=getAlert(r);
          const hasRepairs=(r.repairs||[]).some(rp=>rp.place);
          const rowBg=alerts.some(a=>a.type==="danger")?"#fef2f2":alerts.some(a=>a.type==="warning")?"#fffbeb":"#fff";
          return <tr key={r.no} style={{background:rowBg,borderBottom:"1px solid #f1f5f9"}}>
            <td style={{padding:"5px 6px",fontWeight:700,color:"#1e40af"}}>{r.type}</td>
            <td style={{padding:"5px 6px",fontWeight:700,fontSize:9}}>{r.name||r.code}</td>
            <td style={{padding:"5px 6px"}}>{r.no}</td>
            <td style={{padding:"5px 6px",fontSize:9}}>{r.inspectionDate||"-"}</td>
            <td style={{padding:"5px 6px",fontSize:9}}>
              <div>{r.oilChangeDate||"-"}</div>
              {r.oilChangeKm>0&&<div style={{color:"#64748b"}}>{r.oilChangeKm.toLocaleString()}km</div>}
            </td>
            <td style={{padding:"5px 6px"}}>
              <div style={{fontWeight:600}}>{r.currentOdo?r.currentOdo.toLocaleString():"-"}</div>
              <button onClick={()=>{setOdoPlate(r.no);setOdoInput("");}} style={{fontSize:8,padding:"1px 4px",border:"1px solid #d1d5db",borderRadius:3,background:"#fff",cursor:"pointer",marginTop:2}}>入力</button>
            </td>
            <td style={{padding:"5px 6px"}}>
              {alerts.map((a,i)=><div key={i} style={{fontSize:8,color:a.type==="danger"?"#dc2626":"#d97706",fontWeight:600}}>{a.msg}</div>)}
              {alerts.length===0&&<span style={{color:"#86efac",fontSize:9}}>✓</span>}
            </td>
            <td style={{padding:"5px 6px",fontSize:8}}>
              {r.oilExchange&&<div>油:{r.oilExchange.slice(5)}</div>}
              {r.batteryExchange&&<div>電:{(r.batteryExchange||"").slice(0,10)}</div>}
              {r.tireExchange&&<div>タ:{r.tireExchange.slice(5)}{r.tireCost>0?" ¥"+r.tireCost.toLocaleString():""}</div>}
              {r.coolant&&<div>冷:{r.coolant.slice(5)}</div>}
              {!r.oilExchange&&!r.batteryExchange&&!r.tireExchange&&!r.coolant&&"-"}
            </td>
            <td style={{padding:"5px 6px",fontSize:8}}>
              {r.seatClean&&<div>席:{r.seatClean.slice(5)}</div>}
              {r.glassCoat&&<div>硝:{r.glassCoat.slice(5)}</div>}
              {r.bodyCoat&&<div>体:{r.bodyCoat.slice(5)}</div>}
              {!r.seatClean&&!r.glassCoat&&!r.bodyCoat&&"-"}
            </td>
            <td style={{padding:"5px 6px",fontSize:8}}>
              {hasRepairs?(r.repairs||[]).filter(rp=>rp.place).map((rp,i)=><div key={i}>{rp.place}{rp.date?" "+rp.date.slice(5):""}</div>):"-"}
            </td>
            <td style={{padding:"5px 6px"}}>
              <button onClick={()=>{setEditRow({...r});setEditPlate(r.no);}} style={{fontSize:9,padding:"3px 8px",border:"1px solid #93c5fd",borderRadius:4,background:"#eff6ff",color:"#1d4ed8",cursor:"pointer"}}>編集</button>
            </td>
          </tr>;
        })}
        </tbody>
      </table>
      {filtered.length===0&&<div style={{textAlign:"center",padding:24,color:"#94a3b8",fontSize:12}}>車両マスターにデータがありません</div>}
    </div>
  </div>;
}

/* ==========================================
   車両稼働管理 — 配車表メンテ＋整備管理＋保守台帳 を統合
   ========================================== */
function VehicleFleetStatus({vehicles,vehicleClasses,maintenance,data,fleet,hmCars,hmCarData,hmLogs}){
  var E=React.createElement;
  var isMob=useMobile();
  var today=new Date().toISOString().slice(0,10);
  var _dt=useState(today);var viewDate=_dt[0];var setViewDate=_dt[1];
  var _twins=useState({});var twinsMap=_twins[0];var setTwinsMap=_twins[1];
  var _sf=useState("all");var statusFilter=_sf[0];var setStatusFilter=_sf[1];
  var _ec=useState({});var expandedClasses=_ec[0];var setExpandedClasses=_ec[1]; // デフォルト折りたたみ
  // ★ コスト内訳ドリルダウン用
  var _dr=useState(null);var drill=_dr[0];var setDrill=_dr[1];
  var _inactPop=useState(false);var showInactPop=_inactPop[0];var setShowInactPop=_inactPop[1];

  // kpiFlags: 配車表の当月稼働/未稼働フラグ
  var _kpi=useState({});var kpiFlags=_kpi[0];var setKpiFlags=_kpi[1];
  React.useEffect(function(){
    if(!sb)return;
    var ym=viewDate.slice(0,7);
    sb.from("bt_vehicle_monthly_kpi").select("vehicle_code,active").eq("year_month",ym)
      .then(function(res){var m={};(res.data||[]).forEach(function(k){m[k.vehicle_code]=k.active;});setKpiFlags(m);});
    sb.from("vehicle_twins").select("id,status,current_damages,odometer,last_check_at,current_resv_no").eq("store","takamatsu")
      .then(function(res){var m={};(res.data||[]).forEach(function(t){m[t.id]=t;});setTwinsMap(m);});
  },[viewDate]);
  var isKpiActive=function(code){return kpiFlags[code]!==false;};

  var rows=React.useMemo(function(){
    var vd=viewDate;
    return (vehicles||[]).map(function(v){
      var am=null;
      (maintenance||[]).forEach(function(m){if(m.vehicleCode===v.code&&norm(m.endDate)>=vd&&norm(m.startDate)<=vd)am=m;});
      var tr=[];
      (data||[]).forEach(function(r){if(r.status==="cancelled")return;if(fleet[r.id]===v.code&&norm(r.lendDate)<=vd&&norm(r.returnDate)>=vd)tr.push(r);});
      var twin=twinsMap[v.code]||null;
      var odo=(twin&&twin.odometer)||0;
      var dmg=(twin&&twin.current_damages)||[];
      var st="ready",sl="空車",sc="#059669",sb3="#f0fdf4";
      if(am){st="maint";sl=am.label||"整備中";sc="#7c3aed";sb3="#faf5ff";}
      else if(tr.length>0){st="out";sl="貸出中";sc="#d97706";sb3="#fef9c3";}
      else if(v.active===false){st="inactive";sl="未稼働";sc="#64748b";sb3="#f1f5f9";}
      return{v:v,st:st,sl:sl,sc:sc,sbg:sb3,am:am,resv:tr[0]||null,odo:odo,hasDmg:dmg.length>0,dmgCount:dmg.length};
    });
  },[vehicles,maintenance,data,fleet,twinsMap,viewDate]);

  var total=(vehicles||[]).length;
  var activeN=(vehicles||[]).filter(function(v){return isKpiActive(v.code);}).length;
  var inactiveN=(vehicles||[]).filter(function(v){return !isKpiActive(v.code);}).length;
  var outN=rows.filter(function(r){return r.st==="out";}).length;
  var readyN=activeN-outN; // 稼働 - 貸出中 = 待機中（整備中含む）
  // 次回車検/点検日マップ（未来予定の最早日）と 直近実施日マップ（過去含む最新）を両方計算
  // ★ 2026-05-06 fix: 過去レコードを完全無視するバグ修正
  //   旧: m.startDate < today2 で過去除外 → 直近に車検実施済の車両も「未登録」と誤判定
  //   新: latestShaken/latestTenken に過去含む最新を保持。
  //       業務ルール: 車検=2年周期 / 半年点検=6ヶ月周期 → 直近の実施から
  //       車検24ヶ月以内・半年点検6ヶ月以内なら登録済扱い（アラート対象外）
  var today2=new Date().toISOString().slice(0,10);
  var nextShaken={};var nextTenken={};         // 未来予定（次回日表示用）
  var latestShaken={};var latestTenken={};     // 過去含む最新（アラート判定用）
  (maintenance||[]).forEach(function(m){
    if(!m.startDate)return;
    if(m.label==="車検"){
      if(!latestShaken[m.vehicleCode]||m.startDate>latestShaken[m.vehicleCode])latestShaken[m.vehicleCode]=m.startDate;
      if(m.startDate>=today2&&(!nextShaken[m.vehicleCode]||m.startDate<nextShaken[m.vehicleCode]))nextShaken[m.vehicleCode]=m.startDate;
    }
    if(m.label==="半年点検"){
      if(!latestTenken[m.vehicleCode]||m.startDate>latestTenken[m.vehicleCode])latestTenken[m.vehicleCode]=m.startDate;
      if(m.startDate>=today2&&(!nextTenken[m.vehicleCode]||m.startDate<nextTenken[m.vehicleCode]))nextTenken[m.vehicleCode]=m.startDate;
    }
  });
  var maintN=rows.filter(function(r){return r.st==="maint";}).length;
  var filtered=statusFilter==="all"?rows:statusFilter==="active"?rows.filter(function(r){return isKpiActive(r.v.code);}):rows.filter(function(r){return !isKpiActive(r.v.code);});

  // 車検/点検アラート計算
  // 車検: 直近実施から24ヶ月超 OR 履歴なし → アラート
  // 半年点検: 直近実施から6ヶ月超 OR 履歴なし → アラート
  var ago24m=new Date();ago24m.setMonth(ago24m.getMonth()-24);var ago24mStr=ago24m.toISOString().slice(0,10);
  var ago6m=new Date();ago6m.setMonth(ago6m.getMonth()-6);var ago6mStr=ago6m.toISOString().slice(0,10);
  var shakenAlert=(vehicles||[]).filter(function(v){return isKpiActive(v.code)&&(!latestShaken[v.code]||latestShaken[v.code]<ago24mStr);});
  var tenkenAlert=(vehicles||[]).filter(function(v){return isKpiActive(v.code)&&(!latestTenken[v.code]||latestTenken[v.code]<ago6mStr);});

  var byClass={};
  rows.forEach(function(r){var t=r.v.type||"?";if(!byClass[t])byClass[t]={total:0,active:0,inactive:0};byClass[t].total++;if(r.st==="inactive")byClass[t].inactive++;else byClass[t].active++;});

  return E("div",{style:{maxWidth:1000,margin:"0 auto"}},
    E("div",{style:{display:"flex",alignItems:"center",gap:12,marginBottom:16,flexWrap:"wrap"}},
      E("h3",{style:{fontSize:15,fontWeight:800,margin:0}},"運用サマリー"),
      E("input",{type:"date",value:viewDate,onChange:function(e){setViewDate(e.target.value);},style:{padding:"5px 10px",border:"1px solid #d1d5db",borderRadius:8,fontSize:12}}),
      today!==viewDate&&E("button",{onClick:function(){setViewDate(today);},style:{fontSize:11,padding:"4px 10px",border:"1px solid #e2e8f0",borderRadius:6,background:"#f8fafc",cursor:"pointer"}},"今日に戻る"),
      E("a",{href:"https://buddica-touring.github.io/damage/",target:"_blank",rel:"noopener noreferrer",style:{marginLeft:"auto",fontSize:11,padding:"6px 14px",background:"#1e293b",color:"#fff",borderRadius:8,textDecoration:"none",fontWeight:700}},"🔍 傷管理APP →")
    ),
    // ===== 上段 KPI: 2行レイアウト =====
    // Row1: 稼働状況
    E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(80px,1fr))",gap:8,marginBottom:8}},
      E("div",{style:{background:"#1e293b",borderRadius:10,padding:"10px 8px",textAlign:"center"}},
        E("div",{style:{fontSize:10,color:"#94a3b8",fontWeight:700,marginBottom:2}},"運用台数"),
        E("div",{style:{fontSize:26,fontWeight:900,color:"#fff",lineHeight:1}},total)),
      E("div",{style:{background:"#f0fdf4",border:"1px solid #86efac",borderRadius:10,padding:"10px 8px",textAlign:"center"}},
        E("div",{style:{fontSize:10,color:"#166534",fontWeight:700,marginBottom:2}},"稼働"),
        E("div",{style:{fontSize:26,fontWeight:900,color:"#059669",lineHeight:1}},activeN)),
      E("div",{onClick:function(){setShowInactPop(true);},style:{background:"#f1f5f9",border:"1px solid #cbd5e1",borderRadius:10,padding:"10px 8px",textAlign:"center",cursor:"pointer",userSelect:"none"},title:"クリックで未稼働車両一覧"},
        E("div",{style:{fontSize:10,color:"#475569",fontWeight:700,marginBottom:2}},"未稼働"),
        E("div",{style:{fontSize:26,fontWeight:900,color:"#64748b",lineHeight:1}},inactiveN)),
      E("div",{style:{background:"#fef9c3",border:"1px solid #fde68a",borderRadius:10,padding:"10px 8px",textAlign:"center"}},
        E("div",{style:{fontSize:10,color:"#92400e",fontWeight:700,marginBottom:2}},"貸出中"),
        E("div",{style:{fontSize:26,fontWeight:900,color:"#d97706",lineHeight:1}},outN)),
      E("div",{style:{background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:10,padding:"10px 8px",textAlign:"center"}},
        E("div",{style:{fontSize:10,color:"#1e40af",fontWeight:700,marginBottom:2}},"待機中"),
        E("div",{style:{fontSize:26,fontWeight:900,color:"#2563eb",lineHeight:1}},readyN))
    ),
    // Row2: 月次・年次コスト
    (function(){
      var ins=(vehicles||[]).reduce(function(s,v){return s+Number(v.insuranceAnnual||0);},0);
      var tax=(vehicles||[]).reduce(function(s,v){return s+Math.round(Number(v.carTax||0)/12);},0);
      var shk=(vehicles||[]).reduce(function(s,v){return s+Math.round(Number(v.shakenCost||0)/12);},0);
      var tnk=(vehicles||[]).reduce(function(s,v){return s+Math.round(Number(v.tenkenCost||0)/6);},0);
      var mTotal=ins+tax+shk+tnk;
      var yTotal=mTotal*12;
      // 整備実績（hm_logsから算出）
      var nowY=String(new Date().getFullYear());
      var nowM=(String(new Date().getFullYear())+"-"+String(new Date().getMonth()+1).padStart(2,"0"));
      var MCAT=[{v:"inspection",l:"車検"},{v:"semi_annual",l:"半年点検"},{v:"repair",l:"修理"},{v:"oil",l:"OIL"},{v:"other",l:"その他"}];
      var mByCat={};var yByCat={};MCAT.forEach(function(c){mByCat[c.v]=0;yByCat[c.v]=0;});
      var maintMonth=0;var maintYear=0;
      (hmLogs||[]).forEach(function(l){
        var ym=(l.date||"").slice(0,7);var cat=l.type||"other";var cost=Number(l.cost||0);
        if(ym===nowM){mByCat[cat]=(mByCat[cat]||0)+cost;maintMonth+=cost;}
        if((l.date||"").startsWith(nowY)){yByCat[cat]=(yByCat[cat]||0)+cost;maintYear+=cost;}
      });
      var fmt2=function(n){if(!n)return"¥0";return n>=10000?"¥"+Math.round(n/10000*10)/10+"万":"¥"+n.toLocaleString();};
      var rcCard=function(lbl,mv,yv,bg,bd,fg){return E("div",{style:{background:bg,border:"1px solid "+bd,borderRadius:10,padding:"6px 10px",textAlign:"center",flex:1,minWidth:72}},
        E("div",{style:{borderBottom:"1px solid "+bd,paddingBottom:4,marginBottom:4}},
          E("div",{style:{fontSize:8,color:fg,fontWeight:700,opacity:.6}},"月"),
          E("div",{style:{fontSize:mv>=1000000?12:mv>=100000?14:15,fontWeight:900,color:fg,lineHeight:1.1}},fmt2(mv))),
        E("div",null,
          E("div",{style:{fontSize:8,color:fg,fontWeight:700,opacity:.6}},"年"),
          E("div",{style:{fontSize:yv>=1000000?12:yv>=100000?13:14,fontWeight:800,color:fg,lineHeight:1.1,opacity:.85}},fmt2(yv))),
        E("div",{style:{fontSize:8,color:fg,fontWeight:700,opacity:.5,marginTop:3}},"/ "+lbl));};
      var rcTotal=function(mv,yv){return E("div",{style:{display:"flex",alignItems:"center",justifyContent:"center",flex:1,minWidth:80,background:"#1e293b",borderRadius:10,padding:"6px 10px",textAlign:"center"}},
        E("div",{style:{width:"100%"}},
          E("div",{style:{borderBottom:"1px solid #334155",paddingBottom:4,marginBottom:4}},
            E("div",{style:{fontSize:8,color:"#94a3b8"}},"月"),
            E("div",{style:{fontSize:mv>=1000000?12:mv>=100000?14:15,fontWeight:900,color:"#4ade80",lineHeight:1.1}},fmt2(mv))),
          E("div",null,
            E("div",{style:{fontSize:8,color:"#94a3b8"}},"年"),
            E("div",{style:{fontSize:yv>=1000000?12:yv>=100000?13:14,fontWeight:800,color:"#86efac",lineHeight:1.1}},fmt2(yv))),
          E("div",{style:{fontSize:8,color:"#475569",marginTop:3}},"合計")));};
      return E("div",{style:{marginBottom:12}},
        // ランニングコスト（固定）
        E("div",{style:{display:"flex",gap:6,marginBottom:6,flexWrap:"wrap",padding:"10px 12px",background:"#f8fafc",borderRadius:10,border:"1px solid #e2e8f0"}},
          E("div",{style:{fontSize:10,fontWeight:800,color:"#64748b",alignSelf:"center",flexShrink:0,marginRight:4,lineHeight:1.3}},"ランニング",E("br"),"コスト"),
          rcCard("保険",ins,ins*12,"#f0fdf4","#86efac","#059669"),
          rcCard("税金",tax,tax*12,"#fefce8","#fde68a","#d97706"),
          rcCard("車検",shk,shk*12,"#dbeafe","#93c5fd","#2563eb"),
          rcCard("点検",tnk,tnk*12,"#dcfce7","#6ee7b7","#059669"),
          rcTotal(mTotal,yTotal)
        ),
        // 整備実績コスト（hm_logs）
        E("div",{style:{padding:"10px 12px",background:"#fef2f2",borderRadius:10,border:"1px solid #fecaca"}},
          E("div",{style:{display:"flex",gap:8,marginBottom:6,alignItems:"center"}},
            E("span",{style:{fontSize:10,fontWeight:800,color:"#991b1b"}},"整備コスト（実績）"),
            E("span",{style:{fontSize:9,color:"#94a3b8"}},"hm_logsより")
          ),
          // カテゴリ別行
          E("div",{style:{display:"flex",gap:4,marginBottom:6,flexWrap:"wrap"}},
            MCAT.map(function(c){
              var mv=mByCat[c.v]||0;var yv=yByCat[c.v]||0;
              if(!mv&&!yv)return E("div",{key:c.v,style:{flex:1,minWidth:60,background:"#fff",border:"1px solid #fecaca",borderRadius:8,padding:"5px 8px",textAlign:"center",opacity:.5}},
                E("div",{style:{fontSize:8,color:"#64748b",fontWeight:700}},"月/"+c.l),
                E("div",{style:{fontSize:12,fontWeight:700,color:"#cbd5e1"}},"-"),
                E("div",{style:{fontSize:7,color:"#94a3b8"}},"年 -"));
              return E("div",{key:c.v,style:{flex:1,minWidth:60,background:"#fff",border:"1px solid #fecaca",borderRadius:8,padding:"5px 8px",textAlign:"center"}},
                E("div",{style:{fontSize:8,color:"#991b1b",fontWeight:700}},"月/"+c.l),
                E("div",{style:{fontSize:mv>=100000?11:12,fontWeight:900,color:"#dc2626"}},fmt2(mv)),
                E("div",{style:{fontSize:7,color:"#94a3b8"}},"年 "+fmt2(yv)));
            })
          ),
          // 合計行
          E("div",{style:{display:"flex",gap:6}},
            E("div",{style:{flex:1,background:"#fff",border:"1px solid #fecaca",borderRadius:8,padding:"6px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}},
              E("span",{style:{fontSize:9,color:"#991b1b",fontWeight:800}},"当月合計"),
              E("span",{style:{fontSize:maintMonth>=1000000?13:15,fontWeight:900,color:"#dc2626"}},fmt2(maintMonth))),
            E("div",{style:{flex:1,background:"#991b1b",borderRadius:8,padding:"6px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}},
              E("span",{style:{fontSize:9,color:"#fca5a5",fontWeight:800}},"年間進捗"),
              E("span",{style:{fontSize:maintYear>=1000000?13:15,fontWeight:900,color:"#fff"}},fmt2(maintYear)))
          )
        )
      );
    })(),

    // ===== 📊 月別 車検 / 点検 / 修理 = 当月総コスト =====
    //   予算 = bt_maintenance（配車表メンテブロックの cost）
    //   実績 = bt_logs（整備記録）: type='inspection'→車検, 'semi_annual'→点検, 'repair'→修理
    (function(){
      var filterYearVS=new Date().getFullYear();
      var curYmVS=(new Date()).toISOString().slice(0,7);
      var monthCat3={};
      var initM3=function(ym){if(!monthCat3[ym])monthCat3[ym]={kensaB:0,kensaA:0,tenkenB:0,tenkenA:0,repairB:0,repair:0,total:0};};
      var cellD=function(actual,budget){
        if(!budget)return E("span",{style:{color:"#e2e8f0",fontSize:9}},"-");
        var diff=actual-budget;
        var col=diff>0?"#dc2626":diff<0?"#16a34a":"#94a3b8";
        var sym=diff>0?"+":"";
        var abs=Math.abs(diff);
        var txt=sym+(abs>=10000?"¥"+Math.round(abs/10000*10)/10+"万":"¥"+abs.toLocaleString());
        return E("span",{style:{fontSize:9,fontWeight:800,color:col,padding:"1px 4px",borderRadius:3,background:diff>0?"#fee2e2":diff<0?"#dcfce7":"#f1f5f9"}},diff===0?"±0":txt);
      };
      // 予算: bt_maintenance
      (maintenance||[]).forEach(function(m){
        if(m.label!=="車検"&&m.label!=="半年点検"&&m.label!=="修理")return;
        var ym=(m.startDate||"").slice(0,7);
        if(!ym||ym.slice(0,4)!==String(filterYearVS))return;
        var planned=Number(m.cost||0);if(planned<=0)return;
        initM3(ym);
        if(m.label==="車検")monthCat3[ym].kensaB+=planned;
        else if(m.label==="半年点検")monthCat3[ym].tenkenB+=planned;
        else monthCat3[ym].repairB+=planned;
      });
      // 実績: bt_logs
      // ★ 2026-05-06 fix: 月合計は全項目（オイル交換・その他含む）を集計する
      //   旧: 車検/半年点検/修理 のみ total に加算 → 「月別整備費」と合計が一致しない
      //   新: 表示3列(車検/点検/修理)はそのまま、total は全タイプ合算で「月別整備費」と一致
      (hmLogs||[]).forEach(function(l){
        var t=l.type||"";
        var ym=(l.date||"").slice(0,7);if(!ym)return;
        if(ym.slice(0,4)!==String(filterYearVS))return;
        var amt=Number(l.cost||0);if(amt<=0)return;
        initM3(ym);
        if(t==="inspection")monthCat3[ym].kensaA+=amt;
        else if(t==="semi_annual")monthCat3[ym].tenkenA+=amt;
        else if(t==="repair")monthCat3[ym].repair+=amt;
        // 全タイプを total に加算（オイル/その他も含む）→ 「月別整備費」と一致
        monthCat3[ym].total+=amt;
      });
      var allM3Keys=Object.keys(monthCat3).sort();
      var cur=monthCat3[curYmVS]||{kensaB:0,kensaA:0,tenkenB:0,tenkenA:0,repairB:0,repair:0,total:0};
      var y3={kensaB:0,kensaA:0,tenkenB:0,tenkenA:0,repairB:0,repair:0,total:0};
      allM3Keys.forEach(function(ym){["kensaB","kensaA","tenkenB","tenkenA","repairB","repair","total"].forEach(function(k){y3[k]+=monthCat3[ym][k];});});
      // ドリルダウン用ヘルパー
      var openDrill=function(period,types,labelTxt,col){
        var items=(hmLogs||[]).filter(function(l){
          if(types.indexOf(l.type||"")<0)return false;
          var ld=(l.date||"");
          if(period.length===7)return ld.slice(0,7)===period;
          if(period.length===4)return ld.slice(0,4)===period;
          return false;
        }).sort(function(a,b){return(a.date||"").localeCompare(b.date||"");});
        setDrill({period:period,labelTxt:labelTxt,col:col,items:items});
      };
      var cellA=function(v,col,onClick){
        if(v<=0)return E("span",{style:{color:"#e2e8f0"}},"-");
        return E("span",{onClick:onClick||null,style:{fontWeight:700,color:col,cursor:onClick?"pointer":"default",textDecoration:onClick?"underline":"none",textDecorationStyle:"dotted",textDecorationColor:col+"55",textUnderlineOffset:2}},"¥"+v.toLocaleString());
      };
      var cellB=function(v){return v>0?E("span",{style:{fontWeight:500,color:"#94a3b8",fontSize:10}},"¥"+v.toLocaleString()):E("span",{style:{color:"#e2e8f0"}},"-");};
      return E("div",{style:{marginBottom:12}},
        // 当月総コストカード
        E("div",{style:{background:"#fef3c7",border:"2px solid #f59e0b",borderRadius:10,padding:"12px 16px",marginBottom:8,boxShadow:"0 2px 6px rgba(245,158,11,0.2)",display:"flex",alignItems:"center",gap:14,flexWrap:"wrap"}},
          E("div",{style:{flex:1,minWidth:200}},
            E("div",{style:{fontSize:11,color:"#92400e",fontWeight:700,marginBottom:2}},"💰 当月総コスト("+curYmVS+") = 車検実績 + 点検実績 + 修理"),
            E("div",{style:{fontSize:24,fontWeight:900,color:"#92400e",lineHeight:1}},"¥"+cur.total.toLocaleString())
          ),
          E("div",{style:{display:"grid",gridTemplateColumns:"repeat(3,auto)",gap:"4px 14px",fontSize:11,color:"#92400e"}},
            E("div",{style:{fontSize:9,opacity:.7,gridColumn:1}},"車検"),
            E("div",{style:{fontSize:9,opacity:.7,gridColumn:2}},"点検"),
            E("div",{style:{fontSize:9,opacity:.7,gridColumn:3}},"修理"),
            E("div",{style:{fontWeight:800}},"¥"+cur.kensaA.toLocaleString(),cur.kensaB>0?E("div",{style:{fontSize:9,color:"#94a3b8"}},"予 ¥"+cur.kensaB.toLocaleString()):null),
            E("div",{style:{fontWeight:800}},"¥"+cur.tenkenA.toLocaleString(),cur.tenkenB>0?E("div",{style:{fontSize:9,color:"#94a3b8"}},"予 ¥"+cur.tenkenB.toLocaleString()):null),
            E("div",{style:{fontWeight:800}},"¥"+cur.repair.toLocaleString())
          )
        ),
        // 月別テーブル
        E("div",{style:{border:"1px solid #93c5fd",borderRadius:8,background:"#fff",overflow:"auto"}},
          E("div",{style:{display:"flex",alignItems:"center",gap:8,padding:"8px 14px",background:"#dbeafe",borderBottom:"1px solid #93c5fd"}},
            E("span",{style:{fontSize:12,fontWeight:800,color:"#1e40af",flex:1}},"📊 月別推移 ("+filterYearVS+"年)"),
            E("span",{style:{fontSize:11,color:"#1e40af",fontWeight:700}},"年計実績 ¥"+y3.total.toLocaleString())
          ),
          E("div",{style:{padding:"5px 10px",fontSize:9,color:"#64748b",background:"#f8fafc",borderBottom:"1px solid #e2e8f0"}},"※ 予算 = 配車表メンテブロックの登録金額 ・ 実績 = 整備記録 (bt_logs) ・ 修理 = type=修理"),
          allM3Keys.length===0
            ?E("div",{style:{textAlign:"center",padding:20,color:"#94a3b8",fontSize:12}},"記録なし")
            :E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:860}},
              E("thead",null,
                E("tr",{style:{background:"#eff6ff",borderBottom:"1px solid #93c5fd"}},
                  E("th",{rowSpan:2,style:{padding:"7px 10px",textAlign:"left",fontSize:11,fontWeight:700,color:"#1e40af",borderRight:"1px solid #93c5fd"}},"月"),
                  E("th",{colSpan:3,style:{padding:"4px 8px",textAlign:"center",fontSize:11,fontWeight:700,color:"#1e40af",borderRight:"1px solid #93c5fd",background:"#dbeafe"}},"🛡️ 車検"),
                  E("th",{colSpan:3,style:{padding:"4px 8px",textAlign:"center",fontSize:11,fontWeight:700,color:"#92400e",borderRight:"1px solid #93c5fd",background:"#fef3c7"}},"🔧 点検"),
                  E("th",{colSpan:3,style:{padding:"4px 8px",textAlign:"center",fontSize:11,fontWeight:700,color:"#991b1b",borderRight:"1px solid #93c5fd",background:"#fef2f2"}},"🔩 修理"),
                  E("th",{rowSpan:2,style:{padding:"7px 10px",textAlign:"right",fontSize:11,fontWeight:700,color:"#991b1b"}},"月合計 (実績)")
                ),
                E("tr",{style:{background:"#eff6ff",borderBottom:"2px solid #93c5fd"}},
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:600,color:"#94a3b8"}},"予算"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:700,color:"#1e40af"}},"実績"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:700,color:"#475569",borderRight:"1px solid #93c5fd"}},"差分"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:600,color:"#94a3b8"}},"予算"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:700,color:"#92400e"}},"実績"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:700,color:"#475569",borderRight:"1px solid #93c5fd"}},"差分"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:600,color:"#94a3b8"}},"予算"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:700,color:"#991b1b"}},"実績"),
                  E("th",{style:{padding:"4px 5px",textAlign:"right",fontSize:9,fontWeight:700,color:"#475569",borderRight:"1px solid #93c5fd"}},"差分")
                )
              ),
              E("tbody",null,
                allM3Keys.map(function(ym){
                  var d=monthCat3[ym];
                  var isCur=(ym===curYmVS);
                  var totalClickable=d.total>0;
                  return E("tr",{key:ym,style:{borderBottom:"1px solid #f1f5f9",background:isCur?"#fef9c3":"transparent"}},
                    E("td",{style:{padding:"7px 10px",fontWeight:isCur?900:700,fontSize:12,color:isCur?"#92400e":"#0f172a",borderRight:"1px solid #f1f5f9"}},ym,isCur?E("span",{style:{marginLeft:6,fontSize:9,padding:"1px 6px",background:"#f59e0b",color:"#fff",borderRadius:4,fontWeight:800}},"当月"):null),
                    E("td",{style:{padding:"7px 5px",textAlign:"right"}},cellB(d.kensaB)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right"}},cellA(d.kensaA,"#1e40af",d.kensaA>0?function(){openDrill(ym,["inspection"],"🛡️ 車検 実績","#1e40af");}:null)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right",borderRight:"1px solid #f1f5f9"}},cellD(d.kensaA,d.kensaB)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right"}},cellB(d.tenkenB)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right"}},cellA(d.tenkenA,"#92400e",d.tenkenA>0?function(){openDrill(ym,["semi_annual"],"🔧 半年点検 実績","#92400e");}:null)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right",borderRight:"1px solid #f1f5f9"}},cellD(d.tenkenA,d.tenkenB)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right"}},cellB(d.repairB)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right"}},cellA(d.repair,"#991b1b",d.repair>0?function(){openDrill(ym,["repair"],"🔩 修理 実績","#991b1b");}:null)),
                    E("td",{style:{padding:"7px 5px",textAlign:"right",borderRight:"1px solid #f1f5f9"}},cellD(d.repair,d.repairB)),
                    E("td",{onClick:totalClickable?function(){openDrill(ym,["inspection","semi_annual","repair"],"💰 月合計 (車検+点検+修理)","#92400e");}:null,style:{padding:"7px 10px",textAlign:"right",fontWeight:isCur?900:800,color:isCur?"#92400e":d.total>0?"#991b1b":"#e2e8f0",fontSize:isCur?13:11,cursor:totalClickable?"pointer":"default",textDecoration:totalClickable?"underline":"none",textDecorationStyle:"dotted",textDecorationColor:"#dc262655",textUnderlineOffset:2}},d.total>0?"¥"+d.total.toLocaleString():"-")
                  );
                }),
                E("tr",{style:{borderTop:"2px solid #93c5fd",background:"#1e293b",fontWeight:800}},
                  E("td",{style:{padding:"9px 10px",fontSize:11,color:"#fff",borderRight:"1px solid #334155"}},"年間合計"),
                  E("td",{style:{padding:"9px 5px",textAlign:"right",color:"#94a3b8",fontSize:9}},y3.kensaB>0?"¥"+y3.kensaB.toLocaleString():"-"),
                  E("td",{onClick:y3.kensaA>0?function(){openDrill(String(filterYearVS),["inspection"],"🛡️ 車検 年間実績","#1e40af");}:null,style:{padding:"9px 5px",textAlign:"right",color:"#93c5fd",fontWeight:700,cursor:y3.kensaA>0?"pointer":"default",textDecoration:y3.kensaA>0?"underline":"none",textDecorationStyle:"dotted",textUnderlineOffset:2}},y3.kensaA>0?"¥"+y3.kensaA.toLocaleString():"-"),
                  E("td",{style:{padding:"9px 5px",textAlign:"right",borderRight:"1px solid #334155"}},cellD(y3.kensaA,y3.kensaB)),
                  E("td",{style:{padding:"9px 5px",textAlign:"right",color:"#94a3b8",fontSize:9}},y3.tenkenB>0?"¥"+y3.tenkenB.toLocaleString():"-"),
                  E("td",{onClick:y3.tenkenA>0?function(){openDrill(String(filterYearVS),["semi_annual"],"🔧 半年点検 年間実績","#92400e");}:null,style:{padding:"9px 5px",textAlign:"right",color:"#fcd34d",fontWeight:700,cursor:y3.tenkenA>0?"pointer":"default",textDecoration:y3.tenkenA>0?"underline":"none",textDecorationStyle:"dotted",textUnderlineOffset:2}},y3.tenkenA>0?"¥"+y3.tenkenA.toLocaleString():"-"),
                  E("td",{style:{padding:"9px 5px",textAlign:"right",borderRight:"1px solid #334155"}},cellD(y3.tenkenA,y3.tenkenB)),
                  E("td",{style:{padding:"9px 5px",textAlign:"right",color:"#94a3b8",fontSize:9}},y3.repairB>0?"¥"+y3.repairB.toLocaleString():"-"),
                  E("td",{onClick:y3.repair>0?function(){openDrill(String(filterYearVS),["repair"],"🔩 修理 年間実績","#991b1b");}:null,style:{padding:"9px 5px",textAlign:"right",color:"#fca5a5",fontWeight:700,cursor:y3.repair>0?"pointer":"default",textDecoration:y3.repair>0?"underline":"none",textDecorationStyle:"dotted",textUnderlineOffset:2}},y3.repair>0?"¥"+y3.repair.toLocaleString():"-"),
                  E("td",{style:{padding:"9px 5px",textAlign:"right",borderRight:"1px solid #334155"}},cellD(y3.repair,y3.repairB)),
                  E("td",{onClick:y3.total>0?function(){openDrill(String(filterYearVS),["inspection","semi_annual","repair"],"💰 年間合計 (車検+点検+修理)","#4ade80");}:null,style:{padding:"9px 10px",textAlign:"right",fontSize:13,fontWeight:900,color:"#4ade80",cursor:y3.total>0?"pointer":"default",textDecoration:y3.total>0?"underline":"none",textDecorationStyle:"dotted",textUnderlineOffset:2}},"¥"+y3.total.toLocaleString())
                )
