  const[saveStatus,setSaveStatus]=useState("ok"); // "ok"|"saving"|"error"
  const pendingSaves=React.useRef(0);
  const upd=async(id,t,resFieldChanges)=>{
    selfUpdatedIds.current.set(id,Date.now());
    let changedFields={};
    setTasks(ts=>{
      const prev=ts.find(x=>x._id===id);
      if(prev){
        Object.keys(t).forEach(k=>{
          if(k.startsWith("_")&&k!=='_changed'&&k!=='_timeFromSheet'&&k!=='_timeChangeSource'&&k!=='_placeSource'&&k!=='_ssTime'&&k!=='_ssPlace'&&k!=='_ssTimeAt'&&k!=='_ssPlaceAt'&&k!=='_manualTimeAt'&&k!=='_manualPlaceAt')return;
          if(k==='opts'){if(JSON.stringify(t.opts)!==JSON.stringify(prev.opts))changedFields.opts=t.opts;return;}
          if(t[k]!==prev[k])changedFields[k]=t[k];
        });
      }else{changedFields=t;}
      const next=ts.map(x=>x._id===id?t:x);DB._lsSave(next,selDate);return next;
    });
    pendingSaves.current++;setSaveStatus("saving");
    if(Object.keys(changedFields).length>0&&Object.keys(changedFields).length<=10){
      await DB.updateTaskFields(id,selDate,changedFields);
    }else{
      await DB.updateTask(t,selDate);
    }
