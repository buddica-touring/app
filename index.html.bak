                  E("td",{style:{padding:"7px 10px",textAlign:"center",fontSize:10}},
                    nextShaken[row.v.code]?E("span",{style:{color:"#2563eb",fontWeight:600}},nextShaken[row.v.code]):E("span",{style:{color:"#cbd5e1"}},"-")),
                  E("td",{style:{padding:"7px 10px",textAlign:"center",fontSize:10}},
                    nextTenken[row.v.code]?E("span",{style:{color:"#059669",fontWeight:600}},nextTenken[row.v.code]):E("span",{style:{color:"#cbd5e1"}},"-")),
                  E("td",{style:{padding:"7px 10px",textAlign:"right",color:"#64748b",fontSize:11}},row.odo>0?row.odo.toLocaleString()+"km":"-"),
                  E("td",{style:{padding:"7px 10px",textAlign:"center"}},
                    row.dmgCount>0?E("span",{style:{fontSize:10,fontWeight:700,padding:"2px 6px",borderRadius:4,background:"#fee2e2",color:"#dc2626"}},row.dmgCount+"箇所"):E("span",{style:{color:"#cbd5e1",fontSize:10}},"なし")),
                  E("td",{style:{padding:"7px 10px",textAlign:"center"}},
                    E("a",{href:"https://buddica-touring.github.io/damage/",target:"_blank",rel:"noopener noreferrer",style:{fontSize:10,color:"#1e293b",background:"#f1f5f9",padding:"3px 8px",borderRadius:6,textDecoration:"none",fontWeight:600,border:"1px solid #e2e8f0"}},"🔍"))
                );
              }))
            )
          )
        );
      })
    ),
    // ===== 未稼働車両 ポップアップ =====
    showInactPop&&E("div",{onClick:function(){setShowInactPop(false);},style:{position:"fixed",inset:0,background:"rgba(15,23,42,0.55)",zIndex:9000,display:"flex",alignItems:"center",justifyContent:"center",padding:20}},
      E("div",{onClick:function(e){e.stopPropagation();},style:{background:"#fff",borderRadius:12,minWidth:280,maxWidth:480,width:"100%",maxHeight:"70vh",overflow:"auto",boxShadow:"0 12px 48px rgba(0,0,0,0.3)"}},
        E("div",{style:{padding:"12px 16px",borderBottom:"2px solid #e2e8f0",background:"#f8fafc",display:"flex",alignItems:"center",justifyContent:"space-between",position:"sticky",top:0}},
          E("div",{style:{fontSize:14,fontWeight:900,color:"#475569"}},"未稼働車両 "+inactiveN+"台"),
          E("button",{onClick:function(){setShowInactPop(false);},style:{padding:"4px 12px",fontSize:12,fontWeight:700,background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,cursor:"pointer"}},"× 閉じる")
        ),
        E("div",{style:{padding:8}},
          (vehicles||[]).filter(function(v){return !isKpiActive(v.code);}).length===0
            ?E("div",{style:{padding:20,textAlign:"center",color:"#94a3b8",fontSize:12}},"未稼働車両はありません")
            :(vehicles||[]).filter(function(v){return !isKpiActive(v.code);}).map(function(v){
              return E("div",{key:v.code,style:{display:"flex",alignItems:"center",gap:10,padding:"9px 12px",borderBottom:"1px solid #f1f5f9",fontSize:12}},
                E("span",{style:{fontWeight:800,color:"#1e293b",minWidth:60}},v.code),
                E("span",{style:{fontWeight:700,color:"#2563eb",minWidth:60,fontSize:13}},v.no||"—"),
                E("span",{style:{color:"#64748b",flex:1,fontSize:11}},v.type||""),
                E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:"#f1f5f9",color:"#64748b",fontWeight:600}},"未稼働")
              );
            })
        )
      )
    ),
    // ===== ドリルダウン モーダル =====
    drill&&E("div",{onClick:function(){setDrill(null);},style:{position:"fixed",inset:0,background:"rgba(15,23,42,0.55)",zIndex:9000,display:"flex",alignItems:"center",justifyContent:"center",padding:20}},
      E("div",{onClick:function(e){e.stopPropagation();},style:{background:"#fff",borderRadius:12,maxWidth:760,width:"100%",maxHeight:"82vh",overflow:"auto",boxShadow:"0 12px 48px rgba(0,0,0,0.3)"}},
        // ヘッダー
        E("div",{style:{padding:"14px 20px",borderBottom:"3px solid "+drill.col,background:"#f8fafc",display:"flex",alignItems:"center",justifyContent:"space-between",position:"sticky",top:0,zIndex:1}},
          E("div",null,
            E("div",{style:{fontSize:14,fontWeight:900,color:drill.col}},drill.labelTxt),
            E("div",{style:{fontSize:11,color:"#64748b",marginTop:2}},drill.period+" ・ "+drill.items.length+"件 ・ ¥"+drill.items.reduce(function(s,l){return s+Number(l.cost||0);},0).toLocaleString())
          ),
          E("button",{onClick:function(){setDrill(null);},style:{padding:"6px 14px",fontSize:12,fontWeight:700,background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,cursor:"pointer"}},"× 閉じる")
        ),
        // 内訳テーブル
        drill.items.length===0
          ?E("div",{style:{padding:30,textAlign:"center",color:"#94a3b8",fontSize:12}},"記録なし")
          :E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11}},
            E("thead",null,E("tr",{style:{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}},
              E("th",{style:{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b"}},"日付"),
              E("th",{style:{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b"}},"車両"),
              E("th",{style:{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b"}},"種別"),
              E("th",{style:{padding:"8px 10px",textAlign:"right",fontSize:10,fontWeight:700,color:"#991b1b"}},"金額"),
              E("th",{style:{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:"#64748b"}},"詳細")
            )),
            E("tbody",null,drill.items.map(function(l,i){
              var t=l.type||"";
              var typeLbl=t==="inspection"?"🛡️ 車検":t==="semi_annual"?"🔧 半年点検":t==="repair"?"🔩 修理":t;
              var typeCol=t==="inspection"?"#1e40af":t==="semi_annual"?"#92400e":t==="repair"?"#991b1b":"#64748b";
              var typeBg=t==="inspection"?"#dbeafe":t==="semi_annual"?"#fef3c7":t==="repair"?"#fee2e2":"#f1f5f9";
              var car=(hmCars||[]).find(function(c){return c.id===l.car_id;});
              return E("tr",{key:l.id||i,style:{borderBottom:"1px solid #f1f5f9"}},
                E("td",{style:{padding:"8px 10px",fontWeight:600,color:"#0f172a",fontSize:11}},l.date||"-"),
                E("td",{style:{padding:"8px 10px"}},
                  E("div",{style:{fontWeight:700,fontSize:11}},car?car.name:l.car_id||"-"),
                  car?E("div",{style:{fontSize:10,color:"#94a3b8"}},car.plate||""):null
                ),
                E("td",{style:{padding:"8px 10px"}},E("span",{style:{fontSize:10,fontWeight:800,padding:"2px 8px",borderRadius:4,background:typeBg,color:typeCol}},typeLbl)),
                E("td",{style:{padding:"8px 10px",textAlign:"right",fontSize:12,fontWeight:800,color:typeCol}},"¥"+Number(l.cost||0).toLocaleString()),
                E("td",{style:{padding:"8px 10px",fontSize:10,color:"#475569"}},l.detail||l.description||"-")
              );
            }),
            E("tr",{style:{background:"#1e293b"}},
              E("td",{colSpan:3,style:{padding:"10px",color:"#fff",fontWeight:800,fontSize:12}},"合計"),
              E("td",{style:{padding:"10px",textAlign:"right",color:"#4ade80",fontWeight:900,fontSize:14}},"¥"+drill.items.reduce(function(s,l){return s+Number(l.cost||0);},0).toLocaleString()),
              E("td",{style:{padding:"10px"}})
            )
          )
        )
      )
    )
  );
}


function VehicleTab(props){
  var _subTab=useState("status");
  var subTab=_subTab[0];
  var setSubTab=_subTab[1];
  var tabBtn=function(id,label,badge){return React.createElement("button",{onClick:function(){setSubTab(id);},style:{padding:"8px 12px",fontSize:13,fontWeight:subTab===id?700:500,color:subTab===id?"#2563eb":"#64748b",background:"none",border:"none",cursor:"pointer",borderBottom:subTab===id?"2px solid #2563eb":"none",position:"relative"}},label,badge?React.createElement("span",{style:{fontSize:9,marginLeft:4,padding:"1px 5px",borderRadius:8,background:"#dc2626",color:"#fff",fontWeight:700}},badge):null)};
  var maintCount=(props.maintenance||[]).length;
  return React.createElement("div",null,
    React.createElement("div",{style:{display:"flex",gap:8,marginBottom:12,borderBottom:"1px solid #e2e8f0",paddingBottom:8,overflowX:"auto"}},
      tabBtn("status","運用サマリー",maintCount>0?maintCount:null),
      tabBtn("master","マスター"),
      tabBtn("inspection","車検/点検/修理"),
      tabBtn("odometer","距離管理"),
      tabBtn("fleet","整備管理"),
    ),
    subTab==="status"&&React.createElement(VehicleFleetStatus,{vehicles:props.vehicles||[],vehicleClasses:props.vehicleClasses||[],maintenance:props.maintenance||[],data:props.data||[],fleet:props.fleet||{},hmCars:props.hmCars||[],hmCarData:props.hmCarData||[],hmLogs:props.hmLogs||[]}),
    subTab==="master"&&React.createElement(VehicleManager,{vehicles:props.vehicles||[],onVehiclesChange:props.onVehiclesChange,vehicleClasses:props.vehicleClasses||[],onDeleteVehicle:props.onDeleteVehicle,maintenance:props.maintenance||[]}),
    subTab==="inspection"&&React.createElement(InspectionCalendar,{vehicles:props.vehicles||[],maintenance:props.maintenance||[],onMaintenanceChange:props.onMaintenanceChange,hmLogs:props.hmLogs||[]}),
    subTab==="odometer"&&React.createElement(OdometerManager,{vehicles:props.vehicles||[]}),
    subTab==="fleet"&&React.createElement(FleetManager,{cars:props.hmCars||[],carData:props.hmCarData||[],logs:props.hmLogs||[],classes:props.hmClasses||[],hmReload:props.hmReload,maintenance:props.maintenance||[],onMaintenanceChange:props.onMaintenanceChange}),
  );
}

/* ==========================================
   距離管理タブ（全車両リスト + 走行距離入力・履歴）
   ========================================== */
function OdometerManager({vehicles}){
  // Slack Bot Token: localStorage に運用環境で設定（公開リポにハードコードしない）
  // セット方法: localStorage.setItem('bt_slack_token','xoxb-xxx')
  const SLACK_TOKEN = (typeof localStorage !== 'undefined' && localStorage.getItem('bt_slack_token')) || "";
  const SLACK_CH="C06L91W6T08"; // #kagawa_operations-team

  const OIL_INTERVAL=10000; // 固定: 10,000km毎
  const OIL_WARN=9000;      // 警告閾値: 9,000km
  const[odoRecs,setOdoRecs]=useState({});  // {code:[走行距離 records...]}
  const[oilRecs,setOilRecs]=useState({});  // {code:[オイル交換 records...]}
  const[twins,setTwins]=useState({});
  const[loading,setLoading]=useState(true);
  const[expanded,setExpanded]=useState({});
  // 走行距離入力
  const[odoInputVc,setOdoInputVc]=useState(null);
  const[odoKm,setOdoKm]=useState("");
  const[odoDate,setOdoDate]=useState(new Date().toISOString().slice(0,10));
  const[odoNote,setOdoNote]=useState("");
  // オイル交換入力
  const[oilInputVc,setOilInputVc]=useState(null);
  const[oilKm,setOilKm]=useState("");
  const[oilDate,setOilDate]=useState(new Date().toISOString().slice(0,10));
  const[oilNote,setOilNote]=useState("");
  const[saving,setSaving]=useState(false);
  const[slackStatus,setSlackStatus]=useState(null);
  const[openCls,setOpenCls]=useState({});
  const toggleCls2=(tp)=>setOpenCls(p=>({...p,[tp]:!p[tp]}));
  const today=new Date().toISOString().slice(0,10);

  const loadData=async()=>{
    setLoading(true);
    try{
      if(sb){
        const[odoRes,oilRes,twRes]=await Promise.all([
          sb.from("bt_vehicle_maintenance").select("*").eq("type","走行距離").order("completed_date",{ascending:false}),
          sb.from("bt_vehicle_maintenance").select("*").eq("type","オイル交換").order("completed_date",{ascending:false}),
          sb.from("vehicle_twins").select("id,odometer").eq("store","takamatsu")
        ]);
        const om={},oil={};
        (odoRes.data||[]).forEach(r=>{if(!om[r.vehicle_code])om[r.vehicle_code]=[];om[r.vehicle_code].push(r);});
        (oilRes.data||[]).forEach(r=>{if(!oil[r.vehicle_code])oil[r.vehicle_code]=[];oil[r.vehicle_code].push(r);});
        setOdoRecs(om);setOilRecs(oil);
        const tw={};(twRes.data||[]).forEach(t=>{if(t.odometer)tw[t.id]=t.odometer;});setTwins(tw);
      }
    }finally{setLoading(false);}
  };
  useEffect(()=>{loadData();},[]);

  // オイル交換アラート計算（10,000km固定・9,000km警告）
  const getOilStatus=(code)=>{
    const latestOdo=(odoRecs[code]||[])[0];
    const latestOil=(oilRecs[code]||[])[0];
    if(!latestOil)return{level:"none",label:"未記録",color:"#94a3b8",bg:"#f1f5f9",nextKm:null};
    const lastKm=Number(latestOil.odometer_km)||0;
    const nextKm=lastKm+OIL_INTERVAL;
    // 現在km: 走行距離レコード優先 → vehicle_twins → 0
    const curKm=latestOdo?Number(latestOdo.odometer_km):(twins[code]||0);
    const daysSince=latestOil.completed_date?Math.floor((new Date()-new Date(latestOil.completed_date))/(1000*60*60*24)):999;
    if(curKm>0&&curKm>=lastKm){
      const traveled=curKm-lastKm;
      const remaining=OIL_INTERVAL-traveled;
      if(remaining<=0)return{level:"danger",label:`超過 ${Math.abs(remaining).toLocaleString()}km`,color:"#dc2626",bg:"#fee2e2",traveled,remaining,nextKm,curKm,daysSince};
      if(traveled>=OIL_WARN)return{level:"warn",label:`残 ${remaining.toLocaleString()}km`,color:"#d97706",bg:"#fef9c3",traveled,remaining,nextKm,curKm,daysSince};
      return{level:"ok",label:`残 ${remaining.toLocaleString()}km`,color:"#059669",bg:"#f0fdf4",traveled,remaining,nextKm,curKm,daysSince};
    }
    // km不明: 日数ベース
    if(daysSince>180)return{level:"danger",label:`${daysSince}日経過（km記録なし）`,color:"#dc2626",bg:"#fee2e2",nextKm,daysSince};
    if(daysSince>120)return{level:"warn",label:`${daysSince}日経過（km記録なし）`,color:"#d97706",bg:"#fef9c3",nextKm,daysSince};
    return{level:"ok",label:`次回目安 ${nextKm.toLocaleString()}km`,color:"#059669",bg:"#f0fdf4",nextKm,daysSince};
  };

  const saveOdo=async(vc)=>{
    const km=Number(odoKm);if(!km||km<=0){alert("走行距離を入力してください");return;}
    setSaving(true);
    try{
      const row={vehicle_code:vc,type:"走行距離",completed_date:odoDate||today,cost:0,invoice_no:"",notes:odoNote||"",odometer_km:km};
      const{error}=await sb.from("bt_vehicle_maintenance").insert(row);
      if(error){dbLog("saveOdo",false,error.message);alert("⚠️ 保存失敗\n\n"+error.message+"\n\n通信状態を確認して再試行してください。");return;}
      dbLog("saveOdo",true,vc+" "+km+"km");
      setOdoRecs(p=>{const n={...p};if(!n[vc])n[vc]=[];n[vc]=[{...row,id:"t_"+Date.now()},...n[vc]];return n;});
      setOdoInputVc(null);setOdoKm("");setOdoNote("");
      alert("✅ 走行距離 "+km.toLocaleString()+"km を保存しました");
    }catch(e){
      const msg=String((e&&e.message)||e);
      dbLog("saveOdo",false,msg);
      alert("⚠️ 保存失敗（通信エラー）\n\n"+msg+"\n\n• Wi-Fi/モバイル回線を確認\n• ページを再読込\n• それでも改善しなければ管理者に連絡");
    }finally{setSaving(false);}
  };

  const saveOil=async(vc)=>{
    const km=Number(oilKm);if(!km||km<=0){alert("走行距離を入力してください");return;}
    setSaving(true);
    try{
      const row={vehicle_code:vc,type:"オイル交換",completed_date:oilDate||today,cost:0,invoice_no:"",notes:oilNote||"",odometer_km:km};
      const{error}=await sb.from("bt_vehicle_maintenance").insert(row);
      if(error){dbLog("saveOil",false,error.message);alert("⚠️ 保存失敗\n\n"+error.message+"\n\n通信状態を確認して再試行してください。");return;}
      dbLog("saveOil",true,vc+" "+km+"km");
      setOilRecs(p=>{const n={...p};if(!n[vc])n[vc]=[];n[vc]=[{...row,id:"t_"+Date.now()},...n[vc]];return n;});
      setOilInputVc(null);setOilKm("");setOilNote("");
      alert("✅ オイル交換 "+km.toLocaleString()+"km を保存しました");
    }catch(e){
      const msg=String((e&&e.message)||e);
      dbLog("saveOil",false,msg);
      alert("⚠️ 保存失敗（通信エラー）\n\n"+msg+"\n\n• Wi-Fi/モバイル回線を確認\n• ページを再読込\n• それでも改善しなければ管理者に連絡");
    }finally{setSaving(false);}
  };

  const sendSlack=async()=>{
    setSlackStatus("sending");
    const now=new Date().toLocaleDateString("ja-JP",{year:"numeric",month:"2-digit",day:"2-digit"});
    const dangers=[],warns=[],oks=[];
    (vehicles||[]).forEach(v=>{
      const st=getOilStatus(v.code);
      const latestOil=(oilRecs[v.code]||[])[0];
      const curKm=twins[v.code]||0;
      const line=`・${v.name}（${v.no}）  現在:${curKm>0?curKm.toLocaleString()+"km":"不明"} | 最終交換:${latestOil?`${latestOil.completed_date} @${Number(latestOil.odometer_km).toLocaleString()}km`:"未記録"} | *${st.label}*`;
      if(st.level==="danger")dangers.push(line);
      else if(st.level==="warn")warns.push(line);
      else if(st.level==="ok")oks.push(line);
    });
    // 月平均走行距離（走行距離記録廃止）
    const avgKmPerMonth=0;
    let msg=`🔧 *オイル交換アラート（BUDDICA TOURISM 高松空港店）${now}*\n`;
    if(dangers.length>0)msg+=`\n🔴 *要交換 ${dangers.length}台*\n${dangers.join("\n")}\n`;
    if(warns.length>0)msg+=`\n🟡 *交換時期接近 ${warns.length}台*\n${warns.join("\n")}\n`;
    if(oks.length>0)msg+=`\n🟢 正常 ${oks.length}台`;
    if(avgKmPerMonth>0)msg+=`\n\n📊 平均走行距離: 約${avgKmPerMonth.toLocaleString()}km/月`;
    try{
      const res=await fetch("https://slack.com/api/chat.postMessage",{
        method:"POST",headers:{"Content-Type":"application/json","Authorization":"Bearer "+SLACK_TOKEN},
        body:JSON.stringify({channel:SLACK_CH,text:msg,mrkdwn:true})
      });
      const j=await res.json();
      setSlackStatus(j.ok?"sent":"err");
      setTimeout(()=>setSlackStatus(null),5000);
    }catch(e){setSlackStatus("err");}
  };

  if(loading)return <div style={{padding:32,textAlign:"center",color:"#94a3b8"}}>読込中...</div>;

  const thS={padding:"8px 10px",fontSize:11,fontWeight:700,color:"#64748b",borderBottom:"2px solid #e2e8f0",background:"#f8fafc",textAlign:"left",whiteSpace:"nowrap"};
  const tdS={padding:"7px 10px",fontSize:11,verticalAlign:"middle",borderBottom:"1px solid #f1f5f9"};

  const dangerCnt=(vehicles||[]).filter(v=>getOilStatus(v.code).level==="danger").length;
  const warnCnt=(vehicles||[]).filter(v=>getOilStatus(v.code).level==="warn").length;

  return <div style={{maxWidth:1080,margin:"0 auto"}}>
    {/* ヘッダー */}
    <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12,flexWrap:"wrap"}}>
      <h3 style={{fontSize:15,fontWeight:800,margin:0}}>🚗 距離管理</h3>
      <span style={{fontSize:11,color:"#64748b"}}>{(vehicles||[]).length}台</span>
      {dangerCnt>0&&<span style={{fontSize:11,fontWeight:800,padding:"2px 10px",borderRadius:8,background:"#fee2e2",color:"#dc2626"}}>🔴 要交換 {dangerCnt}台</span>}
      {warnCnt>0&&<span style={{fontSize:11,fontWeight:700,padding:"2px 10px",borderRadius:8,background:"#fef9c3",color:"#d97706"}}>🟡 接近 {warnCnt}台</span>}
      <div style={{marginLeft:"auto",display:"flex",gap:6}}>
        <button onClick={sendSlack} disabled={slackStatus==="sending"} style={{fontSize:11,padding:"5px 14px",background:"#4A154B",color:"#fff",border:"none",borderRadius:8,cursor:"pointer",fontWeight:700,display:"flex",alignItems:"center",gap:4}}>
          <span>📣</span>{slackStatus==="sending"?"送信中...":slackStatus==="sent"?"✅ 送信済み":slackStatus==="err"?"❌ エラー":"Slackアラート"}
        </button>
        <button onClick={loadData} style={{fontSize:11,padding:"5px 12px",border:"1px solid #e2e8f0",borderRadius:8,background:"#f8fafc",cursor:"pointer"}}>🔄</button>
      </div>
    </div>

    {/* クラス別アコーディオン */}
    {(()=>{
      // クラス別グループ化
      const grpMap={};const grpOrder=[];
      (vehicles||[]).forEach(v=>{const tp=v.type||"?";if(!grpMap[tp]){grpMap[tp]=[];grpOrder.push(tp);}grpMap[tp].push(v);});
      const thead=<thead><tr>
        <th style={thS}>車両</th>
        <th style={{...thS,textAlign:"right"}}>現在km</th>
        <th style={{...thS,textAlign:"right",color:"#64748b"}}>前回km</th>
        <th style={{...thS,background:"#fff7ed",color:"#92400e"}}>最終OIL交換</th>
        <th style={{...thS,background:"#fff7ed",textAlign:"right"}}>次回目安</th>
        <th style={{...thS,background:"#fff7ed"}}>アラート</th>
        <th style={{...thS,textAlign:"center"}}>操作</th>
      </tr></thead>;
      return grpOrder.map(tp=>{
        const grpVehs=grpMap[tp];
        const isOpen=!!openCls[tp];
        const dCnt=grpVehs.filter(v=>getOilStatus(v.code).level==="danger").length;
        const wCnt=grpVehs.filter(v=>getOilStatus(v.code).level==="warn").length;
        return<div key={tp} style={{marginBottom:8}}>
          <div onClick={()=>toggleCls2(tp)} style={{display:"flex",alignItems:"center",gap:8,padding:"9px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:isOpen?"8px 8px 0 0":"8px",cursor:"pointer",userSelect:"none"}}>
            <span style={{padding:"2px 9px",background:"#2563eb",color:"#fff",borderRadius:4,fontSize:11,fontWeight:800}}>{tp}</span>
            <span style={{fontSize:12,fontWeight:700,color:"#374151",flex:1}}>{tp}クラス</span>
            <span style={{fontSize:11,color:"#94a3b8"}}>{grpVehs.length}台</span>
            {dCnt>0&&<span style={{fontSize:10,fontWeight:800,padding:"1px 8px",borderRadius:6,background:"#fee2e2",color:"#dc2626"}}>🔴 {dCnt}</span>}
            {wCnt>0&&<span style={{fontSize:10,fontWeight:700,padding:"1px 8px",borderRadius:6,background:"#fef9c3",color:"#d97706"}}>🟡 {wCnt}</span>}
            <span style={{fontSize:12,color:"#94a3b8"}}>{isOpen?"▲":"▼"}</span>
          </div>
          {isOpen&&<div style={{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",minWidth:600}}>
              {thead}
              <tbody>
          {grpVehs.map(v=>{
            const odoList=odoRecs[v.code]||[];
            const latest=odoList[0]||null;const prev=odoList[1]||null;
            const oilRec=(oilRecs[v.code]||[])[0]||null;
            const oilHistory=(oilRecs[v.code]||[]).slice(1);
            const oilSt=getOilStatus(v.code);
            const isOdoOpen=odoInputVc===v.code;
            const isOilOpen=oilInputVc===v.code;
            const isExp=expanded[v.code];
            return <React.Fragment key={v.code}>
              <tr style={{background:"#fff"}}>
                <td style={tdS}>
                  <div style={{fontWeight:700,fontSize:12}}>{v.name}</div>
                  <div style={{fontSize:10,color:"#94a3b8"}}>{v.no} <span style={{padding:"1px 5px",borderRadius:3,background:"#f1f5f9",color:"#64748b"}}>{v.type}</span></div>
                </td>
                {/* 現在km */}
                <td style={{...tdS,textAlign:"right"}}>
                  {latest?<div><div style={{fontSize:13,fontWeight:900,color:"#1e293b"}}>{Number(latest.odometer_km).toLocaleString()} km</div><div style={{fontSize:9,color:"#94a3b8"}}>{latest.completed_date}</div></div>:<span style={{color:"#cbd5e1",fontSize:10}}>未記録</span>}
                </td>
                {/* 前回km */}
                <td style={{...tdS,textAlign:"right"}}>
                  {prev?<div><div style={{fontSize:12,fontWeight:600,color:"#64748b"}}>{Number(prev.odometer_km).toLocaleString()} km</div>{latest&&<div style={{fontSize:9,color:"#2563eb",fontWeight:600}}>+{(Number(latest.odometer_km)-Number(prev.odometer_km)).toLocaleString()}km</div>}</div>:<span style={{color:"#e2e8f0",fontSize:10}}>-</span>}
                </td>
                {/* 最終OIL交換 */}
                <td style={{...tdS,background:"#fff7ed"}}>
                  {oilRec?<div><div style={{fontSize:11,fontWeight:700,color:"#92400e"}}>{oilRec.completed_date} @ {Number(oilRec.odometer_km).toLocaleString()}km</div>{oilRec.notes&&<div style={{fontSize:9,color:"#94a3b8"}}>{oilRec.notes}</div>}</div>:<span style={{fontSize:10,color:"#fed7aa"}}>未記録</span>}
                </td>
                {/* 次回目安 */}
                <td style={{...tdS,background:"#fff7ed",textAlign:"right"}}>
                  {oilSt.nextKm?<span style={{fontSize:12,fontWeight:800,color:"#374151"}}>{oilSt.nextKm.toLocaleString()} km</span>:<span style={{fontSize:10,color:"#fed7aa"}}>-</span>}
                </td>
                {/* アラート */}
                <td style={{...tdS,background:"#fff7ed"}}>
                  <span style={{fontSize:10,fontWeight:800,padding:"3px 10px",borderRadius:8,background:oilSt.bg,color:oilSt.color}}>
                    {oilSt.level==="danger"?"🔴":oilSt.level==="warn"?"🟡":oilSt.level==="ok"?"🟢":"⚪"} {oilSt.label}
                  </span>
                </td>
                {/* 操作 */}
                <td style={{...tdS,textAlign:"center"}}>
                  <div style={{display:"flex",gap:3,justifyContent:"center",flexWrap:"wrap"}}>
                    <button onClick={()=>{setOdoInputVc(isOdoOpen?null:v.code);setOilInputVc(null);setOdoKm(latest?String(latest.odometer_km):"");setOdoDate(today);setOdoNote("");}} style={{fontSize:9,padding:"3px 8px",background:isOdoOpen?"#eff6ff":"#2563eb",color:isOdoOpen?"#2563eb":"#fff",border:isOdoOpen?"1px solid #93c5fd":"none",borderRadius:5,cursor:"pointer",fontWeight:700}}>🚗 走行</button>
                    <button onClick={()=>{setOilInputVc(isOilOpen?null:v.code);setOdoInputVc(null);setOilKm(latest?String(latest.odometer_km):"");setOilDate(today);setOilNote("");}} style={{fontSize:9,padding:"3px 8px",background:isOilOpen?"#fff7ed":"#ea580c",color:isOilOpen?"#ea580c":"#fff",border:isOilOpen?"1px solid #fed7aa":"none",borderRadius:5,cursor:"pointer",fontWeight:700}}>🔧 OIL</button>
                    {prev&&<button onClick={()=>setExpanded(p=>({...p,[v.code]:!p[v.code]}))} style={{fontSize:9,padding:"3px 7px",background:"none",border:"1px solid #e2e8f0",borderRadius:5,cursor:"pointer",color:"#64748b"}}>{isExp?"▲":"▼"}</button>}
                  </div>
                </td>
              </tr>
              {/* 走行距離入力 */}
              {isOdoOpen&&<tr style={{background:"#eff6ff"}}><td colSpan={7} style={{padding:"10px 14px"}}>
                <div style={{display:"flex",gap:8,alignItems:"flex-end",flexWrap:"wrap"}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#1e40af",flexShrink:0}}>🚗 走行距離更新</span>
                  <div><div style={{fontSize:9,color:"#64748b",fontWeight:700,marginBottom:2}}>現在km</div><input type="number" value={odoKm} onChange={e=>setOdoKm(e.target.value)} style={{width:110,border:"1px solid #93c5fd",borderRadius:6,padding:"4px 7px",fontSize:12,fontWeight:700}} placeholder="例: 48000" autoFocus/></div>
                  <div><div style={{fontSize:9,color:"#64748b",fontWeight:700,marginBottom:2}}>日付</div><input type="date" value={odoDate} onChange={e=>setOdoDate(e.target.value)} style={{border:"1px solid #93c5fd",borderRadius:6,padding:"4px 7px",fontSize:11}}/></div>
                  <button onClick={()=>saveOdo(v.code)} disabled={saving} style={{padding:"5px 14px",background:"#2563eb",color:"#fff",border:"none",borderRadius:7,cursor:"pointer",fontSize:11,fontWeight:700}}>{saving?"…":"保存"}</button>
                  <button onClick={()=>setOdoInputVc(null)} style={{padding:"5px 10px",background:"none",border:"1px solid #e2e8f0",borderRadius:7,cursor:"pointer",fontSize:11,color:"#64748b"}}>✕</button>
                </div>
                {prev&&<div style={{marginTop:4,fontSize:9,color:"#64748b"}}>前回: {Number(prev.odometer_km).toLocaleString()}km（{prev.completed_date}）</div>}
              </td></tr>}
              {/* OIL交換入力 */}
              {isOilOpen&&<tr style={{background:"#fff7ed"}}><td colSpan={7} style={{padding:"10px 14px"}}>
                <div style={{display:"flex",gap:8,alignItems:"flex-end",flexWrap:"wrap"}}>
                  <span style={{fontSize:11,fontWeight:700,color:"#ea580c",flexShrink:0}}>🔧 OIL交換記録</span>
                  <div><div style={{fontSize:9,color:"#64748b",fontWeight:700,marginBottom:2}}>交換時km★</div><input type="number" value={oilKm} onChange={e=>setOilKm(e.target.value)} style={{width:110,border:"1px solid #fed7aa",borderRadius:6,padding:"4px 7px",fontSize:12,fontWeight:700}} placeholder="例: 45000" autoFocus/></div>
                  <div><div style={{fontSize:9,color:"#64748b",fontWeight:700,marginBottom:2}}>交換日</div><input type="date" value={oilDate} onChange={e=>setOilDate(e.target.value)} style={{border:"1px solid #fed7aa",borderRadius:6,padding:"4px 7px",fontSize:11}}/></div>
                  <div style={{flex:1,minWidth:80}}><div style={{fontSize:9,color:"#64748b",fontWeight:700,marginBottom:2}}>メモ</div><input type="text" value={oilNote} onChange={e=>setOilNote(e.target.value)} style={{width:"100%",border:"1px solid #fed7aa",borderRadius:6,padding:"4px 7px",fontSize:11}} placeholder="5W-30等"/></div>
                  <button onClick={()=>saveOil(v.code)} disabled={saving} style={{padding:"5px 14px",background:"#ea580c",color:"#fff",border:"none",borderRadius:7,cursor:"pointer",fontSize:11,fontWeight:700}}>{saving?"…":"保存"}</button>
                  <button onClick={()=>setOilInputVc(null)} style={{padding:"5px 10px",background:"none",border:"1px solid #fed7aa",borderRadius:7,cursor:"pointer",fontSize:11,color:"#d97706"}}>✕</button>
                </div>
                <div style={{marginTop:4,fontSize:9,color:"#92400e",fontWeight:700}}>次回目安: {oilKm?`${(Number(oilKm)+OIL_INTERVAL).toLocaleString()} km（+10,000km）`:"-"}</div>
              </td></tr>}
              {/* 履歴（前回1件） */}
              {isExp&&prev&&<tr style={{background:"#fafafa"}}>
                <td colSpan={2} style={{...tdS,paddingLeft:20,color:"#94a3b8",fontSize:10}}>前回走行距離</td>
                <td style={{...tdS,textAlign:"right",color:"#64748b",fontSize:10,fontWeight:600}}>{Number(prev.odometer_km).toLocaleString()} km</td>
                <td style={{...tdS,color:"#94a3b8",fontSize:10}}>{prev.completed_date}</td>
                <td colSpan={3} style={{...tdS,color:"#94a3b8",fontSize:10}}>{prev.notes}</td>
              </tr>}
              {isExp&&oilHistory.map((r,i)=><tr key={r.id||i} style={{background:"#fff7ed"}}>
                <td colSpan={3} style={{...tdS,paddingLeft:20,color:"#92400e",fontSize:10}}>OIL履歴 {r.completed_date}</td>
                <td style={{...tdS,color:"#92400e",fontSize:10,fontWeight:600}}>@ {Number(r.odometer_km).toLocaleString()}km</td>
                <td colSpan={3} style={{...tdS,color:"#94a3b8",fontSize:10}}>{r.notes}</td>
              </tr>)}
            </React.Fragment>;
          })}
              </tbody>
            </table>
          </div>}
        </div>;
      });
    })()}
    <div style={{marginTop:8,fontSize:10,color:"#94a3b8"}}>🔧 オイル交換の実績はマスター → メンテナンスタブにも自動表示されます</div>
  </div>;
}

function FleetManager(p){
  var E=React.createElement;
  var _v=useState("list");var view=_v[0];var setView=_v[1];
  var _sel=useState(null);var selCar=_sel[0];var setSelCar=_sel[1];
  var _mi=useState("");var miIn=_mi[0];var setMiIn=_mi[1];
  var _oi=useState("");var oiIn=_oi[0];var setOiIn=_oi[1];
  var _iv=useState("");var ivIn=_iv[0];var setIvIn=_iv[1];
  var _ins=useState(null);var insIn=_ins[0];var setInsIn=_ins[1];
  var _sav=useState(false);var busy=_sav[0];var setBusy=_sav[1];
  // 整備記録入力用
  var _ld=useState(new Date().toISOString().slice(0,10));var logDate=_ld[0];var setLogDate=_ld[1];
  var _lc=useState("");var logCost=_lc[0];var setLogCost=_lc[1];
  var _ldesc=useState("");var logDesc=_ldesc[0];var setLogDesc=_ldesc[1];
  var _lcat=useState("oil");var logCat=_lcat[0];var setLogCat=_lcat[1];
  var _ledit=useState(null);var editLogId=_ledit[0];var setEditLogId=_ledit[1];
  var COST_CATS=[{v:"inspection",l:"車検"},{v:"semi_annual",l:"半年点検"},{v:"repair",l:"修理"},{v:"oil",l:"オイル交換"},{v:"other",l:"その他"}];
  var catLabel=function(v){var f=COST_CATS.filter(function(c){return c.v===v});return f.length?f[0].l:v||""}
  // 集計期間選択
  var _yr=useState(new Date().getFullYear());var filterYear=_yr[0];var setFilterYear=_yr[1];

  var cars=p.cars||[];var carData=p.carData||[];var logs=p.logs||[];
  var today=new Date().toISOString().slice(0,10);
  // 車両ステータス: 配車表の稼働フラグ（vehicles.active）を使用
  var getEffectiveStatus=function(c){
    return (c.active!==false)?"稼働中":"未稼働";
  };
  var getEffectiveStatusKey=function(c){
    return (c.active!==false)?"active":"inactive";
  };

  // ★ マウント時にhmReloadして最新データを取得（配車表からの変更を反映）
  useEffect(function(){if(p.hmReload)p.hmReload().catch(function(){});},[]);

  // 保存通知用（画面中央にポップアップ）
  var _msg=useState("");var saveMsg=_msg[0];var setSaveMsg=_msg[1];
  var showMsg=function(text,isErr){setSaveMsg(text);setTimeout(function(){setSaveMsg("")},isErr?6000:2500)};
  var save=function(fn){setBusy(true);return Promise.resolve().then(function(){return fn()}).then(function(){if(p.hmReload)return p.hmReload()}).then(function(){showMsg("登録完了",false)}).catch(function(e){console.error("HM save:",e);showMsg("保存エラー: "+String(e&&e.message||e),true)}).finally(function(){setBusy(false)})};

  // --- ヘルパー ---
  var sortDesc=function(arr){return arr.slice().sort(function(a,b){var d=(b.date||"").localeCompare(a.date||"");if(d!==0)return d;return(b.created_at||"").localeCompare(a.created_at||"")})};
  var cdFilter=function(carId,type){return(carData).filter(function(d){return d&&d.car_id===carId&&d.type===type})};
  var latestCD=function(carId,type){var items=sortDesc(cdFilter(carId,type));return items.length?items[0]:null};
  var getMileage=function(cid){var items=cdFilter(cid,"mileage");if(!items.length)return 0;var max=0;items.forEach(function(d){var km=Number(d.value||0);if(km>max)max=km;});return max};
  // オイル交換間隔は全車両共通（car_id="__global__"に保存）
  var getOilInterval=function(){var items=(carData).filter(function(d){return d&&d.car_id==="__global__"&&d.type==="oil_interval"});if(!items.length)return 5000;var sorted=sortDesc(items);return Number(sorted[0].value||0)||5000};
  var getLastOil=function(cid){return latestCD(cid,"oil_change")};
  var getNextOil=function(cid){var last=getLastOil(cid);var iv=getOilInterval();return last?Number(last.value||0)+iv:iv};
  var getInsurance=function(cid){var m=latestCD(cid,"insurance");return m?Number(m.value||0):0};
  var totalInsurance=function(){var t=0;cars.forEach(function(c){t+=getInsurance(c.id)});return t};
  var carLogs=function(cid){return(logs).filter(function(l){return l&&l.car_id===cid})};

  // 月別集計: {YYYY-MM: amount}
  var monthlyCost=function(logArr){var m={};(logArr||[]).forEach(function(l){var ym=(l.date||"").slice(0,7);if(ym){m[ym]=(m[ym]||0)+Number(l.cost||0)}});return m};
  // 年間集計
  var yearlyCost=function(logArr,yr){var t=0;(logArr||[]).forEach(function(l){if((l.date||"").slice(0,4)===String(yr)){t+=Number(l.cost||0)}});return t};

  // --- 保存処理 ---
  var saveMileage=function(){if(!selCar){showMsg("車両を選択してください",true);return;}if(!miIn){showMsg("走行距離を入力してください",true);return;}var km=Number(miIn);if(km<=0){showMsg("走行距離は1以上を入力してください",true);return;}if(!window.confirm("走行距離を"+km.toLocaleString()+"kmで記録しますか？"))return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"takamatsu",car_id:selCar.id,type:"mileage",date:today,value:km,memo:""})}).then(function(){setMiIn("")})};
  var saveOil=function(){if(!selCar){showMsg("車両を選択してください",true);return;}if(!oiIn){showMsg("走行距離を入力してください",true);return;}var km=Number(oiIn);if(km<=0){showMsg("走行距離は1以上を入力してください",true);return;}if(!window.confirm("オイル交換を"+km.toLocaleString()+"kmで記録しますか？"))return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"takamatsu",car_id:selCar.id,type:"oil_change",date:today,value:km,memo:""})}).then(function(){setOiIn("")})};
  var saveIv=function(){if(!ivIn){showMsg("交換間隔を入力してください",true);return;}var km=Number(ivIn);if(km<=0){showMsg("交換間隔は1以上を入力してください",true);return;}if(!window.confirm("オイル交換間隔を"+km.toLocaleString()+"kmに変更しますか？"))return;save(function(){return DB.hm.saveCarData({id:crypto.randomUUID(),store_id:"takamatsu",car_id:"__global__",type:"oil_interval",date:today,value:km,memo:""})}).then(function(){setIvIn("")})};
  var saveSt=function(st){if(!selCar)return;
    var labelMap2={active:"稼働中",repair:"修理中",waiting:"修理待機中",estimating:"見積中"};
    if(!window.confirm((selCar.name||"")+"のステータスを「"+(labelMap2[st]||st)+"」に変更しますか？"))return;
    var u={id:selCar.id,store_id:selCar.store_id||"takamatsu",name:selCar.name||"",plate:selCar.plate||"",class_id:selCar.class_id||"",status:st,notes:selCar.notes||""};
    setBusy(true);
    DB.hm.saveCar(u).then(async function(){
      setSelCar(u);
      showMsg("ステータス変更: "+(labelMap2[st]||st),false);
      // saveCar完了後にhmReloadでpropsのcars配列も更新（awaitで完了を待つ）
      if(p.hmReload){await p.hmReload();}
    }).catch(function(e){console.error("saveSt:",e);showMsg("保存エラー: "+String(e&&e.message||e),true);}).finally(function(){setBusy(false);});
  };
  var saveIns=function(){if(!selCar)return;var v=Number(insIn!=null?insIn:getInsurance(selCar.id));if(isNaN(v)||v<0)return;if(!window.confirm("保険料を¥"+v.toLocaleString()+"/月で保存しますか？"))return;var existing=sortDesc(cdFilter(selCar.id,"insurance"));var keepId=existing.length?existing[0].id:crypto.randomUUID();var delIds=existing.slice(1).map(function(d){return d.id});save(function(){var chain=Promise.resolve();delIds.forEach(function(did){chain=chain.then(function(){return DB.hm.deleteCarData(did)})});return chain.then(function(){return DB.hm.saveCarData({id:keepId,store_id:"takamatsu",car_id:selCar.id,type:"insurance",date:today,value:v,memo:""})})}).then(function(){setInsIn(null)});};
  var saveLog=function(){
    if(!selCar){showMsg("車両を選択してください",true);return;}
    if(!logDate){showMsg("日付を入力してください",true);return;}
    if(!logCost||Number(logCost)<=0){showMsg("金額を入力してください",true);return;}
    if(!logDesc||!logDesc.trim()){showMsg("詳細を入力してください（必須）",true);return;}
    var c=Number(logCost);var isEdit=!!editLogId;
    if(!window.confirm(isEdit?"整備記録を更新しますか？\n"+logDate+" ¥"+c.toLocaleString()+" "+logDesc:"整備記録を保存しますか？\n"+logDate+" ¥"+c.toLocaleString()+" "+logDesc))return;
    // 車検/半年点検は bt_maintenance.actual_cost にも書き込み
    var mLabel=logCat==="inspection"?"車検":logCat==="semi_annual"?"半年点検":null;
    save(function(){
      var chain=DB.hm.saveLog({id:isEdit?editLogId:crypto.randomUUID(),store_id:"takamatsu",car_id:selCar.id,date:logDate,type:logCat||"other",detail:logDesc||"",description:logDesc||"",cost:c,mileage:getMileage(selCar.id)});
      if(mLabel){
        // 同車両の同種別の最新bt_vehicle_maintenanceレコードにactual_cost書込
        var mRecs=(p.maintenance||[]).filter(function(m){return m.vehicleCode===selCar.id&&m.label===mLabel;}).sort(function(a,b){return(b.startDate||"").localeCompare(a.startDate||"");});
        if(mRecs.length>0){
          chain=chain.then(function(){
            DB.updateMaintenanceActualCost(mRecs[0].id,c);
            if(p.onMaintenanceChange){var next=(p.maintenance||[]).map(function(m){return m.id===mRecs[0].id?Object.assign({},m,{actualCost:c}):m;});p.onMaintenanceChange(next);}
          });
        }
      }
      return chain;
    }).then(function(){setLogCost("");setLogDesc("");setEditLogId(null);});
  };;
  var startEditLog=function(log){setEditLogId(log.id);setLogDate(log.date||"");setLogCost(String(log.cost||""));setLogDesc(log.detail||log.description||"");setLogCat(log.type||"other")};
  var cancelEditLog=function(){setEditLogId(null);setLogCost("");setLogDesc("");setLogDate(new Date().toISOString().slice(0,10));setLogCat("oil")};
  var delLog=function(id){if(!window.confirm("削除しますか？"))return;save(function(){return DB.hm.deleteLog(id)})};
  // 受領請求書連携ログ(id=0a1b2c3d-...)から、連携元の受領請求書の画像/PDFを開く
  var INV_LOG_PREFIX="0a1b2c3d-0000-4000-8000-";
  var isInvLog=function(id){return String(id||"").indexOf(INV_LOG_PREFIX)===0;};
  var openLinkedInvoice=function(id){
    try{
      var hex=String(id).slice(INV_LOG_PREFIX.length);var invId=parseInt(hex,16);
      if(!invId){alert("請求書IDを特定できません");return;}
      sb.from("received_invoices").select("file_url,file_name,payee").eq("id",invId).maybeSingle().then(function(res){
        if(res.error){alert("請求書の取得に失敗: "+res.error.message);return;}
        var r=res.data;
        if(!r){alert("連携元の受領請求書が見つかりません（削除済みの可能性）");return;}
        if(!r.file_url){alert("この受領請求書には画像/PDFが添付されていません（受領請求書タブで画像を登録してください）");return;}
        window.open(r.file_url,"_blank","noopener,noreferrer");
      });
    }catch(e){alert("請求書の取得に失敗: "+(e.message||e));}
  };

  // --- 共通パーツ ---
  var navBtn=function(id,label){return E("button",{key:id,onClick:function(){setView(id)},style:{padding:"6px 14px",fontSize:12,fontWeight:view===id?700:500,background:view===id?"#2563eb":"#f1f5f9",color:view===id?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},label)};
  // 通知ポップアップ（画面中央に大きく表示、全画面で常に見える）
  var isErr=saveMsg&&saveMsg.indexOf("エラー")>=0;
  var msgPopup=saveMsg?E("div",{style:{position:"fixed",top:0,left:0,right:0,bottom:0,display:"flex",alignItems:"center",justifyContent:"center",zIndex:99999,pointerEvents:"none"}},
    E("div",{style:{background:isErr?"#fee2e2":"#dcfce7",color:isErr?"#991b1b":"#15803d",border:"2px solid "+(isErr?"#f87171":"#4ade80"),borderRadius:12,padding:"20px 40px",fontSize:18,fontWeight:800,boxShadow:"0 8px 30px rgba(0,0,0,0.2)",textAlign:"center",pointerEvents:"auto"}},
      E("div",{style:{fontSize:28,marginBottom:4}},isErr?"❌":"✅"),
      saveMsg
    )
  ):null;
  var nav=E("div",{style:{display:"flex",gap:6,marginBottom:14,flexWrap:"wrap"}},navBtn("list","車両一覧"),navBtn("summary","コスト集計"));
  // クラス別アコーディオン状態（デフォルト折りたたみ）
  var _oc=useState({});var openClsFM=_oc[0];var setOpenClsFM=_oc[1];
  var toggleClsFM=function(tp){setOpenClsFM(function(p){var n=Object.assign({},p);n[tp]=!n[tp];return n;});};
  var statusBadge=function(s){var bg=s==="active"?"#f0fdf4":s==="inactive"?"#f1f5f9":s==="repair"?"#fee2e2":s==="waiting"?"#fef3c7":"#dbeafe";var fg=s==="active"?"#15803d":s==="inactive"?"#94a3b8":s==="repair"?"#991b1b":s==="waiting"?"#92400e":"#1e40af";var lb=s==="active"?"稼働中":s==="inactive"?"未稼働":s==="repair"?"修理中":s==="waiting"?"修理待機中":"見積中";return E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:bg,color:fg,fontWeight:600}},lb)};
  var section=function(bg,border,title,children){return E("div",{style:{background:bg,border:"1px solid "+border,borderRadius:8,padding:12,marginBottom:10}},E("div",{style:{fontSize:13,fontWeight:700,marginBottom:8}},title),children)};
  var card=function(bg,border,fg,val,label){return E("div",{style:{background:bg,border:"1px solid "+border,borderRadius:8,padding:14,textAlign:"center",minWidth:120}},E("div",{style:{fontSize:22,fontWeight:700,color:fg}},val),E("div",{style:{fontSize:11,color:fg,marginTop:4}},label))};

  // ========== 統合ビュー（車両一覧 + コスト集計） ==========
  if(view!=="detail"){
    var allYearly2=yearlyCost(logs,filterYear);
    var yearOpts2=[];for(var yi2=2024;yi2<=2027;yi2++){yearOpts2.push(yi2);}
    var allLogsYear2=(logs||[]).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
    var yearCatTotals2={};COST_CATS.forEach(function(c){yearCatTotals2[c.v]=0});
    allLogsYear2.forEach(function(l){yearCatTotals2[l.type||"other"]=(yearCatTotals2[l.type||"other"]||0)+Number(l.cost||0);});
    var catColor=function(v){return v==="inspection"?"#1e40af":v==="semi_annual"?"#92400e":v==="repair"?"#991b1b":v==="oil"?"#9a3412":"#475569"};
    var catBg=function(v){return v==="inspection"?"#dbeafe":v==="semi_annual"?"#fef3c7":v==="repair"?"#fee2e2":v==="oil"?"#fff7ed":"#f1f5f9"};
    // 月別集計
    var monthCatData2={};
    allLogsYear2.forEach(function(l){var ym=(l.date||"").slice(0,7);if(!ym)return;if(!monthCatData2[ym]){monthCatData2[ym]={total:0};COST_CATS.forEach(function(c){monthCatData2[ym][c.v]=0});}monthCatData2[ym].total+=Number(l.cost||0);monthCatData2[ym][l.type||"other"]=(monthCatData2[ym][l.type||"other"]||0)+Number(l.cost||0);});
    var allMonthKeys2=Object.keys(monthCatData2).sort();

    // クラス別グループ化
    var grpMap2={};var grpOrder2=[];
    cars.forEach(function(c){if(!c||!c.id)return;var tp=c.class_id||"?";if(!grpMap2[tp]){grpMap2[tp]=[];grpOrder2.push(tp);}grpMap2[tp].push(c);});

    return E("div",{style:{maxWidth:1100,margin:"0 auto"}},msgPopup,

      // KPIカード + 年度切替
      E("div",{style:{display:"flex",gap:8,marginBottom:12,flexWrap:"wrap",alignItems:"center"}},
        E("div",{style:{background:"#fee2e2",border:"1px solid #fca5a5",borderRadius:8,padding:"10px 16px",textAlign:"center",minWidth:150}},
          E("div",{style:{fontSize:10,color:"#991b1b",fontWeight:600}},"整備費 年間合計("+filterYear+")"),
          E("div",{style:{fontSize:18,fontWeight:800,color:"#991b1b"}},"¥"+allYearly2.toLocaleString())
        ),
        E("div",{style:{background:"#dbeafe",border:"1px solid #93c5fd",borderRadius:8,padding:"10px 16px",textAlign:"center",minWidth:100}},
          E("div",{style:{fontSize:10,color:"#1e40af",fontWeight:600}},"管理車両数"),
          E("div",{style:{fontSize:18,fontWeight:800,color:"#1e40af"}},cars.length+"台")
        ),
        E("div",{style:{marginLeft:"auto",display:"flex",gap:4,alignItems:"center"}},
          E("span",{style:{fontSize:11,color:"#64748b",marginRight:2}},"年度:"),
          yearOpts2.map(function(y){return E("button",{key:y,onClick:function(){setFilterYear(y);},style:{padding:"4px 10px",fontSize:11,fontWeight:filterYear===y?700:400,background:filterYear===y?"#2563eb":"#f1f5f9",color:filterYear===y?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},String(y));})
        )
      ),

      // カテゴリ別合計チップ
      E("div",{style:{display:"flex",gap:6,marginBottom:12,flexWrap:"wrap"}},
        COST_CATS.map(function(c){var v=yearCatTotals2[c.v]||0;return E("div",{key:c.v,style:{background:catBg(c.v),border:"1px solid #e2e8f0",borderRadius:6,padding:"6px 12px",textAlign:"center"}},
          E("div",{style:{fontSize:10,color:catColor(c.v),fontWeight:700}},c.l),
          E("div",{style:{fontSize:13,fontWeight:800,color:catColor(c.v)}},"¥"+v.toLocaleString())
        );})
      ),

      // クラス別アコーディオン（ステータス + コスト統合）
      E("div",{style:{display:"grid",gap:8,marginBottom:12}},
        cars.length===0
          ?E("div",{style:{textAlign:"center",color:"#94a3b8",padding:40,fontSize:13}},"BUDDICA TOURISMのcarsテーブルに車両を登録してください")
          :grpOrder2.map(function(tp){
            var grpCars=grpMap2[tp];
            var isOpen=!!openClsFM[tp];
            var grpTotal=0;var grpCt={};COST_CATS.forEach(function(c){grpCt[c.v]=0;});
            grpCars.forEach(function(c){var cl=carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear);});cl.forEach(function(l){var amt=Number(l.cost||0);grpCt[l.type||"other"]=(grpCt[l.type||"other"]||0)+amt;grpTotal+=amt;});});
            var grpCnt=grpCars.reduce(function(s,c){return s+carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear);}).length;},0);
            return E("div",{key:tp,style:{marginBottom:8}},
              // ヘッダー（クリックで展開）
              E("div",{onClick:function(){toggleClsFM(tp);},style:{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:"8px 8px 0 0",cursor:"pointer",userSelect:"none"}},
                E("span",{style:{padding:"2px 9px",background:"#2563eb",color:"#fff",borderRadius:4,fontSize:11,fontWeight:800}},tp),
                E("span",{style:{fontSize:12,fontWeight:700,color:"#374151",flex:1}},tp+"クラス"),
                E("span",{style:{fontSize:11,color:"#94a3b8"}},grpCars.length+"台"),
                E("span",{style:{fontSize:12,color:"#94a3b8"}},isOpen?"▲":"▼")
              ),
              // 小計行（常時表示）
              E("div",{style:{display:"flex",alignItems:"center",gap:0,border:"1px solid #e2e8f0",borderTop:"none",borderRadius:isOpen?"0":"0 0 8px 8px",background:"#fff",overflow:"auto"}},
                E("span",{style:{padding:"6px 12px",fontSize:11,fontWeight:800,color:"#374151",flexShrink:0,borderRight:"1px solid #f1f5f9",minWidth:70}},tp+" 小計"),
                COST_CATS.map(function(c){return grpCt[c.v]>0?E("span",{key:c.v,style:{padding:"6px 10px",fontSize:11,fontWeight:700,color:catColor(c.v),flexShrink:0,borderRight:"1px solid #f1f5f9"}},c.l+" ¥"+grpCt[c.v].toLocaleString()):null;}),
                E("span",{style:{marginLeft:"auto",padding:"6px 14px",fontSize:12,fontWeight:900,color:"#991b1b",flexShrink:0,background:grpTotal>0?"#fef2f2":"transparent"}},grpTotal>0?"¥"+grpTotal.toLocaleString():"-"),
                grpCnt>0&&E("span",{style:{padding:"6px 10px",fontSize:10,color:"#94a3b8",flexShrink:0}},grpCnt+"件")
              ),
              // 車両詳細テーブル（展開時のみ）
              isOpen&&E("div",{style:{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"auto"}},
                E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:600}},
                  E("thead",null,E("tr",{style:{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}},
                    E("th",{style:{padding:"7px 10px",textAlign:"left",fontSize:11,fontWeight:700,color:"#64748b"}},"車両"),
                    E("th",{style:{padding:"7px 10px",textAlign:"center",fontSize:10,fontWeight:700,color:"#64748b"}},"状態"),
                    COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"7px 8px",textAlign:"right",color:catColor(c.v),fontSize:10,fontWeight:700}},c.l);}),
                    E("th",{style:{padding:"7px 10px",textAlign:"right",fontSize:11,fontWeight:700,color:"#991b1b"}},"合計"),
                    E("th",{style:{padding:"7px 6px",textAlign:"center",fontSize:10,color:"#64748b"}},"件"),
                    E("th",{style:{padding:"7px 6px"}})
                  )),
                  E("tbody",null,
                    grpCars.map(function(c){
                      var cl=carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear);});
                      var ct={};COST_CATS.forEach(function(cat){ct[cat.v]=0;});var total=0;
                      cl.forEach(function(l){ct[l.type||"other"]=(ct[l.type||"other"]||0)+Number(l.cost||0);total+=Number(l.cost||0);});
                      var sk=getEffectiveStatusKey(c);
                      return E("tr",{key:c.id,style:{borderBottom:"1px solid #f1f5f9",background:"#fff",cursor:"pointer"},
                        onClick:function(){setSelCar(c);setInsIn(null);setView("detail");}},
                        E("td",{style:{padding:"8px 10px",fontWeight:600,fontSize:12}},
                          c.name||"",E("span",{style:{fontSize:10,color:"#2563eb",fontWeight:600,marginLeft:6}},c.plate||"")
                        ),
                        E("td",{style:{padding:"8px 6px",textAlign:"center"}},statusBadge(sk)),
                        COST_CATS.map(function(cat){return E("td",{key:cat.v,style:{padding:"8px 8px",textAlign:"right",color:ct[cat.v]>0?catColor(cat.v):"#e2e8f0",fontSize:11}},ct[cat.v]>0?"¥"+ct[cat.v].toLocaleString():"-");}),
                        E("td",{style:{padding:"8px 10px",textAlign:"right",fontWeight:700,color:total>0?"#991b1b":"#e2e8f0",fontSize:11}},total>0?"¥"+total.toLocaleString():"-"),
                        E("td",{style:{padding:"8px 6px",textAlign:"center",color:"#94a3b8",fontSize:10}},cl.length>0?cl.length+"件":"-"),
                        E("td",{style:{padding:"8px 8px",textAlign:"center",color:"#94a3b8",fontSize:11}},"›")
                      );
                    })
                  )
                )
              )
            );
          })
      ),

      // 全体合計バー
      allYearly2>0&&E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"10px 14px",background:"#1e293b",borderRadius:8,marginBottom:12}},
        E("span",{style:{fontSize:12,fontWeight:900,color:"#fff"}},"全車両合計 ("+filterYear+"年)"),
        E("div",{style:{display:"flex",gap:12,alignItems:"center",flexWrap:"wrap"}},
          COST_CATS.map(function(c){return yearCatTotals2[c.v]>0?E("span",{key:c.v,style:{fontSize:10,fontWeight:700,color:catBg(c.v)}},c.l+" ¥"+yearCatTotals2[c.v].toLocaleString()):null;}),
          E("span",{style:{fontSize:14,fontWeight:900,color:"#4ade80"}},"¥"+allYearly2.toLocaleString())
        )
      ),

      // 月別推移（折りたたみ）
      (function(){
        var isOpen=!!openClsFM["__monthly__"];
        return E("div",null,
          E("div",{onClick:function(){toggleClsFM("__monthly__");},style:{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:isOpen?"8px 8px 0 0":"8px",cursor:"pointer",userSelect:"none"}},
            E("span",{style:{fontSize:13,fontWeight:700,flex:1,color:"#374151"}},"📅 月別整備費（"+filterYear+"年）"),
            allMonthKeys2.length>0&&E("span",{style:{fontSize:11,color:"#94a3b8"}},"¥"+allYearly2.toLocaleString()),
            E("span",{style:{fontSize:12,color:"#94a3b8"}},isOpen?"▲":"▼")
          ),
          isOpen&&E("div",{style:{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"auto"}},
            allMonthKeys2.length>0?E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:500}},
              E("thead",null,E("tr",{style:{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}},
                E("th",{style:{padding:"7px 10px",textAlign:"left",fontSize:11,fontWeight:700,color:"#64748b"}},"月"),
                COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"7px 8px",textAlign:"right",color:catColor(c.v),fontSize:10,fontWeight:700}},c.l);}),
                E("th",{style:{padding:"7px 10px",textAlign:"right",fontSize:11,fontWeight:700,color:"#991b1b"}},"月合計")
              )),
              E("tbody",null,
                allMonthKeys2.map(function(ym){var md=monthCatData2[ym];return E("tr",{key:ym,style:{borderBottom:"1px solid #f1f5f9",background:"#fff"}},
                  E("td",{style:{padding:"7px 10px",fontWeight:700,fontSize:11}},ym),
                  COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"7px 8px",textAlign:"right",color:(md[c.v]||0)>0?catColor(c.v):"#e2e8f0"}},(md[c.v]||0)>0?"¥"+(md[c.v]).toLocaleString():"-");}),
                  E("td",{style:{padding:"7px 10px",textAlign:"right",fontWeight:700,color:"#991b1b"}},"¥"+(md.total||0).toLocaleString())
                );}),
                E("tr",{style:{borderTop:"2px solid #e2e8f0",background:"#1e293b",fontWeight:700}},
                  E("td",{style:{padding:"8px 10px",fontSize:11,color:"#fff"}},"年間合計"),
                  COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"8px 8px",textAlign:"right",color:yearCatTotals2[c.v]>0?catBg(c.v):"#475569",fontWeight:700}},yearCatTotals2[c.v]>0?"¥"+yearCatTotals2[c.v].toLocaleString():"-");}),
                  E("td",{style:{padding:"8px 10px",textAlign:"right",fontSize:13,fontWeight:900,color:"#4ade80"}},"¥"+allYearly2.toLocaleString())
                )
              )
            ):E("div",{style:{textAlign:"center",color:"#94a3b8",padding:20,fontSize:12}},"まだ整備記録がありません")
          )
        );
      })()
    );
  }

  // ========== 車両詳細 ==========
  if(view==="detail"&&selCar){
    var cid=selCar.id;
    var milHist=sortDesc(cdFilter(cid,"mileage"));
    var oilHist=sortDesc(cdFilter(cid,"oil_change"));
    var insHist=sortDesc(cdFilter(cid,"insurance"));
    var myLogs=sortDesc(carLogs(cid));
    var myMonthly=monthlyCost(carLogs(cid));
    var myYearly=yearlyCost(carLogs(cid),filterYear);
    var monthKeys=Object.keys(myMonthly).sort().reverse();
    var curMileage=getMileage(cid);
    var curIns=getInsurance(cid);
    var lastOil=getLastOil(cid);

    // 種別ごとの小計
    var catTotals={};COST_CATS.forEach(function(c){catTotals[c.v]=0});
    myLogs.forEach(function(l){if((l.date||"").slice(0,4)===String(filterYear)){catTotals[l.type||"other"]=(catTotals[l.type||"other"]||0)+Number(l.cost||0)}});

    // セクションヘッダー共通
    var secHead=function(emoji,title,badge){return E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}},E("div",{style:{fontSize:13,fontWeight:700}},emoji+" "+title),badge||null)};
    // 小テーブルヘッダー
    var tblHead=function(cols){return E("thead",null,E("tr",{style:{background:"#f1f5f9",borderBottom:"2px solid #cbd5e1"}},cols.map(function(c,i){return E("th",{key:i,style:{padding:"5px 8px",fontSize:11,fontWeight:600,textAlign:c.align||"left",color:"#475569"}},c.label)})))};

    return E("div",{style:{maxWidth:800,margin:"0 auto"}},msgPopup,
      // ヘッダー
      E("div",{style:{background:"white",border:"1px solid #e2e8f0",borderRadius:10,padding:14,marginBottom:14,display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}},
        E("button",{onClick:function(){setView("list")},className:"btn-ghost",style:{padding:"5px 12px",fontSize:12}},"← 一覧へ"),
        E("div",{style:{flex:1}},
          E("div",{style:{display:"flex",alignItems:"center",gap:8}},
            E("span",{style:{fontSize:18,fontWeight:800}},selCar.name||""),
            E("span",{style:{fontSize:13,color:"#64748b"}},selCar.plate||""),
            statusBadge(getEffectiveStatusKey(selCar))
          ),
          E("div",{style:{display:"flex",gap:16,fontSize:11,color:"#64748b",marginTop:4}},
            E("span",null,"整備費("+filterYear+"): ¥"+myYearly.toLocaleString())
          )
        )
      ),

      // 整備記録（実費入力はここから）
      E("div",{style:{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:8,padding:12,marginBottom:10}},
        secHead("⑤","整備記録",E("span",{style:{fontSize:14,fontWeight:800,color:"#991b1b"}},"年間("+filterYear+"): ¥"+myYearly.toLocaleString())),
        E("div",{style:{fontSize:11,color:"#991b1b",marginBottom:6}},"1項目ごとに 種別・日付・金額・詳細 を入力（複数回登録可）"),
        E("div",{style:{display:"grid",gridTemplateColumns:"110px 120px 110px 1fr",gap:6,marginBottom:8}},
          E("select",{value:logCat,onChange:function(e){setLogCat(e.target.value)},className:"input-s"},
            COST_CATS.map(function(c){return E("option",{key:c.v,value:c.v},c.l)})
          ),
          E("input",{type:"date",value:logDate,onChange:function(e){setLogDate(e.target.value)},className:"input-s"}),
          E("input",{type:"number",value:logCost,onChange:function(e){setLogCost(e.target.value)},placeholder:"金額（円）",className:"input-s"}),
          E("input",{value:logDesc,onChange:function(e){setLogDesc(e.target.value)},placeholder:"詳細（必須）",className:"input-s"})
        ),
        E("button",{onClick:saveLog,className:"btn-primary",disabled:busy||!logDesc.trim(),style:{background:editLogId?"#e65100":"#2563eb"}},editLogId?"整備記録を更新":"整備記録を追加"),
        editLogId&&E("button",{onClick:cancelEditLog,style:{padding:"6px 14px",fontSize:12,background:"#78909c",color:"#fff",border:"none",borderRadius:6,cursor:"pointer",marginLeft:4}},"キャンセル"),

        // 種別ごとの年間小計
        E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(90px,1fr))",gap:4,marginTop:12,marginBottom:8}},
          COST_CATS.map(function(c){return E("div",{key:c.v,style:{background:"#fff",border:"1px solid #fecaca",borderRadius:4,padding:6,textAlign:"center"}},
            E("div",{style:{fontSize:10,color:"#64748b"}},c.l),
            E("div",{style:{fontSize:12,fontWeight:700,color:catTotals[c.v]>0?"#991b1b":"#cbd5e1"}},"¥"+(catTotals[c.v]||0).toLocaleString())
          )})
        ),

        // 月別集計
        monthKeys.length>0?E("div",{style:{marginTop:8,marginBottom:12}},
          E("div",{style:{fontSize:11,fontWeight:600,color:"#991b1b",marginBottom:4}},"月別集計"),
          E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(90px,1fr))",gap:4}},
            monthKeys.map(function(ym){return E("div",{key:ym,style:{background:"#fff",border:"1px solid #e2e8f0",borderRadius:4,padding:6,textAlign:"center",fontSize:11}},
              E("div",{style:{color:"#64748b"}},ym),E("div",{style:{fontWeight:700}},"¥"+myMonthly[ym].toLocaleString())
            )})
          )
        ):null,

        // 履歴一覧
        myLogs.length>0?E("div",{style:{marginTop:8}},
          E("div",{style:{fontSize:11,fontWeight:600,color:"#991b1b",marginBottom:4}},"整備履歴（"+myLogs.length+"件）"),
          E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,background:"#fff",borderRadius:4}},
            tblHead([{label:"日付"},{label:"種別"},{label:"金額",align:"right"},{label:"詳細"},{label:"",align:"right"}]),
            E("tbody",null,myLogs.map(function(l,i){return E("tr",{key:l.id||i,style:{borderBottom:"1px solid #f1f5f9"}},
              E("td",{style:{padding:"5px 8px"}},l.date||""),
              E("td",{style:{padding:"5px 8px"}},E("span",{style:{fontSize:10,padding:"2px 8px",borderRadius:4,background:l.type==="inspection"?"#dbeafe":l.type==="repair"?"#fee2e2":l.type==="semi_annual"?"#fef3c7":l.type==="oil"?"#fff7ed":"#f1f5f9",color:l.type==="inspection"?"#1e40af":l.type==="repair"?"#991b1b":l.type==="semi_annual"?"#92400e":l.type==="oil"?"#9a3412":"#475569",fontWeight:600}},catLabel(l.type))),
              E("td",{style:{padding:"5px 8px",textAlign:"right",fontWeight:700}},"¥"+Number(l.cost||0).toLocaleString()),
              E("td",{style:{padding:"5px 8px",color:"#475569",maxWidth:200,overflow:"hidden",textOverflow:"ellipsis"}},l.detail||l.description||"",isInvLog(l.id)?E("span",{style:{marginLeft:6,fontSize:9,fontWeight:700,color:"#1a56db",background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:4,padding:"1px 5px",whiteSpace:"nowrap"}},"📥連携"):null),
              E("td",{style:{padding:"5px 8px",textAlign:"right",whiteSpace:"nowrap"}},
                isInvLog(l.id)?E("button",{onClick:function(){openLinkedInvoice(l.id)},style:{fontSize:10,color:"#1a56db",background:"#eff6ff",border:"1px solid #93c5fd",borderRadius:5,cursor:"pointer",padding:"2px 7px",marginRight:6,fontWeight:700}},"📄 請求書"):null,
                E("button",{onClick:function(){startEditLog(l)},style:{fontSize:10,color:"#2563eb",background:"none",border:"none",cursor:"pointer",marginRight:6}},"編集"),
                E("button",{onClick:function(){delLog(l.id)},style:{fontSize:10,color:"#dc2626",background:"none",border:"none",cursor:"pointer"}},"削除")
              )
            )}))
          )
        ):E("div",{style:{fontSize:11,color:"#94a3b8",padding:12,textAlign:"center"}},"まだ整備記録がありません。上のフォームから追加してください。")
      )
    );
  }

  // ========== コスト集計（統合ビューに移動済み）==========
  if(false&&view==="summary"){
    var yearOpts=[];for(var yi=2024;yi<=2027;yi++){yearOpts.push(yi)}
    var allLogsYear=(logs||[]).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
    var allYearly=yearlyCost(logs,filterYear);

    // カテゴリ別年間集計
    var yearCatTotals={};COST_CATS.forEach(function(c){yearCatTotals[c.v]=0});
    allLogsYear.forEach(function(l){yearCatTotals[l.type||"other"]=(yearCatTotals[l.type||"other"]||0)+Number(l.cost||0)});

    // 月別＋カテゴリ別集計 {YYYY-MM: {total:N, inspection:N, repair:N, ...}}
    var monthCatData={};
    allLogsYear.forEach(function(l){
      var ym=(l.date||"").slice(0,7);if(!ym)return;
      if(!monthCatData[ym]){monthCatData[ym]={total:0};COST_CATS.forEach(function(c){monthCatData[ym][c.v]=0})}
      monthCatData[ym].total+=Number(l.cost||0);
      monthCatData[ym][l.type||"other"]=(monthCatData[ym][l.type||"other"]||0)+Number(l.cost||0);
    });
    var allMonthKeys=Object.keys(monthCatData).sort();

    // カテゴリ色
    var catColor=function(v){return v==="inspection"?"#1e40af":v==="semi_annual"?"#92400e":v==="repair"?"#991b1b":v==="oil"?"#9a3412":"#475569"};
    var catBg=function(v){return v==="inspection"?"#dbeafe":v==="semi_annual"?"#fef3c7":v==="repair"?"#fee2e2":v==="oil"?"#fff7ed":"#f1f5f9"};

    return E("div",{style:{maxWidth:1100,margin:"0 auto"}},msgPopup,nav,

      // 年度切替
      E("div",{style:{display:"flex",gap:8,alignItems:"center",marginBottom:14}},
        E("span",{style:{fontSize:12,fontWeight:600}},"年度:"),
        yearOpts.map(function(y){return E("button",{key:y,onClick:function(){setFilterYear(y)},style:{padding:"5px 14px",fontSize:12,fontWeight:filterYear===y?700:400,background:filterYear===y?"#2563eb":"#f1f5f9",color:filterYear===y?"#fff":"#64748b",border:"none",borderRadius:6,cursor:"pointer"}},String(y))})
      ),

      // サマリーカード（上段）
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:10,marginBottom:10}},
        card("#fee2e2","#fca5a5","#991b1b","¥"+allYearly.toLocaleString(),"整備 年間合計("+filterYear+")"),
        card("#dbeafe","#93c5fd","#1e40af",cars.length+"台","管理車両数")
      ),

      // カテゴリ別年間サマリー
      E("div",{style:{display:"grid",gridTemplateColumns:"repeat("+COST_CATS.length+",1fr)",gap:6,marginBottom:14}},
        COST_CATS.map(function(c){return E("div",{key:c.v,style:{background:catBg(c.v),border:"1px solid #e2e8f0",borderRadius:6,padding:8,textAlign:"center"}},
          E("div",{style:{fontSize:10,color:catColor(c.v),fontWeight:600}},c.l),
          E("div",{style:{fontSize:15,fontWeight:800,color:catColor(c.v)}},"¥"+(yearCatTotals[c.v]||0).toLocaleString())
        )})
      ),

      // 整備費内訳（クラス別アコーディオン）
      (function(){
        var grpMap={};var grpOrder=[];
        cars.forEach(function(c){if(!c||!c.id)return;var tp=c.class_id||"?";if(!grpMap[tp]){grpMap[tp]=[];grpOrder.push(tp);}grpMap[tp].push(c);});
        var thead=E("thead",null,E("tr",{style:{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}},
          E("th",{style:{padding:"7px 10px",textAlign:"left",fontSize:11,fontWeight:700,color:"#64748b"}},"車両"),
          COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"7px 10px",textAlign:"right",color:catColor(c.v),fontSize:10,fontWeight:700}},c.l)}),
          E("th",{style:{padding:"7px 10px",textAlign:"right",fontSize:11,fontWeight:700,color:"#991b1b"}},"合計"),
          E("th",{style:{padding:"7px 10px",textAlign:"right",fontSize:10,color:"#64748b"}},"件数")
        ));
        return E("div",{style:{marginBottom:12}},
          grpOrder.map(function(tp){
            var grpCars=grpMap[tp];
            var isOpen=!!openClsFM[tp];
            var grpTotal=0;var grpCt={};COST_CATS.forEach(function(c){grpCt[c.v]=0});
            grpCars.forEach(function(c){
              var cl=carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
              cl.forEach(function(l){var amt=Number(l.cost||0);grpCt[l.type||"other"]=(grpCt[l.type||"other"]||0)+amt;grpTotal+=amt;});
            });
            return E("div",{key:tp,style:{marginBottom:8}},
              // アコーディオンヘッダー
              E("div",{onClick:function(){toggleClsFM(tp);},style:{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:isOpen?"8px 8px 0 0":"8px",cursor:"pointer",userSelect:"none"}},
                E("span",{style:{padding:"2px 9px",background:"#2563eb",color:"#fff",borderRadius:4,fontSize:11,fontWeight:800}},tp),
                E("span",{style:{fontSize:12,fontWeight:700,color:"#374151",flex:1}},tp+"クラス"),
                E("span",{style:{fontSize:11,color:"#94a3b8"}},grpCars.length+"台"),
                grpTotal>0&&E("span",{style:{fontSize:11,fontWeight:800,color:"#991b1b"}},"¥"+grpTotal.toLocaleString()),
                E("span",{style:{fontSize:12,color:"#94a3b8"}},isOpen?"▲":"▼")
              ),
              // 展開時テーブル
              isOpen&&E("div",{style:{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"auto"}},
                E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:500}},
                  thead,
                  E("tbody",null,
                    grpCars.map(function(c){
                      var cl=carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)});
                      var ct={};COST_CATS.forEach(function(cat){ct[cat.v]=0});var total=0;
                      cl.forEach(function(l){ct[l.type||"other"]=(ct[l.type||"other"]||0)+Number(l.cost||0);total+=Number(l.cost||0);});
                      return E("tr",{key:c.id,style:{borderBottom:"1px solid #f1f5f9",background:"#fff"}},
                        E("td",{style:{padding:"7px 10px",fontWeight:600,fontSize:11}},c.name||"",E("span",{style:{fontSize:10,color:"#2563eb",fontWeight:600,marginLeft:6}},c.plate||"")),
                        COST_CATS.map(function(cat){return E("td",{key:cat.v,style:{padding:"7px 10px",textAlign:"right",color:ct[cat.v]>0?catColor(cat.v):"#e2e8f0",fontSize:11}},ct[cat.v]>0?"¥"+ct[cat.v].toLocaleString():"-")}),
                        E("td",{style:{padding:"7px 10px",textAlign:"right",fontWeight:700,fontSize:11,color:total>0?"#991b1b":"#e2e8f0"}},total>0?"¥"+total.toLocaleString():"-"),
                        E("td",{style:{padding:"7px 10px",textAlign:"right",color:"#94a3b8",fontSize:10}},cl.length+"件")
                      );
                    }),
                    // クラス小計行
                    E("tr",{style:{borderTop:"2px solid #e2e8f0",background:"#f8fafc",fontWeight:700}},
                      E("td",{style:{padding:"7px 10px",fontSize:11,fontWeight:800,color:"#374151"}},tp+"クラス 小計"),
                      COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"7px 10px",textAlign:"right",color:grpCt[c.v]>0?catColor(c.v):"#e2e8f0",fontWeight:700}},grpCt[c.v]>0?"¥"+grpCt[c.v].toLocaleString():"-")}),
                      E("td",{style:{padding:"7px 10px",textAlign:"right",fontWeight:800,color:"#991b1b"}},"¥"+grpTotal.toLocaleString()),
                      E("td",{style:{padding:"7px 10px",textAlign:"right",color:"#64748b",fontSize:10}},grpCars.reduce(function(s,c){return s+carLogs(c.id).filter(function(l){return(l.date||"").slice(0,4)===String(filterYear)}).length;},0)+"件")
                    )
                  )
                )
              )
            );
          }),
          // 全体合計行
          E("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"10px 14px",background:"#1e293b",borderRadius:8,marginTop:4}},
            E("span",{style:{fontSize:12,fontWeight:900,color:"#fff"}},"全車両合計 ("+filterYear+"年)"),
            E("div",{style:{display:"flex",gap:16,alignItems:"center"}},
              COST_CATS.map(function(c){return yearCatTotals[c.v]>0?E("span",{key:c.v,style:{fontSize:10,fontWeight:700,color:catBg(c.v)}},c.l+" ¥"+(yearCatTotals[c.v]||0).toLocaleString()):null;}),
              E("span",{style:{fontSize:14,fontWeight:900,color:"#4ade80"}},"¥"+allYearly.toLocaleString())
            )
          )
        );
      })(),

      // 月別推移（折りたたみ）
      (function(){
        var isOpen=!!openClsFM["__monthly__"];
        return E("div",{style:{marginBottom:12}},
          E("div",{onClick:function(){toggleClsFM("__monthly__");},style:{display:"flex",alignItems:"center",gap:8,padding:"10px 14px",background:"#f8fafc",border:"1px solid #e2e8f0",borderRadius:isOpen?"8px 8px 0 0":"8px",cursor:"pointer",userSelect:"none"}},
            E("span",{style:{fontSize:13,fontWeight:700,flex:1,color:"#374151"}},"📅 月別整備費（"+filterYear+"年）"),
            allMonthKeys.length>0&&E("span",{style:{fontSize:11,color:"#94a3b8"}},"¥"+allYearly.toLocaleString()),
            E("span",{style:{fontSize:12,color:"#94a3b8"}},isOpen?"▲":"▼")
          ),
          isOpen&&E("div",{style:{border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px",overflow:"auto"}},
            allMonthKeys.length>0?E("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:500}},
              E("thead",null,E("tr",{style:{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}},
                E("th",{style:{padding:"7px 10px",textAlign:"left",fontSize:11,fontWeight:700,color:"#64748b"}},"月"),
                COST_CATS.map(function(c){return E("th",{key:c.v,style:{padding:"7px 10px",textAlign:"right",color:catColor(c.v),fontSize:10,fontWeight:700}},c.l)}),
                E("th",{style:{padding:"7px 10px",textAlign:"right",fontSize:11,fontWeight:700,color:"#991b1b"}},"月合計")
              )),
              E("tbody",null,
                allMonthKeys.map(function(ym){
                  var md=monthCatData[ym];
                  return E("tr",{key:ym,style:{borderBottom:"1px solid #f1f5f9",background:"#fff"}},
                    E("td",{style:{padding:"7px 10px",fontWeight:700,fontSize:11}},ym),
                    COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"7px 10px",textAlign:"right",color:(md[c.v]||0)>0?catColor(c.v):"#e2e8f0"}},(md[c.v]||0)>0?"¥"+(md[c.v]).toLocaleString():"-")}),
                    E("td",{style:{padding:"7px 10px",textAlign:"right",fontWeight:700,color:"#991b1b"}},"¥"+(md.total||0).toLocaleString())
                  );
                }),
                E("tr",{style:{borderTop:"2px solid #e2e8f0",background:"#1e293b",fontWeight:700}},
                  E("td",{style:{padding:"8px 10px",fontSize:11,color:"#fff"}},"年間合計"),
                  COST_CATS.map(function(c){return E("td",{key:c.v,style:{padding:"8px 10px",textAlign:"right",color:yearCatTotals[c.v]>0?catBg(c.v):"#475569",fontWeight:700}},yearCatTotals[c.v]>0?"¥"+(yearCatTotals[c.v]||0).toLocaleString():"-")}),
                  E("td",{style:{padding:"8px 10px",textAlign:"right",fontSize:13,fontWeight:900,color:"#4ade80"}},"¥"+allYearly.toLocaleString())
                )
              )
            ):E("div",{style:{textAlign:"center",color:"#94a3b8",padding:20,fontSize:12}},"まだ整備記録がありません")
          )
        );
      })()
    );
  }

  return null;
}

/* ==========================================
   経営管理タブ (2026-04-17 追加)
   売上入力 / PL / CF / ダッシュボード / コスト入力
   - sales_entries を Excel「売上入力」の代わりに直接編集
   - PL/CF は reservations から直接計算（入金サイクルは設定タブ参照）
   ========================================== */

/* ===== 車両別稼働率・売上・粗利テーブル ===== */
function VehicleProfitTable({u,nowYm,vehicleCosts,dbVehs}){
  const[sortKey,setSortKey]=useState("profit");
  const[openCls,setOpenCls]=useState({});
  const toggleCls=(tp)=>setOpenCls(p=>({...p,[tp]:p[tp]===false?true:false}));
  const isOpen=(tp)=>openCls[tp]!==false; // デフォルト開く
  if(!u)return React.createElement("div",{style:{fontSize:12,color:"#94a3b8",padding:8}},"データなし");
  const CLS_C={A:"#7c3aed",B:"#0284c7",C:"#059669",D:"#374151",F:"#db2877",H:"#64748b",S:"#d97706"};
  // 原価内訳: 旧vehicleCosts → なければbt_vehiclesの新フィールドを使用
  const getCostBreakdown=(code)=>{
    const c=vehicleCosts[code];
    if(c&&(c.monthlyFee||c.insuranceAnnual||c.shakenAnnual||c.inspection6m)){
      return{ins:0,lease:c.monthlyFee||0,tax:Math.round((c.insuranceAnnual||0)/12),shk:Math.round((c.shakenAnnual||0)/12),tnk:Math.round((c.inspection6m||0)*2/12)};
    }
    const veh=(dbVehs||[]).find(v=>(v.code||v.id)===code);
    if(!veh)return{ins:0,lease:0,tax:0,shk:0,tnk:0};
    return{
      ins:Number(veh.insurance_annual||0),
      lease:Number(veh.lease_monthly||0),
      tax:Math.round(Number(veh.car_tax||0)/12),
      shk:Math.round(Number(veh.shaken_cost||0)/12),
      tnk:Math.round(Number(veh.tenken_cost||0)/6)
    };
  };
  const classOrder=["AA","A","B","C","S","H","F"];
  const grouped={};
  Object.entries(u.perVeh).forEach(([code,d])=>{
    const tp=d.type||"?";if(!grouped[tp])grouped[tp]=[];
    const cb=getCostBreakdown(code);
    const cost=cb.ins+cb.lease+cb.tax+cb.shk+cb.tnk;
    const profit=d.rev-cost;const profitRate=d.rev>0?Math.round(profit/d.rev*100):0;
    grouped[tp].push({code,name:d.name,type:tp,days:d.days,pct:d.pct,rev:d.rev,cb,cost,profit,profitRate});
  });
  const sortFn=(a,b)=>sortKey==="util"?b.pct-a.pct:sortKey==="rev"?b.rev-a.rev:b.profit-a.profit;
  // 旧vehicleCosts OR 新bt_vehicles原価のどちらかがあればhasCost=true
  const hasCost=Object.values(vehicleCosts).length>0||(dbVehs||[]).some(v=>Number(v.insurance_annual||0)>0||Number(v.lease_monthly||0)>0||Number(v.car_tax||0)>0);
  const fmtY=(v)=>{if(v===0)return"¥0";const a=Math.abs(v);const s=a>=10000?(Math.round(a/1000)/10).toFixed(1)+"万":a.toLocaleString();return(v<0?"▲":"")+s;};
  const sortBtn=(k,l)=>React.createElement("button",{onClick:()=>setSortKey(k),style:{padding:"3px 8px",fontSize:10,fontWeight:700,border:"none",borderRadius:4,cursor:"pointer",background:sortKey===k?"#2563eb":"#f1f5f9",color:sortKey===k?"#fff":"#64748b"}},l);
  const thS={fontSize:10,fontWeight:700,padding:"5px 8px",background:"#f8fafc",color:"#64748b",borderBottom:"2px solid #e2e8f0",whiteSpace:"nowrap"};
  const tdS=(align="left")=>({fontSize:11,padding:"5px 8px",borderBottom:"1px solid #f1f5f9",textAlign:align,whiteSpace:"nowrap"});
  const visibleCls=classOrder.filter(tp=>grouped[tp]?.length);
  const allOpen=visibleCls.every(tp=>isOpen(tp));
  return React.createElement("div",null,
    React.createElement("div",{style:{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12,flexWrap:"wrap",gap:8}},
      React.createElement("div",{style:{fontSize:13,fontWeight:900,color:"#1e3a5f"}},"車両別 稼働率・売上・粗利（"+nowYm+"）"),
      React.createElement("div",{style:{display:"flex",gap:4,alignItems:"center",flexWrap:"wrap"}},
        React.createElement("button",{onClick:()=>{const next={};visibleCls.forEach(tp=>{next[tp]=!allOpen;});setOpenCls(next);},style:{padding:"3px 8px",fontSize:10,fontWeight:700,border:"1px solid #e2e8f0",borderRadius:4,cursor:"pointer",background:"#f8fafc",color:"#64748b",marginRight:6}},allOpen?"▲ 全て閉じる":"▼ 全て開く"),
        React.createElement("span",{style:{fontSize:10,color:"#94a3b8",marginRight:2}},"並び替え:"),
        sortBtn("profit","粗利"),sortBtn("rev","売上"),sortBtn("util","稼働率")
      )
    ),
    !hasCost&&React.createElement("div",{style:{padding:"8px 12px",background:"#fffbeb",border:"1px solid #fde68a",borderRadius:8,fontSize:11,color:"#92400e",marginBottom:12}},"⚠️ 車両原価が未設定です。車両タブ → 「原価」から設定してください。"),
    visibleCls.map(tp=>{
      const items=[...grouped[tp]].sort(sortFn);
      const totalRev=items.reduce((s,v)=>s+v.rev,0);
      const totalCost=items.reduce((s,v)=>s+v.cost,0);
      const totalProfit=totalRev-totalCost;
      const avgUtil=items.length?Math.round(items.reduce((s,v)=>s+v.pct,0)/items.length):0;
      const cc=CLS_C[tp]||"#64748b";
      const open=isOpen(tp);
      return React.createElement("div",{key:tp,style:{marginBottom:10}},
        // クラスヘッダー（クリックで折りたたみ）
        React.createElement("div",{onClick:()=>toggleCls(tp),style:{display:"flex",alignItems:"center",gap:8,padding:"7px 12px",background:cc+"18",borderRadius:open?"8px 8px 0 0":"8px",borderTop:`3px solid ${cc}`,border:`1px solid ${cc}33`,borderTopColor:cc,cursor:"pointer",flexWrap:"wrap",userSelect:"none"}},
          React.createElement("span",{style:{fontSize:12,color:cc,fontWeight:900,minWidth:16}},open?"▼":"▶"),
          React.createElement("span",{style:{fontWeight:900,fontSize:12,color:cc}},"["+tp+"] "+items.length+"台"),
          React.createElement("span",{style:{fontSize:11,color:"#64748b"}},"平均稼働 "+avgUtil+"%"),
          hasCost&&React.createElement("span",{style:{fontSize:11,color:"#0f172a",fontWeight:700,marginLeft:4}},
            "売上 "+fmtY(totalRev)+" / 粗利 ",
            React.createElement("span",{style:{color:totalProfit>=0?"#059669":"#dc2626",fontWeight:900}},fmtY(totalProfit))
          ),
          React.createElement("span",{style:{marginLeft:"auto",fontSize:10,color:"#94a3b8"}},open?"閉じる":"開く")
        ),
        // テーブル（開閉）
        open&&React.createElement("div",{style:{overflowX:"auto",border:"1px solid "+cc+"33",borderTop:"none",borderRadius:"0 0 8px 8px"}},
          React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
            React.createElement("thead",null,React.createElement("tr",null,
              React.createElement("th",{style:thS},"車両"),
              React.createElement("th",{style:{...thS,textAlign:"right"}},"稼働日"),
              React.createElement("th",{style:{...thS,textAlign:"right",minWidth:90}},"稼働率"),
              React.createElement("th",{style:{...thS,textAlign:"right"}},"売上"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",color:"#059669",background:"#f0fdf4"}},"保険"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",color:"#6366f1",background:"#eef2ff"}},"リース"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",color:"#d97706",background:"#fffbeb"}},"税金"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",color:"#2563eb",background:"#eff6ff"}},"車検"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",color:"#059669",background:"#f0fdf4"}},"点検"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",color:"#374151",borderLeft:"2px solid #e2e8f0"}},"合計原価"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right",background:"#fef3c7"}},"粗利"),
              hasCost&&React.createElement("th",{style:{...thS,textAlign:"right"}},"粗利率")
            )),
            React.createElement("tbody",null,
              items.map((v,i)=>{
                const rc=v.pct>=60?"#059669":v.pct>=40?"#d97706":"#dc2626";
                const pc=v.profit>=0?"#059669":"#dc2626";
                const cv=(n)=>n>0?"¥"+n.toLocaleString():"-";
                return React.createElement("tr",{key:v.code,style:{background:i%2===0?"#fff":"#f8fafc"}},
                  React.createElement("td",{style:{...tdS(),fontWeight:700}},
                    React.createElement("span",{style:{width:8,height:8,borderRadius:"50%",background:cc,display:"inline-block",marginRight:5}}),
                    v.name
                  ),
                  React.createElement("td",{style:tdS("right")},v.days+"日"),
                  React.createElement("td",{style:tdS("right")},
                    React.createElement("div",{style:{display:"flex",alignItems:"center",gap:4,justifyContent:"flex-end"}},
                      React.createElement("div",{style:{width:40,height:6,background:"#e2e8f0",borderRadius:3,overflow:"hidden"}},
                        React.createElement("div",{style:{height:"100%",width:v.pct+"%",background:rc,borderRadius:3}})
                      ),
                      React.createElement("span",{style:{fontWeight:700,color:rc,fontSize:11}},(v.pct||0).toFixed(1)+"%")
                    )
                  ),
                  React.createElement("td",{style:{...tdS("right"),fontWeight:600}},v.rev>0?"¥"+v.rev.toLocaleString():"-"),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),color:"#059669",fontSize:10}},cv(v.cb.ins)),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),color:"#6366f1",fontSize:10}},cv(v.cb.lease)),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),color:"#d97706",fontSize:10}},cv(v.cb.tax)),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),color:"#2563eb",fontSize:10}},cv(v.cb.shk)),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),color:"#059669",fontSize:10}},cv(v.cb.tnk)),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),fontWeight:700,color:v.cost>0?"#374151":"#cbd5e1",borderLeft:"2px solid #e2e8f0"}},v.cost>0?"¥"+v.cost.toLocaleString():"-"),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),fontWeight:800,color:pc,background:"#fffbeb"}},v.rev>0?fmtY(v.profit):"-"),
                  hasCost&&React.createElement("td",{style:{...tdS("right"),color:v.profitRate>=50?"#059669":v.profitRate>=0?"#d97706":"#dc2626",fontWeight:700}},v.rev>0?v.profitRate+"%":"-")
                );
              })
            )
          )
        )
      );
    })
  );
}

/* ===== クラス別売上カード ===== */
function ClsRevCard({u,nowYm}){
  if(!u)return null;
  const CLS_C={AA:"#facc15",A:"#dc2626",B:"#2563eb",C:"#16a34a",S:"#ea580c",H:"#475569",F:"#7c3aed"};
  const classOrder=["AA","A","B","C","S","H","F"];
  const clsMap={};
  Object.values(u.perVeh).forEach(d=>{
    const t=d.type||"?";
    if(!clsMap[t])clsMap[t]={rev:0,count:0,days:0,maxDays:0};
    clsMap[t].rev+=d.rev;clsMap[t].count++;clsMap[t].days+=d.days;clsMap[t].maxDays+=(d.maxDays!=null?d.maxDays:u.dim);
  });
  const entries=classOrder.filter(t=>clsMap[t]);
  if(!entries.length)return null;
  const maxRev=Math.max(1,...entries.map(t=>clsMap[t].rev));
  const totalRev=entries.reduce((s,t)=>s+clsMap[t].rev,0);
  const fmtRev=(v)=>{if(v===0)return"-";if(v>=10000)return Math.round(v/10000)+"万";return"¥"+v.toLocaleString();};
  return React.createElement("div",null,
    React.createElement("div",{style:{fontSize:13,fontWeight:900,color:"#1e3a5f",marginBottom:10}},"クラス別売上（"+nowYm+"）"),
    React.createElement("div",{style:{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(130px,1fr))",gap:8}},
      entries.map(t=>{
        const d=clsMap[t];
        const cc=CLS_C[t]||"#64748b";
        const pct=totalRev>0?Math.round(d.rev/totalRev*100):0;
        const perV=d.count>0?Math.round(d.rev/d.count):0;
        const barW=Math.round(d.rev/maxRev*100);
        const util=d.maxDays>0?Math.round(d.days/d.maxDays*100):0;
        const utilC=util>=50?"#059669":util>=30?"#d97706":"#dc2626";
        return React.createElement("div",{key:t,style:{background:"#fff",border:`1px solid ${cc}33`,borderTop:`3px solid ${cc}`,borderRadius:10,padding:"10px 12px"}},
          React.createElement("div",{style:{display:"flex",alignItems:"center",gap:6,marginBottom:8}},
            React.createElement("span",{style:{width:26,height:26,borderRadius:8,background:cc+"18",color:cc,fontWeight:900,fontSize:13,display:"flex",alignItems:"center",justifyContent:"center"}},t),
            React.createElement("span",{style:{fontSize:10,color:"#64748b"}},d.count+"台")
          ),
          React.createElement("div",{style:{fontSize:15,fontWeight:900,color:"#1e293b",marginBottom:2}},fmtRev(d.rev)),
          React.createElement("div",{style:{fontSize:9,color:"#94a3b8",marginBottom:5}},pct+"% | 1台 "+fmtRev(perV)),
          React.createElement("div",{style:{height:4,background:"#f1f5f9",borderRadius:2,overflow:"hidden",marginBottom:5}},
            React.createElement("div",{style:{height:"100%",width:barW+"%",background:cc,borderRadius:2}})
          ),
          React.createElement("div",{style:{fontSize:9,color:utilC,fontWeight:700}},"稼働 "+util+"% · "+d.days+"/"+d.maxDays+"日")
        );
      })
    )
  );
}

/* ===== 車両原価マスタ入力 ===== */


function VehicleCostManager({vehicles,store}){
  const[costs,setCosts]=useState({});
  const[saving,setSaving]=useState(false);
  const[savedMsg,setSavedMsg]=useState("");
  const tbl=(store==="spk")?"app_settings":"bt_app_settings";
  useEffect(()=>{
    if(!sb)return;
    sb.from(tbl).select("value").eq("key","vehicle_costs").single()
      .then(({data})=>{if(data?.value)try{setCosts(typeof data.value==="string"?JSON.parse(data.value):data.value);}catch(e){}});
  },[tbl]);
  const calcMC=(c)=>{if(!c)return 0;return(c.monthlyFee||0)+Math.round((c.insuranceAnnual||0)/12)+Math.round((c.shakenAnnual||0)/12)+Math.round((c.inspection6m||0)*2/12);};
  const upd=(code,field,val)=>setCosts(prev=>({...prev,[code]:{...(prev[code]||{}),[field]:val}}));
  const save=async()=>{
    setSaving(true);
    await sb.from(tbl).upsert({key:"vehicle_costs",value:JSON.stringify(costs)},{onConflict:"key"});
    setSaving(false);setSavedMsg("✅ 保存しました");setTimeout(()=>setSavedMsg(""),2500);
  };
  const CLS_C={AA:"#facc15",A:"#dc2626",B:"#2563eb",C:"#16a34a",S:"#ea580c",H:"#475569",F:"#7c3aed"};
  const CLS_ORDER=["AA","A","B","C","S","H","F"];
  const grouped={};
  vehicles.forEach(v=>{const t=v.type||"?";if(!grouped[t])grouped[t]=[];grouped[t].push(v);});
  const inpS={width:"100%",border:"1px solid #e2e8f0",borderRadius:4,padding:"3px 6px",fontSize:11,textAlign:"right",background:"#fffbeb"};
  const thS={fontSize:9,fontWeight:700,padding:"5px 8px",background:"#f1f5f9",borderBottom:"2px solid #e2e8f0",whiteSpace:"nowrap",textAlign:"right"};
  const tdS={fontSize:11,padding:"5px 6px",borderBottom:"1px solid #f1f5f9"};
  const totalMC=vehicles.reduce((s,v)=>s+calcMC(costs[v.code]),0);
  const setVehs=vehicles.filter(v=>calcMC(costs[v.code])>0).length;
  return React.createElement("div",null,
    React.createElement("div",{style:{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:8,flexWrap:"wrap",gap:8}},
      React.createElement("div",null,
        React.createElement("div",{style:{fontSize:13,fontWeight:800,marginBottom:2}},"🚗 車両原価マスタ"),
        React.createElement("div",{style:{fontSize:10,color:"#64748b"}},"月次原価 ＝ リース/ローン(月) ＋ 保険(年)÷12 ＋ 車検(年)÷12 ＋ 半年点検×2÷12")
      ),
      React.createElement("div",{style:{display:"flex",gap:8,alignItems:"center"}},
        savedMsg&&React.createElement("span",{style:{fontSize:11,color:"#059669",fontWeight:700}},savedMsg),
        React.createElement("button",{onClick:save,disabled:saving,style:{padding:"6px 16px",borderRadius:8,border:"none",background:"#2563eb",color:"#fff",fontSize:12,fontWeight:700,cursor:"pointer"}},saving?"保存中...":"💾 保存")
      )
    ),
    setVehs>0&&React.createElement("div",{style:{padding:"6px 12px",background:"#f0fdf4",borderRadius:8,marginBottom:12,fontSize:11,display:"flex",gap:16}},
      React.createElement("span",null,"設定済み: ",React.createElement("strong",null,setVehs+"/"+vehicles.length+"台")),
      React.createElement("span",null,"月次原価 合計: ",React.createElement("strong",{style:{color:"#dc2626"}},"¥"+totalMC.toLocaleString()))
    ),
    CLS_ORDER.filter(tp=>grouped[tp]?.length).map(tp=>{
      const cc=CLS_C[tp]||"#64748b";
      return React.createElement("div",{key:tp,style:{marginBottom:16}},
        React.createElement("div",{style:{fontWeight:800,fontSize:11,color:cc,padding:"4px 10px",background:cc+"18",borderRadius:"8px 8px 0 0",borderLeft:`4px solid ${cc}`}},"["+tp+"] "+grouped[tp].length+"台"),
        React.createElement("div",{style:{overflowX:"auto",border:"1px solid #e2e8f0",borderTop:"none",borderRadius:"0 0 8px 8px"}},
          React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
            React.createElement("thead",null,React.createElement("tr",null,
              React.createElement("th",{style:{...thS,textAlign:"left"}},"車両"),
              React.createElement("th",{style:{...thS,width:80}},"費用種別"),
              React.createElement("th",{style:thS},"リース/ローン(月)"),
              React.createElement("th",{style:thS},"保険料(年)"),
              React.createElement("th",{style:thS},"車検見積(年)"),
              React.createElement("th",{style:thS},"半年点検(1回)"),
              React.createElement("th",{style:{...thS,background:"#fef3c7"},"data-col":"mc"},"月次原価")
            )),
            React.createElement("tbody",null,
              grouped[tp].map((v,i)=>{
                const c=costs[v.code]||{};const mc=calcMC(c);
                return React.createElement("tr",{key:v.code,style:{background:i%2===0?"#fff":"#f8fafc"}},
                  React.createElement("td",{style:{...tdS,fontWeight:700}},v.code," ",React.createElement("span",{style:{fontWeight:400,color:"#64748b",fontSize:10}},v.name)),
                  React.createElement("td",{style:tdS},
                    React.createElement("select",{value:c.costType||"lease",onChange:e=>upd(v.code,"costType",e.target.value),style:{...inpS,textAlign:"left",width:72}},
                      React.createElement("option",{value:"lease"},"リース"),React.createElement("option",{value:"loan"},"ローン")
                    )
                  ),
                  React.createElement("td",{style:tdS},React.createElement("input",{type:"number",value:c.monthlyFee||"",onChange:e=>upd(v.code,"monthlyFee",+e.target.value),style:inpS,placeholder:"0"})),
                  React.createElement("td",{style:tdS},React.createElement("input",{type:"number",value:c.insuranceAnnual||"",onChange:e=>upd(v.code,"insuranceAnnual",+e.target.value),style:inpS,placeholder:"0"})),
                  React.createElement("td",{style:tdS},React.createElement("input",{type:"number",value:c.shakenAnnual||"",onChange:e=>upd(v.code,"shakenAnnual",+e.target.value),style:inpS,placeholder:"0"})),
                  React.createElement("td",{style:tdS},React.createElement("input",{type:"number",value:c.inspection6m||"",onChange:e=>upd(v.code,"inspection6m",+e.target.value),style:inpS,placeholder:"0"})),
                  React.createElement("td",{style:{...tdS,fontWeight:800,textAlign:"right",background:"#fef3c7",color:mc>0?"#dc2626":"#94a3b8"}},mc>0?"¥"+mc.toLocaleString():"未設定")
                );
              })
            )
          )
        )
      );
    })
  );
}

function ClsUtilCard({utilByM,ymList,nowYm,yrList,DB_VEH_TYPES}){
  const TC={A:"#7c3aed",B:"#0284c7",C:"#059669",S:"#d97706",F:"#db2777",H:"#64748b",D:"#374151",E:"#94a3b8",LUX:"#7c3aed",MPV:"#0284c7",SUV:"#d97706",CSUV:"#059669",SDN:"#64748b",CPT:"#db2777"};
  const bgTC={A:"#f5f3ff",B:"#eff6ff",C:"#f0fdf4",S:"#fffbeb",F:"#fdf2f8",H:"#f8fafc",D:"#f8fafc",E:"#f8fafc",LUX:"#f5f3ff",MPV:"#eff6ff",SUV:"#fffbeb",CSUV:"#f0fdf4",SDN:"#f8fafc",CPT:"#fdf2f8"};
  const [clsMode,setClsMode]=useState("month");
  const validMs=ymList.filter(ym=>utilByM[ym]);
  const [selYm,setSelYm]=useState(()=>validMs.includes(nowYm)?nowYm:(validMs[validMs.length-1]||""));
  const nowYr=String(new Date().getFullYear());
  const [selYr,setSelYr]=useState(()=>yrList.includes(nowYr)?nowYr:(yrList[yrList.length-1]||""));
  const rankIcon=i=>i===0?"🥇":i===1?"🥈":i===2?"🥉":null;
  const monthEntries=(()=>{
    const u=utilByM[selYm];if(!u)return [];
    return DB_VEH_TYPES.filter(t=>u.vtUtil[t]!=null).map(t=>({t,pct:u.vtUtil[t]})).sort((a,b)=>b.pct-a.pct);
  })();
  const yearEntries=(()=>{
    const yms=validMs.filter(ym=>ym.startsWith(selYr));if(!yms.length)return [];
    const sumW={},sumD={};
    yms.forEach(ym=>{const u=utilByM[ym];if(!u)return;DB_VEH_TYPES.forEach(t=>{if(u.vtUtil[t]==null)return;sumW[t]=(sumW[t]||0)+u.dim;sumD[t]=(sumD[t]||0)+u.vtUtil[t]*u.dim;});});
    return DB_VEH_TYPES.filter(t=>sumW[t]>0).map(t=>({t,pct:Math.round(sumD[t]/sumW[t]*10)/10})).sort((a,b)=>b.pct-a.pct);
  })();
  const entries=clsMode==="month"?monthEntries:yearEntries;
  return <div>
    <div style={{display:"flex",gap:6,marginBottom:14,alignItems:"center",flexWrap:"wrap"}}>
      {["month","year"].map(m=><button key={m} onClick={()=>setClsMode(m)} style={{padding:"4px 14px",borderRadius:8,border:"none",cursor:"pointer",fontSize:11,fontWeight:700,background:clsMode===m?"#2563eb":"#f1f5f9",color:clsMode===m?"#fff":"#64748b"}}>{m==="month"?"月別":"年別"}</button>)}
      {clsMode==="month"
        ?<select value={selYm} onChange={e=>setSelYm(e.target.value)} style={{fontSize:11,padding:"3px 8px",borderRadius:6,border:"1px solid #d1d5db",color:"#374151",marginLeft:6}}>
            {[...validMs].reverse().map(ym=><option key={ym} value={ym}>{ym}{ym===nowYm?" (今月)":""}</option>)}
          </select>
        :<select value={selYr} onChange={e=>setSelYr(e.target.value)} style={{fontSize:11,padding:"3px 8px",borderRadius:6,border:"1px solid #d1d5db",color:"#374151",marginLeft:6}}>
            {[...yrList].reverse().map(yr=><option key={yr} value={yr}>{yr}年{yr===nowYr?" (今年)":""}</option>)}
          </select>
      }
    </div>
    {entries.length===0?<div style={{color:"#94a3b8",fontSize:12,padding:16,textAlign:"center"}}>データなし</div>
    :<div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(130px,1fr))",gap:10}}>
      {entries.map(({t,pct},i)=>{
        const col=TC[t]||"#64748b";const bg=bgTC[t]||"#f8fafc";
        const barCol=pct>=60?"#059669":pct>=40?"#d97706":"#dc2626";
        return <div key={t} style={{background:bg,border:`2px solid ${col}22`,borderRadius:12,padding:"12px 12px 10px",position:"relative"}}>
          {rankIcon(i)&&<div style={{position:"absolute",top:8,right:10,fontSize:18,lineHeight:1}}>{rankIcon(i)}</div>}
          <div style={{fontSize:10,fontWeight:700,color:"#64748b",marginBottom:2}}>#{i+1}</div>
          <div style={{fontSize:22,fontWeight:900,color:col,lineHeight:1,marginBottom:4}}>{t}<span style={{fontSize:11,fontWeight:600,color:"#94a3b8",marginLeft:3}}>クラス</span></div>
          <div style={{fontSize:28,fontWeight:900,color:barCol,lineHeight:1,marginBottom:6}}>{pct}<span style={{fontSize:12,fontWeight:700}}>%</span></div>
          <div style={{height:6,background:"#e2e8f0",borderRadius:3,overflow:"hidden"}}>
            <div style={{height:"100%",width:Math.min(pct,100)+"%",background:barCol,borderRadius:3}}/>
          </div>
        </div>;
      })}
    </div>}
  </div>;
}

// ══════════════════════════════════════════════════════════════
// 📋 月次レポートPDF 生成（2026-05-19）
// 📋 月次レポートPDF 生成（2026-05-19）
// ① window.open → ② 広告費async取得 → ③ レポート生成 → ④ window.write
// （window.openを先に実行することでpopupブロックを回避しつつ広告費も取得）
function openFullMonthlyReport_(dbStore,repYm,allResvs,allVehs,allFleetArr,allKpi,_cmMap,_costMap,extraByM,dashKpi,dashYearly,byClassData){
  // ★ STEP1: 先にウィンドウを開く（ユーザジェスチャー内 = popupブロック回避）
  var w=window.open("","_blank","width=1000,height=800");
  if(!w){alert("ポップアップがブロックされています。\nブラウザのアドレスバーでこのサイトのポップアップを許可してから再度お試しください。");return;}
  w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"></head><body style="background:#0f172a;color:#fff;font-family:sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;margin:0"><div style="text-align:center"><p style="font-size:32px;margin-bottom:8px">📋</p><p style="font-size:16px">月次レポートを生成中...</p><p style="font-size:11px;color:#94a3b8;margin-top:8px">広告費データを取得しています</p></div></body></html>');
  // ★ STEP2: 広告費データを非同期取得（ウィンドウは既に開いている）
  var yr=repYm.slice(0,4);
  var _parse=function(rows,pfx){var m={};(rows||[]).forEach(function(r){var ym=(r.key||"").replace(pfx,"");if(ym)try{m[ym]=typeof r.value==="string"?JSON.parse(r.value):r.value;}catch(e){m[ym]={};}});return m;};
  var adPromise=(typeof sb!=='undefined'&&sb)?Promise.all([
    sb.from("nha_app_settings").select("key,value").like("key","cm_nha_"+yr+"%").limit(200),
    sb.from("nha_app_settings").select("key,value").like("key","cm_spk_"+yr+"%").limit(200),
    sb.from("nha_app_settings").select("key,value").like("key","cost_nha_"+yr+"%").limit(200),
    sb.from("nha_app_settings").select("key,value").like("key","cost_spk_"+yr+"%").limit(200),
    // ② クラス別売上: monthly_snapshots からAPP計算済みデータを取得（再計算しない）
    sb.from("monthly_snapshots").select("class_detail").eq("store",dbStore==="spk"?"spk":"nha").eq("year_month",repYm).maybeSingle(),
  ]).then(function(res){
    var snapCls=null;
    if(res[4]&&res[4].data&&res[4].data.class_detail){
      // APPが計算済みのbyClassデータをそのまま使用
      snapCls={};
      (res[4].data.class_detail||[]).forEach(function(c){
        snapCls[c.type]={count:c.count,capDays:c.avail_days,usedDays:c.rental_days,rev:c.revenue};
      });
    }
    return {cm:{nha:_parse(res[0].data,"cm_nha_"),spk:_parse(res[1].data,"cm_spk_")},
            co:{nha:_parse(res[2].data,"cost_nha_"),spk:_parse(res[3].data,"cost_spk_")},
            snapCls:snapCls};
  }).catch(function(){return{cm:_cmMap,co:_costMap,snapCls:null};}):Promise.resolve({cm:_cmMap,co:_costMap,snapCls:null});
  // ★ STEP3: 取得完了後にレポート生成してウィンドウに書き込む
  adPromise.then(function(ad){
    var cmMap=ad.cm,costMap=ad.co; // 新鮮な広告費データ
    var snapCls=ad.snapCls; // APPのmonthly_snapshotsから取得したbyClass（再計算なし）
  var isSpk=dbStore==="spk";
  var sn=isSpk?"札幌デリバリー専門店":"那覇空港店";
  var co="株式会社Global Lines";
  var rdKey=isSpk?"return_date":"end_date";
  var ldKey=isSpk?"lend_date":"start_date";
  var yrStr=repYm.slice(0,4),moStr=parseInt(repYm.slice(5));
  var period=yrStr+"年"+moStr+"月";
  var gd=new Date().toLocaleDateString("ja-JP",{year:"numeric",month:"long",day:"numeric",timeZone:"Asia/Tokyo"});
  var f=function(n){return"¥"+Math.round(n||0).toLocaleString();};
  var fp=function(v,d){return d>0?(Math.round(v/d*10)/10).toFixed(1)+"%":"-";};

  // ── フリートマップ
  var fMap={};(allFleetArr||[]).forEach(function(x){fMap[x.reservation_id]=x.vehicle_code;});
  var vMap={};(allVehs||[]).forEach(function(v){vMap[v.code]=v;});
  var kpiF={};(allKpi||[]).forEach(function(k){if(!kpiF[k.year_month])kpiF[k.year_month]={};kpiF[k.year_month][k.vehicle_code]=k.active;});

  // ── 対象月の予約
  var active=(allResvs||[]).filter(function(r){return r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel";});
  var monthResv=active.filter(function(r){var rd=r[rdKey];return rd&&rd.slice(0,7)===repYm;});

  // ── 月次KPI集計
  var totalRev=0,totalBase=0,totalOpt=0,totalDisc=0,totalCnt=monthResv.length,totalNights=0;
  monthResv.forEach(function(r){
    var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
    var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
    var ld=r[ldKey],rd=r[rdKey];
    var nights=ld&&rd?Math.max(0,Math.round((new Date(rd)-new Date(ld))/86400000)):0;
    totalRev+=rev;totalBase+=(bp>0||op>0)?bp:(Number(r.price)||0);totalOpt+=op;totalDisc+=dc;totalNights+=nights;
  });
  var unitPrice=totalCnt>0?Math.round(totalRev/totalCnt):0;
  var avgNights=totalCnt>0?totalNights/totalCnt:0;

  // ── 稼働率（APPのLeadTimeWidget/KpiTabと同じ計算方式）
  // 返却月だけでなく、月中に稼働した全予約（月をまたぐ予約も含む）でカウント
  var daysInM=new Date(parseInt(yrStr),parseInt(moStr),0).getDate();
  var monthKpi=kpiF[repYm]||{};
  var activeVehs=(allVehs||[]).filter(function(v){return v.active&&(!(v.code in monthKpi)||monthKpi[v.code]);});
  var utilMaxDays=activeVehs.length*daysInM;
  var mStart=new Date(repYm+"-01T00:00:00");
  var mEnd=new Date(yrStr+"-"+String(moStr).padStart(2,"0")+"-"+String(daysInM).padStart(2,"0")+"T23:59:59");
  var utilDays=0;
  // 月中に稼働している全予約（start <= 月末 AND end >= 月初）
  active.filter(function(r){
    var ld=r[ldKey],rd=r[rdKey];
    return ld&&rd&&ld<=yrStr+"-"+String(moStr).padStart(2,"0")+"-"+String(daysInM).padStart(2,"0")&&rd>=repYm+"-01";
  }).forEach(function(r){
    var vc=fMap[r.id];if(!vc)return;
    var ld=new Date(r[ldKey]+"T00:00:00"),rd=new Date(r[rdKey]+"T00:00:00");
    var s=ld<mStart?mStart:ld,e=rd>mEnd?mEnd:rd;
    var d=Math.max(0,Math.round((e-s)/86400000));
    utilDays+=d;
  });
  var utilPct=utilMaxDays>0?Math.round(utilDays/utilMaxDays*100):0;

  // ── リードタイム中央値（貸出月ベース）
  var ltArr=[];
  active.filter(function(r){var ld=r[ldKey];return ld&&ld.slice(0,7)===repYm;}).forEach(function(r){
    var bm=r.booked_at||(r.created_at&&r.created_at.slice(0,10)!=="2026-03-29"?r.created_at:null);
    if(!bm)return;
    var lt=Math.max(0,Math.round((new Date(r[ldKey])-new Date(bm.slice(0,10)))/86400000));
    ltArr.push(lt);
  });
  ltArr.sort(function(a,b){return a-b;});
  var ltMedian=ltArr.length>0?ltArr[Math.floor(ltArr.length/2)]:null;

  // ── 当月予約率（返却月のうち予約発生も同月の割合）
  var bookedInMonth=monthResv.filter(function(r){
    var bm=r.booked_at||(r.created_at&&r.created_at.slice(0,10)!=="2026-03-29"?r.created_at:null);
    return bm&&bm.slice(0,7)===repYm;
  }).length;
  var reservationRate=totalCnt>0?Math.round(bookedInMonth/totalCnt*100):0;

  // ── デリバリ利用率
  var NON_DEL_RE=/(那覇空港|空港|来店|店舗|店頭|ヤード|営業所|HANDYMAN)/;
  var isDelPlace=function(p){var s=String(p||"").trim();return s&&!NON_DEL_RE.test(s);};
  var deliveryCnt=monthResv.filter(function(r){
    if(isSpk)return true;
    var vt=(r.visit_type||"").toUpperCase(),rt=(r.return_type||"").toUpperCase();
    if(vt.includes("DEL")||vt==="L")return true;
    if(rt.includes("COL"))return true;
    if(isDelPlace(r.del_place)||isDelPlace(r.col_place))return true;
    return false;
  }).length;
  var deliveryRate=totalCnt>0?Math.round(deliveryCnt/totalCnt*100):0;

  // ── RevPACD / 台あたり（raw計算）
  var revpacd=utilMaxDays>0?Math.round(totalRev/utilMaxDays):0;
  var extraRev=(extraByM||{})[repYm]||0;
  var grandTotal=totalRev+extraRev;
  var perVehicleRev=activeVehs.length>0?Math.round(grandTotal/activeVehs.length):0;

  // ── dashKpiが渡された場合: APPの計算済み値で上書き（再計算不要・数値完全一致）
  if(dashKpi){
    totalRev=dashKpi.plRev||0;
    totalBase=dashKpi.plBase||0;
    totalOpt=dashKpi.plOpt||0;
    totalDisc=dashKpi.plDisc||0;
    totalCnt=dashKpi.plCnt||0;
    unitPrice=Math.round(dashKpi.unitPrice||0);
    avgNights=dashKpi.avgNights||0;
    utilPct=dashKpi.utilPct||0;
    utilDays=dashKpi.utilDays||0;
    utilMaxDays=dashKpi.utilMaxDays||0;
    var aktCount=dashKpi.utilActiveCount||activeVehs.length;
    revpacd=utilMaxDays>0?Math.round(totalRev/utilMaxDays):0;
    extraRev=(extraByM||{})[repYm]||0;
    grandTotal=totalRev+extraRev;
    perVehicleRev=aktCount>0?Math.round(grandTotal/aktCount):0;
  }

  // ── チャンネル別集計
  var byCh={};
  monthResv.forEach(function(r){
    var ch=r.ota||"?";var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
    var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
    if(!byCh[ch])byCh[ch]={rev:0,cnt:0};
    byCh[ch].rev+=rev;byCh[ch].cnt+=1;
  });

  // ── HP/OTA 広告効率（KPI管理表：返却月ベース）
  var AD_CODES=isSpk?["xmoxky29punj","xmoxky7sxos9","xmoxkyd9yojr"]:["xmop3xv4n7f6"];
  var getAd=function(ym){
    var cm=(cmMap[dbStore]||{})[ym]||{};
    var tot=0;AD_CODES.forEach(function(c){tot+=Number(cm[c]||0);});
    if(tot>0)return tot;
    var costArr=(costMap[dbStore]||{})[ym]||[];
    var ct=0;(Array.isArray(costArr)?costArr:[]).forEach(function(it){if((it.account_code||"")==="sga_ad")ct+=Number(it.amount||0);});
    return ct;
  };
  var hpSalesR=0,hpNR=0,otaSales=0,otaN=0,rakutenDisc=0;
  monthResv.forEach(function(r){
    var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
    var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
    if(r.ota==="HP"){hpSalesR+=rev;hpNR+=1;}
    else if(["J","R","S","O","RC","G"].includes(r.ota)){otaSales+=rev;otaN+=1;if(r.ota==="R"&&dc>0)rakutenDisc+=dc;}
  });
  var adCost=getAd(repYm);
  var otaFee=Math.round(otaSales*0.18);
  var otaCostTotal=otaFee+rakutenDisc;
  var hpRate=hpSalesR>0?adCost/hpSalesR*100:(adCost>0?999:0);
  var otaRateActual=otaSales>0?otaCostTotal/otaSales*100:0;
  var totalSales=hpSalesR+otaSales,totalCost=adCost+otaCostTotal;
  var totalRate=totalSales>0?totalCost/totalSales*100:0;
  var cpa=function(c,n){return n>0?"¥"+Math.round(c/n).toLocaleString()+"/件":"-";};

  // ── クラス別ランキング（粗利順・全期間）
  var PERIOD_START_MAP={nha:"2026-04",spk:"2026-02",bt:"2026-05"};
  var ps=PERIOD_START_MAP[dbStore]||"2026-01";
  var today2=new Date();
  var todayYM2=today2.getFullYear()+"-"+String(today2.getMonth()+1).padStart(2,"0");
  var mList2=[];var cy2=parseInt(ps.slice(0,4)),cm2=parseInt(ps.slice(5));
  var ey2=today2.getFullYear(),em2=today2.getMonth()+1;
  while(cy2<ey2||(cy2===ey2&&cm2<=em2)){mList2.push(cy2+"-"+String(cm2).padStart(2,"0"));cm2++;if(cm2>12){cm2=1;cy2++;}}
  var nm=mList2.length||1;
  var vStat2={};
  active.filter(function(r){return r[ldKey]&&r[ldKey].slice(0,7)>=ps;}).forEach(function(r){
    var vc=fMap[r.id];if(!vc)return;
    var ld2=new Date(r[ldKey]),rd2=new Date(r[rdKey]);
    if(rd2>today2)rd2=today2;
    var days2=Math.max(1,Math.floor((rd2-ld2)/86400000)+1);
    var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
    var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
    if(!vStat2[vc])vStat2[vc]={rev:0,days:0};
    vStat2[vc].rev+=rev;vStat2[vc].days+=days2;
  });
  var capByV={};
  mList2.forEach(function(ym){
    var yy=parseInt(ym.slice(0,4)),mm=parseInt(ym.slice(5));
    var dim2;if(yy===today2.getFullYear()&&mm===today2.getMonth()+1){dim2=today2.getDate();}else{dim2=new Date(yy,mm,0).getDate();}
    var mk=kpiF[ym]||{};
    (allVehs||[]).forEach(function(v){if(!v.active)return;var ia=v.code in mk?mk[v.code]:true;if(ia)capByV[v.code]=(capByV[v.code]||0)+dim2;});
  });
  var clsMap={};
  (allVehs||[]).filter(function(v){return v.active;}).forEach(function(v){
    var c=v.type||v.vehicle_class||"?";
    if(!clsMap[c])clsMap[c]={cls:c,count:0,rev:0,days:0,capDays:0,fixed:0};
    var s=vStat2[v.code]||{rev:0,days:0};
    var lease=Number(v.leaseMonthly||v.lease_monthly)||0;
    var ins=Number(v.insuranceAnnual||v.insurance_annual)||0;
    var tax=Math.round((Number(v.carTax||v.car_tax)||0)/12);
    var shaken=Math.round((Number(v.shakenCost||v.shaken_cost)||0)/24);
    var tenken=Math.round((Number(v.tenkenCost||v.tenken_cost)||0)/6);
    var fixedM=(lease+ins+tax+shaken+tenken)*nm;
    clsMap[c].count++;clsMap[c].rev+=s.rev;clsMap[c].days+=s.days;
    clsMap[c].capDays+=(capByV[v.code]||0);clsMap[c].fixed+=fixedM;
  });
  var classRows2=Object.values(clsMap).map(function(c){
    return{cls:c.cls,count:c.count,rev:c.rev,profit:c.rev-c.fixed,fixed:c.fixed,utilPct:c.capDays?Math.round(c.days/c.capDays*100):0,monthlyRev:Math.round(c.rev/nm),monthlyProfit:Math.round((c.rev-c.fixed)/nm)};
  }).sort(function(a,b){return b.profit-a.profit;});

  // ── クラス別稼働率（repYm 単月）APPのKpiTabと同じ計算方式
  // 稼働日数: 月中に稼働した全予約（月をまたぐ予約も含む）
  // 売上: 返却月ベース（monthResv）= APP Summaryと同じ
  var clsMonth={};
  var mS2=new Date(repYm+"-01T00:00:00"),mE2=new Date(yrStr+"-"+String(moStr).padStart(2,"0")+"-"+String(daysInM).padStart(2,"0")+"T23:59:59");
  var lastDayStr=yrStr+"-"+String(moStr).padStart(2,"0")+"-"+String(daysInM).padStart(2,"0");
  (allVehs||[]).filter(function(v){return v.active&&(!(v.code in monthKpi)||monthKpi[v.code]);}).forEach(function(v){
    var c=v.type||v.vehicle_class||"?";
    if(!clsMonth[c])clsMonth[c]={count:0,capDays:0,usedDays:0,rev:0};
    clsMonth[c].count++;clsMonth[c].capDays+=daysInM;
  });
  // 稼働日数: 月中に稼働した全予約（返却月に限らない）
  active.filter(function(r){
    var ld=r[ldKey],rd=r[rdKey];
    return ld&&rd&&ld<=lastDayStr&&rd>=repYm+"-01";
  }).forEach(function(r){
    var vc=fMap[r.id];if(!vc)return;
    var v=vMap[vc];if(!v)return;
    var c=v.type||v.vehicle_class||"?";
    if(!clsMonth[c])return;
    var ld2=new Date(r[ldKey]+"T00:00:00"),rd2=new Date(r[rdKey]+"T00:00:00");
    var s=ld2<mS2?mS2:ld2,e=rd2>mE2?mE2:rd2;
    var d=Math.max(0,Math.round((e-s)/86400000));
    clsMonth[c].usedDays+=d;
  });
  // 売上: 返却月ベース（APP Summaryと同じ）
  monthResv.forEach(function(r){
    var vc=fMap[r.id];if(!vc)return;
    var v=vMap[vc];if(!v)return;
    var c=v.type||v.vehicle_class||"?";
    if(!clsMonth[c])return;
    var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
    var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
    clsMonth[c].rev+=rev;
  });

  // ══ CSS ══
  var css="@page{size:A4;margin:12mm 14mm}*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Hiragino Kaku Gothic Pro','Noto Sans JP',sans-serif;font-size:9.5pt;color:#1a202c;line-height:1.55}.cv{text-align:center;padding:18px 0 12px;border-bottom:3px solid #1e40af;margin-bottom:14px}.sec{margin-bottom:14px}.st{font-size:10.5pt;font-weight:800;color:#1e40af;border-left:4px solid #1e40af;padding-left:8px;margin-bottom:8px}"+
  /* TOPsummary */
  ".ts-wrap{background:#fffde7;border:1.5px solid #fde68a;border-radius:10px;padding:12px 14px}.ts-hdr{text-align:center;font-size:11pt;font-weight:800;color:#374151;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #fde68a}.ts-body{display:grid;grid-template-columns:1fr 1fr;gap:12px}.ts-left{}.ts-right{border-left:1px solid #fde68a;padding-left:14px}.ts-rev-main{font-size:15pt;font-weight:900;color:#059669;margin-bottom:8px}.ts-rev-lbl{font-size:8.5pt;color:#64748b;font-weight:600}.ts-row{display:flex;align-items:center;justify-content:space-between;padding:3px 0;border-bottom:1px solid #f3f4f6}.ts-row:last-child{border-bottom:none}.ts-key{font-size:8.5pt;color:#374151}.ts-val{font-size:9pt;font-weight:700;text-align:right}.ts-val.grn{color:#059669}.ts-val.blu{color:#2563eb}.ts-val.org{color:#d97706}.ts-val.pur{color:#7c3aed}.ts-total-row{display:flex;align-items:center;justify-content:space-between;background:#f0fdf4;padding:5px 8px;border-radius:6px;margin:6px 0}.ts-kpi-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid #f3f4f6}.ts-kpi-row:last-child{border-bottom:none}.ts-kpi-lbl{font-size:8.5pt;color:#374151;flex:1}.ts-kpi-val{font-size:11pt;font-weight:900}.ts-kpi-sub{font-size:7.5pt;color:#94a3b8;margin-left:4px}.ts-bar-wrap{flex:1;background:#e2e8f0;border-radius:3px;height:6px;margin:0 8px}.ts-bar{height:6px;border-radius:3px}.ts-pct{font-size:8pt;color:#64748b;width:30px;text-align:right}.ts-vc-row{display:flex;align-items:center;background:#fff;border:1px solid #fde68a;border-radius:8px;padding:6px 10px;margin-top:8px;gap:10px}"+
  /* テーブル共通 */
  "table{width:100%;border-collapse:collapse;font-size:8.5pt}th{background:#1e40af;color:#fff;padding:5px 7px;font-weight:700;text-align:left;font-size:8pt}td{padding:4px 7px;border-bottom:1px solid #e2e8f0;vertical-align:middle}tr:nth-child(even) td{background:#f8fafc}.tr{background:#1e293b!important}.tr td{color:#fff!important}.pb{break-before:page}.sign{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}.sb{border:1px solid #cbd5e1;border-radius:6px;padding:6px 10px;min-height:44px}.sl{font-size:7.5pt;color:#94a3b8;margin-bottom:3px}"+
  /* クラス別カード */
  ".cls-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px;margin-top:8px}.cls-card{border:2px solid #e2e8f0;border-radius:10px;padding:10px 12px;background:#fff}.cls-badge{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;font-size:13pt;font-weight:900;color:#fff;margin-bottom:4px}.cls-cnt{font-size:8pt;color:#94a3b8;margin-left:4px;font-weight:400}.cls-rev{font-size:15pt;font-weight:900;color:#1e293b;margin:4px 0 2px}.cls-sub{font-size:8pt;color:#64748b;margin-bottom:6px}.cls-bar-bg{background:#e2e8f0;border-radius:3px;height:4px;margin:4px 0}.cls-bar{height:4px;border-radius:3px}.cls-util{font-size:8pt;font-weight:700;margin-top:4px}"+
  "@media print{body{-webkit-print-color-adjust:exact;print-color-adjust:exact}}";

  // ══ HTML組み立て ══
  // grandTotal / extraRev は上で計算済み

  // ヘルパー関数（HTML組み立て前に宣言）
  var bar=function(v,tot,clr){var pct=tot>0?Math.min(100,Math.round(v/tot*100)):0;return'<div class="ts-bar-wrap"><div class="ts-bar" style="width:'+pct+'%;background:'+clr+'"></div></div><span class="ts-pct">'+pct+'%</span>';};
  var rp=function(v){return v>0?v.toFixed(1)+"%":"-";}; // 比率表示ヘルパー
  // 万単位表示（例: 5489963 → "¥549.0万"）
  var fW=function(v){return v?'¥'+(Math.round(v/1000)/10).toFixed(1)+'万':'-';};

  // 1. 表紙
  var html='<!DOCTYPE html><html lang="ja"><head><meta charset="UTF-8"><title>月次レポート '+period+'</title><style>'+css+'</style></head><body>'+
  '<div class="cv">'+
    '<div style="font-size:9pt;color:#64748b;margin-bottom:3px">'+co+'</div>'+
    '<div style="font-size:18pt;font-weight:900;color:#1e40af;margin-bottom:4px">HANDYMAN '+sn+'</div>'+
    '<div style="font-size:12pt;font-weight:700;color:#374151;margin-bottom:6px">経営月次レポート</div>'+
    '<div style="display:inline-block;font-size:12pt;font-weight:800;color:#1e40af;background:#eff6ff;padding:4px 20px;border-radius:24px;border:2px solid #bfdbfe">'+period+'</div>'+
    '<div style="font-size:8.5pt;color:#94a3b8;margin-top:6px">作成日: '+gd+'</div>'+
  '</div>'+

  // ① TOPsummary（アプリのSummaryウィジェットそのまま）
  '<div class="sec"><div class="st">① TOPsummary</div>'+
  '<div class="ts-wrap">'+
    '<div class="ts-hdr">'+moStr+'月 返却 '+totalCnt+'件</div>'+
    '<div class="ts-body">'+
      // 左: 売上ブロック
      '<div class="ts-left">'+
        '<div class="ts-rev-lbl">💰 売上</div>'+
        '<div class="ts-rev-main">'+fW(grandTotal)+'</div>'+
        '<div style="margin-top:6px">'+
          '<div class="ts-row"><span class="ts-key">基本</span><span style="font-size:8.5pt;color:#2563eb;font-weight:700">'+fW(totalBase)+'</span>'+bar(totalBase,grandTotal,"#059669")+'</div>'+
          '<div class="ts-row"><span class="ts-key">付帯</span><span style="font-size:8.5pt;color:#059669;font-weight:700">'+fW(totalOpt)+'</span>'+bar(totalOpt,grandTotal,"#34d399")+'</div>'+
          '<div class="ts-total-row"><span style="font-size:8.5pt;font-weight:700;color:#374151">予約計</span><span style="font-size:10pt;font-weight:900;color:#2563eb">'+fW(totalRev)+'</span><span style="font-size:7.5pt;color:#94a3b8;margin-left:4px">基本+付帯</span></div>'+
          (extraRev>0?'<div class="ts-row"><span class="ts-key">予約外</span><span style="font-size:8.5pt;color:#7c3aed;font-weight:700">'+fW(extraRev)+'</span>'+bar(extraRev,grandTotal,"#a78bfa")+'</div>':'')+
        '</div>'+
        // 台あたり
        '<div class="ts-vc-row">'+
          '<span style="font-size:8.5pt;font-weight:700;color:#374151">🎯 台あたり</span>'+
          '<span style="font-size:12pt;font-weight:900;color:#d97706">'+fW(perVehicleRev)+'</span>'+
          '<span style="font-size:7.5pt;color:#94a3b8">/ '+activeVehs.length+'台</span>'+
        '</div>'+
      '</div>'+
      // 右: KPIカード群
      '<div class="ts-right">'+
        '<div class="ts-kpi-row">'+
          '<span class="ts-kpi-lbl">📊 当月予約率</span>'+
          '<span class="ts-kpi-val" style="color:#d97706">'+reservationRate+'<span style="font-size:8pt">%</span></span>'+
          '<span class="ts-kpi-sub">('+bookedInMonth+'/'+totalCnt+')</span>'+
        '</div>'+
        '<div class="ts-kpi-row">'+
          '<span class="ts-kpi-lbl">⚙️ 稼働率</span>'+
          '<span class="ts-kpi-val" style="color:'+(utilPct>=70?"#059669":utilPct>=40?"#d97706":"#dc2626")+'">'+utilPct+'<span style="font-size:8pt">%</span></span>'+
          '<span class="ts-kpi-sub">('+utilDays+'/'+utilMaxDays+'日)</span>'+
        '</div>'+
        '<div class="ts-kpi-row">'+
          '<span class="ts-kpi-lbl">RevPACD</span>'+
          '<span class="ts-kpi-val" style="color:#0284c7">'+f(revpacd)+'</span>'+
          '<span class="ts-kpi-sub">'+activeVehs.length+'台</span>'+
        '</div>'+
        '<div class="ts-kpi-row">'+
          '<span class="ts-kpi-lbl">🕐 LT中央値</span>'+
          '<span class="ts-kpi-val" style="color:#92400e">'+(ltMedian!=null?ltMedian:"--")+'<span style="font-size:8pt">日</span></span>'+
          '<span class="ts-kpi-sub">'+ltArr.length+'件</span>'+
        '</div>'+
        (!isSpk?'<div class="ts-kpi-row">'+
          '<span class="ts-kpi-lbl">🚗 デリバリ</span>'+
          '<span class="ts-kpi-val" style="color:#7c3aed">'+deliveryRate+'<span style="font-size:8pt">%</span></span>'+
          '<span class="ts-kpi-sub">('+deliveryCnt+'/'+totalCnt+')</span>'+
        '</div>':'')+
        '<div class="ts-kpi-row" style="margin-top:6px;border-top:1px solid #fde68a;padding-top:6px">'+
          '<span class="ts-kpi-lbl" style="font-size:8pt">平均単価</span>'+
          '<span style="font-size:9pt;font-weight:700;color:#374151">'+f(unitPrice)+'</span>'+
        '</div>'+
        '<div class="ts-kpi-row">'+
          '<span class="ts-kpi-lbl" style="font-size:8pt">平均泊数</span>'+
          '<span style="font-size:9pt;font-weight:700;color:#374151">'+avgNights.toFixed(1)+'泊</span>'+
        '</div>'+
      '</div>'+
    '</div>'+
  '</div></div>'+

  // ② クラス別売上 — monthly_snapshots(APPが保存済)を優先・なければclsMonthで代替
  (function(){
    var src=snapCls&&Object.keys(snapCls).length>0?snapCls:clsMonth;
    var CLASS_COLORS={A:"#7c3aed",B:"#2563eb",C:"#059669",F:"#db2777",H:"#64748b",S:"#d97706","AA":"#1e293b"};
    var entries=Object.entries(src).sort(function(a,b){return b[1].rev-a[1].rev;});
    var totR=0,totU=0,totC=0,totN=0;
    entries.forEach(function(e){var d=e[1];totR+=d.rev;totU+=d.usedDays;totC+=d.capDays;totN+=d.count;});
    var cards=entries.map(function(e){
      var cls=e[0],d=e[1];
      var pct=d.capDays?Math.round(d.usedDays/d.capDays*100):0;
      var perV=d.count?Math.round(d.rev/d.count):0;
      var share=totR>0?Math.round(d.rev/totR*100):0;
      var col=CLASS_COLORS[cls]||"#475569";
      var barW=Math.min(100,pct)+'%';
      var utilClr=pct>=70?"#059669":pct>=40?"#d97706":"#dc2626";
      return '<div class="cls-card">'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">'+
          '<div class="cls-badge" style="background:'+col+'">'+cls+'</div>'+
          '<span class="cls-cnt">'+d.count+'台</span>'+
        '</div>'+
        '<div class="cls-rev">'+Math.round(d.rev/10000)+'万</div>'+
        '<div class="cls-sub">'+share+'% | 1台'+Math.round(perV/10000)+'万</div>'+
        '<div class="cls-bar-bg"><div class="cls-bar" style="width:'+barW+';background:'+col+'"></div></div>'+
        '<div class="cls-util" style="color:'+utilClr+'">稼働 '+pct+'% · '+d.usedDays+'/'+d.capDays+'日</div>'+
      '</div>';
    }).join("");
    var totPct=totC?Math.round(totU/totC*100):0;
    return '<div class="sec"><div class="st">② クラス別売上（'+period+'）</div>'+
      '<div class="cls-grid">'+cards+'</div>'+
      '<div style="margin-top:8px;display:flex;gap:16px;font-size:8.5pt;color:#374151;padding:6px 10px;background:#f8fafc;border-radius:6px;border:1px solid #e2e8f0">'+
        '<span>📊 合計売上: <b>'+fW(totR)+'</b></span>'+
        '<span>⚙️ 全体稼働率: <b>'+totPct+'%</b></span>'+
        '<span>稼働: '+totU+'/'+totC+'日</span>'+
        '<span>台数: '+totN+'台</span>'+
      '</div></div>';
  })()+

  // ③ KPI管理表（全12ヶ月の時系列 + 当月詳細）
  (function(){
    var yr3=parseInt(yrStr);
    var months12k=[];for(var mo3k=1;mo3k<=12;mo3k++){var ymk=yr3+"-"+String(mo3k).padStart(2,"0");if(ymk>=ps)months12k.push(ymk);}
    // 月別KPI計算
    var kpiByMonth={};
    months12k.forEach(function(ym){
      var ret3=active.filter(function(r){var rd=r[rdKey];return rd&&rd.slice(0,7)===ym;});
      var hpS=0,hpN=0,otaS=0,otaN_=0,rDisc=0;
      ret3.forEach(function(r){
        var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        if(r.ota==="HP"){hpS+=rev;hpN++;}
        else if(["J","R","S","O","RC","G"].includes(r.ota)){otaS+=rev;otaN_++;if(r.ota==="R"&&dc>0)rDisc+=dc;}
      });
      var ad=getAd(ym);
      var oFee=Math.round(otaS*0.18);
      var oCost=oFee+rDisc;
      var tSales=hpS+otaS,tCost=ad+oCost;
      kpiByMonth[ym]={hpS:hpS,hpN:hpN,otaS:otaS,otaN:otaN_,rDisc:rDisc,ad:ad,oFee:oFee,oCost:oCost,
        tSales:tSales,tCnt:ret3.length,tCost:tCost,
        hpRate:hpS>0?ad/hpS*100:0,
        otaRate:otaS>0?oCost/otaS*100:0,
        totalRate:tSales>0?tCost/tSales*100:0};
    });
    var fK=function(v){return v?'¥'+Math.round(v/10000)+'万':'-';};
    var rK=function(v){return v>0?v.toFixed(1)+'%':'-';};
    var cpaK=function(c,n){return n>0?'¥'+Math.round(c/n).toLocaleString():'-';};
    var hdr='<tr style="background:#0f172a;color:#fff"><th style="text-align:left;white-space:nowrap;min-width:140px">項目</th>'+
      months12k.map(function(ym){var mo=parseInt(ym.slice(5));var isR=(ym===repYm);return'<th style="text-align:right;'+(isR?"color:#fbbf24;font-weight:900":"")+'">'+mo+'月</th>';}).join("")+
      '<th style="text-align:right;color:#6ee7b7">年計</th></tr>';
    var yTot=function(key){return months12k.reduce(function(s,ym){return s+(kpiByMonth[ym][key]||0);},0);};
    var row=function(lbl,valFn,bg,bold,color){
      var cells=months12k.map(function(ym){
        var v=valFn(kpiByMonth[ym]);
        var isR=(ym===repYm);
        return'<td style="text-align:right;'+(isR?"font-weight:900;background:#f0f9ff;":"")+'">'+(v||'-')+'</td>';
      }).join("");
      var yrV=valFn({hpS:yTot("hpS"),hpN:yTot("hpN"),otaS:yTot("otaS"),otaN:yTot("otaN"),rDisc:yTot("rDisc"),ad:yTot("ad"),oFee:yTot("oFee"),oCost:yTot("oCost"),tSales:yTot("tSales"),tCnt:yTot("tCnt"),tCost:yTot("tCost"),hpRate:yTot("tSales")>0?(yTot("ad")/yTot("hpS")||0)*100:0,otaRate:yTot("otaS")>0?yTot("oCost")/yTot("otaS")*100:0,totalRate:yTot("tSales")>0?yTot("tCost")/yTot("tSales")*100:0});
      return'<tr style="background:'+(bg||"")+'"><td style="padding-left:10px;'+(bold?"font-weight:800;":"")+(color?"color:"+color+";":"")+'white-space:nowrap">'+lbl+'</td>'+cells+'<td style="text-align:right;font-weight:700">'+(yrV||'-')+'</td></tr>';
    };
    return '<div class="sec pb"><div class="st">③ KPI管理表（チャネル別広告費効率 / 返却月ベース / '+yr3+'年）<span style="font-size:7.5pt;color:#94a3b8;font-weight:400;margin-left:8px">※ 太字青列＝レポート対象月</span></div>'+
    '<div style="overflow-x:auto"><table style="min-width:900px;font-size:7pt;border-collapse:collapse">'+
    '<thead>'+
    '<tr style="background:#dbeafe"><td colspan="14" style="font-weight:800;color:#1e3a8a;padding:4px 8px">🏠 HPチャネル × 純広告費（返却月ベース）— PL基準・合算用</td></tr>'+
    hdr+
    '</thead><tbody>'+
    row('💰 HP売上（返却月）',function(m){return m.hpS?f(m.hpS):'-';})+
    row('🤝 HP件数（返却月）',function(m){return m.hpN?m.hpN+'件':'-';})+
    row('🎁 純広告費（実支出）',function(m){return f(m.ad||0);})+
    row('📊 HP広告比率（返却月）',function(m){return rK(m.hpRate);},'#eff6ff',true,'#1e40af')+
    row('💰 HP CPA（返却月）',function(m){return cpaK(m.ad,m.hpN);},'#eff6ff',true,'#d97706')+
    '</tbody><thead>'+
    '<tr style="background:#ede9fe"><td colspan="14" style="font-weight:800;color:#5b21b6;padding:4px 8px">🌐 OTAチャネル × 手数料18%（返却月ベース）</td></tr>'+
    hdr+
    '</thead><tbody>'+
    row('💰 OTA売上（返却月）',function(m){return m.otaS?f(m.otaS):'-';})+
    row('🤝 OTA件数',function(m){return m.otaN?m.otaN+'件':'-';})+
    row('🎁 OTA手数料 (18%固定)',function(m){return m.oFee?f(m.oFee):'-';})+
    row('🏦 楽天事業者クーポン',function(m){return m.rDisc?f(m.rDisc):'-';})+
    row('💰 OTAコスト合計（手数料+楽天C）',function(m){return m.oCost?f(m.oCost):'-';},'#faf5ff',true,'#5b21b6')+
    row('📊 OTA実質広告比率',function(m){return rK(m.otaRate);},'#faf5ff',true,'#1e40af')+
    row('💰 OTA CPA（合計）',function(m){return cpaK(m.oCost,m.otaN);},'#faf5ff',true,'#d97706')+
    '</tbody><thead>'+
    '<tr style="background:#fef3c7"><td colspan="14" style="font-weight:800;color:#92400e;padding:4px 8px">📊 合算（HP+OTA / 返却月ベース統一）— PL基準</td></tr>'+
    hdr+
    '</thead><tbody>'+
    row('💰 合算売上',function(m){return m.tSales?f(m.tSales):'-';})+
    row('🤝 合算件数',function(m){return m.tCnt?m.tCnt+'件':'-';})+
    row('🎁 広告費合計（純広告+手数料+楽天C）',function(m){return m.tCost?f(m.tCost):'-';})+
    row('📊 合算広告比率',function(m){return rK(m.totalRate);},'#fef9c3',true,'#1e40af')+
    row('💰 合算 CPA（グロス）',function(m){return cpaK(m.tCost,m.tCnt);},'#fef9c3',true,'#d97706')+
    '</tbody></table></div></div>';
  })()+

  // 5. 車両クラス別ランキング（粗利順・全期間累計）
  '<div class="sec"><div class="st">④ クラス別ランキング（粗利順 / 期間累計: '+ps+'〜'+todayYM2+'・'+nm+'ヶ月）</div>'+
  '<table><thead><tr><th>#</th><th>クラス</th><th style="text-align:right">台数</th><th style="text-align:right">合計売上</th><th style="text-align:right">月平均売上</th><th style="text-align:right">稼働率</th><th style="text-align:right">固定費合計</th><th style="text-align:right">⑤予想粗利</th><th style="text-align:right">月平均粗利</th></tr></thead><tbody>'+
  classRows2.map(function(c,i){
    var profitColor=c.profit>=0?"#059669":"#dc2626";
    var utilBg=c.utilPct>=70?"#dcfce7":c.utilPct>=40?"#fef9c3":"#fee2e2";
    var utilColor=c.utilPct>=70?"#166534":c.utilPct>=40?"#854d0e":"#991b1b";
    return'<tr><td style="text-align:center;font-weight:700">'+(i+1)+'</td><td><b>['+c.cls+']</b></td><td style="text-align:right">'+c.count+'台</td><td style="text-align:right">'+f(c.rev)+'</td><td style="text-align:right">'+f(c.monthlyRev)+'</td><td style="text-align:right"><span style="background:'+utilBg+';color:'+utilColor+';padding:1px 5px;border-radius:3px;font-weight:700">'+c.utilPct+'%</span></td><td style="text-align:right">'+f(c.fixed)+'</td><td style="text-align:right;font-weight:900;color:'+profitColor+'">'+(c.profit>=0?"":"-")+f(Math.abs(c.profit))+'</td><td style="text-align:right;color:'+profitColor+'">'+(c.monthlyProfit>=0?"":"-")+f(Math.abs(c.monthlyProfit))+'</td></tr>';
  }).join("")+
  '</tbody></table></div>'+

  // 6. チャンネル別売上
  '<div class="sec"><div class="st">⑤ チャンネル別売上（'+period+'）</div>'+
  '<table><thead><tr><th>チャンネル</th><th style="text-align:right">売上</th><th style="text-align:right">件数</th><th style="text-align:right">客単価</th><th style="text-align:right">構成比</th></tr></thead><tbody>'+
  Object.entries(byCh).sort(function(a,b){return b[1].rev-a[1].rev;}).map(function(e){
    var ch=e[0],d=e[1];var up=d.cnt?Math.round(d.rev/d.cnt):0;
    return'<tr><td>'+ch+'</td><td style="text-align:right">'+f(d.rev)+'</td><td style="text-align:right">'+d.cnt+'件</td><td style="text-align:right">'+f(up)+'</td><td style="text-align:right">'+(totalRev>0?Math.round(d.rev/totalRev*100)+"%":"-")+'</td></tr>';
  }).join("")+
  '<tr class="tr"><td>合計</td><td style="text-align:right">'+f(totalRev)+'</td><td style="text-align:right">'+totalCnt+'件</td><td style="text-align:right">'+f(unitPrice)+'</td><td style="text-align:right">100%</td></tr>'+
  '</tbody></table></div>'+

  // ⑥ 年間推移 — dashYearly.monthsをそのまま使用（APPと完全一致・再計算なし）
  (function(){
    var yr=parseInt(yrStr);
    var fM=function(v){return v?"¥"+Math.round(v/10000)+"万":"-";};
    // dashYearly.monthsが渡されていればそのまま使う
    var yjMos=(dashYearly&&dashYearly.months)||[];
    // 月別マップ
    var mData={};
    yjMos.forEach(function(m){if(m&&m.ym)mData[m.ym]={plBase:m.plBase||0,plOpt:m.plOpt||0,plDisc:m.plDisc||0,plRev:m.plRev||0,extraRev:m.extraRev||0,grand:m.totalRev||((m.plRev||0)+(m.extraRev||0)),cnt:m.plCnt||0,unitPrice:Math.round(m.unitPrice||0),avgNights:m.avgNights||0,dailyRate:Math.round(m.dailyRate||0),utilPct:m.utilPct||0};});
    // dashYearly.monthsがない場合は raw 計算にフォールバック
    var months12=[];for(var mo12=1;mo12<=12;mo12++){var ym12=yr+"-"+String(mo12).padStart(2,"0");if(ym12>=ps)months12.push(ym12);}
    if(yjMos.length===0){
      months12.forEach(function(ym){
        var dIM=new Date(parseInt(ym.slice(0,4)),parseInt(ym.slice(5)),0).getDate();
        var ret=active.filter(function(r){var rd=r[rdKey];return rd&&rd.slice(0,7)===ym;});
        var pb=0,po=0,pd=0,pr=0,dS=0;
        ret.forEach(function(r){var bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;var rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);var ld=r[ldKey],rd=r[rdKey];var n=ld&&rd?Math.max(0,Math.round((new Date(rd)-new Date(ld))/86400000)):0;pb+=((bp>0||op>0)?bp:(Number(r.price)||0));po+=op;pd+=dc;pr+=rev;dS+=n;});
        var ex=(extraByM||{})[ym]||0;
        var kpiM=kpiF[ym]||{};var actV=(allVehs||[]).filter(function(v){return v.active&&(!(v.code in kpiM)||kpiM[v.code]);});
        var maxD=actV.length*dIM;var uD=0;
        active.filter(function(r){var ld=r[ldKey],rd=r[rdKey];return ld&&rd&&ld<=ym+"-"+String(dIM).padStart(2,"0")&&rd>=ym+"-01";}).forEach(function(r){var vc=fMap[r.id];if(!vc)return;var mS=new Date(ym+"-01T00:00:00"),mE=new Date(ym+"-"+String(dIM).padStart(2,"0")+"T23:59:59");var ld2=new Date(r[ldKey]+"T00:00:00"),rd2=new Date(r[rdKey]+"T00:00:00");var s=ld2<mS?mS:ld2,e=rd2>mE?mE:rd2;uD+=Math.max(0,Math.round((e-s)/86400000));});
        mData[ym]={plBase:pb,plOpt:po,plDisc:pd,plRev:pr,extraRev:ex,grand:pr+ex,cnt:ret.length,unitPrice:ret.length?Math.round(pr/ret.length):0,avgNights:ret.length?dS/ret.length:0,dailyRate:uD?Math.round(pr/uD):0,utilPct:maxD?Math.round(uD/maxD*100):0};
      });
    }
    // 年計
    var totBase=0,totOpt=0,totDisc=0,totRev=0,totEx=0,totCnt=0;
    months12.forEach(function(ym){var m=mData[ym]||{};totBase+=(m.plBase||0);totOpt+=(m.plOpt||0);totDisc+=(m.plDisc||0);totRev+=(m.plRev||0);totEx+=(m.extraRev||0);totCnt+=(m.cnt||0);});
    var utilColor3=function(p){return p>=50?"#059669":p>=30?"#d97706":"#dc2626";};
    var tblRows3=months12.map(function(ym){
      var m=mData[ym],mo=parseInt(ym.slice(5));
      var isRepMo=(ym===repYm);
      var bg=isRepMo?"#eff6ff":"";
      var bw=isRepMo?"font-weight:700;":"";
      if(!m.cnt)return'<tr style="background:'+bg+'"><td style="'+bw+'">'+mo+'月</td><td>-</td><td>-</td><td>-</td><td>-</td><td>-</td><td style="color:#059669">-</td><td>-</td><td>-</td><td>-</td><td>-</td><td style="text-align:center"><span style="background:#e2e8f0;color:#94a3b8;padding:1px 5px;border-radius:3px;font-size:7.5pt">0%</span></td><td></td></tr>';
      var uc=utilColor3(m.utilPct);
      var barW=Math.min(100,m.utilPct*2)+'%';
      return'<tr style="background:'+bg+'">'+
        '<td style="'+bw+'font-weight:700">'+mo+'月</td>'+
        '<td style="text-align:right;color:#2563eb">'+fM(m.plBase)+'</td>'+
        '<td style="text-align:right;color:#059669">'+fM(m.plOpt)+'</td>'+
        '<td style="text-align:right;color:#dc2626">'+(m.plDisc>0?'-'+fM(m.plDisc):'-')+'</td>'+
        '<td style="text-align:right;font-weight:700">'+fM(m.plRev)+'</td>'+
        '<td style="text-align:right;color:#7c3aed">'+(m.extraRev>0?'+'+fM(m.extraRev):'-')+'</td>'+
        '<td style="text-align:right;font-weight:800;color:#059669">'+fM(m.grand)+'</td>'+
        '<td style="text-align:right">'+m.cnt+'件</td>'+
        '<td style="text-align:right">'+f(m.unitPrice)+'</td>'+
        '<td style="text-align:right">'+(m.avgNights>0?m.avgNights.toFixed(2)+'泊':'-')+'</td>'+
        '<td style="text-align:right">'+(m.dailyRate>0?f(m.dailyRate):'-')+'</td>'+
        '<td style="text-align:center"><span style="background:'+(m.utilPct>=50?"#dcfce7":m.utilPct>=30?"#fef9c3":"#fee2e2")+';color:'+uc+';padding:1px 5px;border-radius:3px;font-size:7.5pt;font-weight:700">'+m.utilPct+'%</span></td>'+
        '<td><div style="height:5px;background:#e2e8f0;border-radius:2px;width:60px"><div style="height:5px;background:'+uc+';border-radius:2px;width:'+barW+'"></div></div></td>'+
      '</tr>';
    }).join("");
    return '<div class="sec pb"><div class="st">⑥ 年間推移（'+yr+'年）<span style="font-size:7.5pt;color:#94a3b8;font-weight:400;margin-left:8px">ダッシュボードと同一ロジックで月別集計</span></div>'+
    '<div style="overflow-x:auto"><table style="min-width:900px;font-size:7.5pt">'+
    '<thead><tr style="background:#0f172a;color:#fff">'+
      '<th style="white-space:nowrap">月</th>'+
      '<th style="text-align:right;color:#93c5fd">基本料金</th>'+
      '<th style="text-align:right;color:#6ee7b7">付帯売上</th>'+
      '<th style="text-align:right;color:#fca5a5">割引</th>'+
      '<th style="text-align:right">売上計上</th>'+
      '<th style="text-align:right;color:#c4b5fd">予約外</th>'+
      '<th style="text-align:right;color:#6ee7b7;font-weight:900">合計売上</th>'+
      '<th style="text-align:right">件数</th>'+
      '<th style="text-align:right">客単価</th>'+
      '<th style="text-align:right">平均泊数</th>'+
      '<th style="text-align:right">泊単価</th>'+
      '<th style="text-align:center">稼働率</th>'+
      '<th style="text-align:center">売上グラフ</th>'+
    '</tr></thead><tbody>'+
    tblRows3+
    '<tr class="tr">'+
      '<td style="font-weight:700">合計</td>'+
      '<td style="text-align:right">'+fM(totBase)+'</td>'+
      '<td style="text-align:right">'+fM(totOpt)+'</td>'+
      '<td style="text-align:right">'+(totDisc>0?'-'+fM(totDisc):'-')+'</td>'+
      '<td style="text-align:right;font-weight:800">'+fM(totRev)+'</td>'+
      '<td style="text-align:right">'+(totEx>0?'+'+fM(totEx):'-')+'</td>'+
      '<td style="text-align:right;font-weight:900;color:#6ee7b7">'+fM(totRev+totEx)+'</td>'+
      '<td style="text-align:right">'+totCnt+'件</td>'+
      '<td style="text-align:right">'+(totCnt>0?f(Math.round(totRev/totCnt)):'-')+'</td>'+
      '<td style="text-align:center" colspan="3">年平均</td>'+
      '<td></td>'+
    '</tr>'+
    '</tbody></table></div></div>';
  })()+

  // 署名欄
  '<hr style="border:none;border-top:1px solid #e2e8f0;margin:12px 0">'+
  '<div class="sign"><div><div class="sl">担当者確認欄</div><div class="sb"></div></div><div><div class="sl">承認欄</div><div class="sb"></div></div></div>'+
  '<div style="text-align:right;font-size:7.5pt;color:#94a3b8;margin-top:8px">HANDYMAN '+sn+' | '+period+' | 作成: '+gd+'<br>本資料はHANDYMAN業務管理システムより自動出力されました。</div>'+
  '</body></html>';

  // ★ STEP4: ウィンドウにレポートHTMLを書き込む
  if(!w.closed){w.document.open();w.document.write(html);w.document.close();setTimeout(function(){if(!w.closed)w.print();},600);}
  }); // end adPromise.then
}


function openPdfReport_(dbStore,dashPeriod,dashYm,kpi,yr,resvs){
  var isSpk=dbStore==="spk";
  var sn=isSpk?"札幌デリバリー専門店":"BUDDICA TOURISM 高松空港店";
  var co="株式会社Global Lines";
  var period=dashPeriod==="month"?dashYm.slice(0,4)+"年"+parseInt(dashYm.slice(5))+"月":dashYm.slice(0,4)+"年（年間）";
  var gd=new Date().toLocaleDateString("ja-JP",{year:"numeric",month:"long",day:"numeric",timeZone:"Asia/Tokyo"});
  var f=function(n){return"￥"+Math.round(n||0).toLocaleString();};
  var p=function(a,b){return b>0?Math.round((a||0)/b*100)+"%":"-%";};
  var ex=kpi.extraRev||0;var tot=(kpi.plRev||0)+ex;
  var mos=(yr&&yr.months)||[];var yrt=yr&&yr.total||{};
  var ud=mos.reduce(function(a,m){return a+(m.utilDays||0);},0);
  var umd=mos.reduce(function(a,m){return a+(m.utilMaxDays||1);},0);

  // OTA別集計: dashKpi.byChBreak を使用（アプリと同じ計算値で金額一致を保証）
  // + dbResvs から件数・泊数の補足データを取得
  var OTA_LABELS={J:"じゃらん",R:"楽天",S:"スカイチケット",O:"エアトリ",HP:"HP直販",G:"GoGoOut",RC:"レンタカードットコム",SP:"スタッフ予約",direct:"直接"};
  var rdKey=isSpk?"return_date":"end_date";
  var ldKey=isSpk?"lend_date":"start_date";
  var year=dashYm.slice(0,4);
  // 件数・泊数をresvs からサブ集計
  var otaSub={};
  (resvs||[]).forEach(function(r){
    if(r.status==="cancelled")return;
    var rd=r[rdKey]||"";
    var match=dashPeriod==="month"?rd.startsWith(dashYm):rd.startsWith(year);
    if(!match)return;
    var ch=r.ota||"不明";
    if(!otaSub[ch])otaSub[ch]={cnt:0,nights:0};
    otaSub[ch].cnt++;
    var ld=r[ldKey]||"",rd2=r[rdKey]||"";
    if(ld&&rd2){var d1=new Date(ld+"T00:00:00"),d2=new Date(rd2+"T00:00:00");var nights=Math.max(0,Math.round((d2-d1)/86400000));otaSub[ch].nights+=nights;}
  });
  // byChBreak の金額を正として行を生成
  var chs2=Object.entries(kpi.byChBreak||{}).sort(function(a,b){return b[1].rev-a[1].rev;});
  var otaRows=chs2.map(function(r){var ch=r[0],d=r[1];var sub=otaSub[ch]||{cnt:d.cnt||0,nights:0};return[ch,{rev:d.rev,cnt:sub.cnt||d.cnt||0,nights:sub.nights||0,base:d.base||0,opt:d.opt||0}];});
  var totalOtaRev=kpi.plRev||0; // dashKpi の値を正とする

  var css="@page{size:A4;margin:15mm 12mm}*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Hiragino Kaku Gothic Pro','Noto Sans JP',sans-serif;font-size:9.5pt;color:#1a202c;line-height:1.5}.cv{text-align:center;padding:20px 0 14px;border-bottom:3px solid #1e40af;margin-bottom:16px}.sec{margin-bottom:12px}.st{font-size:10.5pt;font-weight:800;color:#1e40af;border-left:4px solid #1e40af;padding-left:8px;margin-bottom:6px}.hl{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;margin-bottom:8px}.hlc{background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;padding:6px 10px;display:flex;justify-content:space-between;align-items:center}.kg{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:8px}.kc{background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:6px 8px}.kl{font-size:7.5pt;color:#64748b;margin-bottom:1px}.kv{font-size:13pt;font-weight:900}.ks{font-size:7.5pt;color:#94a3b8}table{width:100%;border-collapse:collapse;font-size:8.5pt}th{background:#1e40af;color:#fff;padding:4px 7px;font-weight:700;text-align:left;font-size:8pt}td{padding:3px 7px;border-bottom:1px solid #e2e8f0}tr:nth-child(even) td{background:#f8fafc}.tr{background:#1e293b!important}.tr td{color:#fff!important}.tc{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px}.sb{border:1px solid #cbd5e1;border-radius:6px;padding:6px 10px;min-height:44px}.sl{font-size:7.5pt;color:#94a3b8;margin-bottom:3px}.pb{break-before:page}@media print{body{-webkit-print-color-adjust:exact;print-color-adjust:exact}}";

  // ── セクション生成 ──
  // チャンネル別
  var chs=Object.entries(kpi.byChBreak||{}).sort(function(a,b){return b[1].rev-a[1].rev;});
  var chSec=chs.length>0?('<div class="sec"><div class="st">チャンネル別売上構成</div>'+
    '<table><thead><tr><th>チャンネル</th><th>売上</th><th>基本料金</th><th>付帯</th><th>件数</th><th>客単価</th><th>構成比</th></tr></thead><tbody>'+
    chs.map(function(r){var ch=r[0],d=r[1];var up=d.cnt>0?Math.round(d.rev/d.cnt):0;return'<tr><td>'+ch+'</td><td>'+f(d.rev)+'</td><td>'+f(d.base||0)+'</td><td>'+f(d.opt||0)+'</td><td>'+(d.cnt||0)+'件</td><td>'+f(up)+'</td><td>'+p(d.rev,kpi.plRev)+'</td></tr>';}).join("")+
    '</tbody></table></div>'):"";

  // OTA別集計
  var otaSec=otaRows.length>0?('<div class="sec"><div class="st">OTA別実績</div>'+
    '<table><thead><tr><th>OTA</th><th>売上</th><th>件数</th><th>客単価</th><th>平均泊数</th><th>構成比</th></tr></thead><tbody>'+
    otaRows.map(function(r){var n=r[0],d=r[1];var lbl=OTA_LABELS[n]||n;var up=d.cnt>0?Math.round(d.rev/d.cnt):0;var an=d.cnt>0?(d.nights/d.cnt).toFixed(1):"-";return'<tr><td>'+lbl+' ('+n+')</td><td>'+f(d.rev)+'</td><td>'+d.cnt+'件</td><td>'+f(up)+'</td><td>'+an+'泊</td><td>'+p(d.rev,totalOtaRev)+'</td></tr>';}).join("")+
    '</tbody></table></div>'):"";

  // 月別詳細推移（年モード：全列）
  var moSec=dashPeriod==="year"&&mos.length>0?('<div class="sec pb"><div class="st">月別推移詳細（'+yr.year+'年）</div>'+
    '<table><thead><tr><th>月</th><th>合計売上</th><th>基本料金</th><th>付帯</th><th>割引</th><th>件数</th><th>稼働率</th><th>客単価</th><th>平均泊数</th></tr></thead><tbody>'+
    mos.map(function(m){return'<tr><td>'+(m.mo||"")+'月</td><td>'+f((m.plRev||0)+(m.extraRev||0))+'</td><td>'+f(m.plBase||0)+'</td><td>'+f(m.plOpt||0)+'</td><td>'+f(m.plDisc||0)+'</td><td>'+(m.plCnt||0)+'件</td><td>'+(m.utilPct||0)+'%</td><td>'+f(m.unitPrice||0)+'</td><td>'+((m.avgNights||0).toFixed(1))+'泊</td></tr>';}).join("")+
    '<tr class="tr"><td>年計</td><td>'+f((yrt.plRev||0)+(yrt.extraRev||0))+'</td><td>'+f(yrt.plBase||0)+'</td><td>'+f(yrt.plOpt||0)+'</td><td>'+f(yrt.plDisc||0)+'</td><td>'+(yrt.plCnt||0)+'件</td><td>'+(umd>0?Math.round(ud/umd*100):0)+'%</td><td>'+f(yrt.plCnt>0?(yrt.plRev||0)/yrt.plCnt:0)+'</td><td>'+((yrt.plCnt>0?(yrt.daysSum||0)/yrt.plCnt:0).toFixed(1))+'泊</td></tr>'+
    '</tbody></table></div>'):"";

  // 月別チャンネル×月 クロス（年モード）
  var ybch=yr&&yr.yearByCh||{};
  var chNames=Object.keys(ybch).sort();
  var crossSec=dashPeriod==="year"&&chNames.length>0&&mos.length>0?('<div class="sec"><div class="st">チャンネル別 月次内訳（'+yr.year+'年・売上）</div>'+
    '<table style="font-size:7.5pt"><thead><tr><th>チャンネル</th>'+mos.map(function(m){return'<th>'+m.mo+'月</th>';}).join("")+'<th>年計</th></tr></thead><tbody>'+
    chNames.map(function(ch){var d=ybch[ch]||{};return'<tr><td>'+ch+'</td>'+mos.map(function(m){var v=d[m.mo]||0;return'<td style="text-align:right">'+(v>0?Math.round(v/10000)+"万":"-")+'</td>';}).join("")+'<td style="text-align:right;font-weight:700">'+Math.round((d.total||0)/10000)+'万</td></tr>';}).join("")+
    '</tbody></table></div>'):"";

  var html='<!DOCTYPE html><html lang="ja"><head><meta charset="UTF-8"><title>経営レポート '+period+'</title><style>'+css+'</style></head><body>'+
  '<div class="cv"><div style="font-size:9.5pt;color:#64748b;margin-bottom:3px">'+co+'</div>'+
  '<div style="font-size:17pt;font-weight:900;color:#1e40af;margin-bottom:3px">BUDDICA TOURISM '+sn+'</div>'+
  '<div style="font-size:12pt;font-weight:700;color:#374151;margin-bottom:6px">経営月次レポート</div>'+
  '<div style="display:inline-block;font-size:11pt;font-weight:700;color:#2563eb;background:#eff6ff;padding:3px 16px;border-radius:20px">'+period+'</div>'+
  '<div style="font-size:8.5pt;color:#94a3b8;margin-top:6px">作成日: '+gd+'</div></div>'+

  '<div class="sec"><div class="st">経営サマリー</div>'+
  '<div class="hl">'+
    '<div class="hlc"><span style="font-size:8.5pt">合計売上</span><span style="font-size:13pt;font-weight:900;color:#059669">'+f(tot)+'</span></div>'+
    '<div class="hlc"><span style="font-size:8.5pt">入金（CF）</span><span style="font-size:13pt;font-weight:900;color:#d97706">'+f(kpi.cfIn||0)+'</span></div>'+
    '<div class="hlc"><span style="font-size:8.5pt">予約売上</span><span style="font-size:12pt;font-weight:700;color:#2563eb">'+f(kpi.plRev)+'</span></div>'+
    (ex>0?'<div class="hlc"><span style="font-size:8.5pt">予約外売上</span><span style="font-size:12pt;font-weight:700;color:#7c3aed">'+f(ex)+'</span></div>':'')+
  '</div>'+
  '<div class="kg">'+
    '<div class="kc"><div class="kl">予約件数</div><div class="kv" style="color:#2563eb">'+(kpi.plCnt||0)+'件</div></div>'+
    '<div class="kc"><div class="kl">稼働率</div><div class="kv" style="color:'+((kpi.utilPct||0)>=70?"#059669":"#d97706")+'">'+(kpi.utilPct||0)+'%</div><div class="ks">'+(kpi.utilDays||0)+'/'+(kpi.utilMaxDays||0)+'日</div></div>'+
    '<div class="kc"><div class="kl">客単価</div><div class="kv">'+f(kpi.unitPrice||0)+'</div></div>'+
    '<div class="kc"><div class="kl">平均泊数</div><div class="kv">'+((kpi.avgNights||0).toFixed(1))+'泊</div></div>'+
  '</div></div>'+

  '<div class="sec"><div class="st">売上内訳（4分解）</div>'+
  '<table><thead><tr><th>項目</th><th>金額</th><th>構成比</th></tr></thead><tbody>'+
    '<tr><td>基本料金</td><td>'+f(kpi.plBase||0)+'</td><td>'+p(kpi.plBase,tot)+'</td></tr>'+
    '<tr><td>付帯売上</td><td>'+f(kpi.plOpt||0)+'</td><td>'+p(kpi.plOpt,tot)+'</td></tr>'+
    (ex>0?'<tr><td>予約外売上</td><td>'+f(ex)+'</td><td>'+p(ex,tot)+'</td></tr>':'')+
    '<tr><td>割引</td><td>-'+f(kpi.plDisc||0)+'</td><td>-</td></tr>'+
    '<tr class="tr"><td>合計売上</td><td>'+f(tot)+'</td><td>100%</td></tr>'+
  '</tbody></table></div>'+

  chSec+otaSec+moSec+crossSec+

  '<hr style="border:none;border-top:1px solid #e2e8f0;margin:10px 0">'+
  '<div class="tc"><div><div class="sl">担当者確認欄</div><div class="sb"></div></div>'+
  '<div><div class="sl">承認欄</div><div class="sb"></div></div></div>'+
  '<div style="text-align:right;font-size:7.5pt;color:#94a3b8;margin-top:8px">'+
    'BUDDICA TOURISM '+sn+' | '+period+' | 作成: '+gd+'<br>'+
    '本資料はBUDDICA TOURISM業務管理システムより自動出力されました。数値は計上ベースです。'+
  '</div></body></html>';

  var w=window.open("","_blank","width=1000,height=800");
  if(w){w.document.write(html);w.document.close();w.print();}
}

function ManagementTab({store}){
  const[sub,setSub]=useState("dashboard");

  // ★ 設定保存ヘルパー: app_settings RLS UPSERT問題を回避
  // TKM→bt_app_settings(upsert正常) / SPK→app_settings(INSERT→PATCH)
  const settingsUpsertRef = React.useRef(null);
  settingsUpsertRef.current = async(isNhaData,key,value)=>{
    if(!sb)return;
    if(isNhaData){
      await sb.from("bt_app_settings").upsert({key,value},{onConflict:"key"});
    }else{
      const{error:ie}=await sb.from("app_settings").insert({key,value});
      if(ie&&ie.code==="23505"){
        await sb.from("app_settings").update({value}).eq("key",key);
      }
    }
  };
  const settingsUpsert_ = React.useCallback((...args)=>settingsUpsertRef.current(...args),[]);

  const[loading,setLoading]=useState(false);
  const[msg,setMsg]=useState("");
  const[channels,setChannels]=useState([]);
  // 売上入力用
  const[salesRows,setSalesRows]=useState([]);
  const[salesFilter,setSalesFilter]=useState({ym:"",channel:"",vt:""});
  const[editing,setEditing]=useState(null); // {id,...}
  const[newEntry,setNewEntry]=useState(null);
  // PL/CF (computed from dbResvs + costAllMonths in plPivot/cfPivot)
  // コスト入力
  const[costRows,setCostRows]=useState([]);
  const[costYm,setCostYm]=useState("");
  // 全月コスト（PL/CF連動用）: {ym: [{account_code, amount, note}]}
  const[costAllMonths,setCostAllMonths]=useState({});
  // 直近予約変動
  const[recentData,setRecentData]=useState(null);
  const[recentLoading,setRecentLoading]=useState(false);
  const[recentHours,setRecentHours]=useState(6);
  // 当月ダッシュボード
  const[dashYm,setDashYm]=useState(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");});
  const[reportYm,setReportYm]=useState(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")}); // 月次レポート対象月
  const[dashChView,setDashChView]=useState("month"); // "month" | "year"
  const[dashPeriod,setDashPeriod]=useState("month"); // "month" | "year" ★ ヘッダー月/年トグル
  // ★ 2026-04-25 データ健全性チェック state
  const[hcChecking,setHcChecking]=useState(false);
  const[hcResults,setHcResults]=useState(null);
  const[hcLastRunAt,setHcLastRunAt]=useState("");

  // ===== 経営DB (Excel再現ダッシュボード) =====
  const[dbStore,setDbStore]=useState(store||"tkm");
  const[dbResvs,setDbResvs]=useState([]);
  const[dbFleet,setDbFleet]=useState([]);
  const[dbVehs,setDbVehs]=useState([]);
  const[dbKpi,setDbKpi]=useState([]);
  const[dbMaint,setDbMaint]=useState([]);
  const[dbTasks,setDbTasks]=useState([]);
  const[dbPlaces,setDbPlaces]=useState([]);
  const[dbLoading2,setDbLoading2]=useState(false);
  const[dbTargets,setDbTargets]=useState({});  // {ym: {rev:目標売上, cnt:目標件数, perV:台/売上目標}}
  // ★ 解析タブ用: 予約外売上（type='extra_sales'、じゃらん事前決済除外）月別マップ
  const[extraByM,setExtraByM]=useState({}); // {YYYY-MM: amount}
  useEffect(()=>{
    if(!sb)return;
    const tbl=dbStore==="spk"?"spk_accounting":"bt_accounting";
    (async()=>{
      const{data:rows}=await sb.from(tbl).select("date,amount,description").eq("type","extra_sales");
      const m={};
      (rows||[]).forEach(r=>{
        if((r.description||"").startsWith("じゃらん事前決済"))return;
        const k=(r.date||"").slice(0,7);if(!k)return;
        m[k]=(m[k]||0)+(Number(r.amount)||0);
      });
      setExtraByM(m);
    })();
  },[dbStore]);
  // 解析セクション開閉（デフォルト: 全て折り畳み）
  const[secOpen,setSecOpen]=useState({A:false,B:false,C:false,D:false,E:false});
  const[analyticsDataKey,setAnalyticsDataKey]=useState(0); // 解析タブを開くたびにインクリメント → 強制リロード
  // 解析タブに切り替わるたびに強制リロード（kpiデータ等の最新化）
  useEffect(()=>{if(sub==="analytics")setAnalyticsDataKey(k=>k+1);},[sub]);
  // E. 車両別P&L用: 整備ログ
  const[hmLogsForPL,setHmLogsForPL]=useState([]);
  const toggleSec=(k)=>setSecOpen(p=>({...p,[k]:!p[k]}));
  // 解析タブ 全セクション共通期間フィルタ
  const[analyticsPeriod,setAnalyticsPeriod]=useState(()=>{const d=new Date();return{mode:"month",ym:d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0"),year:String(d.getFullYear())};});
  // 投資回転率コスト仮定
  const[roiCost,setRoiCost]=useState({insurance:12000,parking:17600,inspection:5000,maintenance:5000});
  // 車両原価マスタ {[code]:{costType,monthlyFee,insuranceAnnual,shakenAnnual,inspection6m}}
  const[vehicleCosts,setVehicleCosts]=useState({});
  // 売上入力フィルタ
  const[salesYmF,setSalesYmF]=useState("");
  const[salesChF,setSalesChF]=useState("");
  const[salesResvF,setSalesResvF]=useState("");
  const[salesEditId,setSalesEditId]=useState(null);
  const[salesEditVals,setSalesEditVals]=useState({bp:0,op:0,dc:0});
  // 予算CF
  const[bcfStore,setBcfStore]=useState("tkm");
  const[hpcvOpenYears,setHpcvOpenYears]=useState({});
  const[bcfData,setBcfData]=useState({tkm:{},spk:{}});
  // 予実比較
  const[yjData,setYjData]=useState({tkm:{},spk:{}});
  const yjLoadedRef=React.useRef(false);
  const[yjCf,setYjCf]=useState({tkm:{},spk:{}});
  // KPI管理表 広告費効率: 経営管理シート + コスト内訳（sga_ad）
  const[cmMap,setCmMap]=useState({tkm:{},spk:{}});
  const[costMap,setCostMap]=useState({tkm:{},spk:{}});
  // 設定（マスターデータ）
  const[mgSettings,setMgSettings]=useState({
    channels:[
      {name:"オフィシャル",cycle:0,note:"入金日を手入力（予約当日）"},
      {name:"じゃらん",cycle:0,note:"当月末入金"},
      {name:"楽天",cycle:3,note:"3ヶ月後末入金"},
      {name:"エアトリ",cycle:1,note:"翌月末入金"},
      {name:"レンタカードットコム",cycle:1,note:"翌月末入金"},
      {name:"スカイチケット",cycle:1,note:"翌月末入金"},
      {name:"その他売上",cycle:0,note:"当月末"},
    ],
    initCash:10000000,minCash:0,runrateMonths:3,
  });

  const storeLabel=store==="spk"?"札幌店":(store==="tkm"?"高松店":store);

  // チャネル一覧（固定定義 — DB不使用）

  // 売上ロード
  const loadSales=useCallback(async(opts={})=>{
    if(!sb)return;
    setLoading(true);
    let q=sb.from("sales_entries").select("*").eq("store",store).order("return_date",{ascending:false}).limit(2000);
    if(opts.ym)q=q.eq("fiscal_month",opts.ym);
    if(opts.channel)q=q.eq("channel",opts.channel);
    if(opts.vt)q=q.eq("vehicle_type",opts.vt);
    const{data,error}=await q;
    if(error){setMsg("ERROR: "+error.message);}
    else{setSalesRows(data||[]);setMsg("");}
    setLoading(false);
  },[store]);

  // コストロード（app_settingsベース）
  const loadCost=useCallback(async(ym)=>{
    if(!sb||!ym)return;
    const key="cost_"+dbStore+"_"+ym;
    const{data}=await sb.from("app_settings").select("*").eq("key",key).single();
    if(data&&data.value)try{setCostRows(JSON.parse(data.value));}catch(e){setCostRows([]);}
    else setCostRows([]);
  },[dbStore]);
  // 全月コストロード（PL/CF連動用）
  const loadCostAll=useCallback(async(st)=>{
    if(!sb)return;
    const{data}=await sb.from("app_settings").select("*").like("key","cost_"+st+"_%");
    const mp={};
    (data||[]).forEach(d=>{
      const ym=d.key.replace("cost_"+st+"_","");
      try{mp[ym]=JSON.parse(d.value);}catch(e){}
    });
    setCostAllMonths(mp);
  },[]);
  // コスト保存
  const saveCostEntry=useCallback(async(ym,acctCode,amount,note)=>{
    const updated=[...costRows.filter(r=>r.account_code!==acctCode),{account_code:acctCode,amount:parseInt(amount)||0,note:note||""}].filter(r=>r.amount>0||r.note);
    setCostRows(updated);
    if(!sb)return;
    const key="cost_"+dbStore+"_"+ym;
    await settingsUpsert_(dbStore==="tkm",key,JSON.stringify(updated));
    setCostAllMonths(prev=>({...prev,[ym]:updated}));
  },[dbStore,costRows,settingsUpsert_]);

  // 経営DB: データロード（ページネーション付き）
  // ★ テーブルによりPKが異なる: bt_tasks/tasks は _id、それ以外は id
  // ORDER BY 指定なしだとページ間で順序が不定 → 重複/欠損発生する
  const loadDbAll=useCallback(async(table)=>{
    if(!sb)return[];
    // ★ 2026-04-25 fix: bt_fleet/fleet のPKを reservation_id に修正
    // ★ 2026-05-08 fix: bt_vehicle_monthly_kpi/vehicle_monthly_kpi は id列なし（複合PK）→ vehicle_code でソート
    //   旧: id にfallback → "column ... does not exist" エラー → 空配列返却 → 解析タブ稼働率が誤計算 (56台/36%)
    //   正: vehicle_code でソート + 合成キー dedup
    const isKpiTable=(table==="bt_vehicle_monthly_kpi"||table==="vehicle_monthly_kpi");
    const pkCol=(table==="bt_tasks"||table==="tasks")?"_id":(table==="bt_vehicles"||table==="vehicles")?"code":(table==="bt_fleet"||table==="fleet")?"reservation_id":isKpiTable?"vehicle_code":"id";
    let all=[],offset=0;
    while(true){
      const{data,error}=await sb.from(table).select("*").order(pkCol,{ascending:true}).range(offset,offset+999);
      if(error){console.error("loadDbAll",table,error.message);break;}
      if(!data||data.length===0)break;
      all=all.concat(data);
      if(data.length<1000)break;
      offset+=1000;
    }
    // ★ 念のためPKで最終 dedup（kpiテーブルは year_month+vehicle_code の合成キー）
    const seen=new Set(),uniq=[];
    for(const r of all){
      const key=isKpiTable?(r&&(r.year_month+"|"+r.vehicle_code)):(r&&(r[pkCol]!==undefined?r[pkCol]:r.id));
      if(key!==undefined&&!seen.has(key)){seen.add(key);uniq.push(r);}
    }
    return uniq;
  },[]);

  useEffect(()=>{
    if(!["exceldash","pl","cf","dashboard","hpcv","budgetcf","roi","cfsim","costsum","analytics","yojitsu"].includes(sub)||!sb)return;
    setDbLoading2(true);
    const isSpk=dbStore==="spk";
    const tasksTable=isSpk?"tasks":"bt_tasks";
    Promise.all([
      loadDbAll(isSpk?"reservations":"bt_reservations"),
      loadDbAll(isSpk?"fleet":"bt_fleet"),
      loadDbAll(isSpk?"vehicles":"bt_vehicles"),
      loadDbAll(isSpk?"vehicle_monthly_kpi":"bt_vehicle_monthly_kpi"),
      sub==="analytics"?loadDbAll(tasksTable):Promise.resolve([]),
      sub==="analytics"?sb.from("bt_logs").select("car_id,date,cost,type").eq("store_id","takamatsu").then(r=>r.data||[]):Promise.resolve([]),
      loadDbAll(isSpk?"maintenance":"bt_maintenance"),
    ]).then(([r,f,v,k,t,hl,mnt])=>{
      setDbResvs(r);setDbFleet(f);setDbVehs(v);setDbKpi(k);setDbMaint(mnt||[]);
      if(hl)setHmLogsForPL(hl);
      // ★ bt_tasks は日本語カラム（内容=type / 予約番号=resId）。SPKの tasks はカラム名が英語。両対応。
      if(sub==="analytics"){
        const filtered=(t||[]).filter(tk=>{
          const ty=isSpk?tk.type:tk["内容"];
          return ty==="DEL"||ty==="COL";
        }).map(tk=>{
          // D構成分析で使うため reservationId / type を正規化して持たせる
          if(isSpk)return tk;
          return Object.assign({},tk,{reservationId:tk["予約番号"],type:tk["内容"]});
        });
        setDbTasks(filtered);
        // places テーブルをロード（OPシートCSV場所データの正本）
        // ★ 2026-06-17 prefix漏れ修正: BTは bt_places（独立Supabase）。無印places は空/エラー→場所マップが常に空になっていた
        if(sb)sb.from("bt_places").select("reservation_id,del_place,col_place")
          .then(({data})=>setDbPlaces(data||[]));
      }
      setDbLoading2(false);
    }).catch(()=>setDbLoading2(false));
    // 目標値をロード
    sb.from("app_settings").select("*").eq("key","budget_targets_"+(isSpk?"spk":"tkm")).single()
      .then(({data})=>{if(data&&data.value)try{setDbTargets(JSON.parse(data.value));}catch(e){}});
    // 全月コストをロード（PL/CF連動用）
    loadCostAll(isSpk?"spk":"tkm");
    // 車両原価マスタをロード
    const vcTable=isSpk?"app_settings":"bt_app_settings";
    sb.from(vcTable).select("value").eq("key","vehicle_costs").single()
      .then(({data})=>{if(data?.value)try{setVehicleCosts(typeof data.value==="string"?JSON.parse(data.value):data.value);}catch(e){}});
  },[sub,dbStore,analyticsDataKey]);

  // 予算CFデータロード
  useEffect(()=>{
    if(sub!=="budgetcf"||!sb)return;
    Promise.all([
      sb.from("app_settings").select("*").eq("key","budgetcf_tkm").single(),
      sb.from("app_settings").select("*").eq("key","budgetcf_spk").single(),
    ]).then(([{data:d1},{data:d2}])=>{
      const tkm=d1?.value?JSON.parse(d1.value):{};
      const spk=d2?.value?JSON.parse(d2.value):{};
      setBcfData({tkm,spk});
    });
  },[sub]);

  const saveDbTarget=useCallback(async(ym,field,val)=>{
    const nv=parseInt(val)||0;
    const next={...dbTargets,[ym]:{...(dbTargets[ym]||{}), [field]:nv}};
    setDbTargets(next);
    if(!sb)return;
    const key="budget_targets_"+dbStore;
    const json=JSON.stringify(next);
    await settingsUpsert_(dbStore==="tkm",key,json);
  },[dbTargets,dbStore,settingsUpsert_]);

  // 直近予約変動: タブ表示時に自動ロード
  useEffect(()=>{
    if(sub!=="recent"||!sb)return;
    const cutoff=new Date(Date.now()-recentHours*3600000).toISOString();
    setRecentLoading(true);
    Promise.all([
      sb.from("bt_reservations").select("id,ota,status,created_at,end_date,start_date,price,base_price,option_price,discount,customer_name,guest_name").gte("created_at",cutoff).neq("status","cancelled").neq("status","キャンセル").neq("status","cancel").order("created_at",{ascending:false}),
      sb.from("bt_reservations").select("id,ota,status,created_at,updated_at,end_date,start_date,price,base_price,option_price,discount,customer_name,guest_name").gte("updated_at",cutoff).in("status",["cancelled","キャンセル","cancel"]).order("updated_at",{ascending:false}),
      sb.from("reservations").select("id,ota,status,created_at,return_date,lend_date,price,base_price,option_price,discount,customer_name,guest_name").gte("created_at",cutoff).neq("status","cancelled").neq("status","キャンセル").neq("status","cancel").order("created_at",{ascending:false}),
      sb.from("reservations").select("id,ota,status,created_at,updated_at,return_date,lend_date,price,base_price,option_price,discount,customer_name,guest_name").gte("updated_at",cutoff).in("status",["cancelled","キャンセル","cancel"]).order("updated_at",{ascending:false}),
    ]).then(([{data:nhNew},{data:nhCan},{data:spNew},{data:spCan}])=>{
      const revCalcR=(r)=>{const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;return(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);};
      const addStore=(arr,store,rdKey,ldKey)=>(arr||[]).map(r=>({...r,_store:store,_rd:r[rdKey],_ld:r[ldKey],_rev:revCalcR(r),_ch:DB_OTA_MAP[r.ota]||"その他売上"}));
      const newAll=[...addStore(nhNew,"高松","end_date","start_date"),...addStore(spNew,"札幌","return_date","lend_date")].sort((a,b)=>b.created_at.localeCompare(a.created_at));
      const canAll=[...addStore(nhCan,"高松","end_date","start_date"),...addStore(spCan,"札幌","return_date","lend_date")].sort((a,b)=>(b.updated_at||"").localeCompare(a.updated_at||""));
      setRecentData({newAll,canAll,ts:new Date().toLocaleString("ja-JP"),hours:recentHours});
      setRecentLoading(false);
    }).catch(e=>{setRecentData({error:e.message});setRecentLoading(false);});
  },[sub,recentHours]);

  // 予実比較: データロード
  useEffect(()=>{
    if(sub!=="yojitsu"||!sb)return;
    Promise.all([
      sb.from("app_settings").select("*").eq("key","yojitsu_tkm").single(),
      sb.from("app_settings").select("*").eq("key","yojitsu_spk").single(),
    ]).then(([{data:d1},{data:d2}])=>{
      if(yjLoadedRef.current)return;
      const tkm=d1?.value?JSON.parse(d1.value):{};
      const spk=d2?.value?JSON.parse(d2.value):{};
      setYjData({tkm,spk});yjLoadedRef.current=true;
    });
    // 入金実績: bt_accountingとaccountingから月別入金額を集計
    Promise.all([
      loadDbAll("bt_reservations"),
      loadDbAll("reservations"),
    ]).then(([nhaR,spkR])=>{
      // CF入金=売上計上ベースで代用（入金タイミングずれは将来対応）
      const calc=(rows,rdKey)=>{
        const byYm={};
        rows.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel").forEach(r=>{
          const rd=r[rdKey];if(!rd)return;
          const ym=rd.slice(0,7);
          const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
          const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
          byYm[ym]=(byYm[ym]||0)+rev;
        });
        return byYm;
      };
      setYjCf({tkm:calc(nhaR,"end_date"),spk:calc(spkR,"return_date")});
    });
    // KPI管理表 広告費効率: cm_xxx + cost_xxx を一括ロード
    Promise.all([
      sb.from("bt_app_settings").select("key,value").like("key","cm_bt_%").limit(200),
      sb.from("bt_app_settings").select("key,value").like("key","cm_spk_%").limit(200),
      sb.from("bt_app_settings").select("key,value").like("key","cost_bt_%").limit(200),
      sb.from("bt_app_settings").select("key,value").like("key","cost_spk_%").limit(200),
    ]).then(([{data:cn},{data:cs},{data:cnc},{data:csc}])=>{
      const parse=(rows,prefix)=>{
        const m={};
        (rows||[]).forEach(r=>{
          const ym=(r.key||"").replace(prefix,"");
          if(!ym)return;
          try{ m[ym]=typeof r.value==="string"?JSON.parse(r.value):r.value; }catch(e){ m[ym]={}; }
        });
        return m;
      };
      setCmMap({tkm:parse(cn,"cm_bt_"),spk:parse(cs,"cm_spk_")});
      setCostMap({tkm:parse(cnc,"cost_bt_"),spk:parse(csc,"cost_spk_")});
    }).catch(()=>{});
  },[sub]);

  const saveYjField=useCallback(async(st,ym,field,val)=>{
    const nv=parseInt(val)||0;
    const next={...yjData,[st]:{...(yjData[st]||{}),[ym]:{...((yjData[st]||{})[ym]||{}),[field]:nv}}};
    setYjData(next);
    if(!sb)return;
    await settingsUpsert_(false,"yojitsu_"+st,JSON.stringify(next[st]));
  },[yjData,settingsUpsert_]);

  // 設定ロード
  useEffect(()=>{
    if(sub!=="settings"||!sb)return;
    sb.from("app_settings").select("*").eq("key","mg_settings").single()
      .then(({data})=>{if(data?.value)try{setMgSettings(p=>({...p,...JSON.parse(data.value)}));}catch(e){}});
  },[sub]);

  const saveMgSettings=useCallback(async(next)=>{
    setMgSettings(next);
    if(!sb)return;
    await settingsUpsert_(false,"mg_settings",JSON.stringify(next));
  },[settingsUpsert_]);

  // 経営DB: メトリクス計算
  const DB_CHANNELS=["オフィシャル","じゃらん","楽天","エアトリ","レンタカードットコム","スカイチケット","その他売上"];
  const DB_OTA_MAP={"HP":"オフィシャル","J":"じゃらん","R":"楽天","O":"エアトリ","A":"エアトリ","S":"スカイチケット","RC":"レンタカードットコム","G":"その他売上","direct":"その他売上"};
  const DB_VEH_TYPES=["A","B","C","D","E","H","S","F"];

  const dbMetrics=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";

    // Fleet map: reservation_id -> vehicle_code
    const fMap={};
    dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
    // Vehicle map: code -> obj
    const vMap={};
    dbVehs.forEach(v=>{vMap[v.code]=v;});
    // KPI flags: {ym: {code: active}}
    const kpiF={};
    dbKpi.forEach(k=>{
      if(!kpiF[k.year_month])kpiF[k.year_month]={};
      kpiF[k.year_month][k.vehicle_code]=k.active;
    });

    const months={};
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");

    active.forEach(r=>{
      const rd=r[rdKey];
      if(!rd)return;
      const ym=rd.slice(0,7);
      if(!months[ym])months[ym]={
        chRev:{},chCnt:{},vtRev:{},vtCnt:{},
        delOta:0,delHp:0,
        totalRev:0,totalCnt:0,
        totalBase:0,totalOpt:0,totalDisc:0,
      };
      const m=months[ym];
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      // ★ 売上計上 = base_price + option_price - discount（割引差引後の最終金額）
      // base_price/option_price が未設定(0)の場合は price をフォールバック
      const bp=Number(r.base_price)||0;
      const op=Number(r.option_price)||0;
      const dc=Number(r.discount)||0;
      const hasBreakdown=bp>0||op>0;
      const revenue=hasBreakdown?(bp+op-dc):(Number(r.price)||0);

      m.chRev[ch]=(m.chRev[ch]||0)+revenue;
      m.chCnt[ch]=(m.chCnt[ch]||0)+1;
      m.totalRev+=revenue;
      m.totalCnt+=1;
      m.totalBase+=bp;
      m.totalOpt+=op;
      m.totalDisc+=dc;

      // デリバリー（札幌=デリバリー専門→全件DEL、高松=visit_typeから判定）
      const isDel=isSpk?true:(()=>{const vt_raw=(r.visit_type||"").toUpperCase();return vt_raw.includes("DEL")||vt_raw==="L"||vt_raw.includes("配達");})();
      if(isDel){if(ch==="オフィシャル")m.delHp++;else m.delOta++;}

      // 車両タイプ別（fleet経由でvehiclesのtypeを取得）
      const vc=fMap[r.id];
      const vObj=vc?vMap[vc]:null;
      let vType="?";
      if(vObj){vType=vObj.type||"?";}
      else if(isSpk&&r.vehicle){vType=r.vehicle;}
      else if(!isSpk&&r.vehicle_class){vType=r.vehicle_class;}
      if(vType&&vType!=="?"){
        m.vtRev[vType]=(m.vtRev[vType]||0)+revenue;
        m.vtCnt[vType]=(m.vtCnt[vType]||0)+1;
      }
    });

    // 稼働率計算（月ごと）
    const ymList=Object.keys(months).sort();
    ymList.forEach(ym=>{
      const m=months[ym];
      const y=parseInt(ym.split("-")[0]),mo=parseInt(ym.split("-")[1]);
      const dim=new Date(y,mo,0).getDate();
      const ms=new Date(y,mo-1,1),me=new Date(y,mo-1,dim);
      const kf=kpiF[ym]||{};
      // ★2026-07 新統一式：メンテ日は分母(稼働可能日)からも除く（実稼働ベース）
      const maintByVeh={};
      (dbMaint||[]).forEach(mm=>{
        if(mm.block_type&&mm.block_type!=="maintenance")return;
        if(!mm.start_date||!mm.end_date)return;
        let s=new Date(mm.start_date.slice(0,10)),e=new Date(mm.end_date.slice(0,10));
        if(s<ms)s=ms;if(e>me)e=me;if(s>e)return;
        const set=maintByVeh[mm.vehicle_code]||(maintByVeh[mm.vehicle_code]=new Set());
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1))set.add(d.toISOString().slice(0,10));
      });
      const availOf=(c)=>dim-((maintByVeh[c]&&maintByVeh[c].size)||0);
      const activeVehs=dbVehs.filter(v=>{
        const c=v.code;
        const act=(kf[c]!==undefined)?(kf[c]!==false):(v.active!==false);
        return act&&availOf(c)>0;
      });
      m.activeCount=activeVehs.length;
      m.totalVehs=dbVehs.length;
      m.dim=dim;
      // 稼働日数（車両別日Set）
      const vehDays={};
      active.forEach(r=>{
        const ld=r[ldKey],rd2=r[rdKey];
        if(!ld||!rd2)return;
        const vc=fMap[r.id];
        if(!vc)return;
        if(!activeVehs.find(v=>v.code===vc))return;
        let s=new Date(ld.slice(0,10)),e=new Date(rd2.slice(0,10));
        if(s<ms)s=ms;if(e>me)e=me;
        if(s>e)return;
        if(!vehDays[vc])vehDays[vc]=new Set();
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){
          vehDays[vc].add(d.toISOString().slice(0,10));
        }
      });
      Object.keys(vehDays).forEach(vc=>{const mset=maintByVeh[vc];if(mset)mset.forEach(dd=>vehDays[vc].delete(dd));});
      let totalDays=0,totalAvail=0;
      activeVehs.forEach(v=>{totalDays+=(vehDays[v.code]?vehDays[v.code].size:0);totalAvail+=availOf(v.code);});
      m.rentalDays=totalDays;
      m.maxDays=totalAvail;
      m.utilPct=m.maxDays>0?Math.round(totalDays/m.maxDays*100):0;
      // 車両タイプ別稼働率
      m.vtUtil={};
      DB_VEH_TYPES.forEach(t=>{
        const typeVehs=activeVehs.filter(v=>(v.type||"")==t);
        if(typeVehs.length===0)return;
        let tDays=0,tAvail=0;
        typeVehs.forEach(v=>{tDays+=(vehDays[v.code]?vehDays[v.code].size:0);tAvail+=availOf(v.code);});
        m.vtUtil[t]=tAvail>0?Math.round(tDays/tAvail*1000)/10:0;
      });
    });

    // ★ 予約外売上を各月に追加（extraByM から）
    Object.keys(extraByM).forEach(ym=>{
      if(!months[ym])months[ym]={chRev:{},chCnt:{},vtRev:{},vtCnt:{},vtUtil:{},delOta:0,delHp:0,totalRev:0,totalCnt:0,totalBase:0,totalOpt:0,totalDisc:0,extraRev:0};
      months[ym].extraRev=(extraByM[ym]||0);
    });
    // 既存の月に extraRev フィールドを保証
    Object.keys(months).forEach(ym=>{if(months[ym].extraRev===undefined)months[ym].extraRev=extraByM[ym]||0;});

    return{months,ymList};
  },[dbResvs,dbFleet,dbVehs,dbKpi,dbMaint,dbStore,extraByM]);

  // サブタブ切替時にロード
  useEffect(()=>{
    if(sub==="cost"){loadCost(costYm||dashYm);if(!costYm)setCostYm(dashYm);}
  },[sub]);

  // 売上追加
  const addSalesRow=async()=>{
    if(!newEntry||!newEntry.channel||!newEntry.return_date){setMsg("チャネルと返却日は必須");return;}
    setLoading(true);
    const payload={
      channel:newEntry.channel,
      return_date:newEntry.return_date,
      booking_date:newEntry.booking_date||null,
      base_amount:parseInt(newEntry.base_amount||0)||0,
      option_amount:parseInt(newEntry.option_amount||0)||0,
      discount:parseInt(newEntry.discount||0)||0,
      store:store,
      rental_days:newEntry.rental_days?parseFloat(newEntry.rental_days):null,
      vehicle_type:newEntry.vehicle_type||null,
      delivery:newEntry.delivery||null,
      resv_no:newEntry.resv_no||null,
      payment_date:newEntry.payment_date||null,
      note:newEntry.note||null,
      source:"app",
    };
    const{error}=await sb.from("sales_entries").insert(payload);
    if(error){setMsg("追加失敗: "+error.message);}
    else{setMsg("追加OK");setNewEntry(null);loadSales(salesFilter);}
    setLoading(false);
  };

  // 売上更新
  const updateSalesRow=async(row)=>{
    if(!row||!row.id)return;
    setLoading(true);
    const payload={
      channel:row.channel,
      return_date:row.return_date,
      booking_date:row.booking_date||null,
      base_amount:parseInt(row.base_amount||0)||0,
      option_amount:parseInt(row.option_amount||0)||0,
      discount:parseInt(row.discount||0)||0,
      rental_days:row.rental_days?parseFloat(row.rental_days):null,
      vehicle_type:row.vehicle_type||null,
      delivery:row.delivery||null,
      resv_no:row.resv_no||null,
      payment_date:row.payment_date||null,
      note:row.note||null,
    };
    const{error}=await sb.from("sales_entries").update(payload).eq("id",row.id);
    if(error){setMsg("更新失敗: "+error.message);}
    else{setMsg("更新OK");setEditing(null);loadSales(salesFilter);}
    setLoading(false);
  };

  // 売上削除
  const deleteSalesRow=async(id)=>{
    if(!confirm("この売上行を削除しますか？ PL/CFから自動的に消えます。"))return;
    setLoading(true);
    const{error}=await sb.from("sales_entries").delete().eq("id",id);
    if(error){setMsg("削除失敗: "+error.message);}
    else{setMsg("削除OK");loadSales(salesFilter);}
    setLoading(false);
  };

  // コスト保存
  const fmt=(n)=>n==null?"-":Number(n).toLocaleString();
  const fmtM=(n)=>n==null?"-":"¥"+Math.round(n/10000).toLocaleString()+"万";

  // PLをピボット化（year_month × channel）
  // PLピボット（reservationsから直接計算）
  const plPivot=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";
    const ymSet=new Set(),chSet=new Set();
    const map={};
    const daysByYm={};
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    active.forEach(r=>{
      const rd=r[rdKey];if(!rd)return;
      const ym=rd.slice(0,7);
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
      const revenue=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
      ymSet.add(ym);chSet.add(ch);
      const key=ym+"|"+ch;
      if(!map[key])map[key]={revenue:0,count:0};
      map[key].revenue+=revenue;
      map[key].count+=1;
      // 泊数
      const ld=r[ldKey];
      if(ld&&rd){
        const d0=new Date(ld.slice(0,10)),d1=new Date(rd.slice(0,10));
        const nights=Math.max(1,Math.round((d1-d0)/(86400000)));
        if(!daysByYm[ym])daysByYm[ym]={sum:0,cnt:0};
        daysByYm[ym].sum+=nights;daysByYm[ym].cnt+=1;
      }
    });
    const yms=Array.from(ymSet).sort();
    const chOrder=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
    const chs=chOrder.filter(c=>chSet.has(c)).concat(Array.from(chSet).filter(c=>!chOrder.includes(c)));
    return{yms,chs,map,daysByYm};
  },[dbResvs,dbStore]);

  // CFピボット（reservations + 入金サイクルから計算）
  const cfPivot=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    // チャネル入金サイクルマップ
    const cycleMap={};
    (mgSettings.channels||[]).forEach(c=>{cycleMap[c.name]=c.cycle||0;});
    const ymSet=new Set(),chSet=new Set();
    const map={};
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    active.forEach(r=>{
      const rd=r[rdKey];if(!rd)return;
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
      const revenue=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
      // 入金月 = 売上月 + cycle月
      const cycle=cycleMap[ch]||0;
      const [sy,sm]=rd.slice(0,7).split("-").map(Number);
      let ny=sy,nm=sm+cycle;
      while(nm>12){nm-=12;ny++;}
      const cashYm=ny+"-"+String(nm).padStart(2,"0");
      ymSet.add(cashYm);chSet.add(ch);
      const key=cashYm+"|"+ch;
      if(!map[key])map[key]={cash_in:0,count:0};
      map[key].cash_in+=revenue;
      map[key].count+=1;
    });
    const yms=Array.from(ymSet).sort();
    const chOrder=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
    const chs=chOrder.filter(c=>chSet.has(c)).concat(Array.from(chSet).filter(c=>!chOrder.includes(c)));
    // 支出予算（costAllMonthsから取得）
    const expByYm={};
    Object.entries(costAllMonths).forEach(([ym,rows])=>{
      if(!rows)return;
      let repay=0,sga=0,cogs=0,vehicle=0;
      rows.forEach(r=>{
        const c=r.account_code||"";const a=r.amount||0;
        if(c.startsWith("repay_"))repay+=a;
        else if(c.startsWith("sga_"))sga+=a;
        else if(c.startsWith("cogs_"))cogs+=a;
        else if(c==="vehicle_purchase")vehicle+=a;
      });
      expByYm[ym]={repay,sga,cogs,vehicle,total:repay+sga+cogs+vehicle};
      ymSet.add(ym);
    });
    const allYms=Array.from(ymSet).sort();
    return{yms:allYms,chs,map,expByYm};
  },[dbResvs,dbStore,mgSettings,costAllMonths]);

  // 当月ダッシュボード集計（reservationsベース / PLピボットから取得）
  const dashSummary=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    const ym=dashYm;
    let plRev=0,plCnt=0,daysSum=0,daysCnt=0,plBase=0,plOpt=0,plDisc=0;
    const byCh={};         // {ch: rev} 後方互換維持
    const byChBreak={};    // {ch: {rev, base, opt, disc, cnt}} 3分解
    active.forEach(r=>{
      const rd=r[rdKey];if(!rd||rd.slice(0,7)!==ym)return;
      const ch=DB_OTA_MAP[r.ota]||"その他売上";
      const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
      const hasSplit=(bp>0||op>0);
      const rev=hasSplit?(bp+op-dc):(Number(r.price)||0);
      // 3分解: base/option/discount が入力されている予約のみ分解加算。
      // 旧データ（price のみ）は base 扱いとし、option/discount=0 として計上
      const bpAdj=hasSplit?bp:(Number(r.price)||0);
      const opAdj=hasSplit?op:0;
      const dcAdj=hasSplit?dc:0;
      plRev+=rev;plCnt+=1;plBase+=bpAdj;plOpt+=opAdj;plDisc+=dcAdj;
      byCh[ch]=(byCh[ch]||0)+rev;
      if(!byChBreak[ch])byChBreak[ch]={rev:0,base:0,opt:0,disc:0,cnt:0};
      byChBreak[ch].rev+=rev;byChBreak[ch].base+=bpAdj;byChBreak[ch].opt+=opAdj;byChBreak[ch].disc+=dcAdj;byChBreak[ch].cnt+=1;
      const ld=r[ldKey];
      if(ld&&rd){const d0=new Date(ld.slice(0,10)),d1=new Date(rd.slice(0,10));const n=Math.max(1,Math.round((d1-d0)/86400000));daysSum+=n;daysCnt++;}
    });
    const avgNights=daysCnt>0?(daysSum/daysCnt):0;
    const unitPrice=plCnt>0?(plRev/plCnt):0;
    const dailyRate=daysSum>0?(plRev/daysSum):0;
    // ★2026-07 稼働率 新統一式: 分母=稼働可能日(月日数−メンテ日)、メンテ重複は稼働から除外（実稼働ベース）
    let utilDays=0,utilActiveCount=0,utilMaxDays=0,utilPct=0;
    {
      const[yr,mo]=ym.split("-").map(Number);
      const dim=new Date(yr,mo,0).getDate();
      const ms=new Date(yr,mo-1,1),me=new Date(yr,mo-1,dim);
      const fMap={};dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
      const kpiYm={};dbKpi.filter(k=>k.year_month===ym).forEach(k=>{kpiYm[k.vehicle_code]=k.active;});
      const isKpiActive=(code)=>kpiYm[code]!==undefined?kpiYm[code]:(dbVehs.find(v=>v.code===code)?.active!==false);
      const maintByVeh={};
      (dbMaint||[]).forEach(mm=>{
        if(mm.block_type&&mm.block_type!=="maintenance")return;
        if(!mm.start_date||!mm.end_date)return;
        let s=new Date(mm.start_date.slice(0,10)),e=new Date(mm.end_date.slice(0,10));
        if(s<ms)s=ms;if(e>me)e=me;if(s>e)return;
        const set=maintByVeh[mm.vehicle_code]||(maintByVeh[mm.vehicle_code]=new Set());
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1))set.add(d.toISOString().slice(0,10));
      });
      dbVehs.forEach(v=>{
        if(!isKpiActive(v.code))return;
        const mSet=maintByVeh[v.code]||new Set();
        const availV=dim-mSet.size;
        if(availV<=0)return;
        utilActiveCount++;utilMaxDays+=availV;
        const days=new Set();
        active.forEach(r=>{
          if(fMap[r.id]!==v.code)return;
          const ld=r[ldKey],rd=r[rdKey];if(!ld||!rd)return;
          const lDate=new Date(ld.slice(0,10)+"T00:00:00"),rDate=new Date(rd.slice(0,10)+"T00:00:00");
          const s=lDate>ms?lDate:ms;const e=rDate<me?rDate:me;
          for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){days.add(d.toISOString().slice(0,10));}
        });
        mSet.forEach(dd=>days.delete(dd));
        utilDays+=days.size;
      });
      utilPct=utilMaxDays>0?Math.round(utilDays/utilMaxDays*100):0;
    }
    // CF入金（当月入金分）
    const cfIn=cfPivot.chs.reduce((a,ch)=>a+((cfPivot.map[ym+"|"+ch]||{}).cash_in||0),0);
    return{plRev,plCnt,cfIn,byCh,byChBreak,plBase,plOpt,plDisc,avgNights,daysSum,unitPrice,dailyRate,utilDays,utilActiveCount,utilMaxDays,utilPct};
  },[dbResvs,dbFleet,dbVehs,dbKpi,dbMaint,dbStore,dashYm,cfPivot]);

  // ★ ダッシュボード用 予約外売上（じゃらん事前決済除外）
  const[dashExtraRev,setDashExtraRev]=useState(0);
  useEffect(()=>{
    if(!sb||!dashYm)return;
    const tbl=dbStore==="spk"?"spk_accounting":"bt_accounting";
    const[y,mo]=dashYm.split("-").map(Number);
    const dim=new Date(y,mo,0).getDate();
    const s=dashYm+"-01",e=dashYm+"-"+String(dim).padStart(2,"0");
    (async()=>{
      const{data:rows}=await sb.from(tbl).select("amount,description").eq("type","extra_sales").gte("date",s).lte("date",e);
      setDashExtraRev((rows||[]).filter(r=>!(r.description||"").startsWith("じゃらん事前決済")).reduce((a,r)=>a+(Number(r.amount)||0),0));
    })();
  },[dashYm,dbStore]);

  // ★ ダッシュボード用 年間 予約外売上マップ（YYYY-MM→金額、じゃらん事前決済除外）
  const[dashYearlyExtra,setDashYearlyExtra]=useState({});
  useEffect(()=>{
    if(!sb||!dashYm)return;
    const tbl=dbStore==="spk"?"spk_accounting":"bt_accounting";
    const yr=dashYm.slice(0,4);
    (async()=>{
      const{data:rows}=await sb.from(tbl).select("date,amount,description").eq("type","extra_sales").gte("date",yr+"-01-01").lte("date",yr+"-12-31");
      const m={};
      (rows||[]).forEach(r=>{
        if((r.description||"").startsWith("じゃらん事前決済"))return;
        const k=(r.date||"").slice(0,7);if(!k)return;
        m[k]=(m[k]||0)+(Number(r.amount)||0);
      });
      setDashYearlyExtra(m);
    })();
  },[dashYm,dbStore]);

  // ★ 年間推移: dashYm の年で1月〜12月の月別KPIを計算
  const dashYearly=useMemo(()=>{
    const isSpk=dbStore==="spk";
    const rdKey=isSpk?"return_date":"end_date";
    const ldKey=isSpk?"lend_date":"start_date";
    const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
    const year=dashYm.slice(0,4);
    const fMap={};dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
    const months=[];
    const yearByCh={}; // {channel: {1:rev, 2:rev, ..., total:rev, base, opt, disc}}
    for(let m=1;m<=12;m++){
      const ym=year+"-"+String(m).padStart(2,"0");
      let plRev=0,plCnt=0,daysSum=0,daysCnt=0,plBase=0,plOpt=0,plDisc=0;
      const byCh={};
      active.forEach(r=>{
        const rd=r[rdKey];if(!rd||rd.slice(0,7)!==ym)return;
        const ch=DB_OTA_MAP[r.ota]||"その他売上";
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const hasSplit=(bp>0||op>0);
        const rev=hasSplit?(bp+op-dc):(Number(r.price)||0);
        const bpAdj=hasSplit?bp:(Number(r.price)||0);
        const opAdj=hasSplit?op:0;
        const dcAdj=hasSplit?dc:0;
        plRev+=rev;plCnt+=1;plBase+=bpAdj;plOpt+=opAdj;plDisc+=dcAdj;
        byCh[ch]=(byCh[ch]||0)+rev;
        if(!yearByCh[ch])yearByCh[ch]={total:0,base:0,opt:0,disc:0,cnt:0};
        yearByCh[ch][m]=(yearByCh[ch][m]||0)+rev;
        yearByCh[ch].total+=rev;
        yearByCh[ch].base+=bpAdj;yearByCh[ch].opt+=opAdj;yearByCh[ch].disc+=dcAdj;yearByCh[ch].cnt+=1;
        const ld=r[ldKey];
        if(ld&&rd){const d0=new Date(ld.slice(0,10)),d1=new Date(rd.slice(0,10));const n=Math.max(1,Math.round((d1-d0)/86400000));daysSum+=n;daysCnt++;}
      });
      const avgNights=daysCnt>0?(daysSum/daysCnt):0;
      const unitPrice=plCnt>0?(plRev/plCnt):0;
      const dailyRate=daysSum>0?(plRev/daysSum):0;
      // 稼働率
      const yr=Number(year),mo=m;
      const dim=new Date(yr,mo,0).getDate();
      const ms=new Date(yr,mo-1,1),me=new Date(yr,mo-1,dim);
      const kpiYm={};dbKpi.filter(k=>k.year_month===ym).forEach(k=>{kpiYm[k.vehicle_code]=k.active;});
      const isKpiActive=(code)=>kpiYm[code]!==undefined?kpiYm[code]:(dbVehs.find(v=>v.code===code)?.active!==false);
      const maintByVeh={};
      (dbMaint||[]).forEach(mm=>{
        if(mm.block_type&&mm.block_type!=="maintenance")return;
        if(!mm.start_date||!mm.end_date)return;
        let s=new Date(mm.start_date.slice(0,10)),e=new Date(mm.end_date.slice(0,10));
        if(s<ms)s=ms;if(e>me)e=me;if(s>e)return;
        const set=maintByVeh[mm.vehicle_code]||(maintByVeh[mm.vehicle_code]=new Set());
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1))set.add(d.toISOString().slice(0,10));
      });
      let utilDays=0,utilActiveCount=0,utilMaxDays=0;
      dbVehs.forEach(v=>{
        if(!isKpiActive(v.code))return;
        const mSet=maintByVeh[v.code]||new Set();
        const availV=dim-mSet.size;
        if(availV<=0)return;
        utilActiveCount++;utilMaxDays+=availV;
        const days=new Set();
        active.forEach(r=>{
          if(fMap[r.id]!==v.code)return;
          const ld=r[ldKey],rd=r[rdKey];if(!ld||!rd)return;
          const lDate=new Date(ld.slice(0,10)+"T00:00:00"),rDate=new Date(rd.slice(0,10)+"T00:00:00");
          const s=lDate>ms?lDate:ms;const e=rDate<me?rDate:me;
          for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){days.add(d.toISOString().slice(0,10));}
        });
        mSet.forEach(dd=>days.delete(dd));
        utilDays+=days.size;
      });
      const utilPct=utilMaxDays>0?Math.round(utilDays/utilMaxDays*100):0;
      const cfIn=cfPivot.chs.reduce((a,ch)=>a+((cfPivot.map[ym+"|"+ch]||{}).cash_in||0),0);
      const extraRev=dashYearlyExtra[ym]||0;
      months.push({ym,mo,plRev,plCnt,extraRev,totalRev:plRev+extraRev,cfIn,unitPrice,dailyRate,avgNights,daysSum,utilPct,utilDays,utilMaxDays,utilActiveCount,byCh,plBase,plOpt,plDisc});
    }
    const total=months.reduce((a,m)=>({plRev:a.plRev+m.plRev,plCnt:a.plCnt+m.plCnt,extraRev:a.extraRev+m.extraRev,totalRev:a.totalRev+m.totalRev,cfIn:a.cfIn+m.cfIn,daysSum:a.daysSum+m.daysSum,plBase:a.plBase+m.plBase,plOpt:a.plOpt+m.plOpt,plDisc:a.plDisc+m.plDisc}),{plRev:0,plCnt:0,extraRev:0,totalRev:0,cfIn:0,daysSum:0,plBase:0,plOpt:0,plDisc:0});
    return{year,months,total,yearByCh};
  },[dbResvs,dbFleet,dbVehs,dbKpi,dbMaint,dbStore,dashYm,cfPivot,dashYearlyExtra]);

  // ★ 月/年切替対応の派生KPI: dashPeriod="month" → dashSummary相当 / "year" → dashYearly.total から加重平均で再計算
  const dashKpi=useMemo(()=>{
    if(dashPeriod==="month"){
      // 月モード: 既存の dashSummary をそのまま返す（extraRev は別 state）
      return{...dashSummary,extraRev:dashExtraRev,totalRev:dashSummary.plRev+dashExtraRev,periodLabel:dashYm};
    }
    // 年モード: dashYearly.total + 加重平均 + 稼働率合算
    const y=dashYearly;const t=y.total;
    const utilDays=y.months.reduce((a,m)=>a+m.utilDays,0);
    const utilMaxDays=y.months.reduce((a,m)=>a+m.utilMaxDays,0);
    const activeCounts=y.months.filter(m=>m.utilActiveCount>0).map(m=>m.utilActiveCount);
    const utilActiveCount=activeCounts.length?Math.round(activeCounts.reduce((a,b)=>a+b,0)/activeCounts.length):0;
    const utilPct=utilMaxDays>0?Math.round(utilDays/utilMaxDays*100):0;
    // byCh / byChBreak を年集計から組み立て
    const byCh={},byChBreak={};
    Object.keys(y.yearByCh||{}).forEach(ch=>{
      const v=y.yearByCh[ch];
      byCh[ch]=v.total;
      byChBreak[ch]={rev:v.total,base:v.base,opt:v.opt,disc:v.disc,cnt:v.cnt||0};
    });
    return{
      plRev:t.plRev,plCnt:t.plCnt,
      plBase:t.plBase,plOpt:t.plOpt,plDisc:t.plDisc,
      daysSum:t.daysSum,cfIn:t.cfIn,
      extraRev:t.extraRev,totalRev:t.totalRev,
      unitPrice:t.plCnt>0?(t.plRev/t.plCnt):0,
      dailyRate:t.daysSum>0?(t.plRev/t.daysSum):0,
      avgNights:t.plCnt>0?(t.daysSum/t.plCnt):0,
      utilDays,utilMaxDays,utilActiveCount,utilPct,
      byCh,byChBreak,
      periodLabel:y.year+"年"
    };
  },[dashPeriod,dashSummary,dashYearly,dashExtraRev,dashYm]);

  // ★ 国内/海外比率: HP予約のみ、出発日（start_date）基準でフィルタ
  const dashRegion=useMemo(()=>{
    const year=dashYm.split('-')[0];
    const hp=(dbResvs||[]).filter(r=>{
      if(r.ota!=='HP'||r.status==='cancelled')return false;
      // booked_at（予約受付日）基準 = 当月に予約が入ったHP予約
      const d=(r.booked_at||r.created_at||'').substring(0,10);
      return dashPeriod==='month'?d.startsWith(dashYm):d.startsWith(year);
    });
    const revOf=r=>{const bp=r.basePrice||r.base_price||0,op=r.optionPrice||r.option_price||0,dc=r.discount||0;return(bp>0||op>0)?(bp+op-dc):(r.price||0);};
    const dom=hp.filter(r=>isJapaneseName(r.name));
    const ovs=hp.filter(r=>!isJapaneseName(r.name));
    return{
      total:hp.length,
      domCnt:dom.length,domRev:dom.reduce((s,r)=>s+revOf(r),0),
      ovsCnt:ovs.length,ovsRev:ovs.reduce((s,r)=>s+revOf(r),0),
    };
  },[dbResvs,dashPeriod,dashYm]);

  const subTabs=[
    {id:"exceldash",l:"📊 経営DB"},
    {id:"yojitsu",l:"🎯 KPI管理表"},
    {id:"settings",l:"⚙️ 設定"},
    {id:"dashboard",l:"📊 ダッシュボード"},
    {id:"sales",l:"📝 売上入力"},
    {id:"monthly",l:"📘 月次PL/CF（収支＋コスト内訳）"},
    {id:"hpcv",l:"🔵 HP-CV"},
    {id:"roi",l:"📈 投資回転率"},
    {id:"analytics",l:"🔬 解析"},
    {id:"healthcheck",l:"🩺 データ健全性"},
  ];

  const card={padding:12,borderRadius:10,background:"#fff",border:"1px solid #e2e8f0"};
  const h={fontSize:16,fontWeight:900,marginBottom:10};
  const lbl={fontSize:10,color:"#64748b",marginBottom:2};
  const val={fontSize:18,fontWeight:800,color:"#0f172a"};
  const inp={width:"100%",padding:"4px 6px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:4};
  const th={padding:"6px 8px",fontSize:10,color:"#64748b",textAlign:"left",borderBottom:"1px solid #e2e8f0",fontWeight:700,background:"#f8fafc"};
  const td={padding:"4px 8px",fontSize:11,borderBottom:"1px solid #f1f5f9"};
  const btn=(c)=>({padding:"4px 10px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:c||"#1e40af",color:"#fff"});

  return <div>
    <h2 style={{fontSize:18,fontWeight:900,marginBottom:6}}>💼 {storeLabel} 経営管理</h2>
    <p style={{fontSize:11,color:"#64748b",marginBottom:12}}>Excel「売上入力」タブの代替。売上入力→PL/CF/ダッシュボードが自動連動。</p>

    {/* サブタブ */}
    <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12,borderBottom:"1px solid #e2e8f0",paddingBottom:8}}>
      {subTabs.map(t=>{
        const sel=sub===t.id;
        return <button key={t.id} onClick={()=>setSub(t.id)} style={{padding:"6px 12px",fontSize:12,fontWeight:700,borderRadius:8,border:"none",cursor:"pointer",background:sel?"#1e40af":"#f1f5f9",color:sel?"#fff":"#334155"}}>{t.l}</button>;
      })}
      <div style={{flex:1}}/>
      {loading&&<span style={{fontSize:11,color:"#64748b"}}>読込中...</span>}
      {msg&&<span style={{fontSize:11,color:msg.startsWith("ERROR")||msg.includes("失敗")?"#dc2626":"#059669",fontWeight:700}}>{msg}</span>}
    </div>

    {/* === 経営DB (Excel再現ダッシュボード) === */}
    {sub==="exceldash"&&<div>
      {/* 店舗切替 */}
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12}}>
        {["tkm","spk"].map(s=>{
          const sel2=dbStore===s;
          const lb=s==="tkm"?"高松店":"札幌店";
          return <button key={s} onClick={()=>setDbStore(s)} style={{padding:"6px 16px",fontSize:13,fontWeight:800,borderRadius:8,border:sel2?"2px solid #1e40af":"2px solid #e2e8f0",cursor:"pointer",background:sel2?"#1e40af":"#fff",color:sel2?"#fff":"#334155"}}>{lb}</button>;
        })}
        {dbLoading2&&<span style={{fontSize:11,color:"#64748b",marginLeft:8}}>読込中...</span>}
        <span style={{fontSize:10,color:"#94a3b8",marginLeft:8}}>※ reservationsから自動集計 | 売上計上 = 基本料金 + 付帯売上 - 割引（最終金額）</span>
      </div>

      {(()=>{
        const{months,ymList}=dbMetrics;
        if(ymList.length===0)return <div style={{padding:20,textAlign:"center",color:"#94a3b8"}}>データなし</div>;
        const sLabel=dbStore==="tkm"?"高松":"札幌";
        const thS={padding:"4px 6px",fontSize:9,color:"#64748b",textAlign:"right",borderBottom:"2px solid #e2e8f0",fontWeight:700,background:"#f8fafc",whiteSpace:"nowrap",position:"sticky",top:0,zIndex:1};
        const tdS={padding:"3px 6px",fontSize:10,textAlign:"right",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap"};
        const tdL={padding:"3px 6px",fontSize:10,textAlign:"left",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap",position:"sticky",left:0,background:"#fff",zIndex:1};
        const secH=(text)=><tr><td colSpan={ymList.length+1} style={{padding:"8px 6px 4px",fontSize:12,fontWeight:900,background:"#f0f9ff",color:"#0369a1",borderBottom:"2px solid #0ea5e9"}}>{text}</td></tr>;
        const fmtK=(n)=>n==null||n===0?"-":"¥"+(n>=10000?Math.round(n/10000).toLocaleString()+"万":n.toLocaleString());
        const fmtN=(n)=>n==null||n===0?"-":n.toLocaleString();
        const fmtP=(n)=>n==null||n===0?"-":(n*100).toFixed(1)+"%";
        const chg=(cur,prev)=>{
          if(!prev||prev===0)return null;
          const d=cur-prev;
          const p=Math.round(d/prev*100);
          const color=d>0?"#059669":d<0?"#dc2626":"#64748b";
          const arrow=d>0?"▲":d<0?"▼":"→";
          return <span style={{fontSize:8,color,marginLeft:2}}>{arrow}{Math.abs(p)}%</span>;
        };

        return <div style={{overflow:"auto",maxHeight:"75vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",minWidth:ymList.length*90}}>
            <thead>
              <tr>
                <th style={{...thS,textAlign:"left",position:"sticky",left:0,zIndex:2,minWidth:160}}>項目</th>
                {ymList.map(ym=><th key={ym} style={thS}>{ym.replace("20","").replace("-","/")}</th>)}
              </tr>
            </thead>
            <tbody>
              {/* ▼ セクション1: チャネル別売上金額 */}
              {secH("▼ チャネル別売上金額（計上ベース）— "+sLabel)}
              {DB_CHANNELS.map(ch=>{
                return <tr key={"rev_"+ch}>
                  <td style={{...tdL,paddingLeft:16}}>{ch}</td>
                  {ymList.map((ym,i)=>{
                    const v=(months[ym]?.chRev[ch])||0;
                    const prev=i>0?((months[ymList[i-1]]?.chRev[ch])||0):0;
                    return <td key={ym} style={tdS}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                  })}
                </tr>;
              })}
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>売上合計</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalRev||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalRev||0):0;
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}
              </tr>
              {/* 構成比率 */}
              <tr><td style={{...tdL,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={ymList.length+1}>↳ 売上金額 構成比率</td></tr>
              {DB_CHANNELS.map(ch=>{
                return <tr key={"revp_"+ch}>
                  <td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>{ch}</td>
                  {ymList.map(ym=>{
                    const v=(months[ym]?.chRev[ch])||0;
                    const total=months[ym]?.totalRev||1;
                    return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{fmtP(v/total)}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション2: 売上件数 */}
              {secH("▼ 売上件数（チャネル別）— "+sLabel)}
              {DB_CHANNELS.map(ch=>{
                return <tr key={"cnt_"+ch}>
                  <td style={{...tdL,paddingLeft:16}}>{ch}</td>
                  {ymList.map((ym,i)=>{
                    const v=(months[ym]?.chCnt[ch])||0;
                    const prev=i>0?((months[ymList[i-1]]?.chCnt[ch])||0):0;
                    return <td key={ym} style={tdS}>{fmtN(v)} {i>0&&chg(v,prev)}</td>;
                  })}
                </tr>;
              })}
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>合計件数</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalCnt||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalCnt||0):0;
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtN(v)} {i>0&&chg(v,prev)}</td>;
                })}
              </tr>
              {/* 件数構成比率 */}
              <tr><td style={{...tdL,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={ymList.length+1}>↳ 件数 構成比率</td></tr>
              {DB_CHANNELS.map(ch=>{
                return <tr key={"cntp_"+ch}>
                  <td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>{ch}</td>
                  {ymList.map(ym=>{
                    const v=(months[ym]?.chCnt[ch])||0;
                    const total=months[ym]?.totalCnt||1;
                    return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{fmtP(v/total)}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション3: デリバリー利用状況 */}
              {secH("▼ デリバリー利用状況 — "+sLabel)}
              <tr><td style={{...tdL,paddingLeft:16}}>OTA DEL利用数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtN(months[ym]?.delOta||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>↳ OTA DEL構成比</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaCnt=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chCnt[c]||0)),0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{otaCnt>0?fmtP((m?.delOta||0)/otaCnt):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>オフィシャル DEL利用数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtN(months[ym]?.delHp||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>↳ HP DEL構成比</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const hpCnt=m?.chCnt["オフィシャル"]||0;
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{hpCnt>0?fmtP((m?.delHp||0)/hpCnt):"-"}</td>;
                })}</tr>
              <tr style={{fontWeight:700}}><td style={{...tdL,paddingLeft:16}}>合算DEL件数</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  return <td key={ym} style={{...tdS,fontWeight:700}}>{fmtN((m?.delOta||0)+(m?.delHp||0))}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>合算DEL利用率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const total=m?.totalCnt||0;
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{total>0?fmtP(((m?.delOta||0)+(m?.delHp||0))/total):"-"}</td>;
                })}</tr>

              {/* ▼ セクション4: 売上目標・実績管理（金額） */}
              {secH("▼ 売上目標・実績管理（金額）— "+sLabel)}
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>目標総売上（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.rev||""} onChange={e=>saveDbTarget(ym,"rev",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>実績総売上（計上）</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.totalRev||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>差分（実績−目標）</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.rev||0;
                  const act=months[ym]?.totalRev||0;
                  const diff=act-tgt;
                  const color=tgt===0?"#64748b":diff>=0?"#059669":"#dc2626";
                  return <td key={ym} style={{...tdS,color,fontWeight:tgt?700:400}}>{tgt?fmtK(diff):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>達成率</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.rev||0;
                  const act=months[ym]?.totalRev||0;
                  const pct=tgt>0?act/tgt:0;
                  const bg=pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":pct>0?"#fef2f2":"transparent";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{tgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>OTA売上合計</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaRev=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chRev[c]||0)),0);
                  return <td key={ym} style={tdS}>{fmtK(otaRev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ OTA 売上構成比率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaRev=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chRev[c]||0)),0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{m?.totalRev>0?fmtP(otaRev/m.totalRev):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>オフィシャル売上</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.chRev["オフィシャル"]||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ オフィシャル 売上構成比率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{m?.totalRev>0?fmtP((m?.chRev["オフィシャル"]||0)/m.totalRev):"-"}</td>;
                })}</tr>

              {/* ▼ セクション5: 売上区分（基本料金 / 付帯売上 / 予約外 / 割引） */}
              {secH("▼ 売上区分（基本料金 / 付帯売上 / 割引）— "+sLabel)}
              <tr><td style={{...tdL,paddingLeft:16}}>基本料金</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalBase||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalBase||0):0;
                  return <td key={ym} style={tdS}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ 基本料金 構成比</td>
                {ymList.map(ym=>{
                  const bp=months[ym]?.totalBase||0;
                  const gross=(months[ym]?.totalBase||0)+(months[ym]?.totalOpt||0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{gross>0?fmtP(bp/gross):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>付帯売上</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalOpt||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalOpt||0):0;
                  return <td key={ym} style={tdS}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ 付帯売上 構成比</td>
                {ymList.map(ym=>{
                  const op=months[ym]?.totalOpt||0;
                  const gross=(months[ym]?.totalBase||0)+(months[ym]?.totalOpt||0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{gross>0?fmtP(op/gross):"-"}</td>;
                })}</tr>
              <tr style={{color:"#dc2626"}}><td style={{...tdL,paddingLeft:16,color:"#dc2626"}}>割引・クーポン</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.totalDisc||0;
                  const prev=i>0?(months[ymList[i-1]]?.totalDisc||0):0;
                  return <td key={ym} style={{...tdS,color:"#dc2626"}}>{v>0?"-"+fmtK(v):"-"} {i>0&&v>0&&prev>0?chg(v,prev):null}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>↳ 割引率（グロス対比）</td>
                {ymList.map(ym=>{
                  const dc=months[ym]?.totalDisc||0;
                  const gross=(months[ym]?.totalBase||0)+(months[ym]?.totalOpt||0);
                  return <td key={ym} style={{...tdS,fontSize:9,color:dc>0?"#dc2626":"#64748b"}}>{gross>0?fmtP(dc/gross):"-"}</td>;
                })}</tr>
              <tr style={{color:"#7c3aed"}}><td style={{...tdL,paddingLeft:16,color:"#7c3aed"}}>予約外売上</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.extraRev||0;
                  const prev=i>0?(months[ymList[i-1]]?.extraRev||0):0;
                  return <td key={ym} style={{...tdS,color:"#7c3aed"}}>{v>0?"+"+fmtK(v):"-"} {i>0&&v>0&&prev>0?chg(v,prev):null}</td>;
                })}</tr>
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>売上計上額（= 基本+付帯+予約外-割引）</td>
                {ymList.map((ym,i)=>{
                  const v=(months[ym]?.totalRev||0)+(months[ym]?.extraRev||0);
                  const prev=i>0?((months[ymList[i-1]]?.totalRev||0)+(months[ymList[i-1]]?.extraRev||0)):0;
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtK(v)} {i>0&&chg(v,prev)}</td>;
                })}</tr>

              {/* ▼ セクション6: 売上件数 目標・実績管理 */}
              {secH("▼ 売上件数 目標・実績管理 — "+sLabel)}
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>目標売上件数（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.cnt||""} onChange={e=>saveDbTarget(ym,"cnt",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>OTA件数</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaCnt=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chCnt[c]||0)),0);
                  return <td key={ym} style={tdS}>{fmtN(otaCnt)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>オフィシャル件数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtN(months[ym]?.chCnt["オフィシャル"]||0)}</td>)}</tr>
              <tr style={{fontWeight:700}}><td style={{...tdL,fontWeight:700}}>実績件数合計</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,fontWeight:700}}>{fmtN(months[ym]?.totalCnt||0)}</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>差分（実績−目標）</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.cnt||0;
                  const act=months[ym]?.totalCnt||0;
                  const diff=act-tgt;
                  const color=tgt===0?"#64748b":diff>=0?"#059669":"#dc2626";
                  return <td key={ym} style={{...tdS,color,fontWeight:tgt?700:400}}>{tgt?fmtN(diff):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>達成率</td>
                {ymList.map(ym=>{
                  const tgt=dbTargets[ym]?.cnt||0;
                  const act=months[ym]?.totalCnt||0;
                  const pct=tgt>0?act/tgt:0;
                  const bg=pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":pct>0?"#fef2f2":"transparent";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{tgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
                })}</tr>

              {/* ▼ セクション7: 運用・稼働・単価分析 */}
              {secH("▼ 運用・稼働・単価分析 — "+sLabel)}
              <tr><td style={{...tdL,paddingLeft:16}}>稼働台数(KPI active)</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{months[ym]?.activeCount||0}台</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>稼働率</td>
                {ymList.map((ym,i)=>{
                  const v=months[ym]?.utilPct||0;
                  const prev=i>0?(months[ymList[i-1]]?.utilPct||0):0;
                  const bg=v>=50?"#dcfce7":v>=30?"#fef9c3":"#fef2f2";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{v}% {i>0&&chg(v,prev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>稼働日数</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{months[ym]?.rentalDays||0}日</td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>最大稼働日数</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{months[ym]?.maxDays||0}日</td>)}</tr>
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>台/売上目標（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.perV||""} onChange={e=>saveDbTarget(ym,"perV",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>台/売上実績</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const perV=m?.activeCount>0?Math.round(m.totalRev/m.activeCount):0;
                  return <td key={ym} style={tdS}>{fmtK(perV)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>台/売上 達成率</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const tgt=dbTargets[ym]?.perV||0;
                  const perV=m?.activeCount>0?Math.round(m.totalRev/m.activeCount):0;
                  const pct=tgt>0?perV/tgt:0;
                  const bg=pct>=1?"#dcfce7":pct>=0.7?"#fef9c3":pct>0?"#fef2f2":"transparent";
                  return <td key={ym} style={{...tdS,background:bg}}>{tgt>0?(pct*100).toFixed(1)+"%":"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>OTA 予約単価</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const otaRev=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chRev[c]||0)),0);
                  const otaCnt=DB_CHANNELS.filter(c=>c!=="オフィシャル").reduce((s,c)=>(s+(m?.chCnt[c]||0)),0);
                  return <td key={ym} style={tdS}>{otaCnt>0?fmtK(Math.round(otaRev/otaCnt)):"-"}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>HP 予約単価</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  const hpR=m?.chRev["オフィシャル"]||0;
                  const hpC=m?.chCnt["オフィシャル"]||0;
                  return <td key={ym} style={tdS}>{hpC>0?fmtK(Math.round(hpR/hpC)):"-"}</td>;
                })}</tr>
              <tr style={{fontWeight:700}}><td style={{...tdL,paddingLeft:16}}>全体 予約単価</td>
                {ymList.map(ym=>{
                  const m=months[ym];
                  return <td key={ym} style={{...tdS,fontWeight:700}}>{m?.totalCnt>0?fmtK(Math.round(m.totalRev/m.totalCnt)):"-"}</td>;
                })}</tr>

              {/* ▼ セクション8: 車両タイプ別稼働率 */}
              {secH("▼ 車両タイプ別 稼働率 — "+sLabel)}
              {DB_VEH_TYPES.map(t=>{
                const hasData=ymList.some(ym=>months[ym]?.vtUtil[t]>0);
                if(!hasData)return null;
                return <tr key={"vtu_"+t}><td style={{...tdL,paddingLeft:16}}>タイプ {t}</td>
                  {ymList.map(ym=>{
                    const v=months[ym]?.vtUtil[t]||0;
                    const bg=v>=50?"#dcfce7":v>=30?"#fef9c3":v>0?"#fef2f2":"transparent";
                    return <td key={ym} style={{...tdS,background:bg}}>{v>0?v.toFixed(1)+"%":"-"}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション9: 車両タイプ別売上 */}
              {secH("▼ 車両タイプ別 売上金額（計上ベース）— "+sLabel)}
              {DB_VEH_TYPES.map(t=>{
                const hasData=ymList.some(ym=>(months[ym]?.vtRev[t]||0)>0);
                if(!hasData)return null;
                return <tr key={"vtrev_"+t}><td style={{...tdL,paddingLeft:16}}>タイプ {t}</td>
                  {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.vtRev[t]||0)}</td>)}
                </tr>;
              })}
              <tr style={{fontWeight:800,background:"#f0fdf4"}}>
                <td style={{...tdL,fontWeight:800}}>合計</td>
                {ymList.map(ym=>{
                  const total=DB_VEH_TYPES.reduce((s,t)=>s+(months[ym]?.vtRev[t]||0),0);
                  return <td key={ym} style={{...tdS,fontWeight:800}}>{fmtK(total)}</td>;
                })}
              </tr>
              {/* 構成比率 */}
              <tr><td style={{...tdL,paddingLeft:16,fontSize:9,color:"#94a3b8"}} colSpan={ymList.length+1}>↳ 車両タイプ別 売上構成比率</td></tr>
              {DB_VEH_TYPES.map(t=>{
                const hasData=ymList.some(ym=>(months[ym]?.vtRev[t]||0)>0);
                if(!hasData)return null;
                return <tr key={"vtrevp_"+t}><td style={{...tdL,paddingLeft:24,fontSize:9,color:"#64748b"}}>タイプ {t}</td>
                  {ymList.map(ym=>{
                    const v=months[ym]?.vtRev[t]||0;
                    const total=DB_VEH_TYPES.reduce((s,tt)=>s+(months[ym]?.vtRev[tt]||0),0);
                    return <td key={ym} style={{...tdS,fontSize:9,color:"#64748b"}}>{total>0?fmtP(v/total):"-"}</td>;
                  })}
                </tr>;
              })}

              {/* ▼ セクション10: コスト・粗利サマリー */}
              {secH("▼ コスト・粗利サマリー — "+sLabel+"（月次コストより）")}
              <tr style={{background:"#fffbeb"}}><td style={{...tdL,paddingLeft:16,fontWeight:700}}>支出合計（入力可）</td>
                {ymList.map(ym=><td key={ym} style={{...tdS,padding:0}}><input type="number" value={dbTargets[ym]?.cost||""} onChange={e=>saveDbTarget(ym,"cost",e.target.value)} style={{width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:10,padding:"3px 4px"}} placeholder="0"/></td>)}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>売上合計（計上ベース）</td>
                {ymList.map(ym=><td key={ym} style={tdS}>{fmtK(months[ym]?.totalRev||0)}</td>)}</tr>
              <tr style={{fontWeight:800}}><td style={{...tdL,fontWeight:800}}>粗利（売上−支出）</td>
                {ymList.map(ym=>{
                  const cost=dbTargets[ym]?.cost||0;
                  const rev=months[ym]?.totalRev||0;
                  const gross=rev-cost;
                  const color=cost===0?"#334155":gross>=0?"#059669":"#dc2626";
                  return <td key={ym} style={{...tdS,fontWeight:800,color}}>{cost>0?fmtK(gross):fmtK(rev)}</td>;
                })}</tr>
              <tr><td style={{...tdL,paddingLeft:16}}>粗利率（粗利÷売上）</td>
                {ymList.map(ym=>{
                  const cost=dbTargets[ym]?.cost||0;
                  const rev=months[ym]?.totalRev||0;
                  const pct=rev>0?(rev-cost)/rev:0;
                  const bg=cost===0?"transparent":pct>=0.3?"#dcfce7":pct>=0?"#fef9c3":"#fef2f2";
                  return <td key={ym} style={{...tdS,background:bg,fontWeight:700}}>{cost>0?(pct*100).toFixed(1)+"%":"100%"}</td>;
                })}</tr>
            </tbody>
          </table>
        </div>;
      })()}
    </div>}

    {/* --- 予実比較 --- */}
    {sub==="yojitsu"&&(()=>{
      // === KPI管理表（TKM: 売上/予約数/稼働率/予約単価） ===
      const today=new Date();
      const yjMonths=[];
      for(let i=-6;i<18;i++){
        const d=new Date(today.getFullYear(),today.getMonth()+i,1);
        yjMonths.push(d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0"));
      }

      const KPIS=[
        {id:"revenue",label:"💰 売上",unit:"¥",fmt:(v)=>v?"¥"+Math.round(v).toLocaleString():"-"},
        {id:"resvCount",label:"📋 予約数",unit:"件",fmt:(v)=>v?v+"件":"-"},
        {id:"utilization",label:"📊 稼働率",unit:"%",fmt:(v)=>v?v.toFixed(1)+"%":"-"},
        {id:"unitPrice",label:"💴 予約単価",unit:"¥",fmt:(v)=>v?"¥"+Math.round(v).toLocaleString():"-"},
      ];

      const calcMonthKpi=(ym)=>{
        const isSpk=dbStore==="spk";
        const rdKey=isSpk?"return_date":"end_date";
        const ldKey=isSpk?"lend_date":"start_date";
        const active=(dbResvs||[]).filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
        const fMap={};(dbFleet||[]).forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
        const [yr,mo]=ym.split("-").map(Number);
        const dim=new Date(yr,mo,0).getDate();
        const ms=new Date(yr,mo-1,1),me=new Date(yr,mo-1,dim);
        let plRev=0,plCnt=0;
        active.forEach(r=>{
          const rd=r[rdKey];if(!rd||rd.slice(0,7)!==ym)return;
          const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
          const hasSplit=(bp>0||op>0);
          plRev+=hasSplit?(bp+op-dc):(Number(r.price)||0);
          plCnt+=1;
        });
        const unitPrice=plCnt>0?(plRev/plCnt):0;
        const kpiYm={};(dbKpi||[]).filter(k=>k.year_month===ym).forEach(k=>{kpiYm[k.vehicle_code]=k.active;});
        const isKpiActive=(code)=>kpiYm[code]!==undefined?kpiYm[code]:((dbVehs||[]).find(v=>v.code===code)?.active!==false);
        let utilDays=0,utilActiveCount=0;
        (dbVehs||[]).forEach(v=>{
          if(!isKpiActive(v.code))return;
          utilActiveCount++;
          const days=new Set();
          active.forEach(r=>{
            if(fMap[r.id]!==v.code)return;
            const ld=r[ldKey],rd=r[rdKey];if(!ld||!rd)return;
            const lDate=new Date(ld.slice(0,10)+"T00:00:00"),rDate=new Date(rd.slice(0,10)+"T00:00:00");
            const s=lDate>ms?lDate:ms;const e=rDate<me?rDate:me;
            for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){days.add(d.toISOString().slice(0,10));}
          });
          utilDays+=days.size;
        });
        const utilMaxDays=utilActiveCount*dim;
        const utilPct=utilMaxDays>0?(utilDays/utilMaxDays*100):0;
        return {revenue:plRev,resvCount:plCnt,utilization:utilPct,unitPrice};
      };

      const thS2={padding:"6px 8px",fontSize:10,color:"#64748b",textAlign:"right",borderBottom:"2px solid #e2e8f0",fontWeight:700,background:"#f8fafc",whiteSpace:"nowrap",position:"sticky",top:0,zIndex:1,minWidth:90};
      const tdS2={padding:"5px 8px",fontSize:11,textAlign:"right",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap"};
      const tdL2={padding:"5px 8px",fontSize:11,textAlign:"left",borderBottom:"1px solid #f1f5f9",whiteSpace:"nowrap",position:"sticky",left:0,background:"#fff",zIndex:1,minWidth:160};
      const inpS={width:"100%",border:"none",background:"#fffbeb",textAlign:"right",fontSize:11,padding:"4px 6px",fontFamily:"inherit"};

      const storeKey=dbStore==="spk"?"yojitsu_spk":"yojitsu_tkm";
      const saveTarget=(ym,kpiId,val)=>{
        const tk={...(yjData[dbStore]||{})};
        if(!tk[ym])tk[ym]={};
        tk[ym][kpiId]=Number(val)||0;
        setYjData({...yjData,[dbStore]:tk});
        settingsUpsert_(dbStore==="tkm",storeKey,JSON.stringify(tk));
      };

      const monthData={};
      yjMonths.forEach(ym=>{monthData[ym]=calcMonthKpi(ym);});
      const targets=yjData[dbStore]||{};

      return <div>
        <div style={{fontSize:14,fontWeight:900,marginBottom:4}}>🎯 KPI管理表 — {storeLabel}</div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:12}}>4つのKPI（売上/予約数/稼働率/予約単価）の実績と目標を月次管理。実績は自動計算、目標欄のみ手動入力。</div>
        <div style={{display:"flex",gap:6,marginBottom:8}}>
          {["tkm","spk"].map(s=>{
            const sel=dbStore===s;
            return <button key={s} onClick={()=>setDbStore(s)} style={{padding:"6px 14px",fontSize:12,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:sel?"#1e40af":"#e2e8f0",color:sel?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>;
          })}
        </div>
        <div style={{overflow:"auto",maxHeight:"75vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",minWidth:yjMonths.length*92+200}}>
            <thead>
              <tr>
                <th style={{...thS2,textAlign:"left",position:"sticky",left:0,zIndex:2,minWidth:160}}>KPI / 月</th>
                {yjMonths.map(ym=>{
                  const isPast=new Date(ym+"-01")<new Date(today.getFullYear(),today.getMonth(),1);
                  const isCurrent=ym===today.getFullYear()+"-"+String(today.getMonth()+1).padStart(2,"0");
                  return <th key={ym} style={{...thS2,background:isCurrent?"#fef3c7":isPast?"#f8fafc":"#eff6ff",color:isCurrent?"#92400e":"#64748b"}}>{ym.replace("-","/")}</th>;
                })}
              </tr>
            </thead>
            <tbody>
              {KPIS.map(kpi=><React.Fragment key={kpi.id}>
                <tr><td colSpan={yjMonths.length+1} style={{padding:"10px 8px 4px",fontSize:13,fontWeight:900,background:"#f0f9ff",color:"#0369a1",borderBottom:"2px solid #0ea5e9"}}>{kpi.label}（{kpi.unit}）</td></tr>
                <tr>
                  <td style={{...tdL2,paddingLeft:24,fontSize:11}}>📊 実績（自動）{kpi.id==="revenue"?"・予約売上":""}</td>
                  {yjMonths.map(ym=>{
                    const v=monthData[ym][kpi.id]||0;
                    return <td key={ym} style={{...tdS2,fontWeight:v>0?700:400,color:"#1e293b"}}>{kpi.fmt(v)}</td>;
                  })}
                </tr>
                {kpi.id==="revenue"&&<React.Fragment>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,color:"#7c3aed"}}>➕ その他売上（予約外）</td>
                    {yjMonths.map(ym=>{const e=extraByM[ym]||0;return <td key={ym} style={{...tdS2,color:"#7c3aed",fontWeight:e>0?700:400}}>{e>0?"¥"+Math.round(e).toLocaleString():"-"}</td>;})}
                  </tr>
                  <tr style={{background:"#f5f3ff"}}>
                    <td style={{...tdL2,paddingLeft:24,fontWeight:800,background:"#f5f3ff",color:"#5b21b6"}}>＝ 合計（実績＋その他）</td>
                    {yjMonths.map(ym=>{const t=(monthData[ym].revenue||0)+(extraByM[ym]||0);return <td key={ym} style={{...tdS2,fontWeight:800,color:"#5b21b6",background:"#f5f3ff"}}>{t>0?"¥"+Math.round(t).toLocaleString():"-"}</td>;})}
                  </tr>
                </React.Fragment>}
                <tr style={{background:"#fffbeb"}}>
                  <td style={{...tdL2,paddingLeft:24,fontWeight:700,background:"#fffbeb"}}>🎯 目標（手動）</td>
                  {yjMonths.map(ym=>{
                    const v=(targets[ym]||{})[kpi.id]||"";
                    return <td key={ym} style={{...tdS2,padding:0,background:"#fffbeb"}}>
                      <input type="number" value={v} onChange={e=>saveTarget(ym,kpi.id,e.target.value)} style={inpS} placeholder="0"/>
                    </td>;
                  })}
                </tr>
                <tr>
                  <td style={{...tdL2,paddingLeft:24,fontSize:11,color:"#64748b"}}>達成率{kpi.id==="revenue"?"（合計÷目標）":""}</td>
                  {yjMonths.map(ym=>{
                    const act=(monthData[ym][kpi.id]||0)+(kpi.id==="revenue"?(extraByM[ym]||0):0);
                    const tgt=(targets[ym]||{})[kpi.id]||0;
                    const pct=tgt>0?(act/tgt)*100:0;
                    const bg=tgt===0?"transparent":pct>=100?"#dcfce7":pct>=70?"#fef9c3":"#fef2f2";
                    const fg=tgt===0?"#64748b":pct>=100?"#15803d":pct>=70?"#854d0e":"#b91c1c";
                    return <td key={ym} style={{...tdS2,background:bg,color:fg,fontWeight:700}}>{tgt>0?pct.toFixed(0)+"%":"-"}</td>;
                  })}
                </tr>
              </React.Fragment>)}
            </tbody>
          </table>
        </div>
        <div style={{marginTop:12,padding:10,background:"#f0f9ff",borderRadius:8,fontSize:11,color:"#0369a1"}}>
          <div style={{fontWeight:700,marginBottom:4}}>💡 使い方</div>
          <div>① 黄色セルの「目標」を入力 → 自動保存（app_settings.{storeKey}）</div>
          <div>② 実績は予約データから自動計算</div>
          <div>③ 達成率: 🟢100%以上 / 🟡70%以上 / 🔴70%未満</div>
        </div>

        {/* === 📊 チャネル別 広告費効率（HP × 純広告費 / OTA × 手数料18%） === */}
        {(()=>{
          // 広告費取得: ① cm_xxx のカスタム項目を優先 / ② 値なしなら cost_xxx の sga_ad にフォールバック
          const AD_CODES=dbStore==="spk"?["xmoxky29punj","xmoxky7sxos9","xmoxkyd9yojr"]:["xmop3xv4n7f6"];
          const getAd=(ym)=>{
            // ① cm_xxx のカスタム広告費項目
            const cm=(cmMap[dbStore]||{})[ym]||{};
            let cmTotal=0;AD_CODES.forEach(c=>{cmTotal+=Number(cm[c]||0);});
            if(cmTotal>0)return cmTotal;
            // ② cost_xxx の sga_ad にフォールバック（cmが0の月のみ）
            const costArr=(costMap[dbStore]||{})[ym]||[];
            let costTotal=0;
            (Array.isArray(costArr)?costArr:[]).forEach(it=>{
              if((it.account_code||"")==="sga_ad") costTotal+=Number(it.amount||0);
            });
            return costTotal;
          };
          const isSpk=dbStore==="spk";
          const rdKey=isSpk?"return_date":"end_date";
          const active=(dbResvs||[]).filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
          const calcAd=(ym)=>{
            // hpSalesB/hpNB = 発生月ベース、hpSalesR/hpNR = 返却月ベース
            let hpSalesB=0,hpNB=0,hpSalesR=0,hpNR=0,otaSales=0,otaN=0,rakutenDisc=0,allN=0;
            active.forEach(r=>{
              const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
              const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
              const rd=r[rdKey];
              // 合算件数: 全チャネルの返却月件数（Summary と同一）
              if(rd&&rd.slice(0,7)===ym)allN++;
              if(r.ota==="HP"){
                // 発生月: booked_at 優先 / なければ created_at（一括インポート日 2026-03-29 を除外）
                let bm=null;
                if(r.booked_at){bm=r.booked_at.slice(0,7);}
                else if(r.created_at && r.created_at.slice(0,10)!=="2026-03-29"){bm=r.created_at.slice(0,7);}
                if(bm===ym){hpSalesB+=rev;hpNB+=1;}
                if(rd && rd.slice(0,7)===ym){hpSalesR+=rev;hpNR+=1;}
              }else if(["J","R","S","O","RC","G"].includes(r.ota)){
                if(rd&&rd.slice(0,7)===ym){
                  otaSales+=rev;otaN+=1;
                  // 楽天事業者クーポン（弊社実負担）= discount。返却月ベース集計
                  if(r.ota==="R" && dc>0) rakutenDisc+=dc;
                }
              }
            });
            const ad=getAd(ym);
            const otaFee=Math.round(otaSales*0.18);
            const otaCostTotal=otaFee+rakutenDisc;
            return {
              hpSalesB,hpNB,hpRateB:hpSalesB>0?ad/hpSalesB*100:(ad>0?Infinity:0),
              hpSalesR,hpNR,hpRateR:hpSalesR>0?ad/hpSalesR*100:(ad>0?Infinity:0),
              ad,
              otaSales,otaN,otaFee,rakutenDisc,otaCostTotal,
              otaRate:18,
              otaRateActual:otaSales>0?otaCostTotal/otaSales*100:0,
              // 合算: HP+OTA売上 / 全件数（全チャネル）/ 広告費
              totalSales:hpSalesR+otaSales,totalN:allN,
              totalCost:ad+otaFee+rakutenDisc,totalRate:(hpSalesR+otaSales)>0?(ad+otaFee+rakutenDisc)/(hpSalesR+otaSales)*100:0,
            };
          };
          const adRows={};yjMonths.forEach(ym=>{adRows[ym]=calcAd(ym);});
          const cpa=(cost,n)=>n>0?'¥'+Math.round(cost/n).toLocaleString()+'/件':'-';
          const cpaV=(cost,n)=>n>0?Math.round(cost/n):0;
          const cpaBg=(v)=>!v?'transparent':v<3000?'#dcfce7':v<6000?'#fef9c3':'#fef2f2';
          const cpaClr=(v)=>!v?'#94a3b8':v<3000?'#15803d':v<6000?'#854d0e':'#b91c1c';
          const sumRange=(filterFn)=>{
            const r={hpSalesB:0,hpNB:0,hpSalesR:0,hpNR:0,ad:0,otaSales:0,otaN:0,otaFee:0,rakutenDisc:0,otaCostTotal:0,totalSales:0,totalN:0,totalCost:0};
            yjMonths.filter(filterFn).forEach(ym=>{
              const a=adRows[ym];
              r.hpSalesB+=a.hpSalesB;r.hpNB+=a.hpNB;
              r.hpSalesR+=a.hpSalesR;r.hpNR+=a.hpNR;
              r.ad+=a.ad;
              r.otaSales+=a.otaSales;r.otaN+=a.otaN;r.otaFee+=a.otaFee;
              r.rakutenDisc+=a.rakutenDisc;r.otaCostTotal+=a.otaCostTotal;
              r.totalSales+=a.totalSales;r.totalN+=a.totalN;r.totalCost+=a.totalCost;
            });
            return r;
          };
          const curYm=today.getFullYear()+"-"+String(today.getMonth()+1).padStart(2,"0");
          const ytd=sumRange(ym=>ym.startsWith(today.getFullYear()+"-")&&ym<=curYm);
          const yen=(v)=>v?"¥"+Math.round(v).toLocaleString():"-";
          const cnt=(v)=>v?v+"件":"-";
          const pctF=(v)=>{if(!v||v===Infinity)return v===Infinity?"∞":"-";return v.toFixed(1)+"%";};
          const sigClr=(v)=>{if(!v||v===Infinity)return v===Infinity?"#b91c1c":"#94a3b8";if(v<10)return"#15803d";if(v<20)return"#854d0e";return"#b91c1c";};
          const sigBg=(v)=>{if(!v||v===Infinity)return v===Infinity?"#fef2f2":"transparent";if(v<10)return"#dcfce7";if(v<20)return"#fef9c3";return"#fef2f2";};

          const sectHeadStyle={padding:"10px 8px 4px",fontSize:13,fontWeight:900,borderBottom:"2px solid #0ea5e9"};
          return <div style={{marginTop:20}}>
            <div style={{fontSize:14,fontWeight:900,marginBottom:4}}>📊 チャネル別 広告費効率 — {storeLabel}</div>
            <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>
              <span style={{color:"#1e40af",fontWeight:700}}>HPチャネル</span>: 純広告費 ¥（経営管理シート入力値）vs 予約発生月ベースのHP売上・件数（投資対効果）
              　/
              <span style={{color:"#7c3aed",fontWeight:700}}>OTAチャネル</span>: OTA売上の18%が手数料（返却月ベース・自動計算）
            </div>
            <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
              <table style={{width:"100%",borderCollapse:"collapse",minWidth:yjMonths.length*92+220}}>
                <thead>
                  <tr>
                    <th style={{...thS2,textAlign:"left",position:"sticky",left:0,zIndex:2,minWidth:200}}>項目 / 月</th>
                    {yjMonths.map(ym=>{
                      const isCurrent=ym===curYm;
                      const isPast=new Date(ym+"-01")<new Date(today.getFullYear(),today.getMonth(),1);
                      return <th key={ym} style={{...thS2,background:isCurrent?"#fef3c7":isPast?"#f8fafc":"#eff6ff",color:isCurrent?"#92400e":"#64748b"}}>{ym.replace("-","/")}</th>;
                    })}
                    <th style={{...thS2,background:"#1e293b",color:"#fff",position:"sticky",right:0,zIndex:2}}>YTD累計</th>
                  </tr>
                </thead>
                <tbody>
                  {/* === 🏠 HPチャネル × 純広告費（予約発生月ベース）— 投資対効果 === */}
                  <tr><td colSpan={yjMonths.length+2} style={{...sectHeadStyle,background:"#dbeafe",color:"#1e3a8a"}}>🏠 HPチャネル × 純広告費（予約発生月ベース）— 投資対効果</td></tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💰 HP売上（発生月）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].hpSalesB>0?700:400}}>{yen(adRows[ym].hpSalesB)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.hpSalesB)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>📥 HP件数（新規発生）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].hpNB>0?700:400}}>{cnt(adRows[ym].hpNB)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{cnt(ytd.hpNB)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💸 純広告費（実支出）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].ad>0?700:400,color:adRows[ym].ad>0?"#1e40af":"#94a3b8"}}>{yen(adRows[ym].ad)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.ad)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:700}}>📊 HP広告比率（発生月）</td>
                    {yjMonths.map(ym=>{
                      const r=adRows[ym].hpRateB;
                      return <td key={ym} style={{...tdS2,background:sigBg(r),color:sigClr(r),fontWeight:700}}>{pctF(r)}</td>;
                    })}
                    {(()=>{const r=ytd.hpSalesB>0?ytd.ad/ytd.hpSalesB*100:0;return <td style={{...tdS2,fontWeight:900,background:sigBg(r),color:sigClr(r),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{pctF(r)}</td>;})()}
                  </tr>
                  <tr style={{background:"#f0fdf4"}}>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:800,color:"#15803d"}}>💰 HP CPA（発生月）</td>
                    {yjMonths.map(ym=>{const v=cpaV(adRows[ym].ad,adRows[ym].hpNB);return <td key={ym} style={{...tdS2,background:cpaBg(v),color:cpaClr(v),fontWeight:700}}>{cpa(adRows[ym].ad,adRows[ym].hpNB)}</td>;})}
                    {(()=>{const v=cpaV(ytd.ad,ytd.hpNB);return <td style={{...tdS2,fontWeight:900,background:cpaBg(v),color:cpaClr(v),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{cpa(ytd.ad,ytd.hpNB)}</td>;})()}
                  </tr>

                  {/* === 🏠 HPチャネル × 純広告費（返却月ベース）— PL/経営管理視点 === */}
                  <tr><td colSpan={yjMonths.length+2} style={{...sectHeadStyle,background:"#bfdbfe",color:"#1e3a8a"}}>🏠 HPチャネル × 純広告費（返却月ベース）— PL基準・合算用</td></tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💰 HP売上（返却月）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].hpSalesR>0?700:400}}>{yen(adRows[ym].hpSalesR)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.hpSalesR)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>📥 HP件数（返却月）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].hpNR>0?700:400}}>{cnt(adRows[ym].hpNR)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{cnt(ytd.hpNR)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💸 純広告費（実支出）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].ad>0?700:400,color:adRows[ym].ad>0?"#1e40af":"#94a3b8"}}>{yen(adRows[ym].ad)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.ad)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:700}}>📊 HP広告比率（返却月）</td>
                    {yjMonths.map(ym=>{
                      const r=adRows[ym].hpRateR;
                      return <td key={ym} style={{...tdS2,background:sigBg(r),color:sigClr(r),fontWeight:700}}>{pctF(r)}</td>;
                    })}
                    {(()=>{const r=ytd.hpSalesR>0?ytd.ad/ytd.hpSalesR*100:0;return <td style={{...tdS2,fontWeight:900,background:sigBg(r),color:sigClr(r),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{pctF(r)}</td>;})()}
                  </tr>
                  <tr style={{background:"#f0fdf4"}}>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:800,color:"#15803d"}}>💰 HP CPA（返却月）</td>
                    {yjMonths.map(ym=>{const v=cpaV(adRows[ym].ad,adRows[ym].hpNR);return <td key={ym} style={{...tdS2,background:cpaBg(v),color:cpaClr(v),fontWeight:700}}>{cpa(adRows[ym].ad,adRows[ym].hpNR)}</td>;})}
                    {(()=>{const v=cpaV(ytd.ad,ytd.hpNR);return <td style={{...tdS2,fontWeight:900,background:cpaBg(v),color:cpaClr(v),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{cpa(ytd.ad,ytd.hpNR)}</td>;})()}
                  </tr>

                  {/* === 🌐 OTAチャネル === */}
                  <tr><td colSpan={yjMonths.length+2} style={{...sectHeadStyle,background:"#ede9fe",color:"#5b21b6"}}>🌐 OTAチャネル × 手数料18%（返却月ベース）</td></tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💰 OTA売上（返却月）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].otaSales>0?700:400}}>{yen(adRows[ym].otaSales)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.otaSales)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>📥 OTA件数</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].otaN>0?700:400}}>{cnt(adRows[ym].otaN)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{cnt(ytd.otaN)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💸 OTA手数料 (18%固定)</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].otaFee>0?700:400,color:adRows[ym].otaFee>0?"#7c3aed":"#94a3b8"}}>{yen(adRows[ym].otaFee)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.otaFee)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11}}>🎫 楽天事業者クーポン（弊社実負担）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].rakutenDisc>0?700:400,color:adRows[ym].rakutenDisc>0?"#dc2626":"#94a3b8"}}>{yen(adRows[ym].rakutenDisc)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.rakutenDisc)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:700}}>💰 OTAコスト合計（手数料+楽天C）</td>
                    {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:adRows[ym].otaCostTotal>0?700:400,color:adRows[ym].otaCostTotal>0?"#7c3aed":"#94a3b8"}}>{yen(adRows[ym].otaCostTotal)}</td>)}
                    <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{yen(ytd.otaCostTotal)}</td>
                  </tr>
                  <tr>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:700}}>📊 OTA実質広告比率</td>
                    {yjMonths.map(ym=>{
                      const r=adRows[ym].otaRateActual;
                      return <td key={ym} style={{...tdS2,background:sigBg(r),color:sigClr(r),fontWeight:700}}>{pctF(r)}</td>;
                    })}
                    {(()=>{const r=ytd.otaSales>0?ytd.otaCostTotal/ytd.otaSales*100:0;return <td style={{...tdS2,fontWeight:900,background:sigBg(r),color:sigClr(r),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{pctF(r)}</td>;})()}
                  </tr>
                  <tr style={{background:"#fdf4ff"}}>
                    <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:800,color:"#7c3aed"}}>💰 OTA CPA（合計）</td>
                    {yjMonths.map(ym=>{const v=cpaV(adRows[ym].otaCostTotal,adRows[ym].otaN);return <td key={ym} style={{...tdS2,background:cpaBg(v),color:cpaClr(v),fontWeight:700}}>{cpa(adRows[ym].otaCostTotal,adRows[ym].otaN)}</td>;})}
                    {(()=>{const v=cpaV(ytd.otaCostTotal,ytd.otaN);return <td style={{...tdS2,fontWeight:900,background:cpaBg(v),color:cpaClr(v),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{cpa(ytd.otaCostTotal,ytd.otaN)}</td>;})()}
                  </tr>

                  {/* === 📊 合算 === 返却月ベース統一 (HP返却売上 + OTA返却売上) */}
                  <tr><td colSpan={yjMonths.length+2} style={{...sectHeadStyle,background:"#fef3c7",color:"#92400e"}}>📊 合算（HP+OTA / 返却月ベース統一）— PL基準</td></tr>
                  {(()=>{
                    const isBoth=(ym)=>(adRows[ym].hpSalesR>0 && adRows[ym].otaSales>0);
                    const isBothYtd=(ytd.hpSalesR>0 && ytd.otaSales>0);
                    return <React.Fragment>
                      <tr>
                        <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💰 合算売上</td>
                        {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:isBoth(ym)?700:400}}>{isBoth(ym)?yen(adRows[ym].totalSales):"-"}</td>)}
                        <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{isBothYtd?yen(ytd.totalSales):"-"}</td>
                      </tr>
                      <tr>
                        <td style={{...tdL2,paddingLeft:24,fontSize:11}}>📥 合算件数</td>
                        {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:isBoth(ym)?700:400}}>{isBoth(ym)?cnt(adRows[ym].totalN):"-"}</td>)}
                        <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{isBothYtd?cnt(ytd.totalN):"-"}</td>
                      </tr>
                      <tr>
                        <td style={{...tdL2,paddingLeft:24,fontSize:11}}>💸 広告費合計（純広告+OTA手数料+楽天C）</td>
                        {yjMonths.map(ym=><td key={ym} style={{...tdS2,fontWeight:isBoth(ym)?700:400,color:isBoth(ym)?"#92400e":"#94a3b8"}}>{isBoth(ym)?yen(adRows[ym].totalCost):"-"}</td>)}
                        <td style={{...tdS2,fontWeight:900,background:"#1e293b",color:"#fff",position:"sticky",right:0}}>{isBothYtd?yen(ytd.totalCost):"-"}</td>
                      </tr>
                      <tr>
                        <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:700}}>📊 合算広告比率</td>
                        {yjMonths.map(ym=>{
                          if(!isBoth(ym))return <td key={ym} style={{...tdS2,color:"#94a3b8"}}>-</td>;
                          const r=adRows[ym].totalRate;
                          return <td key={ym} style={{...tdS2,background:sigBg(r),color:sigClr(r),fontWeight:700}}>{pctF(r)}</td>;
                        })}
                        {(()=>{
                          if(!isBothYtd)return <td style={{...tdS2,color:"#94a3b8",position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>-</td>;
                          const r=ytd.totalSales>0?ytd.totalCost/ytd.totalSales*100:0;
                          return <td style={{...tdS2,fontWeight:900,background:sigBg(r),color:sigClr(r),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{pctF(r)}</td>;
                        })()}
                      </tr>
                      <tr style={{background:"#fef9c3"}}>
                        <td style={{...tdL2,paddingLeft:24,fontSize:11,fontWeight:900,color:"#92400e"}}>💰 合算 CPA（グロス）</td>
                        {yjMonths.map(ym=>{
                          if(!isBoth(ym))return <td key={ym} style={{...tdS2,color:"#94a3b8"}}>-</td>;
                          const v=cpaV(adRows[ym].totalCost,adRows[ym].totalN);
                          return <td key={ym} style={{...tdS2,background:cpaBg(v),color:cpaClr(v),fontWeight:800}}>{cpa(adRows[ym].totalCost,adRows[ym].totalN)}</td>;
                        })}
                        {(()=>{
                          if(!isBothYtd)return <td style={{...tdS2,color:"#94a3b8",position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>-</td>;
                          const v=cpaV(ytd.totalCost,ytd.totalN);
                          return <td style={{...tdS2,fontWeight:900,background:cpaBg(v),color:cpaClr(v),position:"sticky",right:0,boxShadow:"-2px 0 4px rgba(0,0,0,0.1)"}}>{cpa(ytd.totalCost,ytd.totalN)}</td>;
                        })()}
                      </tr>
                    </React.Fragment>;
                  })()}
                </tbody>
              </table>
            </div>
            <div style={{marginTop:8,padding:10,background:"#f0f9ff",borderRadius:8,fontSize:11,color:"#0369a1"}}>
              <div style={{fontWeight:700,marginBottom:4}}>💡 評価軸</div>
              <div>・<b>HP発生月ベース</b> = 投資対効果視点（その月に新規予約された予約のprice合計、未来利用も含む）。booked_at 優先 / なければ created_at（2026-03-29 一括インポート分は除外）</div>
              <div>・<b>HP返却月ベース</b> = PL/経営管理視点（実利用月で計上）。OTA売上と時間軸を統一できるため合算可能</div>
              <div>・<b>合算（返却月ベース）</b> = HP返却売上 + OTA返却売上 / 純広告費 + OTA手数料18% + 楽天事業者クーポン / 売上比 = PL基準の月別広告費比率</div>
              <div>・<b>OTA実質広告比率</b> = (手数料18% + 楽天事業者クーポン) ÷ OTA売上。楽天クーポン分があるため18%超（実態コスト）</div>
              <div>・<b>OTA売上</b> = 返却月ベース（実利用月）。OTA売上 × 18% = 当月手数料負担</div>
              <div>・<b>広告比率</b> 信号: 🟢{"<10%"} / 🟡10-20% / 🔴{">20%"}</div>
              <div>・楽天事業者クーポンは別途（経営管理タブ E. 解析タブを参照）</div>
            </div>
          </div>;
        })()}
      </div>;
    })()}

    {/* --- 設定 --- */}
    {sub==="settings"&&<div>
      <div style={{fontSize:14,fontWeight:900,marginBottom:12}}>設定・マスターデータ</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
        {/* チャネルマスター */}
        <div style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,padding:12}}>
          <div style={{fontSize:12,fontWeight:800,marginBottom:8}}>チャネルマスター（入金サイクル）</div>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr>
              <th style={{fontSize:9,textAlign:"left",padding:"3px 6px",borderBottom:"2px solid #e2e8f0"}}>チャネル名</th>
              <th style={{fontSize:9,textAlign:"center",padding:"3px 6px",borderBottom:"2px solid #e2e8f0",width:80}}>入金サイクル(月後)</th>
              <th style={{fontSize:9,textAlign:"left",padding:"3px 6px",borderBottom:"2px solid #e2e8f0"}}>備考</th>
            </tr></thead>
            <tbody>
              {(mgSettings.channels||[]).map((ch,i)=><tr key={i}>
                <td style={{fontSize:10,padding:"3px 6px",borderBottom:"1px solid #f1f5f9"}}>{ch.name}</td>
                <td style={{padding:0,borderBottom:"1px solid #f1f5f9"}}><input type="number" value={ch.cycle} onChange={e=>{const chs=[...(mgSettings.channels||[])];chs[i]={...chs[i],cycle:parseInt(e.target.value)||0};saveMgSettings({...mgSettings,channels:chs});}} style={{width:"100%",textAlign:"center",border:"none",background:"#fffbeb",fontSize:10,padding:"3px 4px"}}/></td>
                <td style={{fontSize:9,padding:"3px 6px",borderBottom:"1px solid #f1f5f9",color:"#64748b"}}>{ch.note}</td>
              </tr>)}
            </tbody>
          </table>
        </div>
        {/* 主要前提 */}
        <div style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,padding:12}}>
          <div style={{fontSize:12,fontWeight:800,marginBottom:8}}>主要前提</div>
          {[
            {k:"initCash",l:"期初現金残高（円）",note:"銀行残高の期初値"},
            {k:"minCash",l:"最低必要残高（円）",note:"アラート基準"},
            {k:"runrateMonths",l:"ランレート基準月数",note:"直近N月平均でショート予測"},
          ].map(f=><div key={f.k} style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
            <span style={{fontSize:10,width:160,flexShrink:0}}>{f.l}</span>
            <input type="number" value={mgSettings[f.k]||0} onChange={e=>saveMgSettings({...mgSettings,[f.k]:parseInt(e.target.value)||0})} style={{width:120,border:"1px solid #e2e8f0",borderRadius:4,padding:"4px 8px",fontSize:11,background:"#fffbeb"}}/>
            <span style={{fontSize:9,color:"#64748b"}}>{f.note}</span>
          </div>)}
          <div style={{fontSize:12,fontWeight:800,marginTop:16,marginBottom:8}}>店舗マスター</div>
          <div style={{fontSize:10,color:"#334155"}}>1. 高松　2. 札幌</div>
          <div style={{fontSize:9,color:"#94a3b8",marginTop:4}}>※ 店舗の追加はAPPの管理者設定で行います</div>
        </div>
      </div>
      {/* 車両タイプ別台数（APPはSupabase vehiclesから自動取得） */}
      <div style={{background:"#fff",border:"1px solid #e2e8f0",borderRadius:8,padding:12,marginTop:16}}>
        <div style={{fontSize:12,fontWeight:800,marginBottom:4}}>車両タイプ別台数（自動 — Supabase vehicles / vehicle_monthly_kpi）</div>
        <div style={{fontSize:9,color:"#94a3b8",marginBottom:8}}>※ APPでは配車表の「稼働除外」フラグで月別台数を管理。Excelのような手入力不要。</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
          {["tkm","spk"].map(st=>{
            const vehs=st==="spk"?dbVehs:[];
            const label=st==="tkm"?"高松":"札幌";
            return <div key={st}>
              <div style={{fontSize:11,fontWeight:700,marginBottom:4}}>{label}</div>
              <div style={{fontSize:9,color:"#64748b"}}>
                {st==="spk"&&dbVehs.length>0?
                  DB_VEH_TYPES.map(t=>{const c=dbVehs.filter(v=>(v.type||"")==t&&v.active!==false).length;return c>0?<span key={t} style={{marginRight:8}}>タイプ{t}: {c}台</span>:null;}):
                  <span>経営DBタブで店舗を選択するとロードされます</span>
                }
              </div>
            </div>;
          })}
        </div>
      </div>
    </div>}

    {/* --- ダッシュボード --- */}
    {sub==="dashboard"&&<div>
      {/* ★ ヘッダー: 月/年トグル + 期間選択 */}
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12,flexWrap:"wrap"}}>
        <div style={{display:"inline-flex",borderRadius:8,overflow:"hidden",border:"1px solid #cbd5e1"}}>
          {[["month","📊 月別","#2563eb"],["year","📈 年別","#d97706"]].map(([k,l,col])=>{
            const sel=dashPeriod===k;
            return <button key={k} onClick={()=>setDashPeriod(k)} style={{padding:"6px 14px",fontSize:12,fontWeight:800,border:"none",cursor:"pointer",background:sel?col:"#fff",color:sel?"#fff":"#475569",transition:"all 0.15s"}}>{l}</button>;
          })}
        </div>
        {dashPeriod==="month"?<>
          <span style={{fontSize:12,color:"#64748b"}}>対象月:</span>
          <input type="month" value={dashYm} onChange={e=>setDashYm(e.target.value)} style={{padding:"4px 8px",fontSize:12,border:"1px solid #cbd5e1",borderRadius:6}}/>
        </>:<>
          <span style={{fontSize:12,color:"#64748b"}}>対象年:</span>
          <select value={dashYm.slice(0,4)} onChange={e=>setDashYm(e.target.value+"-"+dashYm.slice(5))} style={{padding:"5px 10px",fontSize:12,border:"1px solid #cbd5e1",borderRadius:6,fontWeight:700}}>
            {[...Array(5)].map((_,i)=>{const y=new Date().getFullYear()-i;return <option key={y} value={y}>{y}年</option>;})}
          </select>
        </>}
        <button onClick={()=>setSub("dashboard")} style={btn("#0891b2")}>↻ 再読込</button>
        <button onClick={()=>openPdfReport_(dbStore,dashPeriod,dashYm,dashKpi,dashYearly,dbResvs)} style={btn("#059669")}>📄 PDF出力</button>
        <button onClick={()=>{
          var liveKey=dbStore+"_"+dashYm;
          var liveByClass=window._kpi_byClass&&window._kpi_byClass[liveKey]||null;
          openFullMonthlyReport_(dbStore,dashYm,dbResvs,dbVehs,dbFleet,dbKpi,cmMap,costMap,extraByM,dashKpi,dashYearly,liveByClass);
        }} style={{...btn("#7c3aed"),fontWeight:800}}>📋 月次レポート（{dashYm}）</button>
        <span style={{fontSize:10,color:"#a78bfa"}}>↑ダッシュボードの月選択と連動</span>

        <span style={{marginLeft:"auto",fontSize:10,color:"#94a3b8",fontWeight:600}}>{dashPeriod==="year"?"※ 年モードは加重平均（Σ値/Σ母数）で算出":"※ 月単位の計上ベース"}</span>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:10,marginBottom:16}}>
        <div style={{...card,minWidth:180}}><div style={lbl}>{dashPeriod==="year"?"年間売上 (計上)":"当月売上 (計上)"}</div><div style={{display:"flex",flexDirection:"column",gap:2,marginTop:4}}><div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}><span style={{fontSize:10,color:"#64748b"}}>予約売上</span><span style={{fontSize:14,fontWeight:700,color:"#1e40af"}}>{fmtM(dashKpi.plRev)}</span></div>{dashKpi.extraRev>0&&<div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}><span style={{fontSize:10,color:"#64748b"}}>予約外</span><span style={{fontSize:14,fontWeight:700,color:"#7c3aed"}}>+{fmtM(dashKpi.extraRev)}</span></div>}<div style={{borderTop:"1px solid #e2e8f0",marginTop:3,paddingTop:3,display:"flex",justifyContent:"space-between",alignItems:"center"}}><span style={{fontSize:10,fontWeight:700,color:"#374151"}}>合計</span><span style={{fontSize:16,fontWeight:900,color:"#059669"}}>{fmtM(dashKpi.plRev+dashKpi.extraRev)}</span></div></div><div style={{fontSize:10,color:"#94a3b8",marginTop:2}}>{dashKpi.plCnt}件 · {dashKpi.periodLabel}</div></div>
        <div style={card}><div style={lbl}>{dashPeriod==="year"?"年間入金 (CF)":"当月入金 (CF)"}</div><div style={val}>{fmtM(dashKpi.cfIn)}</div><div style={{fontSize:10,color:"#64748b"}}>{dashKpi.plRev>0?"入金率 "+Math.round(dashKpi.cfIn/dashKpi.plRev*100)+"%":"-"}</div></div>
        <div style={card}><div style={lbl}>売上件数</div><div style={val}>{dashKpi.plCnt}件</div></div>
        <div style={card}><div style={lbl}>客単価 (1予約)</div><div style={val}>{dashKpi.plCnt>0?"¥"+Math.round(dashKpi.unitPrice).toLocaleString():"-"}</div></div>
        <div style={{...card,background:"#f0fdf4",border:"1px solid #bbf7d0"}}><div style={lbl}>稼働率</div><div style={{...val,color:"#059669"}}>{dashKpi.utilPct}%</div><div style={{fontSize:10,color:"#64748b"}}>{dashKpi.utilDays}/{dashKpi.utilMaxDays}日・{dashKpi.utilActiveCount}台{dashPeriod==="year"?"(平均)":""}</div></div>
        <div style={{...card,background:"#eef2ff",border:"1px solid #c7d2fe"}}><div style={lbl}>★ 平均泊数 (1予約あたり)</div><div style={{...val,color:"#4338ca"}}>{dashKpi.avgNights>0?dashKpi.avgNights.toFixed(2)+"泊":"-"}</div><div style={{fontSize:10,color:"#64748b"}}>延べ泊数 {dashKpi.daysSum.toFixed(1)}泊</div></div>
        <div style={card}><div style={lbl}>1日あたり単価</div><div style={val}>{dashKpi.dailyRate>0?"¥"+Math.round(dashKpi.dailyRate).toLocaleString():"-"}</div></div>
      </div>
      {/* ★ 国内/海外 比率カード（HP予約のみ） */}
      {dashRegion.total>0&&<div style={{...card,marginBottom:12}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10}}>
          <div style={{fontSize:14,fontWeight:900}}>🌍 国内 / 海外 比率 — 当月新規HP予約獲得（高松）</div>
          <div style={{fontSize:10,color:"#94a3b8"}}>新規獲得月 · {dashKpi.periodLabel} · {dashRegion.total}件</div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:10}}>
          {/* 国内 */}
          <div style={{background:"#eff6ff",borderRadius:10,padding:"12px 14px",border:"1px solid #bfdbfe"}}>
            <div style={{fontSize:11,color:"#1d4ed8",fontWeight:700,marginBottom:6}}>🇯🇵 国内</div>
            <div style={{fontSize:28,fontWeight:900,color:"#1d4ed8",lineHeight:1}}>{dashRegion.domCnt}<span style={{fontSize:12,fontWeight:600,marginLeft:2}}>件</span></div>
            <div style={{fontSize:13,fontWeight:700,color:"#2563eb",marginTop:4}}>¥{dashRegion.domRev.toLocaleString()}</div>
            <div style={{fontSize:11,color:"#64748b",marginTop:4}}>{dashRegion.total>0?Math.round(dashRegion.domCnt/dashRegion.total*100):0}% · 客単価 ¥{dashRegion.domCnt>0?Math.round(dashRegion.domRev/dashRegion.domCnt).toLocaleString():"-"}</div>
          </div>
          {/* 海外 */}
          <div style={{background:"#fdf4ff",borderRadius:10,padding:"12px 14px",border:"1px solid #e9d5ff"}}>
            <div style={{fontSize:11,color:"#7c3aed",fontWeight:700,marginBottom:6}}>🌏 海外</div>
            <div style={{fontSize:28,fontWeight:900,color:"#7c3aed",lineHeight:1}}>{dashRegion.ovsCnt}<span style={{fontSize:12,fontWeight:600,marginLeft:2}}>件</span></div>
            <div style={{fontSize:13,fontWeight:700,color:"#7c3aed",marginTop:4}}>¥{dashRegion.ovsRev.toLocaleString()}</div>
            <div style={{fontSize:11,color:"#64748b",marginTop:4}}>{dashRegion.total>0?Math.round(dashRegion.ovsCnt/dashRegion.total*100):0}% · 客単価 ¥{dashRegion.ovsCnt>0?Math.round(dashRegion.ovsRev/dashRegion.ovsCnt).toLocaleString():"-"}</div>
          </div>
        </div>
        {/* 比率バー */}
        <div style={{height:8,borderRadius:4,overflow:"hidden",display:"flex"}}>
          <div style={{background:"#3b82f6",width:(dashRegion.total>0?dashRegion.domCnt/dashRegion.total*100:50)+"%",transition:"width .4s"}}/>
          <div style={{background:"#a855f7",flex:1}}/>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:"#94a3b8",marginTop:4}}>
          <span>🇯🇵 国内 {dashRegion.total>0?Math.round(dashRegion.domCnt/dashRegion.total*100):0}%</span>
          <span>※漢字のみ名前は国内判定（手動確認推奨）</span>
          <span>🌏 海外 {dashRegion.total>0?Math.round(dashRegion.ovsCnt/dashRegion.total*100):0}%</span>
        </div>
      </div>}
      {/* ★ 売上4分解（基本料金 / 付帯売上 / 予約外 / 割引）月/年自動切替 */}
      <div style={{...card,marginBottom:12}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:8}}>
          <div style={{fontSize:14,fontWeight:900}}>💰 売上4分解 ({dashKpi.periodLabel})</div>
          <div style={{fontSize:10,color:"#94a3b8"}}>売上 = 基本料金 + 付帯売上 + 予約外 - 割引</div>
        </div>
        {(()=>{
          const extra=dashKpi.extraRev||0;
          const gross=dashKpi.plBase+dashKpi.plOpt+extra;
          const bPct=gross>0?(dashKpi.plBase/gross*100):0;
          const oPct=gross>0?(dashKpi.plOpt/gross*100):0;
          const ePct=gross>0?(extra/gross*100):0;
          const dRate=gross>0?(dashKpi.plDisc/gross*100):0;
          const total=dashKpi.plRev+extra;
          return <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:10}}>
            <div style={{padding:10,borderRadius:8,background:"#eff6ff",border:"1px solid #bfdbfe"}}>
              <div style={{fontSize:10,color:"#64748b",fontWeight:700}}>基本料金</div>
              <div style={{fontSize:18,fontWeight:900,color:"#1e40af",marginTop:2}}>{fmtM(dashKpi.plBase)}</div>
              <div style={{fontSize:10,color:"#64748b"}}>構成比 {bPct.toFixed(1)}%</div>
            </div>
            <div style={{padding:10,borderRadius:8,background:"#f0fdf4",border:"1px solid #bbf7d0"}}>
              <div style={{fontSize:10,color:"#64748b",fontWeight:700}}>付帯売上</div>
              <div style={{fontSize:18,fontWeight:900,color:"#059669",marginTop:2}}>{fmtM(dashKpi.plOpt)}</div>
              <div style={{fontSize:10,color:"#64748b"}}>構成比 {oPct.toFixed(1)}%</div>
            </div>
            <div style={{padding:10,borderRadius:8,background:"#faf5ff",border:"1px solid #e9d5ff"}}>
              <div style={{fontSize:10,color:"#64748b",fontWeight:700}}>予約外</div>
              <div style={{fontSize:18,fontWeight:900,color:"#7c3aed",marginTop:2}}>{fmtM(extra)}</div>
              <div style={{fontSize:10,color:"#64748b"}}>構成比 {ePct.toFixed(1)}%</div>
            </div>
            <div style={{padding:10,borderRadius:8,background:"#fef2f2",border:"1px solid #fecaca"}}>
              <div style={{fontSize:10,color:"#64748b",fontWeight:700}}>割引</div>
              <div style={{fontSize:18,fontWeight:900,color:"#dc2626",marginTop:2}}>-{fmtM(dashKpi.plDisc)}</div>
              <div style={{fontSize:10,color:"#64748b"}}>グロス比 {dRate.toFixed(1)}%</div>
            </div>
            <div style={{padding:10,borderRadius:8,background:"#1e293b",color:"#fff"}}>
              <div style={{fontSize:10,color:"#cbd5e1",fontWeight:700}}>合計売上</div>
              <div style={{fontSize:18,fontWeight:900,color:"#4ade80",marginTop:2}}>{fmtM(total)}</div>
              <div style={{fontSize:10,color:"#cbd5e1"}}>基本+付帯+予約外-割引</div>
            </div>
          </div>;
        })()}
      </div>
      {/* ★ 年間推移（ダッシュボードと同一のロジックで1〜12月を計算） */}
      <div style={{...card,marginBottom:12}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10}}>
          <div style={{fontSize:14,fontWeight:900}}>📈 年間推移 ({dashYearly.year}年)</div>
          <div style={{fontSize:10,color:"#94a3b8"}}>ダッシュボードと同一ロジックで月別集計</div>
        </div>
        {(()=>{
          const maxRev=Math.max(1,...dashYearly.months.map(m=>m.totalRev));
          return <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:720}}>
              <thead>
                <tr style={{background:"#f8fafc"}}>
                  <th style={{...th,textAlign:"center",width:44}}>月</th>
                  <th style={{...th,textAlign:"right",color:"#1e40af"}}>基本料金</th>
                  <th style={{...th,textAlign:"right",color:"#047857"}}>付帯売上</th>
                  <th style={{...th,textAlign:"right",color:"#dc2626"}}>割引</th>
                  <th style={{...th,textAlign:"right"}}>売上 計上</th>
                  <th style={{...th,textAlign:"right"}}>予約外</th>
                  <th style={{...th,textAlign:"right",color:"#059669"}}>合計売上</th>
                  <th style={{...th,textAlign:"right"}}>件数</th>
                  <th style={{...th,textAlign:"right"}}>客単価</th>
                  <th style={{...th,textAlign:"right"}}>平均泊数</th>
                  <th style={{...th,textAlign:"right"}}>泊単価</th>
                  <th style={{...th,textAlign:"center",color:"#059669"}}>稼働率</th>
                  <th style={{...th,textAlign:"left",minWidth:120}}>売上グラフ</th>
                </tr>
              </thead>
              <tbody>
                {dashYearly.months.map(m=>{
                  const isCurrent=m.ym===dashYm;
                  const bar=m.totalRev>0?(m.totalRev/maxRev*100):0;
                  return <tr key={m.ym} onClick={()=>setDashYm(m.ym)} style={{cursor:"pointer",background:isCurrent?"#eff6ff":"#fff",borderBottom:"1px solid #f1f5f9"}}>
                    <td style={{...td,textAlign:"center",fontWeight:isCurrent?800:600,color:isCurrent?"#1e40af":"#334155"}}>{m.mo}月</td>
                    <td style={{...td,textAlign:"right",color:"#1e40af"}}>{m.plBase>0?fmtM(m.plBase):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#047857"}}>{m.plOpt>0?fmtM(m.plOpt):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#dc2626"}}>{m.plDisc>0?"-"+fmtM(m.plDisc):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#1e40af",fontWeight:600}}>{m.plRev>0?fmtM(m.plRev):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#7c3aed"}}>{m.extraRev>0?"+"+fmtM(m.extraRev):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#059669",fontWeight:800}}>{m.totalRev>0?fmtM(m.totalRev):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#64748b"}}>{m.plCnt>0?m.plCnt+"件":"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#475569"}}>{m.plCnt>0?"¥"+Math.round(m.unitPrice).toLocaleString():"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#4338ca",fontWeight:600}}>{m.avgNights>0?m.avgNights.toFixed(2)+"泊":"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#475569"}}>{m.dailyRate>0?"¥"+Math.round(m.dailyRate).toLocaleString():"-"}</td>
                    <td style={{...td,textAlign:"center"}}>
                      {m.utilMaxDays>0?<span style={{display:"inline-block",padding:"2px 8px",borderRadius:4,fontSize:10,fontWeight:800,background:m.utilPct>=70?"#dcfce7":m.utilPct>=40?"#fef3c7":"#fee2e2",color:m.utilPct>=70?"#166534":m.utilPct>=40?"#92400e":"#991b1b"}}>{m.utilPct}%</span>:"-"}
                    </td>
                    <td style={td}>
                      <div style={{width:"100%",height:10,background:"#f1f5f9",borderRadius:3,overflow:"hidden"}}>
                        <div style={{width:bar+"%",height:"100%",background:isCurrent?"#2563eb":"#93c5fd"}}/>
                      </div>
                    </td>
                  </tr>;
                })}
                {/* 合計行 */}
                {(()=>{
                  const t=dashYearly.total;
                  const uni=t.plCnt>0?(t.plRev/t.plCnt):0;
                  const dr=t.daysSum>0?(t.plRev/t.daysSum):0;
                  const avg=t.plCnt>0?(t.daysSum/t.plCnt):0;
                  return <tr style={{background:"#1e293b",color:"#fff",fontWeight:800,borderTop:"2px solid #334155"}}>
                    <td style={{padding:"8px",fontSize:11,textAlign:"center"}}>合計</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right",color:"#93c5fd"}}>{fmtM(t.plBase)}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right",color:"#6ee7b7"}}>{fmtM(t.plOpt)}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right",color:"#fca5a5"}}>{t.plDisc>0?"-"+fmtM(t.plDisc):"-"}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{fmtM(t.plRev)}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{t.extraRev>0?"+"+fmtM(t.extraRev):"-"}</td>
                    <td style={{padding:"8px",fontSize:12,textAlign:"right",color:"#4ade80"}}>{fmtM(t.totalRev)}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{t.plCnt}件</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{t.plCnt>0?"¥"+Math.round(uni).toLocaleString():"-"}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{avg>0?avg.toFixed(2)+"泊":"-"}</td>
                    <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{dr>0?"¥"+Math.round(dr).toLocaleString():"-"}</td>
                    <td style={{padding:"8px",fontSize:10,textAlign:"center"}}>年平均</td>
                    <td style={{padding:"8px"}}/>
                  </tr>;
                })()}
              </tbody>
            </table>
            <div style={{fontSize:10,color:"#94a3b8",marginTop:6,textAlign:"right"}}>※ 月のセルをクリックするとその月のダッシュボードに切り替わります</div>
          </div>;
        })()}
      </div>

      {/* ★ チャネル別構成（ヘッダー月/年トグルに連動） */}
      <div style={{...card,marginBottom:12}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10,flexWrap:"wrap",gap:8}}>
          <div style={{fontSize:14,fontWeight:900}}>チャネル別構成 ({dashKpi.periodLabel})</div>
          <div style={{fontSize:10,color:"#94a3b8"}}>※ ヘッダーの月/年トグルに連動</div>
        </div>
        {/* 月ビュー: 3分解対応 */}
        {dashPeriod==="month"&&(Object.keys(dashKpi.byChBreak).length===0?<div style={{fontSize:11,color:"#94a3b8"}}>データなし</div>:
          <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11,minWidth:720}}>
            <thead><tr style={{background:"#f8fafc"}}>
              <th style={{...th,textAlign:"left",minWidth:110}}>チャネル</th>
              <th style={{...th,textAlign:"right",minWidth:90,color:"#1e40af"}}>基本料金</th>
              <th style={{...th,textAlign:"right",minWidth:90,color:"#047857"}}>付帯売上</th>
              <th style={{...th,textAlign:"right",minWidth:90,color:"#dc2626"}}>割引</th>
              <th style={{...th,textAlign:"right",minWidth:90,color:"#059669"}}>計上額</th>
              <th style={{...th,textAlign:"right",minWidth:54}}>件数</th>
              <th style={{...th,textAlign:"left",minWidth:160}}>構成比</th>
            </tr></thead>
            <tbody>
            {Object.entries(dashKpi.byChBreak).sort((a,b)=>b[1].rev-a[1].rev).map(([ch,d])=>{
              const pct=dashKpi.plRev>0?(d.rev/dashKpi.plRev*100):0;
              return <tr key={ch} style={{borderBottom:"1px solid #f1f5f9"}}>
                <td style={{...td,fontWeight:700}}>{ch}</td>
                <td style={{...td,textAlign:"right",color:"#1e40af"}}>{d.base>0?fmtM(d.base):"-"}</td>
                <td style={{...td,textAlign:"right",color:"#047857"}}>{d.opt>0?fmtM(d.opt):"-"}</td>
                <td style={{...td,textAlign:"right",color:"#dc2626"}}>{d.disc>0?"-"+fmtM(d.disc):"-"}</td>
                <td style={{...td,textAlign:"right",color:"#059669",fontWeight:700}}>{fmtM(d.rev)}</td>
                <td style={{...td,textAlign:"right",color:"#64748b"}}>{d.cnt}</td>
                <td style={td}>
                  <div style={{display:"flex",alignItems:"center",gap:6}}>
                    <div style={{flex:1,height:12,background:"#f1f5f9",borderRadius:4,overflow:"hidden"}}>
                      <div style={{width:pct+"%",height:"100%",background:"#3b82f6"}}/>
                    </div>
                    <span style={{minWidth:42,textAlign:"right",fontWeight:700,fontSize:10}}>{pct.toFixed(1)}%</span>
                  </div>
                </td>
              </tr>;
            })}
            {/* 合計 */}
            <tr style={{background:"#1e293b",color:"#fff",fontWeight:800}}>
              <td style={{padding:"8px",fontSize:11}}>合計</td>
              <td style={{padding:"8px",fontSize:11,textAlign:"right",color:"#93c5fd"}}>{fmtM(dashKpi.plBase)}</td>
              <td style={{padding:"8px",fontSize:11,textAlign:"right",color:"#6ee7b7"}}>{fmtM(dashKpi.plOpt)}</td>
              <td style={{padding:"8px",fontSize:11,textAlign:"right",color:"#fca5a5"}}>{dashKpi.plDisc>0?"-"+fmtM(dashKpi.plDisc):"-"}</td>
              <td style={{padding:"8px",fontSize:12,textAlign:"right",color:"#4ade80"}}>{fmtM(dashKpi.plRev)}</td>
              <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>{dashKpi.plCnt}</td>
              <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>100%</td>
            </tr>
            </tbody>
          </table>
          </div>
        )}
        {/* 年ビュー: チャネル × 月 マトリクス */}
        {dashPeriod==="year"&&(()=>{
          const chEntries=Object.entries(dashYearly.yearByCh).sort((a,b)=>b[1].total-a[1].total);
          const yearTotal=chEntries.reduce((s,[,d])=>s+d.total,0);
          const monthTotals=Array.from({length:12},(_,i)=>chEntries.reduce((s,[,d])=>s+(d[i+1]||0),0));
          if(chEntries.length===0)return <div style={{fontSize:11,color:"#94a3b8"}}>データなし</div>;
          return <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10,minWidth:760}}>
              <thead>
                <tr style={{background:"#f8fafc"}}>
                  <th style={{...th,textAlign:"left",minWidth:90,position:"sticky",left:0,background:"#f8fafc",zIndex:1}}>チャネル</th>
                  {Array.from({length:12},(_,i)=>{const isCur=(i+1)===Number(dashYm.slice(5,7))&&dashYearly.year===dashYm.slice(0,4);return <th key={i} style={{...th,textAlign:"right",minWidth:46,background:isCur?"#dbeafe":"#f8fafc",color:isCur?"#1e40af":"#64748b"}}>{i+1}月</th>;})}
                  <th style={{...th,textAlign:"right",minWidth:60,color:"#1e40af"}}>基本料金</th>
                  <th style={{...th,textAlign:"right",minWidth:60,color:"#047857"}}>付帯売上</th>
                  <th style={{...th,textAlign:"right",minWidth:60,color:"#dc2626"}}>割引</th>
                  <th style={{...th,textAlign:"right",minWidth:64,color:"#059669"}}>年計</th>
                  <th style={{...th,textAlign:"right",minWidth:50}}>構成比</th>
                </tr>
              </thead>
              <tbody>
                {chEntries.map(([ch,d])=>{
                  const pct=yearTotal>0?(d.total/yearTotal*100):0;
                  return <tr key={ch} style={{borderBottom:"1px solid #f1f5f9"}}>
                    <td style={{...td,fontWeight:700,position:"sticky",left:0,background:"#fff",zIndex:1}}>{ch}</td>
                    {Array.from({length:12},(_,i)=>{
                      const v=d[i+1]||0;
                      const isCur=(i+1)===Number(dashYm.slice(5,7))&&dashYearly.year===dashYm.slice(0,4);
                      return <td key={i} style={{...td,textAlign:"right",color:v>0?"#1e40af":"#cbd5e1",background:isCur?"#eff6ff":"transparent",fontWeight:isCur?700:400}}>{v>0?fmtM(v):"-"}</td>;
                    })}
                    <td style={{...td,textAlign:"right",color:"#1e40af"}}>{(d.base||0)>0?fmtM(d.base):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#047857"}}>{(d.opt||0)>0?fmtM(d.opt):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#dc2626"}}>{(d.disc||0)>0?"-"+fmtM(d.disc):"-"}</td>
                    <td style={{...td,textAlign:"right",color:"#059669",fontWeight:800}}>{fmtM(d.total)}</td>
                    <td style={{...td,textAlign:"right",color:"#475569"}}>
                      <div style={{display:"flex",alignItems:"center",gap:3,justifyContent:"flex-end"}}>
                        <div style={{width:32,height:4,background:"#f1f5f9",borderRadius:2,overflow:"hidden"}}>
                          <div style={{width:pct+"%",height:"100%",background:"#3b82f6"}}/>
                        </div>
                        <span style={{minWidth:32,textAlign:"right",fontWeight:700}}>{pct.toFixed(1)}%</span>
                      </div>
                    </td>
                  </tr>;
                })}
                <tr style={{background:"#1e293b",color:"#fff",fontWeight:800}}>
                  <td style={{padding:"8px",fontSize:11,position:"sticky",left:0,background:"#1e293b",zIndex:1}}>合計</td>
                  {monthTotals.map((v,i)=>{const isCur=(i+1)===Number(dashYm.slice(5,7))&&dashYearly.year===dashYm.slice(0,4);return <td key={i} style={{padding:"8px",fontSize:10,textAlign:"right",background:isCur?"#1e3a8a":"transparent"}}>{v>0?fmtM(v):"-"}</td>;})}
                  <td style={{padding:"8px",fontSize:10,textAlign:"right",color:"#93c5fd"}}>{fmtM(dashYearly.total.plBase)}</td>
                  <td style={{padding:"8px",fontSize:10,textAlign:"right",color:"#6ee7b7"}}>{fmtM(dashYearly.total.plOpt)}</td>
                  <td style={{padding:"8px",fontSize:10,textAlign:"right",color:"#fca5a5"}}>{dashYearly.total.plDisc>0?"-"+fmtM(dashYearly.total.plDisc):"-"}</td>
                  <td style={{padding:"8px",fontSize:12,textAlign:"right",color:"#4ade80"}}>{fmtM(yearTotal)}</td>
                  <td style={{padding:"8px",fontSize:11,textAlign:"right"}}>100%</td>
                </tr>
              </tbody>
            </table>
            <div style={{fontSize:10,color:"#94a3b8",marginTop:6,textAlign:"right"}}>※ 青ハイライト列 = 選択中の月（{dashYm}）</div>
          </div>;
        })()}
      </div>
    </div>}

    {/* --- 売上入力 --- */}
    {sub==="sales"&&(()=>{
      // 売上入力（Excel再現）— reservationsから自動表示
      const isSpkS=dbStore==="spk";
      const rdKeyS=isSpkS?"return_date":"end_date";
      const otaMapS={"HP":"オフィシャル","J":"じゃらん","R":"楽天","O":"エアトリ","A":"エアトリ","S":"スカイチケット","RC":"レンタカードットコム","G":"その他売上","direct":"その他売上"};
      const cycleMap={};(mgSettings.channels||[]).forEach(c=>{cycleMap[c.name]=c.cycle||0;});
      const isCx=st=>st==="cancelled"||st==="キャンセル"||st==="cancel";
      const salesList=dbResvs.filter(r=>salesResvF?true:!isCx(r.status)).map(r=>{
        const rd=r[rdKeyS]||"";
        const ym=rd.slice(0,7);
        const ch=otaMapS[r.ota]||"その他売上";
        const bpR=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const priceFb=Number(r.price)||0;
        const bp=(bpR===0&&op===0&&priceFb>0)?priceFb:bpR;
        const rev=(bpR>0||op>0)?(bpR+op-dc):priceFb;
        const cycle=cycleMap[ch]||0;
        let payYm="-";
        if(rd){
          const dt=new Date(rd.slice(0,10));
          dt.setMonth(dt.getMonth()+cycle);
          payYm=dt.getFullYear()+"-"+String(dt.getMonth()+1).padStart(2,"0");
        }
        const ldS=isSpkS?r.lend_date:r.start_date;
        let days=0;
        if(ldS&&rd){const d1=new Date(ldS.slice(0,10)),d2=new Date(rd.slice(0,10));days=Math.max(1,Math.round((d2-d1)/86400000));}
        const cx=isCx(r.status);
        return{id:r.id,resv:r.resv_no||r.id,ch,rd:rd.slice(0,10),bp,op,dc,rev:cx?0:rev,ym,payYm,days,vt:r.vehicle||r.vehicle_class||"-",del:isSpkS?"DEL":(r.visit_type||"-"),cx,name:r.customer_name||r.name||"-",status:r.status||"active"};
      }).sort((a,b)=>b.rd.localeCompare(a.rd));
      const filtered=salesList.filter(r=>{
        if(salesYmF&&r.ym!==salesYmF)return false;
        if(salesChF&&r.ch!==salesChF)return false;
        if(salesResvF&&!(r.resv||"").toLowerCase().includes(salesResvF.toLowerCase()))return false;
        return true;
      });
      const totalRev=filtered.reduce((s,r)=>s+r.rev,0);
      const tblName=isSpkS?"reservations":"bt_reservations";
      const inpS={width:"72px",padding:"2px 4px",fontSize:10,border:"1px solid #93c5fd",borderRadius:4,textAlign:"right"};
      const saveSalesEdit=async()=>{
        if(!salesEditId||!sb)return;
        // ★ 2026-05-11 fix: price/amount も同期更新する
        //   旧: base_price/option_price/discount のみ更新 → price=0 のまま残る
        //   バグ事例: GoGoOut予約 (取込時 price=0) で「売上入力」しても データタブ/売上集計が 0 になる
        const _bp=Number(salesEditVals.bp)||0, _op=Number(salesEditVals.op)||0, _dc=Number(salesEditVals.dc)||0;
        const _rev=_bp+_op-_dc;
        const{error}=await sb.from(tblName).update({base_price:_bp,option_price:_op,discount:_dc,price:_rev,amount:_rev}).eq("id",salesEditId);
        if(!error){
          setDbResvs(prev=>prev.map(r=>r.id===salesEditId?{...r,base_price:_bp,option_price:_op,discount:_dc,price:_rev,amount:_rev}:r));
          setSalesEditId(null);
        }
      };
      return <div>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
        {["tkm","spk"].map(s=>{
          const sel2=dbStore===s;
          return <button key={s} onClick={()=>setDbStore(s)} style={{padding:"6px 16px",fontSize:13,fontWeight:800,borderRadius:8,border:sel2?"2px solid #1e40af":"2px solid #e2e8f0",cursor:"pointer",background:sel2?"#1e40af":"#fff",color:sel2?"#fff":"#334155"}}>{s==="tkm"?"高松店":"札幌店"}</button>;
        })}
        <span style={{fontSize:10,color:"#94a3b8"}}>※ reservationsから全自動表示（Excel売上入力シートと同等）</span>
      </div>
      <div style={{display:"flex",gap:6,marginBottom:10,flexWrap:"wrap",alignItems:"center"}}>
        <span style={{fontSize:11,color:"#64748b"}}>フィルタ:</span>
        <input type="month" value={salesYmF} onChange={e=>setSalesYmF(e.target.value)} style={{padding:"4px 8px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:6}}/>
        <select value={salesChF} onChange={e=>setSalesChF(e.target.value)} style={{padding:"4px 8px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:6}}>
          <option value="">全チャネル</option>
          {DB_CHANNELS.map(c=><option key={c} value={c}>{c}</option>)}
        </select>
        <input type="text" value={salesResvF} onChange={e=>setSalesResvF(e.target.value)} placeholder="🔍 予約番号検索" style={{padding:"4px 8px",fontSize:11,border:"1px solid #cbd5e1",borderRadius:6,width:160}}/>
        <button onClick={()=>{setSalesYmF("");setSalesChF("");setSalesResvF("");}} style={{...btn("#f1f5f9"),color:"#334155"}}>クリア</button>
        <div style={{flex:1}}/>
        <span style={{fontSize:11,fontWeight:700}}>{filtered.length}件 / 合計 ¥{totalRev.toLocaleString()}</span>
      </div>

      <div style={{overflow:"auto",maxHeight:"65vh",border:"1px solid #e2e8f0",borderRadius:8}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
          <thead style={{position:"sticky",top:0,zIndex:1}}>
            <tr>
              <th style={th}>予約番号</th>
              {salesResvF&&<th style={th}>ステータス</th>}
              <th style={th}>チャネル</th>
              {salesResvF&&<th style={th}>顧客名</th>}
              <th style={th}>計上日(返却)</th>
              <th style={{...th,textAlign:"right"}}>基本料金</th>
              <th style={{...th,textAlign:"right"}}>付帯売上</th>
              <th style={{...th,textAlign:"right"}}>割引</th>
              <th style={{...th,textAlign:"right"}}>合計売上</th>
              <th style={th}>車両</th>
              <th style={th}>日数</th>
              <th style={th}>DEL</th>
              <th style={th}>計上月</th>
              <th style={th}>入金月</th>
              <th style={th}></th>
            </tr>
          </thead>
          <tbody>
            {filtered.slice(0,500).map(r=>{
              const isEdit=salesEditId===r.id;
              const ev=salesEditVals;
              const editRev=(ev.bp+ev.op-ev.dc);
              return <tr key={r.id} style={r.cx?{background:"#fef2f2",textDecoration:"line-through",color:"#dc2626"}:isEdit?{background:"#eff6ff"}:{}}>
                <td style={{...td,fontFamily:"monospace",fontSize:9}}>{r.resv}</td>
                {salesResvF&&<td style={{...td,fontSize:9,fontWeight:700,color:r.cx?"#dc2626":"#16a34a"}}>{r.cx?"❌ キャンセル":"✅ 有効"}</td>}
                <td style={td}>{r.ch}</td>
                {salesResvF&&<td style={{...td,fontSize:9}}>{r.name}</td>}
                <td style={td}>{r.rd}</td>
                {isEdit?(
                  <>
                    <td style={{...td,textAlign:"right"}}><input type="number" value={ev.bp} onChange={e=>setSalesEditVals(v=>({...v,bp:Number(e.target.value)||0}))} style={inpS}/></td>
                    <td style={{...td,textAlign:"right"}}><input type="number" value={ev.op} onChange={e=>setSalesEditVals(v=>({...v,op:Number(e.target.value)||0}))} style={inpS}/></td>
                    <td style={{...td,textAlign:"right"}}><input type="number" value={ev.dc} onChange={e=>setSalesEditVals(v=>({...v,dc:Number(e.target.value)||0}))} style={{...inpS,border:"1px solid #fca5a5"}}/></td>
                    <td style={{...td,textAlign:"right",fontWeight:700,color:"#1e40af"}}>¥{editRev.toLocaleString()}</td>
                  </>
                ):(
                  <>
                    <td style={{...td,textAlign:"right"}}>¥{r.bp.toLocaleString()}</td>
                    <td style={{...td,textAlign:"right"}}>¥{r.op.toLocaleString()}</td>
                    <td style={{...td,textAlign:"right",color:r.dc?"#dc2626":"#94a3b8"}}>{r.dc?"-¥"+r.dc.toLocaleString():"0"}</td>
                    <td style={{...td,textAlign:"right",fontWeight:700}}>¥{r.rev.toLocaleString()}</td>
                  </>
                )}
                <td style={td}>{r.vt}</td>
                <td style={td}>{r.days||"-"}</td>
                <td style={td}>{r.del}</td>
                <td style={{...td,fontSize:9,color:"#64748b"}}>{r.ym}</td>
                <td style={{...td,fontSize:9,color:"#64748b"}}>{r.payYm}</td>
                <td style={{...td,whiteSpace:"nowrap"}}>
                  {isEdit?(
                    <span style={{display:"flex",gap:3}}>
                      <button onClick={saveSalesEdit} style={{fontSize:9,padding:"2px 8px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",cursor:"pointer",fontWeight:700}}>保存</button>
                      <button onClick={()=>setSalesEditId(null)} style={{fontSize:9,padding:"2px 6px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer"}}>✕</button>
                    </span>
                  ):(
                    <button onClick={()=>{setSalesEditId(r.id);setSalesEditVals({bp:r.bp,op:r.op,dc:r.dc});}} style={{fontSize:9,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#475569"}}>編集</button>
                  )}
                </td>
              </tr>;
            })}
            {filtered.length===0&&<tr><td colSpan={salesResvF?15:13} style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>{salesResvF?"該当する予約番号が見つかりません":"データなし（経営DBタブでデータをロードしてください）"}</td></tr>}
            {filtered.length>500&&<tr><td colSpan={salesResvF?15:13} style={{padding:8,textAlign:"center",color:"#94a3b8",fontSize:10}}>表示上限500件（全{filtered.length}件）</td></tr>}
          </tbody>
        </table>
      </div>
    </div>;})()}

    {/* --- PL --- */}
    {sub==="pl"&&<div>
      <div style={{marginBottom:10,fontSize:11,color:"#64748b"}}>📘 月次PL = 計上月（返却日ベース）のチャネル別売上集計 + 平均泊数 + 客単価</div>
      <div style={{display:"flex",gap:6,marginBottom:10}}>
        {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#1e40af":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
      </div>
      {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
      <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr>
            <th style={th}>年月</th>
            {plPivot.chs.map(ch=><th key={ch} style={{...th,textAlign:"right"}}>{ch}</th>)}
            <th style={{...th,textAlign:"right",background:"#dbeafe"}}>売上合計</th>
            <th style={{...th,textAlign:"right"}}>件数</th>
            <th style={{...th,textAlign:"right",background:"#eef2ff"}}>平均泊数</th>
            <th style={{...th,textAlign:"right"}}>客単価</th>
            <th style={{...th,textAlign:"right"}}>日単価</th>
          </tr></thead>
          <tbody>
            {plPivot.yms.map(ym=>{
              const total=plPivot.chs.reduce((a,ch)=>a+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0);
              const cnt=plPivot.chs.reduce((a,ch)=>a+((plPivot.map[ym+"|"+ch]||{}).count||0),0);
              const d=(plPivot.daysByYm||{})[ym]||{sum:0,cnt:0};
              const avgN=d.cnt>0?(d.sum/d.cnt):0;
              const unit=cnt>0?(total/cnt):0;
              const daily=d.sum>0?(total/d.sum):0;
              const otaTotal=plPivot.chs.filter(c=>c!=="オフィシャル"&&c!=="その他売上").reduce((a,ch)=>a+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0);
              return <tr key={ym}>
                <td style={{...td,fontWeight:700}}>{ym}</td>
                {plPivot.chs.map(ch=>{
                  const v=(plPivot.map[ym+"|"+ch]||{}).revenue||0;
                  return <td key={ch} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1"}}>{v>0?"¥"+fmt(v):"-"}</td>;
                })}
                <td style={{...td,textAlign:"right",fontWeight:800,background:"#eff6ff"}}>¥{fmt(total)}</td>
                <td style={{...td,textAlign:"right"}}>{cnt}</td>
                <td style={{...td,textAlign:"right",background:"#eef2ff",fontWeight:700,color:"#4338ca"}}>{avgN>0?avgN.toFixed(1):"-"}</td>
                <td style={{...td,textAlign:"right"}}>{unit>0?"¥"+fmt(Math.round(unit)):"-"}</td>
                <td style={{...td,textAlign:"right",color:"#059669"}}>{daily>0?"¥"+fmt(Math.round(daily)):"-"}</td>
              </tr>;
            })}
            {plPivot.yms.length>0&&(()=>{
              const grandTotal=plPivot.yms.reduce((a,ym)=>a+plPivot.chs.reduce((b,ch)=>b+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0),0);
              const grandCnt=plPivot.yms.reduce((a,ym)=>a+plPivot.chs.reduce((b,ch)=>b+((plPivot.map[ym+"|"+ch]||{}).count||0),0),0);
              return <tr style={{background:"#f0f9ff",fontWeight:800}}>
                <td style={{...td,fontWeight:900}}>累計</td>
                {plPivot.chs.map(ch=>{
                  const v=plPivot.yms.reduce((a,ym)=>a+((plPivot.map[ym+"|"+ch]||{}).revenue||0),0);
                  return <td key={ch} style={{...td,textAlign:"right"}}>{v>0?"¥"+fmt(v):"-"}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#dbeafe"}}>¥{fmt(grandTotal)}</td>
                <td style={{...td,textAlign:"right"}}>{grandCnt}</td>
                <td style={td}>-</td>
                <td style={{...td,textAlign:"right"}}>{grandCnt>0?"¥"+fmt(Math.round(grandTotal/grandCnt)):"-"}</td>
                <td style={td}>-</td>
              </tr>;
            })()}
            {plPivot.yms.length===0&&<tr><td colSpan={plPivot.chs.length+6} style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>データなし — 上の店舗ボタンで切り替えてください</td></tr>}
          </tbody>
        </table>
      </div>}
    </div>}

    {/* --- CF --- */}
    {sub==="cf"&&(()=>{
      const expByYm=cfPivot.expByYm||{};
      let cumBal=mgSettings.initCash||0;
      return <div>
      <div style={{marginBottom:10,fontSize:11,color:"#64748b"}}>💰 月次CF = 入金（チャネル別入金サイクル自動計算）− 支出予算（コスト入力から自動取得）→ 純収支・残高推移</div>
      <div style={{display:"flex",gap:6,marginBottom:10}}>
        {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#059669":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
      </div>
      <div style={{marginBottom:8,fontSize:10,color:"#94a3b8"}}>入金サイクル: {(mgSettings.channels||[]).map(c=>c.name+"="+c.cycle+"ヶ月").join(" / ")} | 期初残高: ¥{fmt(mgSettings.initCash||0)}</div>
      {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
      <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
          <thead><tr>
            <th style={th}>月</th>
            {cfPivot.chs.map(ch=><th key={ch} style={{...th,textAlign:"right",fontSize:9}}>{ch.slice(0,4)}</th>)}
            <th style={{...th,textAlign:"right",background:"#dcfce7"}}>入金計</th>
            <th style={{...th,textAlign:"right",background:"#fef2f2"}}>返済</th>
            <th style={{...th,textAlign:"right",background:"#fef2f2"}}>販管費</th>
            <th style={{...th,textAlign:"right",background:"#fef2f2"}}>売上原価</th>
            <th style={{...th,textAlign:"right",background:"#fee2e2"}}>支出計</th>
            <th style={{...th,textAlign:"right",background:"#fef9c3"}}>純収支</th>
            <th style={{...th,textAlign:"right",background:"#fef9c3"}}>残高</th>
          </tr></thead>
          <tbody>
            {cfPivot.yms.map(ym=>{
              const cashIn=cfPivot.chs.reduce((a,ch)=>a+((cfPivot.map[ym+"|"+ch]||{}).cash_in||0),0);
              const exp=expByYm[ym]||{repay:0,sga:0,cogs:0,total:0};
              const net=cashIn-exp.total;
              cumBal+=net;
              return <tr key={ym}>
                <td style={{...td,fontWeight:700}}>{ym}</td>
                {cfPivot.chs.map(ch=>{
                  const v=(cfPivot.map[ym+"|"+ch]||{}).cash_in||0;
                  return <td key={ch} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1",fontSize:9}}>{v>0?"¥"+fmt(v):"-"}</td>;
                })}
                <td style={{...td,textAlign:"right",fontWeight:800,background:"#f0fdf4",color:"#059669"}}>¥{fmt(cashIn)}</td>
                <td style={{...td,textAlign:"right",background:"#fef2f2",color:exp.repay>0?"#dc2626":"#cbd5e1"}}>{exp.repay>0?"¥"+fmt(exp.repay):"-"}</td>
                <td style={{...td,textAlign:"right",background:"#fef2f2",color:exp.sga>0?"#dc2626":"#cbd5e1"}}>{exp.sga>0?"¥"+fmt(exp.sga):"-"}</td>
                <td style={{...td,textAlign:"right",background:"#fef2f2",color:exp.cogs>0?"#dc2626":"#cbd5e1"}}>{exp.cogs>0?"¥"+fmt(exp.cogs):"-"}</td>
                <td style={{...td,textAlign:"right",fontWeight:800,background:"#fee2e2",color:"#dc2626"}}>{exp.total>0?"¥"+fmt(exp.total):"-"}</td>
                <td style={{...td,textAlign:"right",fontWeight:800,color:net>=0?"#059669":"#dc2626"}}>¥{fmt(net)}</td>
                <td style={{...td,textAlign:"right",fontWeight:800,background:cumBal<0?"#fecaca":"#fef9c3",color:cumBal>=0?"#92400e":"#dc2626"}}>¥{fmt(Math.round(cumBal))}</td>
              </tr>;
            })}
            {cfPivot.yms.length===0&&<tr><td colSpan={cfPivot.chs.length+8} style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>データなし</td></tr>}
          </tbody>
        </table>
      </div>}
      {Object.keys(expByYm).length===0&&<div style={{marginTop:8,padding:8,background:"#fffbeb",borderRadius:6,fontSize:11,color:"#92400e"}}>⚠️ 支出予算が未入力です。「コスト入力」タブから月別に返済・販管費・売上原価を入力すると、CFに自動反映されます。</div>}
    </div>;
    })()}

    {/* --- コスト入力 --- */}
    

    {sub==="monthly"&&<div>
      <div style={{marginBottom:12,padding:10,background:"#dbeafe",borderLeft:"4px solid #2563eb",borderRadius:4,fontSize:11,color:"#1e40af"}}>
        💡 月次収支（年間）と コスト内訳マトリックスを表示中。
      </div>
      <div style={{marginBottom:16}}>
        <div style={{fontSize:13,fontWeight:800,marginBottom:6,color:"#1e293b"}}>📘 月次PL（収支＋コスト分解）</div>
        <iframe src={`./monthly.html?store=tkm&v=${APP_VERSION}`} style={{width:"100%",height:600,border:"1px solid #e2e8f0",borderRadius:8,background:"#fff"}}/>
      </div>
      <div>
        <div style={{fontSize:13,fontWeight:800,marginBottom:6,color:"#1e293b"}}>💸 コスト内訳マトリックス（年間）</div>
        <iframe src={`./costmatrix.html?store=tkm&v=${APP_VERSION}`} style={{width:"100%",height:700,border:"1px solid #e2e8f0",borderRadius:8,background:"#fff"}}/>
      </div>
    </div>}
{sub==="cost"&&(()=>{
      const COST_ACCOUNTS=[
        {cat:"返済（CFのみ反映）",items:[
          {code:"repay_1",name:"返済①（道銀/北洋）"},
          {code:"repay_2",name:"返済②（沖銀）"},
          {code:"repay_3",name:"返済③（IUR）"},
          {code:"repay_4",name:"返済④"},
          {code:"repay_5",name:"返済⑤（LAB）"},
        ]},
        {cat:"販管費",items:[
          {code:"sga_social_ins",name:"社会保険"},
          {code:"sga_salary",name:"給与���計"},
          {code:"sga_ota_fee",name:"手数料合計（OTA等）"},
          {code:"sga_telecom",name:"通信費"},
          {code:"sga_fuel",name:"ガソリン代"},
          {code:"sga_travel",name:"出張費"},
          {code:"sga_office",name:"消耗品"},
          {code:"sga_ad",name:"広告費"},
          {code:"sga_transport",name:"移動費"},
          {code:"sga_utility",name:"光熱費"},
          {code:"sga_tax",name:"税金"},
          {code:"sga_repair",name:"車両修理"},
          {code:"sga_construction",name:"工事"},
          {code:"sga_other",name:"その他販管費"},
        ]},
        {cat:"売上原価",items:[
          {code:"cogs_lease",name:"リース/ローン合計"},
          {code:"cogs_insurance",name:"保険"},
          {code:"cogs_inspection",name:"車���費（車検）"},
          {code:"cogs_maintenance",name:"車両費（点検/整備）"},
          {code:"cogs_repair",name:"修理"},
          {code:"cogs_rent",name:"賃料合計（ヤード等）"},
          {code:"cogs_other",name:"その他原価"},
        ]},
      ];
      return <div>
        <div style={{marginBottom:8,fontSize:11,color:"#64748b"}}>🧾 支出予算の入力（コスト内訳）。ここに入力した内容は CF(月次) の支出欄に自動反映されます。</div>
        <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:10,flexWrap:"wrap"}}>
          <div style={{display:"flex",gap:6}}>
            {["tkm","spk"].map(s=><button key={s} onClick={()=>{setDbStore(s);if(costYm)setTimeout(()=>loadCost(costYm),100);}} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#dc2626":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
          </div>
          <span style={{fontSize:12,color:"#64748b"}}>対象月:</span>
          <input type="month" value={costYm} onChange={e=>{setCostYm(e.target.value);loadCost(e.target.value);}} style={{padding:"4px 8px",fontSize:12,border:"1px solid #cbd5e1",borderRadius:6}}/>
        </div>
        {COST_ACCOUNTS.map(({cat,items})=>{
          const catTotal=items.reduce((s,a)=>s+((costRows.find(r=>r.account_code===a.code)||{}).amount||0),0);
          return <div key={cat} style={{...card,marginBottom:12}}>
            <div style={{...h,fontSize:14,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
              <span>{cat}</span>
              <span style={{fontSize:12,color:"#1e40af"}}>合計 ¥{fmt(catTotal)}</span>
            </div>
            <table style={{width:"100%",borderCollapse:"collapse"}}>
              <tbody>
                {items.map(a=>{
                  const cur=costRows.find(r=>r.account_code===a.code)||{amount:0,note:""};
                  return <tr key={a.code}>
                    <td style={{...td,paddingLeft:8,width:"40%"}}>{a.name}</td>
                    <td style={{...td,textAlign:"right",width:140}}>
                      <input type="number" style={{...inp,textAlign:"right"}} defaultValue={cur.amount||0} onBlur={e=>{const v=parseInt(e.target.value||0)||0;if(v!==(cur.amount||0))saveCostEntry(costYm,a.code,v,cur.note);}}/>
                    </td>
                    <td style={{...td,width:200}}>
                      <input style={inp} defaultValue={cur.note||""} placeholder="メモ" onBlur={e=>{if(e.target.value!==(cur.note||""))saveCostEntry(costYm,a.code,cur.amount||0,e.target.value);}}/>
                    </td>
                  </tr>;
                })}
              </tbody>
            </table>
          </div>;
        })}
        {!costYm&&<div style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>対象月を選択してください</div>}
      </div>;
    })()}

    {/* --- コスト一覧（月次サマリー） --- */}
    {sub==="costsum"&&(()=>{
      const COST_ITEMS=[
        {cat:"返済",items:[{name:"返済①",code:"repay_1"},{name:"返済②",code:"repay_2"},{name:"返済③",code:"repay_3"},{name:"返済④",code:"repay_4"},{name:"返済⑤",code:"repay_5"}]},
        {cat:"販管費",items:[{name:"社会保険",code:"sga_social_ins"},{name:"給与合計",code:"sga_salary"},{name:"手数料合計",code:"sga_ota_fee"},{name:"通信費",code:"sga_telecom"},{name:"ガソリン代",code:"sga_fuel"},{name:"出張費",code:"sga_travel"},{name:"消耗品",code:"sga_office"},{name:"広告費",code:"sga_ad"},{name:"移動費",code:"sga_transport"},{name:"光熱費",code:"sga_utility"},{name:"税金",code:"sga_tax"},{name:"車両修理",code:"sga_repair"},{name:"工事",code:"sga_construction"},{name:"その他",code:"sga_other"}]},
        {cat:"売上原価",items:[{name:"リース/ローン",code:"cogs_lease"},{name:"保険",code:"cogs_insurance"},{name:"車検",code:"cogs_inspection"},{name:"点検/整備",code:"cogs_maintenance"},{name:"修理",code:"cogs_repair"},{name:"賃料合計",code:"cogs_rent"},{name:"その他",code:"cogs_other"}]},
      ];
      // 月別コストは costAllMonths を使用
      const costMonthly=costAllMonths;
      const csLoading=false;
      const _stLabel=dbStore==="spk"?"札幌":"高松";
      const yms_inner=Object.keys(costMonthly).sort();
      // Compatibility block
      const setCostMonthly_=()=>{};
      const setCsLoading_=()=>{};
      const yms=yms_inner;
      const store_=dbStore;
      // render below uses old var names, map COST_ITEMS
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#7c3aed":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        <div style={{...h,fontSize:14}}>📋 月次コスト一覧（{_stLabel}）</div>
        {yms.length===0?<div style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>コストデータなし。「コスト入力」タブから月別に入力してください。</div>:
        <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
            <thead><tr>
              <th style={th}>科目</th>
              {yms.map(ym=><th key={ym} style={{...th,textAlign:"right"}}>{ym}</th>)}
            </tr></thead>
            <tbody>
              {COST_ITEMS.map(({cat,items})=><React.Fragment key={cat}>
                <tr style={{background:"#f0f9ff"}}><td colSpan={yms.length+1} style={{...td,fontWeight:900,fontSize:11}}>{cat}</td></tr>
                {items.map(({name,code})=>{
                  return <tr key={code}>
                    <td style={{...td,paddingLeft:16}}>{name}</td>
                    {yms.map(ym=>{
                      const rows=costMonthly[ym]||[];
                      const v=(rows.find(r=>r.account_code===code)||{}).amount||0;
                      return <td key={ym} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1"}}>{v>0?"¥"+fmt(v):"-"}</td>;
                    })}
                  </tr>;
                })}
                <tr style={{background:"#f8fafc",fontWeight:700}}>
                  <td style={td}>{cat}計</td>
                  {yms.map(ym=>{
                    const rows=costMonthly[ym]||[];
                    const total=items.reduce((s,{code})=>s+((rows.find(r=>r.account_code===code)||{}).amount||0),0);
                    return <td key={ym} style={{...td,textAlign:"right",color:"#1e40af"}}>¥{fmt(total)}</td>;
                  })}
                </tr>
              </React.Fragment>)}
            </tbody>
          </table>
        </div>}
      </div>;
    })()}

    {/* --- HP-CV（オフィシャル予約件数） --- */}
    {sub==="hpcv"&&(()=>{
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const hpResvs=dbResvs.filter(r=>r.ota==="HP"&&r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      const byMonth={};
      hpResvs.forEach(r=>{
        const ym=(r[rdKey]||"").slice(0,7);if(!ym)return;
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        if(!byMonth[ym])byMonth[ym]={cnt:0,amt:0};
        byMonth[ym].cnt+=1;
        byMonth[ym].amt+=rev;
      });
      const byYear={};
      Object.entries(byMonth).forEach(([ym,d])=>{
        const [y,m]=ym.split("-").map(Number);
        const fy=m>=4?y:y-1;
        if(!byYear[fy])byYear[fy]={cnt:0,amt:0,months:{}};
        byYear[fy].cnt+=d.cnt;
        byYear[fy].amt+=d.amt;
        byYear[fy].months[ym]=d;
      });
      const years=Object.keys(byYear).map(Number).sort((a,b)=>b-a);

      return <div>
        <div style={{padding:10,background:"#eff6ff",borderRadius:8,marginBottom:14,fontSize:12,color:"#1e40af",fontWeight:700,display:"flex",justifyContent:"space-between"}}>
          <span>🔵 HP-CV（自社HP予約）— 年度別月次推移</span>
          <span>全{hpResvs.length}件</span>
        </div>

        {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
        years.length===0?<div style={{padding:24,textAlign:"center",color:"#94a3b8",fontSize:12}}>HP予約なし</div>:
        years.map(fy=>{
          const yr=byYear[fy];
          const yrMonths=[];
          for(let m=4;m<=12;m++)yrMonths.push({ym:fy+"-"+String(m).padStart(2,"0"),m:m});
          for(let m=1;m<=3;m++)yrMonths.push({ym:(fy+1)+"-"+String(m).padStart(2,"0"),m:m});
          const avg=yr.cnt>0?Math.round(yr.amt/yr.cnt):0;

          return <div key={fy} style={{...card,marginBottom:12}}>
            <div style={{padding:"10px 14px",background:"#1e40af",color:"#fff",borderRadius:"8px 8px 0 0",margin:"-12px -12px 10px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
              <span style={{fontSize:14,fontWeight:900}}>📅 {fy}年度（{fy}/4 〜 {fy+1}/3）</span>
              <span style={{fontSize:12,fontWeight:700}}>{yr.cnt}件 / ¥{fmt(yr.amt)} / 客単価 ¥{fmt(avg)}</span>
            </div>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
              <thead><tr style={{background:"#f8fafc"}}>
                <th style={{...th,textAlign:"left",width:80}}>月</th>
                <th style={{...th,textAlign:"right"}}>件数</th>
                <th style={{...th,textAlign:"right"}}>金額</th>
                <th style={{...th,textAlign:"right"}}>客単価</th>
              </tr></thead>
              <tbody>
                {yrMonths.map(({ym,m})=>{
                  const d=yr.months[ym]||{cnt:0,amt:0};
                  const monthAvg=d.cnt>0?Math.round(d.amt/d.cnt):0;
                  return <tr key={ym} style={{borderBottom:"1px solid #f1f5f9"}}>
                    <td style={{...td,fontWeight:700}}>{m}月</td>
                    <td style={{...td,textAlign:"right",fontWeight:d.cnt>0?700:400,color:d.cnt>0?"#1e40af":"#cbd5e1"}}>{d.cnt>0?d.cnt+"件":"—"}</td>
                    <td style={{...td,textAlign:"right",fontWeight:d.amt>0?800:400,color:d.amt>0?"#059669":"#cbd5e1"}}>{d.amt>0?"¥"+fmt(d.amt):"—"}</td>
                    <td style={{...td,textAlign:"right",fontWeight:monthAvg>0?700:400,color:monthAvg>0?"#7c3aed":"#cbd5e1"}}>{monthAvg>0?"¥"+fmt(monthAvg):"—"}</td>
                  </tr>;
                })}
                <tr style={{background:"#f1f5f9",fontWeight:800}}>
                  <td style={{...td,fontWeight:800}}>年計</td>
                  <td style={{...td,textAlign:"right",fontWeight:800,color:"#1e40af"}}>{yr.cnt}件</td>
                  <td style={{...td,textAlign:"right",fontWeight:800,color:"#059669"}}>¥{fmt(yr.amt)}</td>
                  <td style={{...td,textAlign:"right",fontWeight:800,color:"#7c3aed"}}>¥{fmt(avg)}</td>
                </tr>
              </tbody>
            </table>
          </div>;
        })}
      </div>;
    })()}

    {/* --- 予算CF --- */}
    {sub==="budgetcf"&&(()=>{
      const saveBcf=async(st,ym,field,val)=>{
        const nv=parseFloat(val)||0;
        const next={...bcfData,[st]:{...(bcfData[st]||{}),[ym]:{...((bcfData[st]||{})[ym]||{}),[field]:nv}}};
        setBcfData(next);
        const key="budgetcf_"+st;
        await sb.from("app_settings").upsert({key,value:JSON.stringify(next[st])},{onConflict:"key"});
      };
      const chNames=["オフィシャル","じゃらん","楽天","エアトリ","レンタカードットコム","スカイチケット","その他売上"];
      const cycles={};(mgSettings.channels||[]).forEach(c=>{cycles[c.name]=c.cycle||0;});
      // Generate 24 months
      const yms24=[];
      for(let i=0;i<24;i++){const d=new Date(2026,i,1);yms24.push(d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0"));}
      const stData=bcfData[bcfStore]||{};
      // 予算売上→OTA構成比→入金月計算
      const cashByYm={};
      yms24.forEach(ym=>{
        const d=stData[ym]||{};
        const budgetRev=d.budgetRev||0;
        chNames.forEach(ch=>{
          const ratio=d["r_"+ch]||(ch==="オフィシャル"?0.3:ch==="じゃらん"?0.15:ch==="楽天"?0.35:ch==="エアトリ"?0.1:ch==="スカイチケット"?0.1:0);
          const rev=budgetRev*ratio;
          const cycle=cycles[ch]||0;
          const[sy,sm]=ym.split("-").map(Number);
          let ny=sy,nm=sm+cycle;while(nm>12){nm-=12;ny++;}
          const cashYm=ny+"-"+String(nm).padStart(2,"0");
          if(!cashByYm[cashYm])cashByYm[cashYm]={};
          cashByYm[cashYm][ch]=(cashByYm[cashYm][ch]||0)+rev;
        });
      });
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk","all"].map(s=><button key={s} onClick={()=>setBcfStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:bcfStore===s?"#7c3aed":"#e2e8f0",color:bcfStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":s==="spk"?"札幌":"全体"}</button>)}
        </div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>月別予算売上とOTA構成比を入力 → 入金月を自動シミュレーション</div>
        <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
            <thead><tr>
              <th style={th}>年月</th>
              <th style={{...th,textAlign:"right",background:"#fffbeb"}}>予算売上</th>
              {chNames.map(ch=><th key={ch} style={{...th,textAlign:"right",fontSize:9}}>{ch.slice(0,4)}</th>)}
              <th style={{...th,textAlign:"right",background:"#dcfce7"}}>入金合計</th>
            </tr></thead>
            <tbody>
              {yms24.map(ym=>{
                const d=stData[ym]||{};
                const cashRow=cashByYm[ym]||{};
                const cashTotal=Object.values(cashRow).reduce((a,b)=>a+b,0);
                return <tr key={ym}>
                  <td style={{...td,fontWeight:700}}>{ym}</td>
                  <td style={{...td,textAlign:"right",background:"#fffbeb"}}>
                    {bcfStore!=="all"?<input type="number" style={{...inp,textAlign:"right",width:100}} defaultValue={d.budgetRev||0} onBlur={e=>saveBcf(bcfStore,ym,"budgetRev",e.target.value)}/>:
                    <span>¥{fmt((((bcfData.tkm||{})[ym]||{}).budgetRev||0)+(((bcfData.spk||{})[ym]||{}).budgetRev||0))}</span>}
                  </td>
                  {chNames.map(ch=>{
                    const ratio=d["r_"+ch];
                    return <td key={ch} style={{...td,textAlign:"right",fontSize:9}}>
                      {bcfStore!=="all"?<input type="number" step="0.01" style={{...inp,textAlign:"right",width:50,fontSize:9}} defaultValue={ratio!=null?ratio:(ch==="オフィシャル"?0.3:ch==="じゃらん"?0.15:ch==="楽天"?0.35:ch==="エアトリ"?0.1:ch==="スカイチケット"?0.1:0)} onBlur={e=>saveBcf(bcfStore,ym,"r_"+ch,e.target.value)}/>:
                      <span>{((ratio||0)*100).toFixed(0)}%</span>}
                    </td>;
                  })}
                  <td style={{...td,textAlign:"right",fontWeight:800,background:"#f0fdf4",color:"#059669"}}>¥{fmt(Math.round(cashTotal))}</td>
                </tr>;
              })}
            </tbody>
          </table>
        </div>
      </div>;
    })()}

    {/* --- 価格戦略は TOP > データ・分析 へ移動済（v1.0.29-BT） --- */}

    {/* --- 投資回転率 --- */}
    {sub==="roi"&&(()=>{
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const fMap={};dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
      const vMap={};dbVehs.forEach(v=>{vMap[v.code]=v;});
      const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      // クラス別集計
      const types=isSpk?["A","B","C","S","F","H"]:["AA","A","B","C","S","H","F"];
      const typeStat={};
      types.forEach(t=>{typeStat[t]={rev:0,cnt:0,vehs:dbVehs.filter(v=>(v.type||"")==t&&v.active!==false).length};});
      active.forEach(r=>{
        const rd=r[rdKey];if(!rd)return;
        const vc=fMap[r.id];const vObj=vc?vMap[vc]:null;
        let vType="?";
        if(vObj)vType=vObj.type||"?";
        else if(isSpk&&r.vehicle)vType=r.vehicle;
        else if(!isSpk&&r.vehicle_class)vType=r.vehicle_class;
        if(!typeStat[vType])return;
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        typeStat[vType].rev+=rev;typeStat[vType].cnt+=1;
      });
      // 月数（データ期間）
      const ymSet=new Set();
      active.forEach(r=>{const rd=r[rdKey];if(rd)ymSet.add(rd.slice(0,7));});
      const monthCount=ymSet.size||1;
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#d97706":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>クラス別 1台あたり月間収益分析（データ期間: {monthCount}ヶ月）</div>
        {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
        <div style={{overflow:"auto",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead><tr>
              <th style={th}>項目</th>
              {types.filter(t=>typeStat[t].vehs>0).map(t=><th key={t} style={{...th,textAlign:"right"}}>クラス {t}</th>)}
              <th style={{...th,textAlign:"right",background:"#dbeafe"}}>合計</th>
            </tr></thead>
            <tbody>
              <tr><td style={{...td,fontWeight:700}}>保有台数</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=><td key={t} style={{...td,textAlign:"right"}}>{typeStat[t].vehs}台</td>)}
                <td style={{...td,textAlign:"right",background:"#eff6ff",fontWeight:700}}>{types.reduce((s,t)=>s+typeStat[t].vehs,0)}台</td>
              </tr>
              <tr><td style={{...td,fontWeight:700}}>売上合計</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=><td key={t} style={{...td,textAlign:"right"}}>¥{fmt(typeStat[t].rev)}</td>)}
                <td style={{...td,textAlign:"right",background:"#eff6ff",fontWeight:700}}>¥{fmt(types.reduce((s,t)=>s+typeStat[t].rev,0))}</td>
              </tr>
              <tr><td style={{...td,fontWeight:700}}>月平均売上/台</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=>{
                  const perV=typeStat[t].vehs>0?Math.round(typeStat[t].rev/typeStat[t].vehs/monthCount):0;
                  return <td key={t} style={{...td,textAlign:"right",fontWeight:700,color:"#059669"}}>¥{fmt(perV)}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#eff6ff"}}>-</td>
              </tr>
              <tr style={{background:"#fefce8"}}><td style={{...td,fontWeight:700}}>原価/台/月</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=>{
                  const cost=roiCost.insurance+roiCost.parking+roiCost.inspection+roiCost.maintenance;
                  return <td key={t} style={{...td,textAlign:"right"}}>¥{fmt(cost)}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#eff6ff"}}>-</td>
              </tr>
              <tr style={{fontWeight:800}}><td style={{...td,fontWeight:900,color:"#dc2626"}}>粗利/台/月</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=>{
                  const perV=typeStat[t].vehs>0?Math.round(typeStat[t].rev/typeStat[t].vehs/monthCount):0;
                  const cost=roiCost.insurance+roiCost.parking+roiCost.inspection+roiCost.maintenance;
                  const profit=perV-cost;
                  return <td key={t} style={{...td,textAlign:"right",fontWeight:800,color:profit>0?"#059669":"#dc2626"}}>¥{fmt(profit)}</td>;
                })}
                <td style={{...td,textAlign:"right",background:"#eff6ff"}}>-</td>
              </tr>
              <tr><td style={{...td,fontWeight:700}}>件数合計</td>
                {types.filter(t=>typeStat[t].vehs>0).map(t=><td key={t} style={{...td,textAlign:"right"}}>{typeStat[t].cnt}件</td>)}
                <td style={{...td,textAlign:"right",background:"#eff6ff",fontWeight:700}}>{types.reduce((s,t)=>s+typeStat[t].cnt,0)}件</td>
              </tr>
            </tbody>
          </table>
          <div style={{padding:8,fontSize:10,color:"#94a3b8"}}>
            原価仮定（1台/月）: 保険¥{fmt(roiCost.insurance)} + 駐車場¥{fmt(roiCost.parking)} + 車検月割¥{fmt(roiCost.inspection)} + 点検月割¥{fmt(roiCost.maintenance)} = ¥{fmt(roiCost.insurance+roiCost.parking+roiCost.inspection+roiCost.maintenance)}
          </div>
        </div>}
      </div>;
    })()}

    {/* --- 直近予約変動 --- */}
    {sub==="recent"&&(()=>{
      const loadRecent=async()=>{
        setRecentLoading(true);setRecentData(null);
        try{
          const cutoff=new Date(Date.now()-recentHours*3600000).toISOString();
          const{data:nhNew}=await sb.from("bt_reservations").select("id,ota,status,created_at,end_date,start_date,price,base_price,option_price,discount,customer_name,guest_name").gte("created_at",cutoff).neq("status","cancelled").neq("status","キャンセル").neq("status","cancel").order("created_at",{ascending:false});
          const{data:nhCan}=await sb.from("bt_reservations").select("id,ota,status,created_at,updated_at,end_date,start_date,price,base_price,option_price,discount,customer_name,guest_name").gte("updated_at",cutoff).in("status",["cancelled","キャンセル","cancel"]).order("updated_at",{ascending:false});
          const{data:spNew}=await sb.from("reservations").select("id,ota,status,created_at,return_date,lend_date,price,base_price,option_price,discount,customer_name,guest_name").gte("created_at",cutoff).neq("status","cancelled").neq("status","キャンセル").neq("status","cancel").order("created_at",{ascending:false});
          const{data:spCan}=await sb.from("reservations").select("id,ota,status,created_at,updated_at,return_date,lend_date,price,base_price,option_price,discount,customer_name,guest_name").gte("updated_at",cutoff).in("status",["cancelled","キャンセル","cancel"]).order("updated_at",{ascending:false});
          const revCalcR=(r)=>{const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;return(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);};
          const addStore=(arr,store,rdKey,ldKey)=>(arr||[]).map(r=>({...r,_store:store,_rd:r[rdKey],_ld:r[ldKey],_rev:revCalcR(r),_ch:DB_OTA_MAP[r.ota]||"その他売上"}));
          const newAll=[...addStore(nhNew,"高松","end_date","start_date"),...addStore(spNew,"札幌","return_date","lend_date")].sort((a,b)=>b.created_at.localeCompare(a.created_at));
          const canAll=[...addStore(nhCan,"高松","end_date","start_date"),...addStore(spCan,"札幌","return_date","lend_date")].sort((a,b)=>(b.updated_at||"").localeCompare(a.updated_at||""));
          setRecentData({newAll,canAll,ts:new Date().toLocaleString("ja-JP"),hours:recentHours});
        }catch(e){setRecentData({error:e.message});}
        setRecentLoading(false);
      };
      const rd=recentData;
      const fmtTime=(iso)=>{if(!iso)return"";const d=new Date(iso);return(d.getMonth()+1)+"/"+d.getDate()+" "+String(d.getHours()).padStart(2,"0")+":"+String(d.getMinutes()).padStart(2,"0");};
      const otaLabel={"HP":"HP","J":"じゃらん","R":"楽天","O":"エアトリ","A":"エアトリ","S":"スカイ","RC":"レンカ","G":"GoGo","direct":"直接"};
      const otaColor={"HP":"#2563eb","J":"#7c3aed","R":"#dc2626","O":"#0891b2","A":"#0891b2","S":"#d97706","RC":"#059669","G":"#64748b"};
      const newTotal=rd?rd.newAll?.reduce((a,r)=>a+r._rev,0)||0:0;
      const canTotal=rd?rd.canAll?.reduce((a,r)=>a+r._rev,0)||0:0;
      const newNha=rd?rd.newAll?.filter(r=>r._store==="高松")||[]:[];
      const newSpk=rd?rd.newAll?.filter(r=>r._store==="札幌")||[]:[];
      const canNha=rd?rd.canAll?.filter(r=>r._store==="高松")||[]:[];
      const canSpk=rd?rd.canAll?.filter(r=>r._store==="札幌")||[]:[];
      const rowStyle=(i)=>({background:i%2===0?"#fff":"#f8fafc"});
      return <div>
        <div style={{fontSize:14,fontWeight:900,marginBottom:4}}>📡 直近予約変動</div>
        <div style={{fontSize:10,color:"#64748b",marginBottom:12}}>両店舗の新規予約・キャンセルをリアルタイム表示</div>
        <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:12,flexWrap:"wrap"}}>
          <select value={recentHours} onChange={e=>setRecentHours(Number(e.target.value))} style={{border:"1px solid #d1d5db",borderRadius:8,padding:"6px 10px",fontSize:12,fontWeight:700}}>
            <option value={3}>直近3時間</option>
            <option value={6}>直近6時間</option>
            <option value={12}>直近12時間</option>
            <option value={24}>直近24時間</option>
            <option value={48}>直近48時間</option>
            <option value={72}>直近72時間</option>
          </select>
          <button onClick={loadRecent} disabled={recentLoading} style={{...btn("#2563eb"),padding:"8px 20px",fontSize:12,opacity:recentLoading?0.5:1}}>
            {recentLoading?"🔄 取得中...":"▶ 更新"}
          </button>
          {rd&&!rd.error&&<span style={{fontSize:10,color:"#64748b"}}>最終取得: {rd.ts}</span>}
        </div>
        {rd&&rd.error&&<div style={{padding:12,background:"#fef2f2",borderRadius:8,color:"#dc2626",fontSize:11}}>❌ {rd.error}</div>}
        {rd&&!rd.error&&rd.newAll&&(()=>{
          const net=newTotal-canTotal;
          return <div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:16}}>
              <div style={{padding:12,borderRadius:10,background:"linear-gradient(135deg,#ecfdf5,#d1fae5)",border:"1px solid #86efac"}}>
                <div style={{fontSize:10,color:"#065f46",fontWeight:700}}>📥 新規予約</div>
                <div style={{fontSize:22,fontWeight:900,color:"#059669"}}>{rd.newAll.length}<span style={{fontSize:11}}>件</span></div>
                <div style={{fontSize:12,fontWeight:700,color:"#065f46"}}>¥{fmt(newTotal)}</div>
                <div style={{fontSize:9,color:"#064e3b",marginTop:2}}>高松{newNha.length} / 札幌{newSpk.length}</div>
              </div>
              <div style={{padding:12,borderRadius:10,background:"linear-gradient(135deg,#fef2f2,#fecaca)",border:"1px solid #fca5a5"}}>
                <div style={{fontSize:10,color:"#991b1b",fontWeight:700}}>📤 キャンセル</div>
                <div style={{fontSize:22,fontWeight:900,color:"#dc2626"}}>{rd.canAll.length}<span style={{fontSize:11}}>件</span></div>
                <div style={{fontSize:12,fontWeight:700,color:"#991b1b"}}>¥{fmt(canTotal)}</div>
                <div style={{fontSize:9,color:"#7f1d1d",marginTop:2}}>高松{canNha.length} / 札幌{canSpk.length}</div>
              </div>
              <div style={{padding:12,borderRadius:10,background:net>=0?"linear-gradient(135deg,#eff6ff,#dbeafe)":"linear-gradient(135deg,#fef3c7,#fde68a)",border:"1px solid "+(net>=0?"#93c5fd":"#fbbf24")}}>
                <div style={{fontSize:10,color:net>=0?"#1e40af":"#92400e",fontWeight:700}}>📊 純増減</div>
                <div style={{fontSize:22,fontWeight:900,color:net>=0?"#2563eb":"#d97706"}}>{net>=0?"+":""}{rd.newAll.length-rd.canAll.length}<span style={{fontSize:11}}>件</span></div>
                <div style={{fontSize:12,fontWeight:700,color:net>=0?"#1e40af":"#92400e"}}>{net>=0?"+":""}¥{fmt(net)}</div>
              </div>
            </div>
            {rd.newAll.length>0&&<div style={{marginBottom:16}}>
              <div style={{fontSize:12,fontWeight:900,color:"#059669",marginBottom:6,padding:"4px 8px",background:"#f0fdf4",borderRadius:4,borderLeft:"3px solid #059669"}}>📥 新規予約（{rd.newAll.length}件）</div>
              <div style={{overflow:"auto",border:"1px solid #e2e8f0",borderRadius:8}}>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
                  <thead><tr>
                    <th style={th}>店舗</th><th style={th}>登録時刻</th><th style={th}>予約番号</th><th style={th}>OTA</th><th style={th}>顧客名</th><th style={th}>利用期間</th><th style={{...th,textAlign:"right"}}>金額</th>
                  </tr></thead>
                  <tbody>{rd.newAll.map((r,i)=><tr key={r.id} style={rowStyle(i)}>
                    <td style={{...td,fontWeight:700,color:r._store==="高松"?"#dc2626":"#2563eb"}}>{r._store}</td>
                    <td style={{...td,fontSize:9}}>{fmtTime(r.created_at)}</td>
                    <td style={{...td,fontWeight:600,fontFamily:"monospace"}}>{r.id}</td>
                    <td style={td}><span style={{background:otaColor[r.ota]||"#94a3b8",color:"#fff",padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:700}}>{otaLabel[r.ota]||r.ota}</span></td>
                    <td style={td}>{r.customer_name||r.guest_name||"-"}</td>
                    <td style={{...td,fontSize:9}}>{(r._ld||"").slice(5,10)}〜{(r._rd||"").slice(5,10)}</td>
                    <td style={{...td,textAlign:"right",fontWeight:700,color:"#059669"}}>¥{fmt(r._rev)}</td>
                  </tr>)}</tbody>
                </table>
              </div>
            </div>}
            {rd.canAll.length>0&&<div style={{marginBottom:16}}>
              <div style={{fontSize:12,fontWeight:900,color:"#dc2626",marginBottom:6,padding:"4px 8px",background:"#fef2f2",borderRadius:4,borderLeft:"3px solid #dc2626"}}>📤 キャンセル（{rd.canAll.length}件）</div>
              <div style={{overflow:"auto",border:"1px solid #e2e8f0",borderRadius:8}}>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
                  <thead><tr>
                    <th style={th}>店舗</th><th style={th}>キャンセル時刻</th><th style={th}>予約番号</th><th style={th}>OTA</th><th style={th}>顧客名</th><th style={th}>利用期間</th><th style={{...th,textAlign:"right"}}>金額</th>
                  </tr></thead>
                  <tbody>{rd.canAll.map((r,i)=><tr key={r.id} style={rowStyle(i)}>
                    <td style={{...td,fontWeight:700,color:r._store==="高松"?"#dc2626":"#2563eb"}}>{r._store}</td>
                    <td style={{...td,fontSize:9}}>{fmtTime(r.updated_at)}</td>
                    <td style={{...td,fontWeight:600,fontFamily:"monospace",textDecoration:"line-through",color:"#94a3b8"}}>{r.id}</td>
                    <td style={td}><span style={{background:"#94a3b8",color:"#fff",padding:"1px 6px",borderRadius:4,fontSize:9,fontWeight:700}}>{otaLabel[r.ota]||r.ota}</span></td>
                    <td style={td}>{r.customer_name||r.guest_name||"-"}</td>
                    <td style={{...td,fontSize:9}}>{(r._ld||"").slice(5,10)}〜{(r._rd||"").slice(5,10)}</td>
                    <td style={{...td,textAlign:"right",fontWeight:700,color:"#dc2626"}}>¥{fmt(r._rev)}</td>
                  </tr>)}</tbody>
                </table>
              </div>
            </div>}
            {rd.newAll.length===0&&rd.canAll.length===0&&<div style={{padding:24,textAlign:"center",background:"#f8fafc",borderRadius:12,border:"1px dashed #cbd5e1"}}>
              <div style={{fontSize:32,marginBottom:8}}>😴</div>
              <div style={{fontSize:13,fontWeight:700,color:"#64748b"}}>直近{rd.hours}時間の変動なし</div>
            </div>}
          </div>;
        })()}
        {!rd&&!recentLoading&&<div style={{padding:24,textAlign:"center",background:"#f8fafc",borderRadius:12,border:"1px dashed #cbd5e1"}}>
          <div style={{fontSize:13,color:"#64748b"}}>「更新」ボタンで直近の予約変動を取得</div>
        </div>}
      </div>;
    })()}

    {sub==="analytics"&&(()=>{
      const RELIABLE_FROM="2026-01";
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const ldKey=isSpk?"lend_date":"start_date";

      // --- Shared maps ---
      const fMap={};dbFleet.forEach(f=>{fMap[f.reservation_id]=f.vehicle_code;});
      const vMap={};dbVehs.forEach(v=>{vMap[v.code]=v;});
      const kpiF={};dbKpi.forEach(k=>{if(!kpiF[k.year_month])kpiF[k.year_month]={};kpiF[k.year_month][k.vehicle_code]=k.active;});
      // ★ デバッグ: kpiF["2026-04"]の件数をコンソールに出力
      console.log("[kpiF] 2026-04 entries:", Object.keys(kpiF["2026-04"]||{}).length, "dbKpi total:", dbKpi.length);

      const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      const reliable=active.filter(r=>{const rd=r[rdKey];return rd&&rd.slice(0,7)>=RELIABLE_FROM;});

      const revCalc=(r)=>{const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;return(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);};

      // --- Month aggregation ---
      const mAgg={};
      reliable.forEach(r=>{
        const rd=r[rdKey];if(!rd)return;
        const ym=rd.slice(0,7);
        if(!mAgg[ym])mAgg[ym]={resvs:[],rev:0,cnt:0,daySum:0,otaRev:{},otaCnt:{},otaBase:{},otaOpt:{},otaDisc:{},vtRev:{},vtCnt:{},createdInMonth:0,createdBeforeMonth:0,oneDay:0,prefCnt:{},base:0,opt:0,disc:0,extra:0};
        const m=mAgg[ym];
        const rev=revCalc(r);
        // 3分解
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const hasSplit=(bp>0||op>0);
        const bpAdj=hasSplit?bp:(Number(r.price)||0);
        const opAdj=hasSplit?op:0;
        const dcAdj=hasSplit?dc:0;
        m.resvs.push(r);m.rev+=rev;m.cnt+=1;
        m.base+=bpAdj;m.opt+=opAdj;m.disc+=dcAdj;
        // days
        const ld=r[ldKey],rd2=r[rdKey];
        if(ld&&rd2){const days=Math.max(1,Math.round((new Date(rd2.slice(0,10))-new Date(ld.slice(0,10)))/(86400000)));m.daySum+=days;
          if(ld.slice(0,10)===rd2.slice(0,10))m.oneDay+=1;
        }
        // ota
        const ch=DB_OTA_MAP[r.ota]||"その他売上";
        m.otaRev[ch]=(m.otaRev[ch]||0)+rev;m.otaCnt[ch]=(m.otaCnt[ch]||0)+1;
        m.otaBase[ch]=(m.otaBase[ch]||0)+bpAdj;
        m.otaOpt[ch]=(m.otaOpt[ch]||0)+opAdj;
        m.otaDisc[ch]=(m.otaDisc[ch]||0)+dcAdj;
        // veh type
        const vc=fMap[r.id];const vObj=vc?vMap[vc]:null;
        let vType="?";
        if(vObj)vType=vObj.type||"?";
        else if(isSpk&&r.vehicle)vType=r.vehicle;
        else if(!isSpk&&r.vehicle_class)vType=r.vehicle_class;
        if(vType&&vType!=="?"){m.vtRev[vType]=(m.vtRev[vType]||0)+rev;m.vtCnt[vType]=(m.vtCnt[vType]||0)+1;}
        // lead time & created-in-month
        // booked_at（メール受信日）優先、なければcreated_atにフォールバック
        {const _ba=r.booked_at||r.created_at;if(_ba){
          const caYm=_ba.slice(0,7);
          if(caYm===ym)m.createdInMonth+=1;
          const monthFirst=ym+"-01";
          if(_ba.slice(0,10)<monthFirst)m.createdBeforeMonth+=1;
        }}
        // prefecture
        if(r.prefecture){const p=r.prefecture;m.prefCnt[p]=(m.prefCnt[p]||0)+1;}
      });

      // ★ 予約外売上を mAgg にマージ（reliable 期間内のみ）
      Object.keys(mAgg).forEach(ym=>{mAgg[ym].extra=extraByM[ym]||0;});
      // RELIABLE_FROM 以降で予約データが無い月でも extra があれば mAgg に追加
      Object.keys(extraByM).forEach(ym=>{
        if(ym<RELIABLE_FROM)return;
        if(!mAgg[ym])mAgg[ym]={resvs:[],rev:0,cnt:0,daySum:0,otaRev:{},otaCnt:{},otaBase:{},otaOpt:{},otaDisc:{},vtRev:{},vtCnt:{},createdInMonth:0,createdBeforeMonth:0,oneDay:0,prefCnt:{},base:0,opt:0,disc:0,extra:extraByM[ym]||0};
      });

      // lead time by month
      // グループ化はlend_date月（貸出月）、booked_at優先で実際の予約日を使用
      const leadByM={};
      // 直前予約 (リードタイム ≤ 10日) by month — 4 bucket: a=0-3 / b=4-5 / c=6-7 / d=8-10
      // ★ 有効カウント定義（両店共通ルール）:
      //   1. ota='direct' は除外（手動登録・法人直契約は対象外）
      //   2. 負のリードタイム（created_at > lend_date）は除外（過去予約の遡及取込・信頼性なし）
      const RECENT_THRESHOLD=10;
      const ltBucket=(lt)=>lt<=3?"a":lt<=5?"b":lt<=7?"c":"d";
      const isValidOtaForLastMin=(ota)=>{const o=String(ota||"").toLowerCase();return o&&o!=="direct";};
      const lastMinByM={};
      reliable.forEach(r=>{
        const rd=r[rdKey],ld=r[ldKey];
        const bookedAt=r.booked_at||r.created_at;
        if(!rd||!ld||!bookedAt)return;
        if(!isValidOtaForLastMin(r.ota))return;  // direct は除外（両店共通）
        const ym=ld.slice(0,7);
        const ltRaw=Math.round((new Date(ld.slice(0,10))-new Date(bookedAt.slice(0,10)))/(86400000));
        if(ltRaw<0)return;  // ★ 負のLT = 過去取込疑いで除外（両店共通）
        const lt=ltRaw;
        if(!leadByM[ym])leadByM[ym]=[];
        leadByM[ym].push(lt);
        if(!lastMinByM[ym])lastMinByM[ym]={cnt:0,total:0,items:[],bucketCnt:{a:0,b:0,c:0,d:0},bucketRev:{a:0,b:0,c:0,d:0},otaCnt:{},rev:0,ltSum:0};
        lastMinByM[ym].total+=1;
        if(lt>=0&&lt<=RECENT_THRESHOLD){
          const b=ltBucket(lt),rv=revCalc(r);
          lastMinByM[ym].cnt+=1;
          lastMinByM[ym].ltSum+=lt;
          lastMinByM[ym].bucketCnt[b]+=1;
          lastMinByM[ym].bucketRev[b]+=rv;
          const ota=r.ota||"?";
          lastMinByM[ym].otaCnt[ota]=(lastMinByM[ym].otaCnt[ota]||0)+1;
          lastMinByM[ym].rev+=rv;
          lastMinByM[ym].items.push({id:r.id,ota:r.ota,name:r.name,vehicle:r.vehicle,lend_date:ld,booked_at:bookedAt.slice(0,10),lead:lt,bucket:b,rev:rv});
        }
      });
      const median=(arr)=>{if(!arr||arr.length===0)return 0;const s=[...arr].sort((a,b)=>a-b);const mid=Math.floor(s.length/2);return s.length%2?s[mid]:Math.round((s[mid-1]+s[mid])/2);};

      // utilization per month (same logic as dbMetrics)
      const utilByM={};
      const ymList=Object.keys(mAgg).sort();
      ymList.forEach(ym=>{
        const[y,mo]=[parseInt(ym.split("-")[0]),parseInt(ym.split("-")[1])];
        const dim=new Date(y,mo,0).getDate();
        const ms2=new Date(y,mo-1,1),me2=new Date(y,mo-1,dim);
        const kf=kpiF[ym]||{};
        // ★2026-07 新統一式：メンテ/車検/点検/その他の日を分母から除く（実稼働ベース）
        const maintByVeh={};
        (dbMaint||[]).forEach(mm=>{
          if(mm.block_type&&mm.block_type!=="maintenance")return;
          if(!mm.start_date||!mm.end_date)return;
          let s=new Date(mm.start_date.slice(0,10)),e=new Date(mm.end_date.slice(0,10));
          if(s<ms2)s=ms2;if(e>me2)e=me2;if(s>e)return;
          const set=maintByVeh[mm.vehicle_code]||(maintByVeh[mm.vehicle_code]=new Set());
          for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1))set.add(d.toISOString().slice(0,10));
        });
        const availOf=(c)=>dim-((maintByVeh[c]&&maintByVeh[c].size)||0);
        // ★ kpiF方式 + フォールバック: dbKpiから直接inactive判定
        const inactiveCodes=new Set(dbKpi.filter(k=>k.year_month===ym&&k.active===false).map(k=>k.vehicle_code));
        const activeVehs=dbVehs.filter(v=>{
          const c=v.code;
          if(inactiveCodes.has(c))return false; // kpiで明示的に非稼働
          if(availOf(c)<=0)return false; // 丸ごとメンテ＝分母に入れない
          if(kf[c]!==undefined)return kf[c]!==false;
          return v.active!==false;
        });
        const vehDays={};
        reliable.forEach(r=>{
          const ld=r[ldKey],rd2=r[rdKey];if(!ld||!rd2)return;
          const vc=fMap[r.id];if(!vc)return;
          if(!activeVehs.find(v=>v.code===vc))return;
          let s=new Date(ld.slice(0,10)),e=new Date(rd2.slice(0,10));
          if(s<ms2)s=ms2;if(e>me2)e=me2;if(s>e)return;
          if(!vehDays[vc])vehDays[vc]=new Set();
          for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1))vehDays[vc].add(d.toISOString().slice(0,10));
        });
        Object.keys(vehDays).forEach(vc=>{const mset=maintByVeh[vc];if(mset)mset.forEach(dd=>vehDays[vc].delete(dd));});
        let totalDays=0,totalAvail=0;
        activeVehs.forEach(v=>{totalDays+=(vehDays[v.code]?vehDays[v.code].size:0);totalAvail+=availOf(v.code);});
        const vtUtil={};const vtCount={};
        DB_VEH_TYPES.forEach(t=>{
          const tv=activeVehs.filter(v=>(v.type||"")==t);if(tv.length===0)return;
          vtCount[t]=tv.length;
          let tD=0,tA=0;tv.forEach(v=>{tD+=(vehDays[v.code]?vehDays[v.code].size:0);tA+=availOf(v.code);});
          vtUtil[t]=tA>0?Math.round(tD/tA*1000)/10:0;
        });
        // per-vehicle util + revenue (return_date month)
        const vehRevM={};
        reliable.filter(r=>{const rd=r[rdKey];return rd&&rd.slice(0,7)===ym;}).forEach(r=>{
          const vc=fMap[r.id];if(!vc)return;
          vehRevM[vc]=(vehRevM[vc]||0)+revCalc(r);
        });
        const perVeh={};
        activeVehs.forEach(v=>{
          const ds=vehDays[v.code]?vehDays[v.code].size:0;const av=availOf(v.code);
          perVeh[v.code]={days:ds,maxDays:av,pct:av>0?Math.round(ds/av*1000)/10:0,name:v.name||v.code,type:v.type||"?",rev:vehRevM[v.code]||0};
        });
        utilByM[ym]={activeCount:activeVehs.length,dim,totalDays,maxDays:totalAvail,pct:totalAvail>0?Math.round(totalDays/totalAvail*100):0,vtUtil,vtCount,perVeh,vehDays};
      });

      // year aggregation
      const yearAgg={};
      ymList.forEach(ym=>{
        const yr=ym.slice(0,4);
        if(!yearAgg[yr])yearAgg[yr]={rev:0,cnt:0,daySum:0,leadTimes:[],createdInMonth:0,createdBeforeMonth:0,oneDay:0,totalDays:0,maxDays:0,base:0,opt:0,disc:0,extra:0,otaRev:{},otaCnt:{},otaBase:{},otaOpt:{},otaDisc:{}};
        const ya=yearAgg[yr],m=mAgg[ym],u=utilByM[ym]||{};
        ya.rev+=m.rev;ya.cnt+=m.cnt;ya.daySum+=m.daySum;ya.oneDay+=m.oneDay;
        ya.base+=m.base;ya.opt+=m.opt;ya.disc+=m.disc;ya.extra+=(m.extra||0);
        ya.createdInMonth+=m.createdInMonth;ya.createdBeforeMonth+=m.createdBeforeMonth;
        ya.totalDays+=(u.totalDays||0);ya.maxDays+=(u.maxDays||0);
        if(leadByM[ym])ya.leadTimes=ya.leadTimes.concat(leadByM[ym]);
        // OTA別3分解を年で集約
        Object.keys(m.otaRev||{}).forEach(ch=>{
          ya.otaRev[ch]=(ya.otaRev[ch]||0)+(m.otaRev[ch]||0);
          ya.otaCnt[ch]=(ya.otaCnt[ch]||0)+(m.otaCnt[ch]||0);
          ya.otaBase[ch]=(ya.otaBase[ch]||0)+(m.otaBase[ch]||0);
          ya.otaOpt[ch]=(ya.otaOpt[ch]||0)+(m.otaOpt[ch]||0);
          ya.otaDisc[ch]=(ya.otaDisc[ch]||0)+(m.otaDisc[ch]||0);
        });
      });
      const yrList=Object.keys(yearAgg).sort();

      // current month
      const nowYm=(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");})();

      // ===== グローバル期間フィルタ =====
      const selMode=analyticsPeriod.mode;
      const selYm=analyticsPeriod.ym||(()=>{const d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");})();
      const selYr=analyticsPeriod.year||String(new Date().getFullYear());
      const allYears=[...new Set(ymList.map(ym=>ym.slice(0,4)))].sort();
      const periodLabel=selMode==="month"?selYm:(selYr+"年");
      const selYrMonths=Array.from({length:12},(_,i)=>selYr+"-"+String(i+1).padStart(2,"0")).filter(ym=>ym>=RELIABLE_FROM);
      const relForPeriod=reliable.filter(r=>{
        const rd=r[rdKey];if(!rd)return false;
        return selMode==="month"?rd.slice(0,7)===selYm:rd.slice(0,4)===selYr;
      });
      const tasksForPeriod=dbTasks.filter(tk=>{
        if(!tk.date)return false;
        return selMode==="month"?tk.date.slice(0,7)===selYm:tk.date.slice(0,4)===selYr;
      });

      // time distribution (フィルタ反映)
      const taskTimeBuckets={DEL:{},COL:{}};
      tasksForPeriod.forEach(tk=>{
        if(!tk.time||!tk.type)return;
        const hh=tk.time.slice(0,2);
        const bucket=hh+":00";
        if(tk.type==="DEL"){taskTimeBuckets.DEL[bucket]=(taskTimeBuckets.DEL[bucket]||0)+1;}
        if(tk.type==="COL"){taskTimeBuckets.COL[bucket]=(taskTimeBuckets.COL[bucket]||0)+1;}
      });

      // delivery place ranking（フィルタ反映）
      // 空港・店舗・ヤード・プレースホルダは除外（実配達場所のみ集計）
      const EXCL_PLACE=/(空港|来店|店舗|店頭|ヤード|営業所|BUDDICA TOURISM|★OTA|デリバリー専門店|デリバリ専門店)/;
      // tasks全件から場所マップを構築（reservations.del_place未設定の補完用）
      // SPK: place列は空でchanged_json._ssPlaceに実データが入る → パースして取得
      const getTaskPlace=(tk)=>{
        if(isSpk){
          let cj={};try{cj=JSON.parse(tk.changed_json||'{}');}catch(e){}
          return(cj._placeSource==="manual"?tk.place:(cj._ssPlace||tk.place))||'';
        }
        return tk["送迎場所"]||'';
      };
      // places テーブルから場所マップ（OPシートCSV正本 = 最優先）
      const placesDelMap={},placesColMap={};
      dbPlaces.forEach(p=>{
        if(!p.reservation_id)return;
        const dp=(p.del_place||'').trim();const cp=(p.col_place||'').trim();
        if(dp&&!EXCL_PLACE.test(dp))placesDelMap[p.reservation_id]=dp;
        if(cp&&!EXCL_PLACE.test(cp))placesColMap[p.reservation_id]=cp;
      });
      // tasks からも補完（次点）
      const taskDelMap={},taskColMap={};
      dbTasks.forEach(tk=>{
        const rid=isSpk?(tk.reservation_id||''):tk.reservationId;
        const p=getTaskPlace(tk);
        if(!rid||!p)return;
        const pt=p.trim();if(!pt||EXCL_PLACE.test(pt))return;
        if(tk.type==="DEL")taskDelMap[rid]=pt;
        if(tk.type==="COL")taskColMap[rid]=pt;
      });
      const delPlaces={},colPlaces={};
      relForPeriod.forEach(r=>{
        const dp=((r.del_place||'').trim())||placesDelMap[r.id]||taskDelMap[r.id]||'';
        const cp=((r.col_place||'').trim())||placesColMap[r.id]||taskColMap[r.id]||'';
        if(dp&&!EXCL_PLACE.test(dp))delPlaces[dp]=(delPlaces[dp]||0)+1;
        if(cp&&!EXCL_PLACE.test(cp))colPlaces[cp]=(colPlaces[cp]||0)+1;
      });
      const delRank=Object.entries(delPlaces).sort((a,b)=>b[1]-a[1]).slice(0,20);
      const colRank=Object.entries(colPlaces).sort((a,b)=>b[1]-a[1]).slice(0,20);

