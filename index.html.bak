      shakenAlert.length>0&&E("div",{style:{background:"#fef2f2",border:"1px solid #fecaca",borderRadius:10,padding:"10px 14px"}},
        E("div",{style:{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}},
          E("span",{style:{fontSize:12,fontWeight:800,color:"#dc2626",flexShrink:0}},"🔴 車検未登録（12ヶ月以内） "+shakenAlert.length+"台"),
          E("div",{style:{display:"flex",gap:4,flexWrap:"wrap"}},
            shakenAlert.slice(0,8).map(function(v){return E("span",{key:v.code,style:{fontSize:10,padding:"2px 8px",borderRadius:6,background:"#fee2e2",color:"#991b1b",fontWeight:600}},
              v.name+(nextShaken[v.code]?"→"+nextShaken[v.code].slice(5):"（未定）"));})
          ),
