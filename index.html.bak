  async fetchShifts(){if(!sb){return DB._shiftsLsLoad();}const{data}=await sb.from("bt_shifts").select("*").limit(5000);const s={};(data||[]).forEach(r=>{if(!s[r.date])s[r.date]=[];s[r.date].push({name:r.staff_name,symbol:r.symbol,start:r.start_time,end:r.end_time,memo:r.memo,status:r.status||"確定"});});DB._shiftsLsSave(s);return s;},
  async saveShift(date,staffName,shift){if(!sb)return;await sb.from("bt_shifts").upsert({date,staff_name:staffName,symbol:shift.symbol||"",start_time:shift.start||"",end_time:shift.end||"",memo:shift.memo||"",status:shift.status||"確定"},{onConflict:"date,staff_name"});},
  async _shiftsLsSaveAll(){},
