<body>
<div id="root"></div>
<script>
function showErr(title,detail){
  var d=document.createElement("div");
  d.style.cssText="position:fixed;top:0;left:0;right:0;background:#fee2e2;color:#991b1b;padding:12px;font-size:12px;z-index:99999;white-space:pre-wrap;max-height:300px;overflow:auto";
  d.textContent=title+"\n"+detail;
  document.body.appendChild(d);
}
window.onerror=function(msg,src,line,col,err){
  showErr("[JS Error] "+msg,"Source: "+(src||"unknown")+"\nLine: "+line+" Col: "+col+(err&&err.stack?"\n"+err.stack:""));
};
window.addEventListener("unhandledrejection",function(e){
  var r=e.reason;
  if(r&&r.message&&r.message.indexOf("SyntaxError")>=0){showErr("[Babel Compile Error]",r.message);}
  console.error("Unhandled promise:",r);
});
</script>
<script type="text/babel">
const {useState,useMemo,useCallback,useEffect,useRef}=React;

/* ===== Supabase 設定 ===== */
const SUPABASE_URL = "https://ggqugvyskyiblxiycpci.supabase.co";
const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdncXVndnlza3lpYmx4aXljcGNpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgxMDc3NjksImV4cCI6MjA5MzY4Mzc2OX0.uNhWcBd_Dl5nzemZDQfJ8mQV6iY73MwystGGpTRPC18"; // anon key（RLSで保護）
const SB_ENABLED = !!(SUPABASE_URL && SUPABASE_KEY);
let sb = null;
let sbAuthReady = false;
let sbCurrentUser = null;
// ★ 強制ログアウト epoch：この文字列を変えると全端末が次回起動時に1回だけ強制ログアウトする
const BT_LOGOUT_EPOCH = '2026-07-11a';
const sbAuthPromise = (async () => {
  if (!SB_ENABLED) { sbAuthReady = true; return; }
  try {
    if (localStorage.getItem('bt_logout_epoch') !== BT_LOGOUT_EPOCH) {
      localStorage.setItem('bt_logout_epoch', BT_LOGOUT_EPOCH);
      Object.keys(localStorage).filter(k=>k.startsWith('sb-')).forEach(k=>localStorage.removeItem(k));
    }
  } catch(e) {}
  sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY, {
    auth: { persistSession: true, autoRefreshToken: true, detectSessionInUrl: false }
  });
  try {
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      sbCurrentUser = session.user;
    }
  } catch (e) {
    console.warn("[Auth] Session check failed:", e.message);
  }
  sbAuthReady = true;
})();

/* ===== Auth UI (ログイン画面) =====
   ユーザー名 → Email マッピングテーブル（v1.0.29-BT）
   スタッフはユーザー名と4桁パスコードでログイン → 内部で Supabase Auth (email) に変換 */
const BT_USER_MAP = {
  'oshita':    'oshita@bt.hdm',
  'takeyama':  'takeyama@bt.hdm',
  'saito-y':   'saito-y@bt.hdm',
  'toshima':   'toshima@bt.hdm',
  'saito-s':   'saito-s@bt.hdm',
  'hashisaka': 'hashisaka@bt.hdm',
  'takano':    'takano@bt.hdm',
  'member':    'member@bt.hdm',
};
async function ensureAuthenticated() {
  await sbAuthPromise;
  if (sbCurrentUser) return true;
  return new Promise((resolve) => {
    const overlay = document.createElement('div');
    overlay.id = 'bt-auth-overlay';
    overlay.style.cssText = 'position:fixed;inset:0;background:linear-gradient(135deg,#1e3a8a,#1d4ed8);z-index:99999;display:flex;align-items:center;justify-content:center;font-family:"Hiragino Sans","Yu Gothic","Meiryo",sans-serif;';
    overlay.innerHTML = `
      <div style="background:white;padding:40px;border-radius:12px;box-shadow:0 20px 50px rgba(0,0,0,.3);width:90%;max-width:380px">
        <div style="text-align:center;margin-bottom:24px">
          <img src="bc-logo.png" alt="BUDDICA" style="height:42px;width:auto;margin-bottom:10px">
          <div style="font-size:10pt;color:#6b7280;letter-spacing:.3em;margin-bottom:4px">B U D D I C A &nbsp; T O U R I S M</div>
          <div style="font-size:18pt;font-weight:700;color:#1e3a8a">高松店 管理APP</div>
          <div style="font-size:9pt;color:#6b7280;margin-top:8px">スタッフログイン</div>
        </div>
        <div id="bt-auth-msg" style="display:none;padding:8px 12px;background:#fef2f2;color:#991b1b;border-radius:4px;margin-bottom:12px;font-size:10pt"></div>
        <div style="margin-bottom:12px">
          <label style="display:block;font-size:9pt;font-weight:600;color:#374151;margin-bottom:4px">ユーザー名</label>
          <input id="bt-auth-user" type="text" autocomplete="username" autocapitalize="none" autocorrect="off" spellcheck="false" style="width:100%;padding:10px 12px;border:1px solid #d1d5db;border-radius:5px;font-size:13pt" placeholder="oshita">
        </div>
        <div style="margin-bottom:18px">
          <label style="display:block;font-size:9pt;font-weight:600;color:#374151;margin-bottom:4px">パスコード</label>
          <input id="bt-auth-pass" type="password" inputmode="numeric" autocomplete="current-password" style="width:100%;padding:10px 12px;border:1px solid #d1d5db;border-radius:5px;font-size:13pt;letter-spacing:6px;text-align:center" placeholder="0000">
        </div>
        <button id="bt-auth-submit" style="width:100%;padding:12px;background:#1e3a8a;color:white;border:none;border-radius:5px;font-size:11pt;font-weight:600;cursor:pointer">ログイン</button>
        <div style="margin-top:12px;text-align:center;font-size:8.5pt;color:#9ca3af">
          BUDDICA TOURISM 内部システム
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    const userInp = document.getElementById('bt-auth-user');
    const passInp = document.getElementById('bt-auth-pass');
    const submitBtn = document.getElementById('bt-auth-submit');
    const msg = document.getElementById('bt-auth-msg');
    setTimeout(() => userInp.focus(), 100);
    async function doLogin() {
      const username = (userInp.value || '').trim().toLowerCase();
      const pass = passInp.value;
      if (!username || !pass) {
        msg.textContent = 'ユーザー名とパスコードを入力してください';
        msg.style.display = 'block';
        return;
      }
      const email = BT_USER_MAP[username];
      if (!email) {
        msg.textContent = 'ユーザー名が違います（toshima / saito / saitogl / oshita / takeyama / member）';
        msg.style.display = 'block';
        return;
      }
      submitBtn.disabled = true;
      submitBtn.textContent = 'ログイン中...';
      msg.style.display = 'none';
      try {
        const { data, error } = await sb.auth.signInWithPassword({ email, password: pass });
        if (error) throw error;
        sbCurrentUser = data.user;
        document.body.removeChild(overlay);
        resolve(true);
      } catch (e) {
        msg.textContent = 'パスコードが違います';
        msg.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'ログイン';
      }
    }
    submitBtn.onclick = doLogin;
    passInp.onkeydown = (e) => { if (e.key === 'Enter') doLogin(); };
    userInp.onkeydown = (e) => { if (e.key === 'Enter') passInp.focus(); };
  });
}

async function signOut() {
  try { if (sb) await sb.auth.signOut(); } catch(e) {}
  sbCurrentUser = null;
  try { Object.keys(localStorage).filter(k=>k.startsWith('sb-')).forEach(k=>localStorage.removeItem(k)); } catch(e) {}
  location.reload();
}
// コンソールからも呼べるように公開（btLogout() でログアウト）
window.btLogout = signOut;
// 常時表示の小さなログアウトボタン（右上固定）
(function(){
  function addBtn(){
    if (document.getElementById('bt-logout-fab')) return;
    var b = document.createElement('button');
    b.id = 'bt-logout-fab';
    b.textContent = '⏻ ログアウト';
    b.style.cssText = 'position:fixed;top:6px;right:8px;z-index:99998;background:rgba(30,58,138,.85);color:#fff;border:none;border-radius:6px;padding:5px 10px;font-size:11px;font-weight:700;cursor:pointer;opacity:.85';
    b.onclick = function(){ if(confirm('ログアウトしますか？')) signOut(); };
    document.body.appendChild(b);
  }
  if (document.body) addBtn(); else document.addEventListener('DOMContentLoaded', addBtn);
})();

// 起動時にログインチェック
ensureAuthenticated();

/* ===== SHA-256 ハッシュ ===== */
async function sha256(str){
  const buf=await crypto.subtle.digest("SHA-256",new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,"0")).join("");
}


/* ===== Supabase DB ヘルパー ===== */
// ★ 2026-04-25 グローバル DB エラーバス（赤バッジ通知用）
window._dbErrors = window._dbErrors || [];
function dbLog(op,ok,detail){
  console.log(`[DB ${ok?"✓":"✗"}] ${op}`,detail||"");
  if(!ok){
    window._dbErrors.push({op,detail,ts:Date.now()});
    // 直近1時間のエラーのみ保持
    const cutoff=Date.now()-3600*1000;
    window._dbErrors=window._dbErrors.filter(e=>e.ts>=cutoff);
    // CustomEvent でUIに通知
    try{window.dispatchEvent(new CustomEvent("db-error",{detail:{op,detail}}));}catch(e){}
  }
}
// ★ 2026-04-25 critical fix: fetchAllRows がテーブルごとに正しいPKでorderするよう修正
// 旧実装は .order("id") 固定 → bt_fleet/bt_tasks 等にidカラムがないテーブルで PostgRESTエラー
// → エラー時 break で空配列返却 → fetchFleet が localStorage古い値を使い「未配車」誤表示が発生
async function fetchAllRows(table,selectCols="*",orderCol){if(!sb)return[];const PAGE=1000;
  const pk=orderCol||((table==="bt_fleet"||table==="fleet")?"reservation_id":(table==="bt_tasks"||table==="tasks")?"_id":(table==="bt_vehicles"||table==="vehicles")?"code":"id");
  let all=[];let from=0;while(true){const{data,error}=await sb.from(table).select(selectCols).order(pk,{ascending:true}).range(from,from+PAGE-1);if(error){dbLog("fetchAll:"+table,false,error.message);break;}if(data)all=all.concat(data);if(!data||data.length<PAGE)break;from+=PAGE;}const seen=new Set(),uniq=[];for(const r of all){const k=r&&(r[pk]!==undefined?r[pk]:r.id);if(k!==undefined&&!seen.has(k)){seen.add(k);uniq.push(r);}}return uniq;}
// ★ 同一予約番号の重複除去（GASがリトライで別IDでINSERTしたケースを吸収）
function dedupReservations(arr){
  if(!arr||!arr.length)return arr;
  const seen=new Map();
  arr.forEach(r=>{
    const key=r.reservationId||r.reservation_id||r.id;
    const ex=seen.get(key);
    // より新しいレコード（created_at大）を残す
    if(!ex||(r.createdAt||r.created_at||'')>=(ex.createdAt||ex.created_at||'')){seen.set(key,r);}
  });
  const uniq=Array.from(seen.values());
  if(uniq.length<arr.length)console.warn(`[dedupRes] ${arr.length}件 → ${uniq.length}件（${arr.length-uniq.length}件重複除去）`);
  return uniq;
}
const DB = {
  // --- 予約 ---
  async fetchReservations(){if(!sb)return DB._resLsLoad();let data;try{data=await fetchAllRows("bt_reservations");}catch(e){dbLog("fetchRes",false,e.message);return DB._resLsLoad();}if(!data||!data.length){const c=DB._resLsLoad();if(c.length){dbLog("fetchRes","cache","DB空→キャッシュ"+c.length+"件");return c;}return[];}dbLog("fetchRes",true,data.length+"件");const mapped=data.map(DB._fromDbRes);DB._resIdx={};mapped.forEach(r=>{if(r&&r.id)DB._resIdx[r.id]=r;});DB._resLsSave(mapped);return mapped;},
  async upsertReservations(arr){if(!sb||!arr.length)return;const rows=arr.map(DB._toDbRes);const{error}=await sb.from("bt_reservations").upsert(rows,{onConflict:"id"});if(error)dbLog("upsertRes",false,error.message);else dbLog("upsertRes",true,arr.length+"件保存");},
  async deleteReservations(ids){if(!sb||!ids.length)return;const{error}=await sb.from("bt_reservations").delete().in("id",ids);if(error)dbLog("deleteRes",false,error.message);else dbLog("deleteRes",true,ids.length+"件削除");},
  _toDbRes(r){return{id:r.id,ota:r.ota,name:r.name,start_date:r.lendDate,start_time:r.lendTime,end_date:r.returnDate,end_time:r.returnTime,people:r.people,vehicle_class:r.vehicle,vehicle_name:r.preferVc||"",insurance:r.insurance,tel:r.tel,mail:r.mail,price:r.price,final_price:r.finalPrice||0,base_price:r.basePrice||0,option_price:r.optionPrice||0,discount:r.discount||0,status:r.status,visit_type:r.visitType,return_type:r.returnType,del_time:r.delTime||"",del_place:r.delPlace||"",col_time:r.colTime||"",col_place:r.colPlace||"",del_flight:r.flight||"",opt_b:+(r.optB||0),opt_c:+(r.optC||0),opt_j:+(r.optJ||0),opt_usb:+(r.optUSB||0),prefecture:r.prefecture||""};},
  _fromDbRes(d){return{id:d.id,ota:d.ota,name:d.name,lendDate:norm(d.start_date),lendTime:d.start_time,returnDate:norm(d.end_date),returnTime:d.end_time,people:d.people,vehicle:d.vehicle_class,preferVc:d.vehicle_name||"",insurance:d.insurance,tel:d.tel,mail:d.mail,price:Number(d.price)||0,finalPrice:Number(d.final_price)||0,basePrice:Number(d.base_price)||0,optionPrice:Number(d.option_price)||0,discount:Number(d.discount)||0,status:d.status,visitType:d.visit_type,returnType:d.return_type,delTime:d.del_time,delPlace:d.del_place,colTime:d.col_time,colPlace:d.col_place,flight:d.del_flight,optB:+(d.opt_b||0),optC:+(d.opt_c||0),optJ:+(d.opt_j||0),optUSB:+(d.opt_usb||0),prefecture:d.prefecture||"",createdAt:d.created_at||"",mypageToken:d.mypage_token||"",pickupTime:d.pickup_time||""};},
  // --- 配車（LS併用で車両変更保護） ---
  _fleetLsKey:"bt_fleet",
  _fleetLsSave(f){try{const cnt=Object.keys(f).filter(k=>k!=="_unassignedReasons").length;if(cnt>=10){localStorage.setItem("bt_fleet_backup",JSON.stringify({data:f,ts:Date.now(),count:cnt}));}localStorage.setItem(DB._fleetLsKey,JSON.stringify(f));}catch(e){}},
  _fleetLsLoad(){try{const s=localStorage.getItem(DB._fleetLsKey);return s?JSON.parse(s):{};}catch(e){return{};}},
  // オフライン継続用キャッシュ（Supabase障害中も当日OP/配車/データタブが読める）
  _resLsKey:"bt_reservations_cache",
  _resLsSave(a){try{localStorage.setItem(DB._resLsKey,JSON.stringify(a));}catch(e){}},
  _resLsLoad(){try{const s=localStorage.getItem(DB._resLsKey);const a=s?JSON.parse(s):[];if(a.length&&(!DB._resIdx||!Object.keys(DB._resIdx).length)){DB._resIdx={};a.forEach(r=>{if(r&&r.id)DB._resIdx[r.id]=r;});}return a;}catch(e){return[];}},
  _vehLsKey:"bt_vehicles_cache",
  _vehLsSave(a){try{localStorage.setItem(DB._vehLsKey,JSON.stringify(a));}catch(e){}},
  _vehLsLoad(){try{const s=localStorage.getItem(DB._vehLsKey);return s?JSON.parse(s):null;}catch(e){return null;}},
  _fleetBackupSave(f){try{const backup={data:f,ts:Date.now(),count:Object.keys(f).filter(k=>k!=="_unassignedReasons").length};localStorage.setItem("bt_fleet_backup",JSON.stringify(backup));}catch(e){}},
  _fleetBackupLoad(){try{const s=localStorage.getItem("bt_fleet_backup");return s?JSON.parse(s):null;}catch(e){return null;}},
  async fetchFleet(){if(!sb){return DB._fleetLsLoad();}const data=await fetchAllRows("bt_fleet");if(!data.length){const ls=DB._fleetLsLoad();const lsCount=Object.keys(ls).filter(k=>k!=="_unassignedReasons").length;if(lsCount>0){console.warn("[fetchFleet] DB空だがlocalStorage有り("+lsCount+"件) → LS使用");}if(lsCount===0){const backup=DB._fleetBackupLoad();if(backup&&backup.count>0){console.warn("[fetchFleet] DB空+LS空 → バックアップ復元("+backup.count+"件)");return backup.data;}}return ls;}const f={};data.forEach(r=>f[r.reservation_id]=r.vehicle_code);dbLog("fetchFleet",true,Object.keys(f).length+"件");DB._fleetLsSave(f);return f;},
  async upsertFleet(fleet){DB._fleetLsSave(fleet);if(!sb)return;const rows=Object.entries(fleet).filter(([k,v])=>k!=="_unassignedReasons"&&typeof v==="string").map(([k,v])=>({reservation_id:k,vehicle_code:v}));if(rows.length){for(let i=0;i<rows.length;i+=500){const chunk=rows.slice(i,i+500);const{error}=await sb.from("bt_fleet").upsert(chunk,{onConflict:"reservation_id"});if(error){dbLog("upsertFleet",false,error.message);return;}}dbLog("upsertFleet",true,rows.length+"件");}},
  async updateFleetOne(resId,code){if(!sb)return;const{error}=await sb.from("bt_fleet").upsert({reservation_id:resId,vehicle_code:code},{onConflict:"reservation_id"});if(error)dbLog("updateFleet1",false,error.message);},
  async deleteFleetOne(resId){if(!sb)return;const{error}=await sb.from("bt_fleet").delete().eq("reservation_id",resId);if(error)dbLog("deleteFleet1",false,error.message);},
  // --- Broadcast（CSV取込ロック通知） ---
  _broadcastCh: null,
  _initBroadcast() {
    if (!sb || DB._broadcastCh) return;
    DB._broadcastCh = sb.channel("tkm-broadcast");
    DB._broadcastCh.subscribe();
  },
  broadcastImportLock(locked, user) {
    if (!DB._broadcastCh) DB._initBroadcast();
    if (DB._broadcastCh) {
      DB._broadcastCh.send({ type: "broadcast", event: "import-lock", payload: { locked, user, ts: Date.now() } });
    }
  },
  // --- タスク（localStorage併用で確実に保存） ---
  _lsKey(date){return"bt_tasks_"+date;},
  _lsSave(tasks,date){try{localStorage.setItem(DB._lsKey(date),JSON.stringify(tasks));}catch(e){}},
  _lsLoad(date){try{const s=localStorage.getItem(DB._lsKey(date));return s?JSON.parse(s):null;}catch(e){return null;}},
  _pendingSave:0,
  _hasChangedCol:null, // null=未チェック, true=あり, false=なし
  async fetchTasks(date){
    if(!sb){const ls=DB._lsLoad(date)||[];if(!ls.length){ls._fetchError=true;}return ls;}
    const{data,error}=await sb.from("bt_tasks").select("*").eq("date",date).neq("deleted",true).order("sort_order");
    if(error){dbLog("fetchTasks",false,error.message);const ls=DB._lsLoad(date)||[];ls._fetchError=true;return ls;}
    const tasks=(data||[]).map(DB._fromDbTask);
    // ★ 保存中の場合はlocalStorageを上書きしない（保存中のデータが消えるのを防ぐ）
    if(tasks.length&&DB._pendingSave<=0)DB._lsSave(tasks,date);
    // ★ changed_jsonカラムの存在を自動検出（初回のみ）
    if(DB._hasChangedCol===null&&data&&data.length>0){
      DB._hasChangedCol="changed_json" in data[0];
      dbLog("changed_col_detect",true,DB._hasChangedCol?"あり":"なし");
    }
    return tasks;
  },
  // 3段階保存: full → mid(changed_json付きmin) → bare(changed_jsonなしmin)
  _toDbTaskBare(t,date,i){return{_id:t._id,date:date,"内容":t.type||"","時間":((["DEL","PU","PUB","来店","PUB来店","COL","BD","BDB","返却"].indexOf(t.type)>=0&&!((t.timeChange&&String(t.timeChange).trim())||(t._ssTime&&String(t._ssTime).trim())||(t._manualTimeAt&&String(t._manualTimeAt).trim())))?"":(t.time||"")),"変更":t.timeChange||"","内案":t.typeChange||"","予約者":t.name||"","担当":t.assignee||"","確認":!!t.done,"メモ":t.memo||"","予約番号":t.reservationId||"","OTA":t.ota||"","TEL":t.tel||"","MAIL":t.mail||"",assigned_vehicle:t.assignedVehicle||"","No":t.plateNo||"","人数":t.people||0,"送迎場所":((["DEL","PU","PUB","来店","PUB来店","COL","BD","BDB","返却"].indexOf(t.type)>=0&&!(t._placeSource==="manual"||t._placeSource==="customer"||(t._ssPlace&&String(t._ssPlace).trim())))?"":(t.place||"")),"クラス":t.vehicle||"","確定":t.insurance||"","便名":t.flight||"","返却日":t.returnDate||"","返却":t.returnTime||"","送迎":t.returnType||"","集客":t.colPlace||"","B":t.opts&&t.opts.b||0,"C":t.opts&&t.opts.c||0,"J":t.opts&&t.opts.j||0,"USB":t.opts&&t.opts.usb||0,"約款":!!t.yakkan,"LINE":!!t.line,"決済":!!t.payment,sort_order:(t._sortOrder!=null&&t._sortOrder!==""?+t._sortOrder:i)};},
  _toDbTaskMin(t,date,i){const b=DB._toDbTaskBare(t,date,i);b.changed_json=JSON.stringify(t._changed||{});return b;},
  _dbSaveOk:true,
  // ★ 3段階フォールバック保存関数
  async _upsertWithFallback(rows,label){
    if(!sb||!rows.length)return;
    // 1) フル保存
    const{error}=await sb.from("bt_tasks").upsert(rows,{onConflict:"_id"});
    if(!error){DB._dbSaveOk=true;DB._hasChangedCol=true;return;}
    dbLog(label,false,error.message);
    // 2) changed_jsonなしで再試行
    const bareRows=rows.map(r=>{const b={...r};delete b.changed_json;return b;});
    const{error:e2}=await sb.from("bt_tasks").upsert(bareRows,{onConflict:"_id"});
    if(!e2){dbLog(label+"-bare",true,"ベア保存成功");DB._dbSaveOk=true;DB._hasChangedCol=false;return;}
    dbLog(label+"-bare",false,e2.message);DB._dbSaveOk=false;
  },
  // ★ スタッフ手入力フィールド（再生成/同期で絶対に潰さない）
  _USER_FIELDS:["assignee","place","colPlace","time","returnTime"],
  // 既存DB行(prev)のユーザー入力を、再生成タスク(t)に焼き戻してから保存する
  _mergeUserInput(t,prev){
    if(!prev)return t;
    const m={...t};
    if(String(prev.assignee||"").trim())m.assignee=prev.assignee;
    if(prev._assigneeCustom)m._assigneeCustom=true;
    if(prev._placeSource==="manual"){m.place=prev.place;m._placeSource="manual";}
    else if(String(prev.place||"").trim()&&!String(m.place||"").trim())m.place=prev.place;
    if(String(prev.colPlace||"").trim()&&!String(m.colPlace||"").trim())m.colPlace=prev.colPlace;
    if(prev.timeChange||(prev._changed&&prev._changed.time)){m.time=prev.time;m.timeChange=prev.timeChange;}
    else if(String(prev.time||"").trim()&&!String(m.time||"").trim())m.time=prev.time;
    if(String(prev.returnTime||"").trim()&&!String(m.returnTime||"").trim())m.returnTime=prev.returnTime;
    if(prev._ssPlace){m._ssPlace=prev._ssPlace;m._ssPlaceAt=prev._ssPlaceAt;}
    if(prev._ssTime){m._ssTime=prev._ssTime;m._ssTimeAt=prev._ssTimeAt;}
    if(prev._changed&&Object.keys(prev._changed).length)m._changed={...(m._changed||{}),...prev._changed};
    if(prev.manual)m.manual=true;
    if(prev.done)m.done=true;
    if(String(prev.memo||"").split("\n##BCJ:")[0].trim())m.memo=DB._mergeMemo(m.memo,prev.memo);
    return m;
  },
  _mergeMemo(newMemo,prevMemo){
    const prevBase=(prevMemo||"").split("\n##BCJ:")[0];
    const newBcj=(newMemo||"").includes("\n##BCJ:")?("\n##BCJ:"+(newMemo||"").split("\n##BCJ:")[1]):"";
    return prevBase+newBcj;
  },
  async upsertTasks(tasks,date,opts){
    DB._lsSave(tasks,date);
    if(!sb||!tasks.length)return;
    DB._pendingSave++;
    try{
      // ★ 2026-05-09 緊急 revert (v3.5.14): UNIQUE制約と_id継承の組合せでタスク消失障害発生
      //   担当振り分け保存時にUNIQUE違反となり bt_tasks への保存失敗→ローカル更新だけ→リロードで消える
      //   → _id継承ロジック撤去 + DB UNIQUE INDEX も別途撤去（DROP INDEX SQL ユーザー実行）
      let toSave=tasks;
      // 🛡 protect=true: 再生成/同期由来の保存。DBの既存行を読み、スタッフ入力を焼き戻してから保存
      if(opts&&opts.protect){
        try{
          const ids=tasks.map(t=>t._id).filter(Boolean);
          if(ids.length){
            const{data:exRows}=await sb.from("bt_tasks").select("*").in("_id",ids);
            if(exRows&&exRows.length){
              const exMap={};exRows.forEach(r=>{exMap[r._id]=DB._fromDbTask(r);});
              toSave=tasks.map(t=>exMap[t._id]?DB._mergeUserInput(t,exMap[t._id]):t);
              DB._lsSave(toSave,date);
            }
          }
        }catch(e){console.warn("[upsertTasks protect] merge skip:",e.message);}
      }
      const rows=toSave.map((t,i)=>DB._toDbTask(t,date,i));
      await DB._upsertWithFallback(rows,"upsertTasks");
    }finally{DB._pendingSave--;}
  },
  async updateTask(t,date){
    const ls=DB._lsLoad(date);
    if(ls){const idx=ls.findIndex(x=>x._id===t._id);if(idx>=0){ls[idx]=t;DB._lsSave(ls,date);}else{ls.push(t);DB._lsSave(ls,date);}}
    else{DB._lsSave([t],date);}
    if(!sb)return;
    DB._pendingSave++;
    try{
      const row=DB._toDbTask(t,date,t._sortOrder||0);
      await DB._upsertWithFallback([row],"updateTask");
    }finally{DB._pendingSave--;}
  },
  async updateTaskFields(taskId, date, fieldChanges) {
    const ls = DB._lsLoad(date);
    if (ls) {
      const idx = ls.findIndex(x => x._id === taskId);
      if (idx >= 0) { Object.assign(ls[idx], fieldChanges); DB._lsSave(ls, date); }
    }
    if (!sb) return;
    const colMap = {
      type: "\u5185\u5BB9", time: "\u6642\u9593", timeChange: "\u5909\u66F4", typeChange: "\u5185\u6848",
      name: "\u4E88\u7D04\u8005", assignee: "\u62C5\u5F53", done: "\u78BA\u8A8D", memo: "\u30E1\u30E2",
      reservationId: "\u4E88\u7D04\u756A\u53F7", ota: "OTA", tel: "TEL", mail: "MAIL",
      assignedVehicle: "assigned_vehicle", plateNo: "No", people: "\u4EBA\u6570",
      place: "\u9001\u8FCE\u5834\u6240", vehicle: "\u30AF\u30E9\u30B9", insurance: "\u78BA\u5B9A", flight: "\u4FBF\u540D",
      returnDate: "\u8FD4\u5374\u65E5", returnTime: "\u8FD4\u5374", returnType: "\u9001\u8FCE", colPlace: "\u96C6\u5BA2",
      yakkan: "\u7D04\u6B3E", line: "LINE", payment: "\u6C7A\u6E08"
    };
    const dbChanges = {};
    Object.entries(fieldChanges).forEach(([k, v]) => {
      if (k === 'opts') return;
      if (k === '_changed' || k === '_timeFromSheet' || k === '_timeChangeSource' || k === '_placeSource' || k === '_ssTime' || k === '_ssPlace' || k === '_ssTimeAt' || k === '_ssPlaceAt' || k === '_manualTimeAt' || k === '_manualPlaceAt') return;
      const col = colMap[k];
      if (col) dbChanges[col] = v;
    });
    if (fieldChanges.opts) {
      if ('b' in fieldChanges.opts) dbChanges["B"] = +(fieldChanges.opts.b || 0);
      if ('c' in fieldChanges.opts) dbChanges["C"] = +(fieldChanges.opts.c || 0);
      if ('j' in fieldChanges.opts) dbChanges["J"] = +(fieldChanges.opts.j || 0);
      if ('usb' in fieldChanges.opts) dbChanges["USB"] = +(fieldChanges.opts.usb || 0);
    }
    if (fieldChanges._changed !== undefined || fieldChanges._ssTime !== undefined || fieldChanges._placeSource !== undefined) {
      const lsNow = DB._lsLoad(date);
      const t = lsNow ? lsNow.find(x => x._id === taskId) : null;
      if (t) {
        dbChanges.changed_json = JSON.stringify({
          ...(t._changed || {}),
          _timeFromSheet: !!t._timeFromSheet,
          _timeChangeSource: t._timeChangeSource || "",
          _placeSource: t._placeSource || "",
          _ssTime: t._ssTime || "", _ssPlace: t._ssPlace || "",
          _ssTimeAt: t._ssTimeAt || "", _ssPlaceAt: t._ssPlaceAt || "",
          _manualTimeAt: t._manualTimeAt || "", _manualPlaceAt: t._manualPlaceAt || ""
        });
      }
    }
    if (!Object.keys(dbChanges).length) return;
    const { error } = await sb.from("bt_tasks").update(dbChanges).eq("_id", taskId);
    if (error) dbLog("updateTaskFields", false, error.message);
    else dbLog("updateTaskFields", true, taskId + " " + Object.keys(dbChanges).join(","));
  },
  async deleteTasks(date){try{localStorage.removeItem(DB._lsKey(date));}catch(e){} if(!sb)return;const{error}=await sb.from("bt_tasks").delete().eq("date",date);if(error)dbLog("deleteTasks",false,error.message);},
  async deleteTask(id,date){if(!sb)return;/* ★2026-07-04 墓標方式: 物理削除せず deleted=true。復活不能。 */const{error}=await sb.from("bt_tasks").update({deleted:true}).eq("_id",id);if(error)dbLog("deleteTask",false,error.message);else dbLog("deleteTask",true,id);try{const ls=DB._lsLoad(date);if(ls){const next=ls.filter(t=>t._id!==id);localStorage.setItem(DB._lsKey(date),JSON.stringify(next));}}catch(e){}},
  async fetchTasksRange(fromDate,toDate){if(!sb)return[];const{data,error}=await sb.from("bt_tasks").select("*").gte("date",fromDate).lte("date",toDate).neq("deleted",true).order("date",{ascending:false}).order("sort_order").limit(5000);if(error){dbLog("fetchTasksRange",false,error.message);return[];}return(data||[]).map(r=>({...DB._fromDbTask(r),_date:r.date}));},
  _toDbTask(t,date,i){return{_id:t._id,date:(t._taskDate||date),"内容":t.type||"","時間":((["DEL","PU","PUB","来店","PUB来店","COL","BD","BDB","返却"].indexOf(t.type)>=0&&!((t.timeChange&&String(t.timeChange).trim())||(t._ssTime&&String(t._ssTime).trim())||(t._manualTimeAt&&String(t._manualTimeAt).trim())))?"":(t.time||"")),"変更":t.timeChange||"","内案":t.typeChange||"","予約者":t.name||"","担当":t.assignee||"","確認":!!t.done,"メモ":t.memo||"","予約番号":t.reservationId||"","OTA":t.ota||"","TEL":t.tel||"","MAIL":t.mail||"",assigned_vehicle:t.assignedVehicle||"","No":t.plateNo||"","人数":t.people||0,"送迎場所":((["DEL","PU","PUB","来店","PUB来店","COL","BD","BDB","返却"].indexOf(t.type)>=0&&!(t._placeSource==="manual"||t._placeSource==="customer"||(t._ssPlace&&String(t._ssPlace).trim())))?"":(t.place||"")),"クラス":t.vehicle||"","確定":t.insurance||"","便名":t.flight||"","返却日":t.returnDate||"","返却":t.returnTime||"","送迎":t.returnType||"","集客":t.colPlace||"","B":+(t.opts?.b||0),"C":+(t.opts?.c||0),"J":+(t.opts?.j||0),"USB":+(t.opts?.usb||0),"約款":!!t.yakkan,"LINE":!!t.line,"決済":!!t.payment,sort_order:(t._sortOrder!=null&&t._sortOrder!==""?+t._sortOrder:i),changed_json:JSON.stringify({...(t._changed||{}),_timeFromSheet:!!t._timeFromSheet,_timeChangeSource:t._timeChangeSource||"",_placeSource:t._placeSource||"",_ssTime:t._ssTime||"",_ssPlace:t._ssPlace||"",_ssTimeAt:t._ssTimeAt||"",_ssPlaceAt:t._ssPlaceAt||"",_manualTimeAt:t._manualTimeAt||"",_manualPlaceAt:t._manualPlaceAt||"",_manual:!!t.manual,_taskDate:(t._taskDate||date)})};},
  _fromDbTask(d){const ch=(()=>{try{const p=JSON.parse(d.changed_json||"{}");return Object.keys(p).length?p:undefined;}catch(e){return undefined;}})();const tfs=ch&&ch._timeFromSheet;const tcs=ch&&ch._timeChangeSource;const ps=ch&&ch._placeSource;const sst=ch&&ch._ssTime;const ssp=ch&&ch._ssPlace;const sstAt=ch&&ch._ssTimeAt;const sspAt=ch&&ch._ssPlaceAt;const mtAt=ch&&ch._manualTimeAt;const mpAt=ch&&ch._manualPlaceAt;const isManual=ch&&ch._manual;const td=ch&&ch._taskDate;if(ch){delete ch._timeFromSheet;delete ch._timeChangeSource;delete ch._placeSource;delete ch._ssTime;delete ch._ssPlace;delete ch._ssTimeAt;delete ch._ssPlaceAt;delete ch._manualTimeAt;delete ch._manualPlaceAt;delete ch._manual;delete ch._taskDate;}return{_id:d._id,type:d["内容"],time:(()=>{/* ★2026-07-15 STEP2横展開: 時間の正本は予約(del/col_time)。人間編集(変更/_ssTime/手動)がある時だけタスク値、無ければDEL/COL系のみ予約から導出。洗車/その他はタスク値。 */var _tm=d["時間"];if((d["変更"]&&String(d["変更"]).trim())||(sst&&String(sst).trim())||tcs==="manual"||(mtAt&&String(mtAt).trim()))return _tm;var _r=(d["予約番号"]&&DB._resIdx)?DB._resIdx[d["予約番号"]]:null;if(!_r)return _tm;var _c=d["内容"];var _isCol=["COL","BD","BDB","返却"].indexOf(_c)>=0;var _isDel=["DEL","PU","PUB","来店","PUB来店"].indexOf(_c)>=0;if(!_isCol&&!_isDel)return _tm;var _rt=_isCol?(_r.colTime||_r.returnTime):(_r.delTime||_r.lendTime);return (_rt&&String(_rt).trim())?_rt:_tm;})(),name:d["予約者"],assignee:d["担当"],done:d["確認"]===true||d["確認"]==="true",memo:d["メモ"],reservationId:d["予約番号"],ota:d["OTA"],tel:d["TEL"],mail:d["MAIL"],assignedVehicle:d.assigned_vehicle,plateNo:d["No"],people:d["人数"],place:(()=>{/* ★2026-07-15 STEP2横展開: 場所の正本は予約(del/col_place)。人間編集(手動/顧客/_ssPlace)がある時だけタスク値、無ければDEL/COL系のみ予約から導出。空はタスク値。 */var _p=d["送迎場所"];if(ps==="manual"||ps==="customer"||(ssp&&String(ssp).trim()))return _p;var _r=(d["予約番号"]&&DB._resIdx)?DB._resIdx[d["予約番号"]]:null;if(!_r)return _p;var _c=d["内容"];var _isCol=["COL","BD","BDB","返却"].indexOf(_c)>=0;var _isDel=["DEL","PU","PUB","来店","PUB来店"].indexOf(_c)>=0;if(!_isCol&&!_isDel)return _p;var _fb=_isCol?_r.colPlace:_r.delPlace;return (_fb&&String(_fb).trim())?_fb:_p;})(),vehicle:d["クラス"],insurance:d["確定"],insuranceChange:"",timeChange:d["変更"]||"",typeChange:d["内案"]||"",flight:d["便名"],returnDate:norm(d["返却日"]),returnTime:d["返却"],returnType:d["送迎"],colPlace:d["集客"],opts:(()=>{var _r=(d["予約番号"]&&DB._resIdx)?DB._resIdx[d["予約番号"]]:null;return _r?{b:+(_r.optB||0),c:+(_r.optC||0),j:+(_r.optJ||0),usb:+(_r.optUSB||0)}:{b:+(d["B"]||0),c:+(d["C"]||0),j:+(d["J"]||0),usb:+(d["USB"]||0)};})(),yakkan:d["約款"]===true||d["約款"]==="true",line:d["LINE"]===true||d["LINE"]==="true",payment:d["決済"]===true||d["決済"]==="true",_sortOrder:d.sort_order,_assigneeCustom:false,_timeChanged:false,_changed:ch,_timeFromSheet:!!tfs,_timeChangeSource:tcs||"",_placeSource:ps||"",_ssTime:sst||"",_ssPlace:ssp||"",_ssTimeAt:sstAt||"",_ssPlaceAt:sspAt||"",_manualTimeAt:mtAt||"",_manualPlaceAt:mpAt||"",manual:!!isManual,_taskDate:(td||d.date)};},
  // --- 予約変更管理 ---
  async updateReservationField(resId,changes,changeType,source){
    if(!sb||!resId)return;
    try{
      const{data:cur}=await sb.from("bt_reservations").select("*").eq("id",resId).single();
      const colMap={lendTime:"start_time",returnTime:"end_time",delTime:"del_time",colTime:"col_time",
        delPlace:"del_place",colPlace:"col_place",vehicle:"vehicle_class",insurance:"insurance",
        optB:"opt_b",optC:"opt_c",optJ:"opt_j",optUSB:"opt_usb",visitType:"visit_type",returnType:"return_type",
        lendDate:"start_date",returnDate:"end_date",flight:"del_flight",people:"people",price:"price"};
      const dbChanges={};
      Object.entries(changes).forEach(([k,v])=>{const col=colMap[k]||k;dbChanges[col]=v;});
      const{error}=await sb.from("bt_reservations").update(dbChanges).eq("id",resId);
      if(error){dbLog("updateResField",false,error.message);return;}
      dbLog("updateResField",true,resId+" "+changeType);
      if(cur){
        const logs=[];
        Object.entries(dbChanges).forEach(([col,newVal])=>{
          const oldVal=cur[col];
          if(String(oldVal||"")!==String(newVal||"")){
            logs.push({reservation_id:resId,change_type:changeType,field_name:col,
              old_value:String(oldVal||""),new_value:String(newVal||""),source:source||"op_sheet"});
          }
        });
        if(logs.length){
          sb.from("bt_reservation_changes").insert(logs).then(({error:e2})=>{
            if(e2)dbLog("resChanges",false,e2.message);
            else dbLog("resChanges",true,logs.length+"件記録");
          });
        }
      }
    }catch(e){console.error("[updateResField]",e);}
  },
  async fetchReservationChanges(resId){
    if(!sb)return[];
    const{data,error}=await sb.from("bt_reservation_changes").select("*").eq("reservation_id",resId).order("changed_at",{ascending:false}).limit(50);
    if(error){dbLog("fetchResChanges",false,error.message);return[];}
    return data||[];
  },
  // --- スタッフ ---
  _staffLsKey:"bt_staff_backup",
  _staffLsSave(arr){try{localStorage.setItem(DB._staffLsKey,JSON.stringify(arr));}catch(e){}},
  _staffLsLoad(){try{const s=localStorage.getItem(DB._staffLsKey);return s?JSON.parse(s):null;}catch(e){return null;}},
  async fetchStaff(){if(!sb)return DB._staffLsLoad();const{data,error}=await sb.from("bt_staff").select("*").order("sort_order");if(error){dbLog("fetchStaff",false,error.message);return DB._staffLsLoad();}dbLog("fetchStaff",true,data.length+"件");
    // カラム存在チェック
    const hasWageCols=data.length>0&&data[0].hasOwnProperty("hourly_wage");
    DB._staffHasWageCols=hasWageCols;
    if(!hasWageCols&&data.length>0)console.warn("[fetchStaff] ⚠️ staffテーブルにhourly_wageカラムなし");
    const dbStaff=(data||[]).map(s=>({name:s.name,type:s.type,memo:s.memo||"",hourlyWage:s.hourly_wage||0,transportCost:s.transport_cost||0,monthlySalary:s.monthly_salary||0}));
    // DB側にhourly_wage等カラムがない場合、localStorageの値をマージ→差異あればDBに自動プッシュ
    const lsStaff=DB._staffLsLoad();
    let needPush=false;
    if(lsStaff&&lsStaff.length>0){
      const lsMap={};lsStaff.forEach(s=>{lsMap[s.name]=s;});
      dbStaff.forEach(s=>{const ls=lsMap[s.name];if(ls){
        if(!s.hourlyWage&&ls.hourlyWage){s.hourlyWage=ls.hourlyWage;needPush=true;}
        if(!s.transportCost&&ls.transportCost){s.transportCost=ls.transportCost;needPush=true;}
        if(!s.monthlySalary&&ls.monthlySalary){s.monthlySalary=ls.monthlySalary;needPush=true;}
      }});
    }
    DB._staffLsSave(dbStaff);
    // LSから補完したデータがあればDBに自動保存（他デバイスにも反映）
    if(needPush&&hasWageCols){console.log("[staffSync] LS→DB push: wage data merged");DB.saveStaff(dbStaff).catch(e=>console.error("[staffSync]",e));}
    return dbStaff;},
  _staffHasWageCols:null, // null=未確認, true=あり, false=なし
  async saveStaff(arr){DB._staffLsSave(arr);if(!sb)return;
    const rows=arr.map((s,i)=>({name:s.name,type:s.type,memo:s.memo||"",sort_order:i,active:true,hourly_wage:s.hourlyWage||0,transport_cost:s.transportCost||0,monthly_salary:s.monthlySalary||0}));
    const{error}=await sb.from("bt_staff").upsert(rows,{onConflict:"name"});
    if(error){
      dbLog("saveStaff",false,error.message);
      // カラム不在エラーの場合、給与カラムなしでリトライ
      if(error.message&&(error.message.includes("hourly_wage")||error.message.includes("transport_cost")||error.message.includes("monthly_salary")||error.message.includes("column"))){
        DB._staffHasWageCols=false;
        console.warn("[saveStaff] 給与カラムなし→カラムなしで再保存");
        const rows2=arr.map((s,i)=>({name:s.name,type:s.type,memo:s.memo||"",sort_order:i,active:true}));
        const{error:e2}=await sb.from("bt_staff").upsert(rows2,{onConflict:"name"});
        if(e2)dbLog("saveStaff(retry)",false,e2.message);
        else dbLog("saveStaff(retry)",true,arr.length+"件(給与カラムなし)");
      }
    }else{DB._staffHasWageCols=true;dbLog("saveStaff",true,arr.length+"件保存");}
  },
  async deleteStaff(name){if(!sb)return;const{error}=await sb.from("bt_staff").delete().eq("name",name);if(error)dbLog("deleteStaff",false,error.message);else dbLog("deleteStaff",true,name);},
  // --- 時給履歴 ---
  async fetchWageHistory(){if(!sb)return[];const{data,error}=await sb.from("bt_wage_history").select("*").order("effective_date",{ascending:true});if(error){dbLog("fetchWageHist",false,error.message);return[];}dbLog("fetchWageHist",true,(data||[]).length+"件");return data||[];},
  async saveWageHistory(rec){if(!sb)return;const{error}=await sb.from("bt_wage_history").upsert(rec,{onConflict:"id"});if(error)dbLog("saveWageHist",false,error.message);else dbLog("saveWageHist",true,rec.staff_name);},
  async deleteWageHistory(id){if(!sb)return;const{error}=await sb.from("bt_wage_history").delete().eq("id",id);if(error)dbLog("delWageHist",false,error.message);else dbLog("delWageHist",true,id);},
  // 特定日のスタッフ時給を取得（履歴から逆順で最初にマッチするものを返す）
  getWageForDate(wageHistory,staffName,date){
    const entries=(wageHistory||[]).filter(w=>w.staff_name===staffName&&w.effective_date<=date).sort((a,b)=>b.effective_date.localeCompare(a.effective_date));
    return entries.length>0?entries[0].hourly_wage:null;
  },
  // --- 車両 ---
  async fetchVehicles(){if(!sb)return DB._vehLsLoad();const{data,error}=await sb.from("bt_vehicles").select("*");if(error){dbLog("fetchVehicles",false,error.message);return DB._vehLsLoad();}dbLog("fetchVehicles",true,data.length+"件");const _vm=(data||[]).map(v=>({id:v.code,code:v.code,name:v.name,no:v.plate_no,type:v.type,grade:v.grade||"",brand:v.brand||"",seats:v.seats,insuranceVeh:!!v.insurance_veh,year:v.year||"",color:v.color||"",equip:v.equip||"",insPrice:v.ins_price||"",memo:v.memo||"",insuranceAnnual:Number(v.insurance_annual)||0,leaseMonthly:Number(v.lease_monthly)||0,shakenCost:Number(v.shaken_cost)||0,tenkenCost:Number(v.tenken_cost)||0,carTax:Number(v.car_tax)||0,oilIntervalKm:Number(v.oil_interval_km)||5000,inspectionDueDate:v.inspection_due_date||"",inspectionNextDate:v.inspection_next_date||"",tenkenDueDate:v.tenken_due_date||"",tenkenNextDate:v.tenken_next_date||"",active:v.active!==false,specs:(v.specs&&typeof v.specs==="object")?v.specs:{}}));DB._vehLsSave(_vm);return _vm;},
  async saveVehicles(arr){if(!sb)return;const rows=arr.map(v=>({code:v.code,name:v.name,plate_no:v.no,type:v.type,grade:v.grade||"",brand:v.brand||"",seats:v.seats,insurance_veh:!!v.insuranceVeh,year:v.year||"",color:v.color||"",equip:v.equip||"",ins_price:v.insPrice||"",memo:v.memo||"",insurance_annual:Number(v.insuranceAnnual)||0,lease_monthly:Number(v.leaseMonthly)||0,shaken_cost:Number(v.shakenCost)||0,tenken_cost:Number(v.tenkenCost)||0,car_tax:Number(v.carTax)||0,oil_interval_km:Number(v.oilIntervalKm)||5000,inspection_due_date:v.inspectionDueDate||null,inspection_next_date:v.inspectionNextDate||null,tenken_due_date:v.tenkenDueDate||null,tenken_next_date:v.tenkenNextDate||null,active:v.active!==false,specs:(v.specs&&typeof v.specs==="object")?v.specs:{}}));const{error}=await sb.from("bt_vehicles").upsert(rows,{onConflict:"code"});if(error)dbLog("saveVehicles",false,error.message);else dbLog("saveVehicles",true,arr.length+"件保存");},
  async deleteVehicle(code){if(!sb)return;const{error}=await sb.from("bt_vehicles").delete().eq("code",code);if(error)dbLog("deleteVehicle",false,error.message);else dbLog("deleteVehicle",true,code);},
