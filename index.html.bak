  const[timeLoading,setTimeLoading]=useState(false);
  const updateTimes=async()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length){alert("予約がありません");return;}
    setTimeLoading(true);
    try{
      const timeMap=await fetchTimeData(resIds,(inc)=>setPatrolIncomplete(prev=>{const key=(x)=>x.name+"_"+x.lendDate+"_"+x.kind;const map={};[...prev,...inc].forEach(x=>{map[key(x)]=x;});return Object.values(map);}));
      const matched=Object.keys(timeMap).length;
      if(!matched){setTimeLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      tasks.forEach(t=>{if(t.reservationId&&timeMap[t.reservationId])selfUpdatedIds.current.set(t._id,Date.now());});
      let updatedTasks;let updCount=0;let skipCount=0;
      setTasks(prev=>{
        updatedTasks=prev.map(t=>{
          if(!t.reservationId||!timeMap[t.reservationId])return t;
          const tm=timeMap[t.reservationId];
          let newTime=null;
          if((t.type==="DEL"||t.type==="PU")&&tm.delTime)newTime=tm.delTime;
          if((t.type==="COL"||t.type==="BD")&&tm.colTime)newTime=tm.colTime;
          if(!newTime)return t;
          const normalized=newTime.replace(/^(\d):/, "0$1:").replace(/\uff1a/g,":").slice(0,5);
          // ★ SS値は常に _ssTime に保存
          const updates={_ssTime:normalized,_timeFromSheet:true,_ssTimeAt:new Date().toISOString()};
          // ★ 手動変更済み(timeChange)がある場合はtimeを上書きしない
          if(t._timeChangeSource==="manual"&&t.timeChange){
            skipCount++;
            // SS値だけ更新して返す
            return{...t,...updates};
          }
          if(normalized===t.time)return{...t,...updates};
          updCount++;
          const cf={...(t._changed||{}),time:true};
          return{...t,...updates,time:normalized,_changed:cf,_timeChangeSource:"spreadsheet"};
        });
        DB._lsSave(updatedTasks,selDate);
        return updatedTasks;
      });
      pendingSaves.current++;setSaveStatus("saving");
      await DB.upsertTasks(updatedTasks,selDate);
      pendingSaves.current--;
      setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
      // ★ reservationsマスターにも書き戻し
      Object.entries(timeMap).forEach(([resId,tm])=>{
        const resFields={};
        if(tm.delTime){const n=tm.delTime.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);resFields.delTime=n;}
        if(tm.colTime){const n=tm.colTime.replace(/^(\d):/,"0$1:").replace(/\uff1a/g,":").slice(0,5);resFields.colTime=n;}
        if(Object.keys(resFields).length){
          DB.updateReservationField(resId,resFields,"\u2464\u6642\u9593:\u30b9\u30d7\u30ec\u30c3\u30c9\u30b7\u30fc\u30c8\u53d6\u5f97","spreadsheet");
          if(onReservationUpdate)onReservationUpdate(resId,resFields);
        }
      });
      alert(`${matched}件中 ${updCount}件の時間を更新しました`+(skipCount>0?`\n（手動変更済み${skipCount}件はスキップ）`:""));
    }catch(e){alert("時間データ取得エラー: "+e.message);}
    setTimeLoading(false);
  };
  const[placeLoading,setPlaceLoading]=useState(false);
  const[lineModal,setLineModal]=useState(null);
  const updatePlaces=async()=>{
    const resIds=[...new Set(tasks.filter(t=>t.reservationId).map(t=>t.reservationId))];
    if(!resIds.length){alert("予約がありません");return;}
    setPlaceLoading(true);
    try{
      const placeMap=await fetchPlaceData(resIds,(inc)=>setPatrolIncomplete(prev=>{const key=(x)=>x.name+"_"+x.lendDate+"_"+x.kind;const map={};[...prev,...inc].forEach(x=>{map[key(x)]=x;});return Object.values(map);}));
      const matched=Object.keys(placeMap).length;
      if(!matched){setPlaceLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      tasks.forEach(t=>{if(t.reservationId&&placeMap[t.reservationId])selfUpdatedIds.current.set(t._id,Date.now());});
      // ★ setState内ではLS保存のみ、DB保存は外で行う
      let updatedTasks;let placeSkip=0;
      setTasks(prev=>{
        updatedTasks=prev.map(t=>{
          if(!t.reservationId||!placeMap[t.reservationId])return t;
          const p=placeMap[t.reservationId];
          const isDel=t.type==="DEL"||t.type==="PU";
          const isCol=t.type==="COL"||t.type==="BD";
          // ★ SS値は常に _ssPlace に保存
          const ssPlace=isDel?p.delPlace:isCol?p.colPlace:"";
          const ssUpdates=ssPlace?{_ssPlace:ssPlace,_ssPlaceAt:new Date().toISOString()}:{};
          // ★ 手動変更済みの場合はplaceを上書きしない
          if(t._placeSource==="manual"){placeSkip++;return{...t,...ssUpdates};}
          const updates={};const cf={...(t._changed||{})};
          if(isDel&&p.delPlace){updates.place=p.delPlace;cf.place=true;}
          if(isCol&&p.colPlace){updates.place=p.colPlace;cf.place=true;}
          if(isDel&&p.colPlace){updates.colPlace=p.colPlace;cf.colPlace=true;}
          if(Object.keys(updates).length===0)return{...t,...ssUpdates};
          return{...t,...updates,...ssUpdates,_changed:cf,_placeSource:"spreadsheet"};
        });
        DB._lsSave(updatedTasks,selDate);
        return updatedTasks;
      });
      // ★ DB保存をsetState外で実行（確実にawait）
      pendingSaves.current++;setSaveStatus("saving");
      await DB.upsertTasks(updatedTasks,selDate);
      pendingSaves.current--;
      setSaveStatus(DB._dbSaveOk?(pendingSaves.current>0?"saving":"ok"):"error");
      if(onUpdateSheetPlaces)onUpdateSheetPlaces({...sheetPlaces,...placeMap});
      // ★ placesテーブルにも保存（他端末・リロード時にも場所情報を復元可能にする）
      DB.upsertPlaces(placeMap);
