      });
      const plFixedM=(v)=>Math.round(Number(v.insurance_annual||0)+Number(v.lease_monthly||0)+(Number(v.car_tax||0)/12)+(Number(v.shaken_cost||0)/12)+(Number(v.tenken_cost||0)/6));
      const plYm2=selMode==="month"?selYm:null;
