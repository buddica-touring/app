                      React.createElement("td",{style:td2},bar(Math.round(r.pct),"#10b981"))
                    )),
                    React.createElement("tr",{style:{background:"#1e293b",color:"#fff"}},
                      React.createElement("td",{style:{...td2,fontWeight:900,color:"#fff"}},"合計"),
                      React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:900,color:"#fff"}},tot+"件"),
                      React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:900,color:"#fff"}},delCnt+"件"),
                      React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:900,color:"#fff"}},delPct+"%"),
                      React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:900,color:"#fff"}},"¥"+fmt(delRev)),
                      React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:900,color:"#fff"}},delRevPct+"%"),
                      React.createElement("td",{style:td2},"")
                    )
                  )
                ),
                // ③ 月別内訳（年別モード時のみ）
                selMode==="year"&&React.createElement("div",null,
                  React.createElement("div",{style:{fontSize:11,fontWeight:800,color:"#475569",marginBottom:6,marginTop:16,padding:"4px 8px",background:"#f1f5f9",borderRadius:6,display:"inline-block"}},"③ 月別内訳（"+selYr+"年）"),
                  tableWrap(React.createElement("table",{style:{width:"100%",borderCollapse:"collapse",marginTop:6}},
                    React.createElement("thead",null,React.createElement("tr",null,
                      React.createElement("th",{style:{...th2,position:"sticky",top:0,zIndex:1}},"月"),
                      React.createElement("th",{style:{...th2,textAlign:"right",position:"sticky",top:0,zIndex:1}},"合計"),
                      React.createElement("th",{style:{...th2,textAlign:"right",position:"sticky",top:0,zIndex:1,color:"#059669"}},"デリバリ"),
                      React.createElement("th",{style:{...th2,textAlign:"right",position:"sticky",top:0,zIndex:1,color:"#2563eb"}},"通常"),
                      React.createElement("th",{style:{...th2,textAlign:"right",position:"sticky",top:0,zIndex:1}},"利用率"),
                      React.createElement("th",{style:{...th2,minWidth:80,position:"sticky",top:0,zIndex:1}},"")
                    )),
                    React.createElement("tbody",null,(()=>{
                      const delByM={};
                      dbTasks.forEach(tk=>{
                        if(!tk.date||!tk.reservationId||(tk.type!=="DEL"&&tk.type!=="COL"))return;
                        const ym=tk.date.slice(0,7);
                        if(!delByM[ym])delByM[ym]=new Set();
                        delByM[ym].add(tk.reservationId);
                      });
                      const rows=[];
                      // ★ 2026-04-24: 年モードは1月〜12月 全12ヶ月常時表示（0件でもスキップしない）
                      // selYrMonths 内で RELIABLE_FROM 以前の月のみ除外（それ以外は必ず行を出す）
                      const yrAllMonths=Array.from({length:12},(_,i)=>selYr+"-"+String(i+1).padStart(2,"0"));
                      yrAllMonths.forEach((ym,idx)=>{
                        // RELIABLE_FROM 以前は「データ信頼外」として淡色表示
                        const isReliableMonth=ym>=RELIABLE_FROM;
                        const mRes=isReliableMonth?reliable.filter(r=>{const rd=r[rdKey];return rd&&rd.slice(0,7)===ym;}):[];
                        const mTot=mRes.length;
                        const delSet=delByM[ym]||new Set();
                        const delC=mRes.filter(r=>delSet.has(r.id)).length;
                        const pct=mTot>0?Math.round(delC/mTot*1000)/10:0;
                        const isNow=ym===nowYm;
                        const mLabel=parseInt(ym.slice(5,7),10)+"月";
                        rows.push(React.createElement("tr",{key:ym,style:{...zRow(idx,isNow),fontWeight:isNow?800:400,opacity:!isReliableMonth?0.35:1}},
                          React.createElement("td",{style:{...td2,fontWeight:800}},mLabel),
                          React.createElement("td",{style:{...td2,textAlign:"right"}},mTot===0?"—":mTot+"件"),
                          React.createElement("td",{style:{...td2,textAlign:"right",color:delC>0?"#059669":"#cbd5e1",fontWeight:700}},mTot===0?"—":delC+"件"),
                          React.createElement("td",{style:{...td2,textAlign:"right",color:mTot-delC>0?"#2563eb":"#cbd5e1"}},mTot===0?"—":(mTot-delC)+"件"),
                          React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:800,color:pct>=50?"#059669":pct>=20?"#d97706":"#94a3b8"}},mTot===0?"—":pct+"%"),
                          React.createElement("td",{style:td2},mTot===0?"":bar(Math.round(pct),"#10b981"))
                        ));
                      });
                      rows.push(React.createElement("tr",{key:"_t",style:{background:"#1e293b",color:"#fff",fontWeight:800}},
                        React.createElement("td",{style:{padding:"8px",fontSize:11,fontWeight:900,color:"#fff"}},"合計"),
                        React.createElement("td",{style:{padding:"8px",fontSize:11,textAlign:"right",fontWeight:900,color:"#fff"}},tot+"件"),
                        React.createElement("td",{style:{padding:"8px",fontSize:11,textAlign:"right",color:"#4ade80",fontWeight:700}},delCnt+"件"),
                        React.createElement("td",{style:{padding:"8px",fontSize:11,textAlign:"right",color:"#93c5fd"}},nmlCnt+"件"),
                        React.createElement("td",{style:{padding:"8px",fontSize:11,textAlign:"right",color:"#fff"}},delPct+"%"),
                        React.createElement("td",null)
                      ));
                      return rows;
                    })())
                  ),"40vh")
                ),
                React.createElement("div",{style:{fontSize:10,color:"#94a3b8",marginTop:8,lineHeight:1.5}},
                  "※ 判定基準: 予約メールから抽出された del_place / col_place にホテル等の実住所が入っているか。「高松空港」「店舗」「ヤード」「営業所」等は指定不可のためカウントしない。OTA予約は GAS が「オプション欄」のデリバリー（お届け／回収）表記を解読してプレースホルダ「★OTAデリバリー希望（場所未確定）」を埋めることで判定対象になる（v3.2.92以降のメール取込から有効）。"
                )
              );
            })()
          )),
          // DEL / COL ランキング (2-column)
          React.createElement("div",{style:{display:"flex",gap:12,flexWrap:"wrap",marginBottom:12}},
            // DEL
            React.createElement("div",{style:{flex:"1 1 320px",...card,padding:16}},
              React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#059669"}},"DEL場所 Top20（"+periodLabel+"）"),
              tableWrap(React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
                React.createElement("thead",null,React.createElement("tr",null,
                  React.createElement("th",{style:{...th2,width:28}},"#"),React.createElement("th",{style:th2},"場所"),React.createElement("th",{style:{...th2,textAlign:"right"}},"件数"),React.createElement("th",{style:{...th2,minWidth:100}},"")
                )),
                React.createElement("tbody",null,
                  delRank.map(([p,c],i)=>{const maxC=delRank[0]?delRank[0][1]:1;return React.createElement("tr",{key:p,style:zRow(i,false)},
                    React.createElement("td",{style:{...td2,fontWeight:700,color:"#64748b"}},i+1),React.createElement("td",{style:{...td2,fontWeight:i<3?700:400}},p),React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:600}},c),
                    React.createElement("td",{style:td2},bar(Math.round(c/maxC*100),"#10b981"))
                  );})
                )
              ),"50vh")
            ),
            // COL
            React.createElement("div",{style:{flex:"1 1 320px",...card,padding:16}},
              React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#dc2626"}},"COL場所 Top20（"+periodLabel+"）"),
              tableWrap(React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
                React.createElement("thead",null,React.createElement("tr",null,
                  React.createElement("th",{style:{...th2,width:28}},"#"),React.createElement("th",{style:th2},"場所"),React.createElement("th",{style:{...th2,textAlign:"right"}},"件数"),React.createElement("th",{style:{...th2,minWidth:100}},"")
                )),
                React.createElement("tbody",null,
                  colRank.map(([p,c],i)=>{const maxC=colRank[0]?colRank[0][1]:1;return React.createElement("tr",{key:p,style:zRow(i,false)},
                    React.createElement("td",{style:{...td2,fontWeight:700,color:"#64748b"}},i+1),React.createElement("td",{style:{...td2,fontWeight:i<3?700:400}},p),React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:600}},c),
                    React.createElement("td",{style:td2},bar(Math.round(c/maxC*100),"#f59e0b"))
                  );})
                )
              ),"50vh")
            )
          ),
          // 利用者エリア
          sectionCard(React.createElement("div",null,
            React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#1e3a5f"}},"利用者エリア Top20（都道府県・"+periodLabel+"）"),
            prefRank.length>0?tableWrap(React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
              React.createElement("thead",null,React.createElement("tr",null,
                React.createElement("th",{style:{...th2,width:28}},"#"),React.createElement("th",{style:th2},"都道府県"),React.createElement("th",{style:{...th2,textAlign:"right"}},"件数"),React.createElement("th",{style:{...th2,minWidth:120}},"")
              )),
              React.createElement("tbody",null,
                prefRank.map(([p,c],i)=>{const maxC=prefRank[0]?prefRank[0][1]:1;return React.createElement("tr",{key:p,style:zRow(i,false)},
                  React.createElement("td",{style:{...td2,fontWeight:700,color:"#64748b"}},i+1),React.createElement("td",{style:{...td2,fontWeight:i<3?700:400}},p),React.createElement("td",{style:{...td2,textAlign:"right",fontWeight:600}},c),
                  React.createElement("td",{style:td2},bar(Math.round(c/maxC*100),"#8b5cf6"))
                );})
              )
            ),"40vh"):React.createElement("div",{style:{fontSize:12,color:"#94a3b8",padding:8}},"prefectureデータなし")
          )),
          // タスク時間帯
          sectionCard(React.createElement("div",null,
            React.createElement("div",{style:{fontSize:13,fontWeight:900,marginBottom:10,color:"#1e3a5f"}},"DEL/COL 時間帯分布（"+periodLabel+"）"),
            React.createElement("div",{style:{display:"flex",gap:16,flexWrap:"wrap"}},
              ["DEL","COL"].map(type=>{
                const buckets=taskTimeBuckets[type];
                const sorted=Object.entries(buckets).sort((a,b)=>a[0].localeCompare(b[0]));
                const maxV=sorted.reduce((a,[,v])=>Math.max(a,v),1);
                return React.createElement("div",{key:type,style:{flex:"1 1 240px"}},
                  React.createElement("div",{style:{fontSize:12,fontWeight:800,marginBottom:6,color:type==="DEL"?"#059669":"#dc2626",padding:"4px 10px",background:type==="DEL"?"#f0fdf4":"#fef2f2",borderRadius:6,display:"inline-block"}},type),
                  sorted.length>0?React.createElement("table",{style:{width:"100%",borderCollapse:"collapse"}},
                    React.createElement("tbody",null,
                      sorted.map(([h,c],i)=>React.createElement("tr",{key:h,style:zRow(i,false)},
                        React.createElement("td",{style:{...td2,fontWeight:700,width:50}},h),
                        React.createElement("td",{style:{...td2,textAlign:"right",width:36,fontWeight:600}},c),
                        React.createElement("td",{style:td2},bar(Math.round(c/maxV*100),type==="DEL"?"#059669":"#dc2626"))
                      ))
                    )
                  ):React.createElement("div",{style:{fontSize:11,color:"#94a3b8",padding:8}},"データなし")
                );
              })
            )
          ))
        ),

        // ===== E. 車両別P&L =====
        secHeader("E","E. 車両別 P&L（売上 - 原価 - 支出 = 粗利）"),
        secOpen.E&&React.createElement("div",null,
          plEContent
        )

        ) // end padding div
        ); // end dbLoading2 ternary + return
    })()}

    {sub==="cfsim"&&(()=>{
      const isSpk=dbStore==="spk";
      const rdKey=isSpk?"return_date":"end_date";
      const chOrder=["オフィシャル","じゃらん","楽天","エアトリ","スカイチケット","レンタカードットコム","その他売上"];
      const cycles={};(mgSettings.channels||[]).forEach(c=>{cycles[c.name]=c.cycle||0;});
      // 実績売上からチャネル構成比を算出
      const active=dbResvs.filter(r=>r.status!=="cancelled"&&r.status!=="キャンセル"&&r.status!=="cancel");
      const ymRevByCh={};
      active.forEach(r=>{
        const rd=r[rdKey];if(!rd)return;
        const ym=rd.slice(0,7);
        const ch=DB_OTA_MAP[r.ota]||"その他売上";
        const bp=Number(r.base_price)||0,op=Number(r.option_price)||0,dc=Number(r.discount)||0;
        const rev=(bp>0||op>0)?(bp+op-dc):(Number(r.price)||0);
        if(!ymRevByCh[ym])ymRevByCh[ym]={total:0};
        ymRevByCh[ym][ch]=(ymRevByCh[ym][ch]||0)+rev;
        ymRevByCh[ym].total+=rev;
      });
      // 各月の入金を計算
      const cashByYm={};
      Object.entries(ymRevByCh).forEach(([ym,data])=>{
        chOrder.forEach(ch=>{
          const rev=data[ch]||0;if(rev===0)return;
          const cycle=cycles[ch]||0;
          const[sy,sm]=ym.split("-").map(Number);
          let ny=sy,nm=sm+cycle;while(nm>12){nm-=12;ny++;}
          const cashYm=ny+"-"+String(nm).padStart(2,"0");
          if(!cashByYm[cashYm])cashByYm[cashYm]={};
          cashByYm[cashYm][ch]=(cashByYm[cashYm][ch]||0)+rev;
        });
      });
      const allYmsAsc=[...new Set([...Object.keys(ymRevByCh),...Object.keys(cashByYm)])].sort();
      // Pre-compute cumCash for each month (ascending order)
      let _cum=mgSettings.initCash||0;
      const cumCashMap={};
      allYmsAsc.forEach(ym=>{const cashData=cashByYm[ym]||{};const cashTotal=Object.values(cashData).reduce((a,b)=>a+b,0);_cum+=cashTotal;cumCashMap[ym]=_cum;});
      const allYms=[...allYmsAsc].reverse();
      return <div>
        <div style={{display:"flex",gap:6,marginBottom:10}}>
          {["tkm","spk"].map(s=><button key={s} onClick={()=>setDbStore(s)} style={{padding:"4px 12px",fontSize:11,fontWeight:700,borderRadius:6,border:"none",cursor:"pointer",background:dbStore===s?"#9333ea":"#e2e8f0",color:dbStore===s?"#fff":"#334155"}}>{s==="tkm"?"高松":"札幌"}</button>)}
        </div>
        <div style={{fontSize:11,color:"#64748b",marginBottom:4}}>実績売上 × 入金サイクル → 月別入金シミュレーション（期初現金: ¥{fmt(mgSettings.initCash||0)}）</div>
        {dbLoading2?<div style={{padding:24,textAlign:"center",color:"#94a3b8"}}>読込中...</div>:
        <div style={{overflow:"auto",maxHeight:"70vh",border:"1px solid #e2e8f0",borderRadius:8}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
            <thead><tr>
              <th style={th}>月</th>
              <th style={{...th,textAlign:"right"}}>売上(計上)</th>
              {chOrder.map(ch=><th key={ch} style={{...th,textAlign:"right",fontSize:9}}>{ch.slice(0,3)}</th>)}
              <th style={{...th,textAlign:"right",background:"#dcfce7"}}>入金計</th>
              <th style={{...th,textAlign:"right",background:"#fef3c7"}}>累積CF</th>
            </tr></thead>
            <tbody>
              {allYms.map(ym=>{
                const revData=ymRevByCh[ym]||{};
                const cashData=cashByYm[ym]||{};
                const cashTotal=Object.values(cashData).reduce((a,b)=>a+b,0);
                const cumCashVal=cumCashMap[ym];
                return <tr key={ym}>
                  <td style={{...td,fontWeight:700}}>{ym}</td>
                  <td style={{...td,textAlign:"right"}}>¥{fmt(revData.total||0)}</td>
                  {chOrder.map(ch=>{
                    const v=cashData[ch]||0;
                    return <td key={ch} style={{...td,textAlign:"right",color:v>0?"#0f172a":"#cbd5e1",fontSize:9}}>{v>0?"¥"+fmt(v):"-"}</td>;
                  })}
                  <td style={{...td,textAlign:"right",fontWeight:800,background:"#f0fdf4",color:"#059669"}}>¥{fmt(Math.round(cashTotal))}</td>
                  <td style={{...td,textAlign:"right",fontWeight:800,background:cumCashVal<(mgSettings.minCash||0)?"#fecaca":"#fef9c3",color:cumCashVal>=0?"#92400e":"#dc2626"}}>¥{fmt(Math.round(cumCashVal))}</td>
                </tr>;
              })}
            </tbody>
          </table>
        </div>}
      </div>;
    })()}

    {/* ★ 2026-04-25 データ健全性チェック */}
    {sub==="healthcheck"&&(()=>{
      const isSpk=dbStore==="spk";
      const resvTbl=isSpk?"reservations":"bt_reservations";
      const fleetTbl=isSpk?"fleet":"bt_fleet";
      const today=new Date().toISOString().slice(0,10);
      // hooks は親（ManagementTab）の useState を使用（IIFE内のhook禁止のため）
      const checking=hcChecking,setChecking=setHcChecking;
      const results=hcResults,setResults=setHcResults;
      const lastRunAt=hcLastRunAt,setLastRunAt=setHcLastRunAt;

      const runCheck=async()=>{
        setChecking(true);
        const issues={unassigned:[],cancelledFleet:[],doubleBooking:[],ssMismatch:[]};
        try{
          // 全データ取得
          const allRes=await loadDbAll(resvTbl);
          const allFleet=await loadDbAll(fleetTbl);
          const fleetMap={};
          allFleet.forEach(f=>{
            const rid=isSpk?f.reservation_id:f.reservation_id;
            const vc=isSpk?f.vehicle_code:f.vehicle_code;
            if(!fleetMap[rid])fleetMap[rid]={vc,fleetRow:f};
          });

          // ① 未配車（end_date>=today, status=confirmed, fleet なし）
          const sd=isSpk?"start_date":"start_date",ed=isSpk?"end_date":"end_date";
          allRes.forEach(r=>{
            if(r.status==="cancelled"||r.status==="cancel"||r.status==="キャンセル")return;
            if(!r[ed]||r[ed]<today)return;
            if(!fleetMap[r.id])issues.unassigned.push({
              id:r.id,name:r.name,start:r[sd],end:r[ed],
              cls:r.vehicle_class,model:r.vehicle_name||"",ota:r.ota
            });
          });

          // ② キャンセル済みなのにfleet残存
          allRes.forEach(r=>{
            if(r.status!=="cancelled"&&r.status!=="cancel"&&r.status!=="キャンセル")return;
            if(fleetMap[r.id])issues.cancelledFleet.push({
              id:r.id,name:r.name,start:r[sd],end:r[ed],
              vc:fleetMap[r.id].vc
            });
          });

          // ③ 同一車両ダブルブッキング（同期間に複数予約）
          const byVc={};
          allFleet.forEach(f=>{
            const rid=f.reservation_id,vc=f.vehicle_code;
            const r=allRes.find(x=>x.id===rid);
            if(!r)return;
            if(r.status==="cancelled"||r.status==="cancel"||r.status==="キャンセル")return;
            if(!r[ed]||r[ed]<today)return;
            if(!byVc[vc])byVc[vc]=[];
            byVc[vc].push({id:rid,name:r.name,start:r[sd],end:r[ed]});
          });
          Object.entries(byVc).forEach(([vc,list])=>{
            if(list.length<2)return;
            // 期間オーバーラップを検出
            list.sort((a,b)=>(a.start||"").localeCompare(b.start||""));
            for(let i=0;i<list.length-1;i++){
              for(let j=i+1;j<list.length;j++){
                const a=list[i],b=list[j];
                if(a.end>=b.start&&b.end>=a.start){
                  issues.doubleBooking.push({vc,a,b});
                }
              }
            }
          });

          // ④ SS↔DB 整合性（予約番号でマッチして時間/種別の差分を検出 ※簡易版）
          // ※詳細マッチはパトロール機能に任せ、ここでは数値カウントのみ
          // 省略: 必要なら fetchTimeData/fetchPlaceData の結果を使うことも可能

          setResults(issues);
          setLastRunAt(new Date().toLocaleString("ja-JP"));
        }catch(e){
          alert("チェック中にエラー: "+e.message);
        }
        setChecking(false);
      };

      const totalIssues=results?(results.unassigned.length+results.cancelledFleet.length+results.doubleBooking.length+results.ssMismatch.length):0;
      const sectionTitle=(emoji,label,count,color)=>React.createElement("div",{style:{display:"flex",alignItems:"center",gap:8,padding:"8px 12px",background:count>0?color:"#f1f5f9",color:count>0?"#fff":"#64748b",borderRadius:6,marginBottom:8,fontWeight:800,fontSize:13}},emoji+" "+label,React.createElement("span",{style:{marginLeft:"auto",fontSize:14}},count+"件"));

      return <div>
        <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:16,padding:"12px 16px",background:"#fff",borderRadius:8,border:"1px solid #e2e8f0"}}>
          <div style={{flex:1}}>
            <div style={{fontSize:16,fontWeight:900,color:"#0f172a"}}>🩺 データ健全性チェック</div>
            <div style={{fontSize:11,color:"#64748b",marginTop:2}}>未配車・キャンセル残骸・ダブルブッキングを検出 {lastRunAt&&"｜ 最終実行: "+lastRunAt}</div>
          </div>
          <button onClick={runCheck} disabled={checking} style={{padding:"10px 20px",background:checking?"#94a3b8":"#1e40af",color:"#fff",border:"none",borderRadius:8,fontSize:13,fontWeight:800,cursor:checking?"wait":"pointer"}}>
            {checking?"⏳ チェック中...":"▶️ 実行"}
          </button>
        </div>

        {results&&<>
          <div style={{padding:"12px 16px",background:totalIssues===0?"#dcfce7":"#fef9c3",border:"2px solid "+(totalIssues===0?"#10b981":"#facc15"),borderRadius:8,marginBottom:16,fontWeight:900,color:totalIssues===0?"#065f46":"#854d0e",fontSize:14,textAlign:"center"}}>
            {totalIssues===0?"✅ 異常なし — 全データ整合":"⚠️ 検出 "+totalIssues+"件 — 以下を確認してください"}
          </div>

          {/* ① 未配車 */}
          {sectionTitle("🚗","未配車予約",results.unassigned.length,"#dc2626")}
          {results.unassigned.length>0&&<div style={{maxHeight:240,overflow:"auto",border:"1px solid #fecaca",borderRadius:6,marginBottom:16}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
              <thead><tr style={{background:"#fef2f2",position:"sticky",top:0}}>
                <th style={th}>予約ID</th><th style={th}>顧客</th><th style={th}>期間</th><th style={th}>クラス</th><th style={th}>指定車種</th><th style={th}>OTA</th>
              </tr></thead>
              <tbody>{results.unassigned.map((r,i)=>
                <tr key={r.id} style={{background:i%2?"#fafafa":"#fff"}}>
                  <td style={td}><code style={{fontSize:10}}>{r.id}</code></td>
                  <td style={td}>{r.name}</td>
                  <td style={td}>{r.start}〜{r.end}</td>
                  <td style={td}><span style={{background:"#dbeafe",color:"#1e40af",padding:"1px 6px",borderRadius:3,fontWeight:700,fontSize:10}}>{r.cls}</span></td>
                  <td style={td}>{r.model||"—"}</td>
                  <td style={td}>{r.ota}</td>
                </tr>
              )}</tbody>
            </table>
          </div>}

          {/* ② キャンセル済みfleet残存 */}
          {sectionTitle("🗑️","キャンセル済みなのにfleet残存",results.cancelledFleet.length,"#ea580c")}
          {results.cancelledFleet.length>0&&<div style={{maxHeight:240,overflow:"auto",border:"1px solid #fed7aa",borderRadius:6,marginBottom:16}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
              <thead><tr style={{background:"#fff7ed",position:"sticky",top:0}}>
                <th style={th}>予約ID</th><th style={th}>顧客</th><th style={th}>期間</th><th style={th}>残存車両</th>
              </tr></thead>
              <tbody>{results.cancelledFleet.map((r,i)=>
                <tr key={r.id} style={{background:i%2?"#fafafa":"#fff"}}>
                  <td style={td}><code style={{fontSize:10}}>{r.id}</code></td>
                  <td style={td}>{r.name}</td>
                  <td style={td}>{r.start}〜{r.end}</td>
                  <td style={td}><span style={{background:"#fef3c7",color:"#92400e",padding:"1px 6px",borderRadius:3,fontWeight:700,fontSize:10}}>{r.vc}</span></td>
                </tr>
              )}</tbody>
            </table>
          </div>}

          {/* ③ ダブルブッキング */}
          {sectionTitle("⚠️","同一車両ダブルブッキング",results.doubleBooking.length,"#dc2626")}
          {results.doubleBooking.length>0&&<div style={{maxHeight:240,overflow:"auto",border:"1px solid #fecaca",borderRadius:6,marginBottom:16}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
              <thead><tr style={{background:"#fef2f2",position:"sticky",top:0}}>
                <th style={th}>車両</th><th style={th}>予約A</th><th style={th}>期間A</th><th style={th}>予約B</th><th style={th}>期間B</th>
              </tr></thead>
              <tbody>{results.doubleBooking.map((d,i)=>
                <tr key={i} style={{background:i%2?"#fafafa":"#fff"}}>
                  <td style={td}><span style={{background:"#fee2e2",color:"#b91c1c",padding:"1px 6px",borderRadius:3,fontWeight:700,fontSize:10}}>{d.vc}</span></td>
                  <td style={td}><code style={{fontSize:9}}>{d.a.id}</code><br/>{d.a.name}</td>
                  <td style={td}>{d.a.start}〜{d.a.end}</td>
                  <td style={td}><code style={{fontSize:9}}>{d.b.id}</code><br/>{d.b.name}</td>
                  <td style={td}>{d.b.start}〜{d.b.end}</td>
                </tr>
              )}</tbody>
            </table>
          </div>}

          <div style={{marginTop:24,padding:12,background:"#eff6ff",borderRadius:8,fontSize:11,color:"#1e3a5f",border:"1px solid #bfdbfe"}}>
            <div style={{fontWeight:800,marginBottom:6}}>💡 対応方法</div>
            <div>• <b>未配車</b>: 配車表で手動配車、または GAS の自動配車条件を確認</div>
            <div>• <b>キャンセル残骸</b>: 配車表でキャンセル予約を選んで車両を解除</div>
            <div>• <b>ダブルブッキング</b>: いずれかの予約を別車両に振替（業務影響大・最優先）</div>
          </div>
        </>}
      </div>;
    })()}

  </div>;
}

/* ==========================================
   PASガード（パスコード認証）
   ========================================== */
// ── 月次出納帳（独立タブ・暗証番号1215）──────────────────────
const ML_ACCT_NAMES={repay_1:"返済①",repay_2:"返済②",repay_3:"返済③",repay_4:"返済④",repay_5:"返済⑤",sga_social_ins:"社会保険",sga_salary:"給与合計",sga_ota_fee:"OTA手数料",sga_telecom:"通信費",sga_fuel:"燃料費",sga_travel:"出張費",sga_office:"消耗品",sga_ad:"広告費",sga_transport:"移動費",sga_utility:"光熱費",sga_tax:"税金",sga_repair:"車両修理",sga_construction:"工事費",sga_other:"その他販管費",cogs_lease:"リース/ローン",cogs_insurance:"保険",cogs_inspection:"車検費",cogs_maintenance:"点検/整備",cogs_repair:"修理費",cogs_rent:"賃料",cogs_other:"その他原価"};
const ML_TYPE_LABEL={cash_in:"現金入金",cash_out:"現金出金",extra_sales:"予約外売上",advance:"立替金",card_pay:"カード支払",personal_adv:"個人立替"};
const ML_TYPE_COLOR={現金入金:"#059669",現金出金:"#dc2626",予約外売上:"#7c3aed",立替金:"#d97706","カード支払":"#2563eb",個人立替:"#64748b",整備費用:"#b45309",経営コスト:"#475569"};
function isMLIncome(type){return type==="cash_in"||type==="extra_sales";}

function MonthlyLedger({isSpk,resvData}){
  useEffect(function(){
    // ダッシュボードと同じdataを月別に集計してlocalStorageにキャッシュ
    var now=new Date();var yr=now.getFullYear();
    var MS2=['01','02','03','04','05','06','07','08','09','10','11','12'];
    var cache={};
    MS2.forEach(function(m){
      var ym=yr+'-'+m;
      var rsvs=(resvData||[]).filter(function(r){
        if(r.status==='cancelled'||r.status==='キャンセル'||r.status==='cancel')return false;
        return (r.returnDate||r.lendDate||'').startsWith(ym);
      });
      var base=0,opt=0,disc=0;
      rsvs.forEach(function(r){
        var bp=r.basePrice||r.base_price||0,op=r.optionPrice||r.option_price||0,dc=r.discount||0;
        if(bp>0||op>0){base+=bp;opt+=op;disc+=dc;}else base+=r.price||0;
      });
      cache[ym]={base:base,opt:opt,disc:disc};
    });
    try{localStorage.setItem('monthly_resv_bt',JSON.stringify({ts:Date.now(),year:yr,data:cache}));}catch(e){}
    window.location.href='monthly.html?store=tkm&v='+Date.now();
  },[resvData]);
  return null;
  var PIN="1215"; var _bypassed=true; // PAS解除済
  var[pin,setPin]=useState("");
  var[unlocked,setUnlocked]=useState(true); // PAS解除済
  var[pinErr,setPinErr]=useState("");
  var[ym,setYm]=useState(function(){var d=new Date();return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");});
  var[summary,setSummary]=useState(null);
  var[loading,setLoading]=useState(false);

  var unlock=function(){setUnlocked(true);setPinErr("");}; // PAS解除済
  var fmt=function(n){return(n||0).toLocaleString();};
  var fmtYm=function(s){var p=s.split("-");return p[0]+"年"+parseInt(p[1])+"月";};

  useEffect(function(){
    if(!sb||!unlocked||!ym)return;
    setLoading(true);
    var acctTbl=isSpk?"spk_accounting":"bt_accounting";
    var maintTbl=isSpk?"maintenance":"bt_maintenance";
    var stbl=isSpk?"app_settings":"bt_app_settings";
    var resvTbl=isSpk?"reservations":"bt_reservations";
    var dateCol=isSpk?"lend_date":"start_date";
    var costKey=(isSpk?"cost_spk_":"cost_bt_")+ym;
    var ymEnd=ym+"-31";
    // 収入: dashKpiと同じデータ・同じ計算（resvData=App.data）
    var ymResvs=(resvData||[]).filter(function(r){
      if(r.status==="cancelled"||r.status==="キャンセル"||r.status==="cancel")return false;
      var d=r.lendDate||r.start_date||"";
      return d.startsWith(ym);
    });
    var baseRev=0,optRev=0,discRev=0;
    ymResvs.forEach(function(r){
      var bp=r.basePrice||r.base_price||0,op=r.optionPrice||r.option_price||0,dc=r.discount||0;
      if(bp>0||op>0){baseRev+=bp;optRev+=op;discRev+=dc;}
      else baseRev+=r.price||0;
    });
    Promise.all([
      sb.from(acctTbl).select("type,category,amount,pay_method,paid").gte("date",ym+"-01").lte("date",ymEnd),
      sb.from(maintTbl).select("label,actual_cost").not("actual_cost","is",null).gt("actual_cost",0).gte("start_date",ym+"-01").lte("start_date",ymEnd),
      sb.from(stbl).select("key,value").eq("key",costKey),
    ]).then(function(res){
      var acct=res[0].data||[];
      var maint=res[1].data||[];
      var settings=(res[2].data||[])[0];
      var extraRev=0,cashIn=0;
      // 予約外・現金入金
      acct.forEach(function(r){
        if(r.type==="extra_sales")extraRev+=r.amount||0;
        if(r.type==="cash_in")cashIn+=r.amount||0;
      });

      // 支出: 会計科目別集計
      var expByType={};
      function addExp(group,cat,amt){
        if(!expByType[group])expByType[group]={};
        expByType[group][cat]=(expByType[group][cat]||0)+amt;
      }
      acct.forEach(function(r){
        var t=r.type,a=r.amount||0;
        if(t==="cash_out")addExp("現金出金",r.category||"その他",a);
        else if(t==="card_pay")addExp("カード支払",r.category||"その他",a);
        else if(t==="advance")addExp("立替金",r.category||"その他",a);
        else if(t==="personal_adv")addExp("個人立替",r.category||"その他",a);
      });
      maint.forEach(function(r){
        addExp("整備費用",r.label||"整備",r.actual_cost||0);
      });
      if(settings&&settings.value){
        try{JSON.parse(settings.value).forEach(function(e){
          if(!e.amount)return;
          var c=e.account_code||"";
          var g=c.startsWith("repay_")?"返済":c.startsWith("sga_")?"販管費":c.startsWith("cogs_")?"売上原価":"コスト";
          addExp(g,ML_ACCT_NAMES[c]||c,e.amount||0);
        });}catch(ex){}
      }
      setSummary({baseRev,optRev,discRev,extraRev,cashIn,expByType});
      setLoading(false);
    }).catch(function(){setLoading(false);});
  },[ym,unlocked,isSpk,resvData]);

  if(!unlocked)return(
    <div style={{maxWidth:400,margin:"40px auto",textAlign:"center"}}>
      <div style={{background:"#fff",borderRadius:16,padding:32,border:"1px solid #e2e8f0",boxShadow:"0 2px 8px rgba(0,0,0,.06)"}}>
        <div style={{fontSize:32,marginBottom:12}}>🔒</div>
        <div style={{fontSize:16,fontWeight:800,color:"#1e293b",marginBottom:4}}>月次収支サマリー</div>
        <div style={{fontSize:12,color:"#64748b",marginBottom:20}}>パスコードを入力してください</div>
        <input type="password" inputMode="numeric" maxLength={4} value={pin} onChange={function(e){setPin(e.target.value.replace(/\D/g,""));}} onKeyDown={function(e){if(e.key==="Enter")unlock();}} placeholder="4桁" style={{width:"100%",padding:"12px",border:"1.5px solid #d1d5db",borderRadius:10,fontSize:20,textAlign:"center",letterSpacing:8,boxSizing:"border-box",marginBottom:8}}/>
        {pinErr&&<div style={{color:"#dc2626",fontSize:12,fontWeight:600,marginBottom:8}}>{pinErr}</div>}
        <button onClick={unlock} disabled={pin.length<4} style={{width:"100%",padding:"12px",background:pin.length>=4?"linear-gradient(135deg,#1e40af,#2563eb)":"#94a3b8",color:"#fff",border:"none",borderRadius:10,fontSize:14,fontWeight:700,cursor:pin.length>=4?"pointer":"not-allowed"}}>認証</button>
      </div>
    </div>
  );

  if(loading||!summary)return <div style={{textAlign:"center",padding:60,color:"#94a3b8"}}>読み込み中...</div>;

  var{baseRev,optRev,discRev,extraRev,cashIn,expByType}=summary;
  var totalIn=baseRev+optRev-discRev+extraRev+cashIn;
  var totalEx=Object.values(expByType).reduce(function(s,g){return s+Object.values(g).reduce(function(a,v){return a+v;},0);},0);
  var balance=totalIn-totalEx;

  var secStyle={background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",marginBottom:12,overflow:"hidden"};
  var hStyle={padding:"10px 14px",fontWeight:800,fontSize:13,borderBottom:"1px solid #e2e8f0"};
  var rowStyle=function(alt){return{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"7px 14px",background:alt?"#fafafa":"#fff",borderBottom:"1px solid #f1f5f9"};};
  var amtStyle=function(c){return{fontSize:13,fontWeight:700,color:c,fontVariantNumeric:"tabular-nums"};};

  return(
    <div style={{maxWidth:640,margin:"0 auto",padding:"0 0 40px"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14,flexWrap:"wrap",gap:8}}>
        <div style={{fontSize:15,fontWeight:900,color:"#1e293b"}}>📅 月次収支 — {fmtYm(ym)}</div>
        <input type="month" value={ym} onChange={function(e){setYm(e.target.value);setSummary(null);}} style={{padding:"6px 10px",borderRadius:8,border:"1.5px solid #d1d5db",fontSize:13,fontWeight:700}}/>
      </div>

      {/* 収入 */}
      <div style={secStyle}>
        <div style={{...hStyle,background:"#f0fdf4",color:"#15803d"}}>💰 収入</div>
        {[
          {l:"基本料金",v:baseRev},
          {l:"付帯売上",v:optRev},
          {l:"割引",v:-discRev,c:"#dc2626"},
          {l:"予約外売上",v:extraRev},
          {l:"現金入金",v:cashIn},
        ].filter(function(x){return x.v!==0;}).map(function(x,i){return(
          <div key={x.l} style={rowStyle(i%2===1)}>
            <span style={{fontSize:12,color:"#374151"}}>{x.l}</span>
            <span style={amtStyle(x.c||"#059669")}>{x.v<0?"-":""}¥{fmt(Math.abs(x.v))}</span>
          </div>
        );})}
        <div style={{display:"flex",justifyContent:"space-between",padding:"9px 14px",background:"#dcfce7",borderTop:"2px solid #86efac"}}>
          <span style={{fontSize:13,fontWeight:800,color:"#15803d"}}>収入合計</span>
          <span style={{fontSize:14,fontWeight:900,color:"#15803d"}}>¥{fmt(totalIn)}</span>
        </div>
      </div>

      {/* 支出 */}
      {Object.keys(expByType).map(function(group){
        var cats=expByType[group];
        var groupTotal=Object.values(cats).reduce(function(s,v){return s+v;},0);
        return(
          <div key={group} style={secStyle}>
            <div style={{...hStyle,background:"#fef2f2",color:"#b91c1c"}}>💸 {group}</div>
            {Object.entries(cats).sort(function(a,b){return b[1]-a[1];}).map(function(entry,i){return(
              <div key={entry[0]} style={rowStyle(i%2===1)}>
                <span style={{fontSize:12,color:"#374151"}}>{entry[0]}</span>
                <span style={amtStyle("#dc2626")}>¥{fmt(entry[1])}</span>
              </div>
            );})}
            <div style={{display:"flex",justifyContent:"space-between",padding:"7px 14px",background:"#fee2e2",borderTop:"1px solid #fca5a5"}}>
              <span style={{fontSize:12,fontWeight:700,color:"#b91c1c"}}>小計</span>
              <span style={{fontSize:13,fontWeight:800,color:"#b91c1c"}}>¥{fmt(groupTotal)}</span>
            </div>
          </div>
        );
      })}

      {/* 差引 */}
      <div style={{background:balance>=0?"#1e3a5f":"#450a0a",borderRadius:12,padding:"16px 18px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div>
          <div style={{fontSize:11,color:balance>=0?"#93c5fd":"#fca5a5",fontWeight:600,marginBottom:2}}>支出合計 ¥{fmt(totalEx)}</div>
          <div style={{fontSize:13,fontWeight:800,color:"#fff"}}>差引残高</div>
        </div>
        <div style={{fontSize:24,fontWeight:900,color:balance>=0?"#86efac":"#fca5a5"}}>{balance>=0?"＋":"－"}¥{fmt(Math.abs(balance))}</div>
      </div>
    </div>
  );
}

function PASGuard({children,label,code}){
  if(!code)return children; /* code未指定はロックなし（従来通り） */
  var[unlocked,setUnlocked]=useState(false);
  var[pin,setPin]=useState("");
  var[err,setErr]=useState("");
  if(unlocked)return children;
  var submit=function(){if(pin===String(code)){setUnlocked(true);setErr("");}else{setErr("パスコードが違います");setPin("");}};
  return <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:"60px 20px",minHeight:"50vh"}}>
    <div style={{background:"#fff",border:"1px solid #e6ebf0",borderRadius:16,padding:"32px 28px",width:300,maxWidth:"90vw",boxShadow:"0 8px 30px rgba(0,0,0,.12)",textAlign:"center"}}>
      <div style={{fontSize:34,marginBottom:8}}>🔒</div>
      <div style={{fontSize:16,fontWeight:800,color:"#0e2a47",marginBottom:4}}>{label||"ロック中"}</div>
      <div style={{fontSize:12,color:"#64748b",marginBottom:18}}>パスコードを入力してください</div>
      <input type="password" inputMode="numeric" autoComplete="off" value={pin} onChange={function(e){setPin(e.target.value);}} onKeyDown={function(e){if(e.key==="Enter")submit();}} placeholder="••••" style={{width:"100%",fontSize:20,textAlign:"center",letterSpacing:6,padding:12,border:"2px solid #e6ebf0",borderRadius:10,boxSizing:"border-box"}}/>
      <div style={{color:"#e8505b",fontSize:12,height:16,marginTop:8}}>{err}</div>
      <button onClick={submit} style={{marginTop:10,width:"100%",background:"#1ec8b0",color:"#063",border:"none",borderRadius:10,padding:12,fontSize:15,fontWeight:800,cursor:"pointer"}}>解錠</button>
    </div>
  </div>;
}

/* ==========================================
   Square端末 自動取込失敗 手動起票ウィジェット
   ========================================== */
/* ==========================================
   TOP アイコングリッド（iPhone風）
   モバイル/PC共通で4列アイコン → タップで詳細展開
   ========================================== */
function SummarySection({data,vehicles,fleet,maintenance}){
  const[open,setOpen]=useState(false);
  return <>
    <div onClick={()=>setOpen(o=>!o)} style={{display:"flex",alignItems:"center",gap:10,padding:"10px 14px",background:"#fefce8",border:"1px solid #fde68a",borderRadius:open?"12px 12px 0 0":"12px",cursor:"pointer",userSelect:"none",marginBottom:0,boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
      <span style={{fontSize:20}}>📊</span>
      <span style={{fontSize:14,fontWeight:800,color:"#1e293b",flex:1}}>Summary</span>
      <span style={{fontSize:11,color:"#94a3b8"}}>{open?"閉じる":"タップで詳細"}</span>
      <span style={{fontSize:14,color:"#94a3b8"}}>{open?"▲":"▼"}</span>
    </div>
    {open&&<div style={{border:"1px solid #fde68a",borderTop:"none",borderRadius:"0 0 12px 12px",marginBottom:12,overflow:"hidden"}}>
      <LeadTimeWidget data={data} vehicles={vehicles} fleet={fleet} maintenance={maintenance}/>
    </div>}
    {!open&&<div style={{marginBottom:12}}/>}
  </>;
}

/* ==========================================
   🚗 空車ウィジェット（TOP・今日 空いている車両数 / クラス別）
   仕様: 「今日 物理的にヤードにある (予約に塞がれていない) 稼働車両」
         ・vehicles[active=true] が母数
         ・予約期間 [lendDate, returnDate] が今日を含めば占有 (中日含む)
         ・maintenance が今日にかかれば占有として除外
         ・bt_tasks (date=today, 内容=洗車) の assigned_vehicle は除外（翌日lend準備中）
         ・補完: 翌日lend の配車済み車両も「洗車予定」として除外（DB未保存ケース）
         ・空車 = 稼働 − 占有 − メンテ − 洗車
   ========================================== */
function VacancyWidget({data,vehicles,fleet,maintenance}){
  const[open,setOpen]=useState(false);
  const[kpiCur,setKpiCur]=useState({}); // ★ 当月 vehicle_monthly_kpi 除外フラグ
  const[washDb,setWashDb]=useState(new Set()); // ★ 当日 bt_tasks の洗車対象車両
  const today=new Date();today.setHours(0,0,0,0);
  const ymd=(d)=>{const y=d.getFullYear(),m=String(d.getMonth()+1).padStart(2,"0"),da=String(d.getDate()).padStart(2,"0");return y+"-"+m+"-"+da;};
  const todayStr=ymd(today);
  const todayYM=todayStr.slice(0,7);
  const tomorrow=new Date(today);tomorrow.setDate(tomorrow.getDate()+1);
  const tomorrowStr=ymd(tomorrow);

  // ★ 当月の除外フラグを取得（配車表で active=false にされた車両を空車から除外）
  useEffect(()=>{
    if(!sb)return;
    sb.from("bt_vehicle_monthly_kpi").select("vehicle_code,active").eq("year_month",todayYM)
      .then(({data:rows})=>{const map={};(rows||[]).forEach(r=>{map[r.vehicle_code]=r.active;});setKpiCur(map);});
  },[todayYM]);

  // ★ 当日 bt_tasks の洗車タスク取得（手動洗車・materialize済み洗車をカバー）
  useEffect(()=>{
    if(!sb)return;
    sb.from("bt_tasks").select("assigned_vehicle,内容").eq("date",todayStr).eq("内容","洗車")
      .then(({data:rows})=>{
        const s=new Set();
        (rows||[]).forEach(r=>{if(r.assigned_vehicle)s.add(r.assigned_vehicle);});
        setWashDb(s);
      });
  },[todayStr]);

  const calc=useMemo(()=>{
    // ★ vehicles.active AND bt_vehicle_monthly_kpi.active 両方チェック
    const activeVeh=(vehicles||[]).filter(v=>v.active!==false&&kpiCur[v.code]!==false);
    // 占有 = 今日が予約期間 [lend, return] に含まれる車両（出発日/中日/返却日 全て）
    const occupied=new Set();
    let lendCnt=0,retCnt=0;
    // 洗車補完 = 翌日lend の配車済み車両（DBに洗車タスク未materializeでも除外）
    const washExpected=new Set();
    (data||[]).forEach(r=>{
      if(!r||r.status==="cancelled")return;
      const lend=r.lendDate||r.start_date;
      const ret=r.returnDate||r.end_date;
      if(!lend||!ret)return;
      if(lend<=todayStr&&todayStr<=ret){
        const code=fleet&&fleet[r.id];
        if(code){
          occupied.add(code);
          if(lend===todayStr)lendCnt++;
          if(ret===todayStr)retCnt++;
        }
      }
      // 翌日lend = 今日洗車対象
      if(lend===tomorrowStr){
        const code=fleet&&fleet[r.id];
        if(code)washExpected.add(code);
      }
    });
    // メンテ = 今日にかかる
    const mntCodes=new Set();
    (maintenance||[]).forEach(m=>{
      const sd=m.startDate||m.start_date,ed=m.endDate||m.end_date;
      const vc=m.vehicleCode||m.vehicle_code;
      if(!sd||!ed||!vc)return;
      if(sd<=todayStr&&todayStr<=ed)mntCodes.add(vc);
    });
    // 洗車 = DB(手動 + materialize済み) ∪ 翌日lend補完
    const washCodes=new Set([...washDb,...washExpected]);
    const byClass={};
    activeVeh.forEach(v=>{
      const c=v.type||"?";
      if(!byClass[c])byClass[c]={total:0,occ:0,mnt:0,wash:0,vacantCodes:[]};
      byClass[c].total++;
      if(occupied.has(v.code))byClass[c].occ++;
      else if(mntCodes.has(v.code))byClass[c].mnt++;
      else if(washCodes.has(v.code))byClass[c].wash++;
      else byClass[c].vacantCodes.push(v.code);
    });
    const order=["AA","A","B","C","S","H","F"];
    const allClasses=[...new Set([...order,...Object.keys(byClass)])].filter(c=>byClass[c]);
    const rows=allClasses.map(c=>{
      const b=byClass[c];
      const avail=b.total-b.occ-b.mnt-b.wash;
      return {cls:c,total:b.total,occ:b.occ,mnt:b.mnt,wash:b.wash,avail,vacantCodes:b.vacantCodes};
    });
    const sum=rows.reduce((a,r)=>({total:a.total+r.total,occ:a.occ+r.occ,mnt:a.mnt+r.mnt,wash:a.wash+r.wash,avail:a.avail+r.avail}),{total:0,occ:0,mnt:0,wash:0,avail:0});
    return {rows,sum,lendCnt,retCnt};
  },[data,vehicles,fleet,maintenance,todayStr,tomorrowStr,kpiCur,washDb]);

  const Cell=({r})=>{
    const danger=r.avail<=0;const warn=r.avail<=1&&!danger;
    const bg=danger?"#fef2f2":warn?"#fffbeb":"#f0fdf4";
    const bd=danger?"#fecaca":warn?"#fde68a":"#bbf7d0";
    const fg=danger?"#dc2626":warn?"#d97706":"#16a34a";
    const tip=r.vacantCodes.length?("空車: "+r.vacantCodes.join(", ")):"空車なし";
    return <div title={tip} style={{background:bg,border:"1px solid "+bd,borderRadius:8,padding:"10px 4px",textAlign:"center",minWidth:0}}>
      <div style={{fontSize:12,color:"#64748b",fontWeight:800,letterSpacing:".5px"}}>{r.cls}</div>
      <div style={{fontSize:26,fontWeight:900,color:fg,lineHeight:1.1}}>{r.avail}{danger?"⚠️":""}</div>
      <div style={{fontSize:9,color:"#94a3b8",marginTop:2,lineHeight:1.3}}>稼働{r.occ}/整備{r.mnt}<br/>洗車{r.wash}/保有{r.total}</div>
    </div>;
  };

  return <div style={{marginBottom:12}}>
    <div onClick={()=>setOpen(o=>!o)} style={{display:"flex",alignItems:"center",gap:10,padding:"10px 14px",background:"#ecfdf5",border:"1px solid #bbf7d0",borderRadius:open?"12px 12px 0 0":"12px",cursor:"pointer",userSelect:"none",boxShadow:"0 1px 3px rgba(0,0,0,.06)"}}>
      <span style={{fontSize:20}}>🚗</span>
      <span style={{fontSize:14,fontWeight:800,color:"#1e293b",flex:1}}>今日 空いている車両数（{todayStr.slice(5)}）</span>
      <span style={{fontSize:11,color:"#64748b",fontWeight:700}}>計 <b style={{color:"#10b981",fontSize:18}}>{calc.sum.avail}</b> 台 / 保有{calc.sum.total}</span>
      <span style={{fontSize:14,color:"#94a3b8"}}>{open?"▲":"▼"}</span>
    </div>
    {open&&<div style={{padding:10,border:"1px solid #bbf7d0",borderTop:"none",borderRadius:"0 0 12px 12px",background:"#f7fefb"}}>
      <div style={{fontSize:10,color:"#64748b",marginBottom:8,fontWeight:600}}>
        ※ 今日予約期間外 かつ 整備外 かつ 当日洗車タスクなし（配車表ベース。中日も稼働中扱い／翌日lend配車済も洗車として除外）
        <span style={{color:"#0f766e",fontWeight:700}}> 本日 貸出{calc.lendCnt}件 / 返却{calc.retCnt}件 / 整備{calc.sum.mnt}台 / 洗車{calc.sum.wash}台</span>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(72px,1fr))",gap:6}}>
        {calc.rows.map(r=><Cell key={r.cls} r={r}/>)}
      </div>
    </div>}
  </div>;
}

// ── チームカレンダー ──
function TeamCalendar({data,maintenance,isSpk}){
  const store=isSpk?'spk':'tkm';
  const toYMD=d=>{const dt=typeof d==='string'?new Date(d+'T00:00:00'):d;return dt.getFullYear()+'-'+String(dt.getMonth()+1).padStart(2,'0')+'-'+String(dt.getDate()).padStart(2,'0');};
  const todayStr=toYMD(new Date());
  const CAT=[
    {key:'deadline',label:'締切',icon:'🔴',color:'#ef4444'},
    {key:'task',label:'タスク',icon:'🟡',color:'#f59e0b'},
    {key:'hq',label:'本社依頼',icon:'🔵',color:'#3b82f6'},
    {key:'store',label:'店舗予定',icon:'🟢',color:'#10b981'},
    {key:'overtime',label:'残業',icon:'🟠',color:'#f97316'},
    {key:'holiday_work',label:'休日出勤',icon:'🟣',color:'#7c3aed'},
    {key:'other',label:'その他',icon:'⚪',color:'#8b5cf6'},
  ];
  const getCat=k=>CAT.find(c=>c.key===k)||CAT.find(c=>c.key==='other')||CAT[0];
  const DOW=['月','火','水','木','金','土','日'];
  const today=new Date(todayStr+'T00:00:00');

  const[calOpen,setCalOpen]=useState(false);
  const[view,setView]=useState('day');
  const[curDate,setCurDate]=useState(new Date(today));
  const[events,setEvents]=useState([]);
  const[staffList,setStaffList]=useState([]);
  const[modal,setModal]=useState(null);
  const[form,setForm]=useState({});
  const[saving,setSaving]=useState(false);
  const[loading,setLoading]=useState(false);

  // スタッフ読み込み
  useEffect(()=>{
    if(!sb)return;
    const tbl=isSpk?'staff':'bt_staff';
    sb.from(tbl).select('name,type').eq('active',true).order('sort_order',{ascending:true})
      .then(({data:rows})=>setStaffList(rows||[]));
  },[isSpk]);

  // 表示範囲の計算
  const{rangeStart,rangeEnd}=useMemo(()=>{
    const y=curDate.getFullYear(),mo=curDate.getMonth();
    if(view==='month'){
      const first=new Date(y,mo,1);
      let dow=first.getDay();if(dow===0)dow=7;
      const s=new Date(y,mo,2-dow);
      const last=new Date(y,mo+1,0);
      let ldow=last.getDay();if(ldow===0)ldow=7;
      const e=new Date(y,mo+1,7-ldow);
      return{rangeStart:toYMD(s),rangeEnd:toYMD(e)};
    }else if(view==='week'){
      const d=new Date(curDate);let dow=d.getDay();if(dow===0)dow=7;
      d.setDate(d.getDate()-(dow-1));
      const e=new Date(d);e.setDate(d.getDate()+6);
      return{rangeStart:toYMD(d),rangeEnd:toYMD(e)};
    }else{
      const s=toYMD(curDate);return{rangeStart:s,rangeEnd:s};
    }
  },[curDate,view]);

  // イベント読み込み（広めに取得してeventsByDateで絞り込み）
  const loadEvents=useCallback(async()=>{
    if(!sb)return;
    setLoading(true);
    try{
      const y=curDate.getFullYear(),mo=curDate.getMonth();
      const fs=toYMD(new Date(y,mo-2,1));
      const fe=toYMD(new Date(y,mo+3,0));
      const{data:rows}=await sb.from('store_events').select('*')
        .eq('store',store).gte('event_date',fs).lte('event_date',fe)
        .order('event_date',{ascending:true}).order('created_at',{ascending:true});
      setEvents(rows||[]);
    }catch(e){console.error('[TeamCal]',e);}
    setLoading(false);
  },[curDate,store]);

  useEffect(()=>{loadEvents();},[loadEvents]);

  // イベントを日付マップに展開（複数日対応）
  const eventsByDate=useMemo(()=>{
    const map={};
    events.forEach(ev=>{
      const s=ev.event_date,e=ev.end_date||ev.event_date;
      let d=new Date(s+'T00:00:00');
      const ed=new Date(e+'T00:00:00');
      while(d<=ed){
        const k=toYMD(d);
        if(k>=rangeStart&&k<=rangeEnd){if(!map[k])map[k]=[];map[k].push(ev);}
        d.setDate(d.getDate()+1);
      }
    });
    return map;
  },[events,rangeStart,rangeEnd]);

  // 月グリッド生成
  const monthGrid=useMemo(()=>{
    const y=curDate.getFullYear(),mo=curDate.getMonth();
    const first=new Date(y,mo,1);
    let dow=first.getDay();if(dow===0)dow=7;
    const days=[];
    let d=new Date(y,mo,2-dow);
    while(true){
      days.push(new Date(d));d.setDate(d.getDate()+1);
      if(days.length>=35&&(d.getMonth()>mo||(mo===11&&d.getMonth()===0))){
        let ldow=days[days.length-1].getDay();if(ldow===0)ldow=7;
        if(ldow===7)break;
      }
    }
    while(days.length%7!==0){days.push(new Date(d));d.setDate(d.getDate()+1);}
    const weeks=[];for(let i=0;i<days.length;i+=7)weeks.push(days.slice(i,i+7));
    return weeks;
  },[curDate]);

  // 週の日配列
  const weekDays=useMemo(()=>{
    const d=new Date(view==='day'?curDate:curDate);
    let dow=d.getDay();if(dow===0)dow=7;d.setDate(d.getDate()-(dow-1));
    return Array.from({length:7},(_,i)=>{const dd=new Date(d);dd.setDate(d.getDate()+i);return dd;});
  },[curDate,view]);

  const nav=dir=>setCurDate(d=>{const nd=new Date(d);
    if(view==='month')nd.setMonth(nd.getMonth()+dir);
    else if(view==='week')nd.setDate(nd.getDate()+dir*7);
    else nd.setDate(nd.getDate()+dir);
    return nd;
  });
  const goToday=()=>{setView('day');setCurDate(new Date(today));};
  const headerLabel=()=>{
    const y=curDate.getFullYear(),m=curDate.getMonth()+1;
    if(view==='month')return`${y}年 ${m}月`;
    if(view==='week'){const ds=weekDays;return`${ds[0].getMonth()+1}/${ds[0].getDate()} 〜 ${ds[6].getMonth()+1}/${ds[6].getDate()}`;}
    return`${y}年${m}月${curDate.getDate()}日`;
  };

  const openDay=ds=>{setCurDate(new Date(ds+'T00:00:00'));setView('day');};
  const openNew=ds=>{setForm({event_date:ds,end_date:ds,category:'task',assignees:[],is_all_day:true});setModal({mode:'form'});};
  const openEdit=ev=>{setForm({...ev,assignees:ev.assignees||[]});setModal({mode:'form'});};

  const saveEvent=async()=>{
    if(!sb||!form.title?.trim()||!form.event_date)return alert('タイトルと開始日は必須です');
    // ★ 残業/休日出勤は「理由」必須入力
    if((form.category==='overtime'||form.category==='holiday_work')&&!form.description?.trim()){
      return alert('「理由」の入力が必須です\n\n'+(form.category==='overtime'?'残業':'休日出勤')+'を登録するには、理由欄を必ず入力してください。');
    }
    setSaving(true);
    try{
      const row={store,title:form.title.trim(),description:form.description||'',category:form.category||'task',
        color:getCat(form.category||'task').color,event_date:form.event_date,end_date:form.end_date||form.event_date,
        is_all_day:form.is_all_day!==false,start_time:form.is_all_day!==false?null:(form.start_time||null),
        end_time:form.is_all_day!==false?null:(form.end_time||null),
        assignees:form.assignees||[],created_by:form.created_by||'',is_done:!!form.is_done};
      if(form.id){await sb.from('store_events').update({...row,updated_at:new Date().toISOString()}).eq('id',form.id);}
      else{await sb.from('store_events').insert(row);}
      await loadEvents();setModal(null);setForm({});
    }catch(e){alert('保存失敗: '+e.message);}
    setSaving(false);
  };
  const deleteEvent=async()=>{
    if(!sb||!form.id||!window.confirm('このイベントを削除しますか？'))return;
    await sb.from('store_events').delete().eq('id',form.id);
    await loadEvents();setModal(null);setForm({});
  };
  const toggleDone=async ev=>{
    if(!sb)return;
    const nd=!ev.is_done;
    await sb.from('store_events').update({is_done:nd,updated_at:new Date().toISOString()}).eq('id',ev.id);
    setEvents(es=>es.map(e=>e.id===ev.id?{...e,is_done:nd}:e));
  };

  // 日セル
  const DayCell=({date,inMonth=true})=>{
    const ds=toYMD(date);const isToday=ds===todayStr;
    const dowi=(date.getDay()+6)%7;
    const evs=eventsByDate[ds]||[];const vis=evs.slice(0,3);const more=evs.length-vis.length;
    return <div onClick={()=>openDay(ds)} style={{minHeight:view==='week'?110:68,padding:'2px 3px',
      background:inMonth?'#fff':'#f8fafc',borderRight:'1px solid #e2e8f0',borderBottom:'1px solid #e2e8f0',
      cursor:'pointer',overflow:'hidden'}}>
      <div style={{textAlign:'right',marginBottom:1}}>
        <span style={{display:'inline-flex',alignItems:'center',justifyContent:'center',width:20,height:20,borderRadius:'50%',fontSize:11,
          background:isToday?'#3b82f6':'transparent',
          color:isToday?'#fff':dowi===5?'#dc2626':dowi===6?'#2563eb':inMonth?'#1e293b':'#94a3b8',
          fontWeight:isToday?800:400}}>{date.getDate()}</span>
      </div>
      {vis.map(ev=>{const cat=getCat(ev.category);return <div key={ev.id}
        onClick={e=>{e.stopPropagation();openEdit(ev);}}
        style={{fontSize:9,color:'#fff',background:ev.color||cat.color,borderRadius:3,padding:'1px 4px',marginBottom:1,
        overflow:'hidden',whiteSpace:'nowrap',textOverflow:'ellipsis',
        opacity:ev.is_done?0.6:1,textDecoration:ev.is_done?'line-through':'none',cursor:'pointer'}}>
        {ev.is_done?'✓ ':''}{ev.title}</div>;})}
      {more>0&&<div style={{fontSize:9,color:'#64748b'}}>+{more}件</div>}
    </div>;
  };

  // 日別詳細パネル
  const DayDetail=()=>{
    const ds=modal?.date;if(!ds)return null;
    const dt=new Date(ds+'T00:00:00');
    const JDOW=['日','月','火','水','木','金','土'];
    const evs=eventsByDate[ds]||[];
    return <div>
      <div style={{fontWeight:800,fontSize:15,marginBottom:10,color:'#1e293b'}}>{dt.getMonth()+1}月{dt.getDate()}日（{JDOW[dt.getDay()]}）</div>
      {evs.length>0&&<div style={{marginBottom:12}}>
        <div style={{fontSize:11,color:'#64748b',fontWeight:600,marginBottom:6}}>📌 イベント</div>
        {evs.map(ev=>{const cat=getCat(ev.category);return <div key={ev.id}
          style={{padding:'8px 10px',borderRadius:8,border:'1px solid '+(ev.color||cat.color)+'66',
            background:(ev.color||cat.color)+'11',marginBottom:6,display:'flex',alignItems:'flex-start',gap:6}}>
          <div style={{flex:1,minWidth:0}}>
            <div style={{display:'flex',alignItems:'center',gap:6,marginBottom:2,flexWrap:'wrap'}}>
              <span style={{fontSize:10,padding:'1px 6px',borderRadius:10,background:ev.color||cat.color,color:'#fff',flexShrink:0}}>{cat.icon} {cat.label}</span>
              <span style={{fontSize:13,fontWeight:700,color:'#1e293b',textDecoration:ev.is_done?'line-through':'none'}}>{ev.title}</span>
            </div>
            {ev.assignees?.length>0&&<div style={{fontSize:11,color:'#64748b'}}>👤 {ev.assignees.join('・')}</div>}
            {ev.description&&<div style={{fontSize:11,color:'#64748b',marginTop:2}}>{ev.description}</div>}
            {ev.end_date&&ev.end_date!==ev.event_date&&<div style={{fontSize:10,color:'#94a3b8',marginTop:2}}>{ev.event_date}〜{ev.end_date}</div>}
          </div>
          <div style={{display:'flex',gap:3,flexShrink:0}}>
            <button onClick={e=>{e.stopPropagation();toggleDone(ev);}} title={ev.is_done?'未完了に戻す':'完了'}
              style={{padding:'3px 6px',borderRadius:4,border:'1px solid #e2e8f0',background:ev.is_done?'#dcfce7':'#f1f5f9',fontSize:11,cursor:'pointer',color:ev.is_done?'#15803d':'#64748b'}}>
              {ev.is_done?'✓':'○'}
            </button>
            <button onClick={e=>{e.stopPropagation();openEdit(ev);}}
              style={{padding:'3px 6px',borderRadius:4,border:'1px solid #e2e8f0',background:'#f1f5f9',fontSize:11,cursor:'pointer',color:'#475569'}}>✏️</button>
          </div>
        </div>;})}
      </div>}
      {evs.length===0&&<div style={{fontSize:12,color:'#94a3b8',marginBottom:12}}>イベントなし</div>}
      <button onClick={()=>openNew(ds)} style={{width:'100%',padding:'9px',borderRadius:8,background:'#3b82f6',color:'#fff',border:'none',cursor:'pointer',fontSize:13,fontWeight:700}}>＋ イベントを追加</button>
    </div>;
  };

  // イベント入力フォーム
  const EventForm=()=><div style={{display:'flex',flexDirection:'column',gap:10}}>
    <input placeholder="タイトル *" value={form.title||''} onChange={e=>setForm(f=>({...f,title:e.target.value}))}
      style={{padding:'9px 12px',borderRadius:8,border:'1px solid #e2e8f0',fontSize:14,fontWeight:600,outline:'none'}}/>
    <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:8}}>
      <div><label style={{fontSize:11,color:'#64748b',fontWeight:600}}>開始日 *</label>
        <input type="date" value={form.event_date||''} onChange={e=>setForm(f=>({...f,event_date:e.target.value}))}
          style={{display:'block',width:'100%',marginTop:3,padding:'6px 8px',borderRadius:6,border:'1px solid #e2e8f0',fontSize:13,boxSizing:'border-box'}}/></div>
      <div><label style={{fontSize:11,color:'#64748b',fontWeight:600}}>終了日</label>
        <input type="date" value={form.end_date||''} onChange={e=>setForm(f=>({...f,end_date:e.target.value}))}
          style={{display:'block',width:'100%',marginTop:3,padding:'6px 8px',borderRadius:6,border:'1px solid #e2e8f0',fontSize:13,boxSizing:'border-box'}}/></div>
    </div>
    <div style={{display:'flex',alignItems:'center',gap:10,flexWrap:'wrap'}}>
      <label style={{display:'flex',alignItems:'center',gap:6,fontSize:12,cursor:'pointer',userSelect:'none',color:'#475569'}}>
        <input type="checkbox" checked={form.is_all_day!==false} onChange={e=>setForm(f=>({...f,is_all_day:e.target.checked,start_time:e.target.checked?'':f.start_time,end_time:e.target.checked?'':f.end_time}))}/> 終日
      </label>
      {form.is_all_day===false&&<>
        <div style={{display:'flex',alignItems:'center',gap:4}}>
          <label style={{fontSize:11,color:'#64748b'}}>開始</label>
          <input type="time" value={form.start_time||''} onChange={e=>setForm(f=>({...f,start_time:e.target.value}))}
            style={{padding:'4px 6px',borderRadius:6,border:'1px solid #e2e8f0',fontSize:12}}/>
        </div>
        <div style={{display:'flex',alignItems:'center',gap:4}}>
          <label style={{fontSize:11,color:'#64748b'}}>終了</label>
          <input type="time" value={form.end_time||''} onChange={e=>setForm(f=>({...f,end_time:e.target.value}))}
            style={{padding:'4px 6px',borderRadius:6,border:'1px solid #e2e8f0',fontSize:12}}/>
        </div>
      </>}
    </div>
    <div><label style={{fontSize:11,color:'#64748b',fontWeight:600}}>カテゴリ</label>
      <div style={{display:'flex',gap:5,flexWrap:'wrap',marginTop:4}}>
        {CAT.map(c=>{const sel=form.category===c.key;return <button key={c.key} onClick={()=>setForm(f=>{
          const isOT=c.key==='overtime',isHW=c.key==='holiday_work';
          const next={...f,category:c.key};
          if(isOT||isHW){
            next.is_all_day=false;
            if(f.is_all_day!==false){
              next.start_time=isOT?(f.start_time||'18:00'):(f.start_time||'09:00');
              next.end_time=isOT?(f.end_time||'21:00'):(f.end_time||'18:00');
            }
          }
          if(isHW){
            const seishainSet=new Set(staffList.filter(s=>s.type==='正社員').map(s=>s.name));
            next.assignees=(f.assignees||[]).filter(n=>seishainSet.has(n));
          }
          return next;
        })}
          style={{padding:'4px 10px',borderRadius:16,border:'2px solid '+(sel?c.color:'#e2e8f0'),
            background:sel?c.color+'22':'#fff',fontSize:12,cursor:'pointer',color:sel?c.color:'#64748b',fontWeight:sel?700:400}}>
          {c.icon} {c.label}</button>;})}
      </div></div>
    <div><label style={{fontSize:11,color:'#64748b',fontWeight:600}}>担当者{form.category==='holiday_work'&&<span style={{marginLeft:6,fontSize:10,color:'#7c3aed',fontWeight:700}}>※ 正社員のみ</span>}</label>
      <div style={{display:'flex',gap:4,flexWrap:'wrap',marginTop:4}}>
        {(form.category==='holiday_work'?staffList.filter(s=>s.type==='正社員'):staffList).map(s=>{const name=s.name;const sel=(form.assignees||[]).includes(name);return <button key={name}
          onClick={()=>setForm(f=>({...f,assignees:sel?(f.assignees||[]).filter(n=>n!==name):[...(f.assignees||[]),name]}))}
          style={{padding:'3px 10px',borderRadius:16,border:'1px solid '+(sel?'#3b82f6':'#e2e8f0'),
            background:sel?'#dbeafe':'#f8fafc',fontSize:12,cursor:'pointer',color:sel?'#1d4ed8':'#475569',fontWeight:sel?600:400}}>
          {name}</button>;})}
        {staffList.length===0&&<span style={{fontSize:11,color:'#94a3b8'}}>読み込み中...</span>}
      </div></div>
    {(form.category==='overtime'||form.category==='holiday_work')?
      <div>
        <label style={{fontSize:11,color:'#dc2626',fontWeight:800}}>理由 <span style={{color:'#dc2626'}}>*（必須）</span></label>
        <textarea placeholder={form.category==='overtime'?'例: 在庫棚卸し・繁忙期対応・配車調整など':'例: 繁忙期出勤・店舗ヘルプ・イベント対応など'} value={form.description||''} onChange={e=>setForm(f=>({...f,description:e.target.value}))}
          style={{padding:'8px 12px',borderRadius:8,border:'2px solid '+(form.description?.trim()?'#10b981':'#dc2626'),fontSize:13,minHeight:64,resize:'vertical',background:form.description?.trim()?'#f0fdf4':'#fef2f2',width:'100%',boxSizing:'border-box',marginTop:4}}/>
      </div>
      :
      <textarea placeholder="詳細メモ" value={form.description||''} onChange={e=>setForm(f=>({...f,description:e.target.value}))}
        style={{padding:'8px 12px',borderRadius:8,border:'1px solid #e2e8f0',fontSize:13,minHeight:56,resize:'vertical'}}/>
    }
    {form.id&&<label style={{display:'flex',alignItems:'center',gap:8,fontSize:13,cursor:'pointer',userSelect:'none'}}>
      <input type="checkbox" checked={!!form.is_done} onChange={e=>setForm(f=>({...f,is_done:e.target.checked}))}/> 完了済みにする</label>}
    <div style={{display:'flex',gap:8,justifyContent:'flex-end',marginTop:4}}>
      {form.id&&<button onClick={deleteEvent} style={{padding:'8px 14px',borderRadius:8,background:'#fee2e2',color:'#dc2626',border:'none',cursor:'pointer',fontSize:13}}>🗑 削除</button>}
      <button onClick={()=>{setModal(null);setForm({});}} style={{padding:'8px 14px',borderRadius:8,background:'#f1f5f9',color:'#475569',border:'none',cursor:'pointer',fontSize:13}}>キャンセル</button>
      <button onClick={saveEvent} disabled={saving||!form.title?.trim()||!form.event_date}
        style={{padding:'8px 16px',borderRadius:8,background:'#3b82f6',color:'#fff',border:'none',cursor:'pointer',fontSize:13,fontWeight:700,opacity:saving||!form.title?.trim()||!form.event_date?0.5:1}}>
        {saving?'保存中...':'保存'}</button>
    </div>
  </div>;

  return <div style={{marginBottom:12,background:'#fff',borderRadius:12,border:'1px solid #e2e8f0',boxShadow:'0 1px 3px rgba(0,0,0,.06)'}}>
    {/* ヘッダー（タップで折りたたみ） */}
    <div onClick={()=>setCalOpen(o=>!o)} style={{display:'flex',alignItems:'center',gap:8,padding:'10px 14px',background:'#f0f9ff',borderBottom:'1px solid #e2e8f0',cursor:'pointer',userSelect:'none',borderRadius:'12px 12px 0 0'}}>
      <span style={{fontSize:18}}>📅</span>
      <span style={{fontSize:14,fontWeight:800,color:'#1e293b',flex:1}}>チームカレンダー</span>
      <div onClick={e=>e.stopPropagation()} style={{display:'flex',border:'1px solid #e2e8f0',borderRadius:6,overflow:'hidden'}}>
        {[['month','月'],['week','週'],['day','日']].map(([v,l])=><button key={v} onClick={()=>setView(v)}
          style={{padding:'4px 9px',border:'none',fontSize:11,cursor:'pointer',fontWeight:view===v?700:400,
            background:view===v?'#3b82f6':'#fff',color:view===v?'#fff':'#475569'}}>{l}</button>)}
      </div>
      <button onClick={e=>{e.stopPropagation();openNew(todayStr);}} style={{padding:'4px 12px',borderRadius:6,background:'#3b82f6',color:'#fff',border:'none',cursor:'pointer',fontSize:12,fontWeight:700}}>＋</button>
      <span style={{fontSize:12,color:'#94a3b8',fontWeight:700}}>{calOpen?'▲':'▼'}</span>
    </div>
    <div style={{display:calOpen?'block':'none'}}>
    {/* ナビゲーション */}
    <div style={{display:'flex',alignItems:'center',gap:6,padding:'6px 14px',borderBottom:'1px solid #e2e8f0',background:'#fff'}}>
      <button onClick={()=>nav(-1)} style={{padding:'3px 9px',borderRadius:5,border:'1px solid #e2e8f0',background:'#fff',cursor:'pointer',fontSize:13}}>◀</button>
      <button onClick={goToday} style={{padding:'3px 9px',borderRadius:5,border:'1px solid #e2e8f0',background:'#fff',cursor:'pointer',fontSize:11}}>今日</button>
      <button onClick={()=>nav(1)} style={{padding:'3px 9px',borderRadius:5,border:'1px solid #e2e8f0',background:'#fff',cursor:'pointer',fontSize:13}}>▶</button>
      <span style={{fontSize:13,fontWeight:700,color:'#1e293b',marginLeft:4}}>{headerLabel()}</span>
      {loading&&<span style={{fontSize:11,color:'#94a3b8',marginLeft:'auto'}}>読込中...</span>}
    </div>
    {/* 曜日ヘッダー */}
    {view!=='day'&&<div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)',background:'#f8fafc',borderBottom:'1px solid #e2e8f0'}}>
      {DOW.map((d,i)=><div key={d} style={{textAlign:'center',padding:'4px 0',fontSize:10,fontWeight:700,
        color:i===5?'#dc2626':i===6?'#2563eb':'#64748b',borderRight:i<6?'1px solid #e2e8f0':'none'}}>{d}</div>)}
    </div>}
    {/* 月表示 */}
    {view==='month'&&monthGrid.map((week,wi)=><div key={wi} style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)'}}>
      {week.map((date,di)=><DayCell key={di} date={date} inMonth={date.getMonth()===curDate.getMonth()}/>)}
    </div>)}
    {/* 週表示 */}
    {view==='week'&&<div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)',borderBottom:'1px solid #e2e8f0'}}>
        {weekDays.map((d,i)=>{const isT=toYMD(d)===todayStr;return <div key={i} style={{textAlign:'center',padding:'4px 0',borderRight:i<6?'1px solid #e2e8f0':'none',background:'#f8fafc'}}>
          <div style={{fontSize:10,fontWeight:700,color:i===5?'#dc2626':i===6?'#2563eb':'#64748b'}}>{DOW[i]}</div>
          <div style={{width:24,height:24,borderRadius:'50%',background:isT?'#3b82f6':'transparent',
            color:isT?'#fff':undefined,display:'inline-flex',alignItems:'center',justifyContent:'center',
            fontSize:13,fontWeight:isT?800:400,margin:'2px auto'}}>{d.getDate()}</div>
        </div>;})}
      </div>
      <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)'}}>
        {weekDays.map((d,i)=><DayCell key={i} date={d} inMonth={true}/>)}
      </div>
    </div>}
    {/* 日表示 */}
    {view==='day'&&<div style={{padding:14}}>
      {(eventsByDate[toYMD(curDate)]||[]).map(ev=>{const cat=getCat(ev.category);return <div key={ev.id} onClick={()=>openEdit(ev)}
        style={{padding:'12px',borderRadius:10,border:'2px solid '+(ev.color||cat.color),
          background:(ev.color||cat.color)+'11',marginBottom:8,cursor:'pointer'}}>
        <div style={{display:'flex',alignItems:'center',gap:6,marginBottom:4}}>
          <span style={{fontSize:10,padding:'1px 6px',borderRadius:10,background:ev.color||cat.color,color:'#fff'}}>{cat.icon} {cat.label}</span>
          <span style={{fontSize:14,fontWeight:700,color:'#1e293b',textDecoration:ev.is_done?'line-through':'none'}}>{ev.title}</span>
        </div>
        {ev.assignees?.length>0&&<div style={{fontSize:12,color:'#64748b'}}>👤 {ev.assignees.join('・')}</div>}
        {ev.description&&<div style={{fontSize:12,color:'#64748b',marginTop:4}}>{ev.description}</div>}
      </div>;})}
      {(eventsByDate[toYMD(curDate)]||[]).length===0&&<div style={{fontSize:12,color:'#94a3b8',marginBottom:10}}>この日のイベントはありません</div>}
      <button onClick={()=>openNew(toYMD(curDate))} style={{width:'100%',padding:'9px',borderRadius:8,background:'#3b82f6',color:'#fff',border:'none',cursor:'pointer',fontSize:13,fontWeight:700}}>＋ イベントを追加</button>
    </div>}
    {/* モーダル */}
    {modal&&<div style={{position:'fixed',inset:0,background:'rgba(15,23,42,.65)',zIndex:9200,display:'flex',alignItems:'flex-start',justifyContent:'center',padding:'60px 12px 12px'}}
      onClick={e=>{if(e.target===e.currentTarget){setModal(null);setForm({});}}}>
      <div style={{background:'#fff',borderRadius:16,padding:20,width:'100%',maxWidth:480,maxHeight:'90vh',overflowY:'auto',boxShadow:'0 20px 60px rgba(0,0,0,.3)'}}>
        <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:14}}>
          <span style={{fontSize:15,fontWeight:800,color:'#1e293b'}}>
            {modal.mode==='day'?`📅 ${modal.date}`:modal.mode==='form'&&form.id?'✏️ イベント編集':'＋ イベント追加'}
          </span>
          <button onClick={()=>{setModal(null);setForm({});}} style={{background:'none',border:'none',fontSize:20,cursor:'pointer',color:'#94a3b8',lineHeight:1}}>×</button>
        </div>
        {modal.mode==='day'?DayDetail():EventForm()}
      </div>
    </div>}
    </div>
  </div>;
}

// ── 🚗 車検/点検カレンダー (2026-05-07 追加・TOP表示用) ──
// チームカレンダーと同じ仕様 (月/週/日切替) で「車検/点検 スケジュール」を表示
// データソース:
//   - 車検満了日 / 半年点検期限 = vehicles テーブル (inspection_due_date / tenken_due_date)
//   - 次回車検予定 / 次回点検予定 = maintenance テーブル (label='車検'/'半年点検' の未来日)
function InspectionTopCalendar({vehicles,maintenance,isSpk}){
  const toYMD=d=>{const dt=typeof d==='string'?new Date(d+'T00:00:00'):d;return dt.getFullYear()+'-'+String(dt.getMonth()+1).padStart(2,'0')+'-'+String(dt.getDate()).padStart(2,'0');};
  const todayStr=toYMD(new Date());
  const today=new Date(todayStr+'T00:00:00');
  const DOW=['月','火','水','木','金','土','日'];

  const[calOpen,setCalOpen]=useState(true);// 2026-06-07 デフォルト展開（チームカレンダー同様）
  const[view,setView]=useState('week');// 2026-06-07 週表示デフォルト
  const[curDate,setCurDate]=useState(new Date(today));

  // イベント生成: vehicles + maintenance から
  const events=useMemo(()=>{
    const list=[];
    (vehicles||[]).filter(v=>v.active!==false).forEach(v=>{
      // 車検満了日（車両マスター）
      if(v.inspectionDueDate){
        list.push({id:'shaken-due-'+v.code,date:v.inspectionDueDate,
          type:'shaken_due',label:'🚗 車検満了',vehicle:v.name+(v.no?' '+v.no:''),
          color:'#dc2626',bg:'#fef2f2'});
      }
      // 半年点検期限（車両マスター）
      if(v.tenkenDueDate){
        list.push({id:'tenken-due-'+v.code,date:v.tenkenDueDate,
          type:'tenken_due',label:'🔧 半年点検期限',vehicle:v.name+(v.no?' '+v.no:''),
          color:'#16a34a',bg:'#f0fdf4'});
      }
    });
    // 配車表メンテブロック（開始日のみ表示・期間中の連続表示はしない）
    // 重複防止: 同一車両×同一カテゴリは最早1件のみ
    const seenPlan={};
    (maintenance||[]).forEach(m=>{
      const sd=m.startDate||m.start_date;
      const vc=m.vehicleCode||m.vehicle_code;
      if(!sd||!vc)return;
      const v=(vehicles||[]).find(x=>x.code===vc);
      const vname=v?(v.name+(v.no?' '+v.no:'')):vc;
      if(m.label==='車検'){
        const k='S-'+vc;
        if(seenPlan[k]&&seenPlan[k]<=sd)return;
        seenPlan[k]=sd;
        list.push({id:'shaken-plan-'+vc,date:sd,
          type:'shaken_plan',label:'🚗 車検予定',vehicle:vname,
          color:'#1e40af',bg:'#dbeafe'});
      }else if(m.label==='半年点検'){
        const k='T-'+vc;
        if(seenPlan[k]&&seenPlan[k]<=sd)return;
        seenPlan[k]=sd;
        list.push({id:'tenken-plan-'+vc,date:sd,
          type:'tenken_plan',label:'🔧 点検予定',vehicle:vname,
          color:'#92400e',bg:'#fef3c7'});
      }
    });
    // 同一車両×同一カテゴリで最早日のみ残す（後勝ち）
    const dedup={};
    list.forEach(ev=>{
      const k=ev.type+'-'+ev.vehicle;
      if(!dedup[k]||ev.date<dedup[k].date)dedup[k]=ev;
    });
    return Object.values(dedup);
  },[vehicles,maintenance]);

  // 表示範囲計算
  const{rangeStart,rangeEnd}=useMemo(()=>{
    const y=curDate.getFullYear(),mo=curDate.getMonth();
    if(view==='month'){
      const first=new Date(y,mo,1);
      let dow=first.getDay();if(dow===0)dow=7;
      const s=new Date(y,mo,2-dow);
      const last=new Date(y,mo+1,0);
      let ldow=last.getDay();if(ldow===0)ldow=7;
      const e=new Date(y,mo+1,7-ldow);
      return{rangeStart:toYMD(s),rangeEnd:toYMD(e)};
    }else if(view==='week'){
      const d=new Date(curDate);let dow=d.getDay();if(dow===0)dow=7;
      d.setDate(d.getDate()-(dow-1));
      const e=new Date(d);e.setDate(d.getDate()+6);
      return{rangeStart:toYMD(d),rangeEnd:toYMD(e)};
    }else{
      const s=toYMD(curDate);return{rangeStart:s,rangeEnd:s};
    }
  },[curDate,view]);

  // 日付ごとにイベントを展開（単日のみ・期間表示なし）
  const eventsByDate=useMemo(()=>{
    const map={};
    events.forEach(ev=>{
      const k=ev.date;
      if(k>=rangeStart&&k<=rangeEnd){if(!map[k])map[k]=[];map[k].push(ev);}
    });
    return map;
  },[events,rangeStart,rangeEnd]);

  // 月グリッド
  const monthGrid=useMemo(()=>{
    const y=curDate.getFullYear(),mo=curDate.getMonth();
    const first=new Date(y,mo,1);
    let dow=first.getDay();if(dow===0)dow=7;
    const days=[];
    let d=new Date(y,mo,2-dow);
    while(true){
      days.push(new Date(d));d.setDate(d.getDate()+1);
      if(days.length>=35&&(d.getMonth()>mo||(mo===11&&d.getMonth()===0))){
        let ldow=days[days.length-1].getDay();if(ldow===0)ldow=7;
        if(ldow===7)break;
      }
    }
    while(days.length%7!==0){days.push(new Date(d));d.setDate(d.getDate()+1);}
    const weeks=[];for(let i=0;i<days.length;i+=7)weeks.push(days.slice(i,i+7));
    return weeks;
  },[curDate]);

  const weekDays=useMemo(()=>{
    const d=new Date(view==='day'?curDate:curDate);
    let dow=d.getDay();if(dow===0)dow=7;d.setDate(d.getDate()-(dow-1));
    return Array.from({length:7},(_,i)=>{const dd=new Date(d);dd.setDate(d.getDate()+i);return dd;});
  },[curDate,view]);

  const nav=dir=>setCurDate(d=>{const nd=new Date(d);
    if(view==='month')nd.setMonth(nd.getMonth()+dir);
    else if(view==='week')nd.setDate(nd.getDate()+dir*7);
    else nd.setDate(nd.getDate()+dir);
    return nd;
  });
  const goToday=()=>{setView('month');setCurDate(new Date(today));};
  const headerLabel=()=>{
    const y=curDate.getFullYear(),m=curDate.getMonth()+1;
    if(view==='month')return`${y}年 ${m}月`;
    if(view==='week'){const ds=weekDays;return`${ds[0].getMonth()+1}/${ds[0].getDate()} 〜 ${ds[6].getMonth()+1}/${ds[6].getDate()}`;}
    return`${y}年${m}月${curDate.getDate()}日`;
  };

  // 日セル
  const DayCell=({date,inMonth=true})=>{
    const ds=toYMD(date);const isToday=ds===todayStr;
    const dowi=(date.getDay()+6)%7;
    const evs=eventsByDate[ds]||[];const vis=evs.slice(0,3);const more=evs.length-vis.length;
    return <div onClick={()=>{setCurDate(new Date(ds+'T00:00:00'));setView('day');}} style={{minHeight:view==='week'?100:64,padding:'2px 3px',
      background:inMonth?'#fff':'#f8fafc',borderRight:'1px solid #e2e8f0',borderBottom:'1px solid #e2e8f0',
      cursor:'pointer',overflow:'hidden'}}>
      <div style={{textAlign:'right',marginBottom:1}}>
        <span style={{display:'inline-flex',alignItems:'center',justifyContent:'center',width:20,height:20,borderRadius:'50%',fontSize:11,
          background:isToday?'#3b82f6':'transparent',
          color:isToday?'#fff':dowi===5?'#dc2626':dowi===6?'#2563eb':inMonth?'#1e293b':'#94a3b8',
          fontWeight:isToday?800:400}}>{date.getDate()}</span>
      </div>
      {vis.map(ev=><div key={ev.id} style={{fontSize:9,color:'#fff',background:ev.color,borderRadius:3,padding:'1px 4px',marginBottom:1,
        overflow:'hidden',whiteSpace:'nowrap',textOverflow:'ellipsis'}}>
        {ev.label.split(' ')[0]}<span style={{opacity:.85}}>{ev.vehicle}</span>
      </div>)}
      {more>0&&<div style={{fontSize:8,color:'#64748b'}}>+{more}件</div>}
    </div>;
  };

  // 日表示の詳細リスト
  const dayList=useMemo(()=>{
    if(view!=='day')return[];
    return eventsByDate[toYMD(curDate)]||[];
  },[view,curDate,eventsByDate]);

  return <div style={{marginBottom:12}}>
    <div onClick={()=>setCalOpen(o=>!o)} style={{display:'flex',alignItems:'center',gap:10,padding:'10px 14px',background:'#fef3c7',border:'1px solid #fde68a',borderRadius:calOpen?'12px 12px 0 0':'12px',cursor:'pointer',userSelect:'none',boxShadow:'0 1px 3px rgba(0,0,0,.06)'}}>
      <span style={{fontSize:20}}>🚗</span>
      <span style={{fontSize:14,fontWeight:800,color:'#1e293b',flex:1}}>整備カレンダー</span>
      <span style={{fontSize:11,color:'#92400e',fontWeight:700}}>{events.length}件</span>
      <span style={{fontSize:14,color:'#94a3b8'}}>{calOpen?'▲':'▼'}</span>
    </div>
    {calOpen&&<div style={{padding:10,border:'1px solid #fde68a',borderTop:'none',borderRadius:'0 0 12px 12px',background:'#fffbeb'}}>
      {/* ヘッダー: ナビ + 切替 */}
      <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:8,flexWrap:'wrap'}}>
        <button onClick={()=>nav(-1)} style={{padding:'4px 10px',border:'1px solid #d1d5db',borderRadius:6,background:'#fff',cursor:'pointer',fontSize:12}}>‹</button>
        <span style={{fontSize:13,fontWeight:800,color:'#1e293b',minWidth:130,textAlign:'center'}}>{headerLabel()}</span>
        <button onClick={()=>nav(1)} style={{padding:'4px 10px',border:'1px solid #d1d5db',borderRadius:6,background:'#fff',cursor:'pointer',fontSize:12}}>›</button>
        <button onClick={goToday} style={{padding:'4px 10px',border:'1px solid #d1d5db',borderRadius:6,background:'#fff',cursor:'pointer',fontSize:11}}>今日</button>
        <div style={{marginLeft:'auto',display:'flex',gap:0,border:'1px solid #d1d5db',borderRadius:6,overflow:'hidden'}}>
          {['month','week','day'].map(v=>{const lab=v==='month'?'月':v==='week'?'週':'日';return <button key={v} onClick={()=>setView(v)} style={{padding:'4px 12px',border:'none',background:view===v?'#1e293b':'#fff',color:view===v?'#fff':'#1e293b',cursor:'pointer',fontSize:11,fontWeight:600}}>{lab}</button>;})}
        </div>
      </div>
      {/* 凡例 */}
      <div style={{display:'flex',gap:10,marginBottom:8,fontSize:10,color:'#64748b',flexWrap:'wrap'}}>
        <span style={{padding:'2px 8px',background:'#dc2626',color:'#fff',borderRadius:4,fontWeight:700}}>🚗 車検満了</span>
        <span style={{padding:'2px 8px',background:'#16a34a',color:'#fff',borderRadius:4,fontWeight:700}}>🔧 半年点検期限</span>
        <span style={{padding:'2px 8px',background:'#1e40af',color:'#fff',borderRadius:4,fontWeight:700}}>🚗 車検予定(配車表)</span>
        <span style={{padding:'2px 8px',background:'#92400e',color:'#fff',borderRadius:4,fontWeight:700}}>🔧 点検予定(配車表)</span>
      </div>
      {/* カレンダー本体 */}
      {view==='month'&&<div style={{border:'1px solid #e2e8f0',borderRadius:8,overflow:'hidden',background:'#fff'}}>
        <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)',background:'#f1f5f9',borderBottom:'1px solid #e2e8f0'}}>
          {DOW.map((d,i)=><div key={d} style={{padding:'6px 4px',textAlign:'center',fontSize:11,fontWeight:700,color:i===5?'#dc2626':i===6?'#2563eb':'#475569'}}>{d}</div>)}
        </div>
        <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)'}}>
          {monthGrid.map((week,wi)=>week.map((d,di)=>{const inMo=d.getMonth()===curDate.getMonth();return <DayCell key={wi+'-'+di} date={d} inMonth={inMo}/>;}))}
        </div>
      </div>}
      {view==='week'&&<div style={{border:'1px solid #e2e8f0',borderRadius:8,overflow:'hidden',background:'#fff'}}>
        <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)',background:'#f1f5f9',borderBottom:'1px solid #e2e8f0'}}>
          {weekDays.map((d,i)=><div key={i} style={{padding:'6px 4px',textAlign:'center',fontSize:11,fontWeight:700,color:i===5?'#dc2626':i===6?'#2563eb':'#475569'}}>{DOW[i]} {d.getDate()}</div>)}
        </div>
        <div style={{display:'grid',gridTemplateColumns:'repeat(7,1fr)'}}>
          {weekDays.map((d,i)=><DayCell key={i} date={d}/>)}
        </div>
      </div>}
      {view==='day'&&<div style={{background:'#fff',border:'1px solid #e2e8f0',borderRadius:8,padding:14}}>
        <div style={{fontSize:13,fontWeight:800,marginBottom:10}}>{headerLabel()} の予定</div>
        {dayList.length===0?<div style={{textAlign:'center',color:'#94a3b8',padding:24,fontSize:12}}>この日の車検/点検イベントはありません</div>
          :<div style={{display:'flex',flexDirection:'column',gap:6}}>
            {dayList.map(ev=><div key={ev.id} style={{display:'flex',alignItems:'center',gap:10,padding:'8px 12px',background:ev.bg,borderLeft:'4px solid '+ev.color,borderRadius:6}}>
              <span style={{fontSize:12,fontWeight:800,color:ev.color,minWidth:130}}>{ev.label}</span>
              <span style={{fontSize:12,color:'#1e293b',flex:1}}>{ev.vehicle}</span>
            </div>)}
          </div>}
      </div>}
    </div>}
  </div>;
}

// ── システム監視ウィジェット（TOPサマリー下） ──
function MonitorWidget({isSpk}){
  const[st,setSt]=useState(null);
  const load=async()=>{
    if(!sb)return;
    try{
      const d=new Date();d.setDate(d.getDate()+1);
      const tomorrow=d.toISOString().slice(0,10);
      const jalanTbl=isSpk?'jalan_payments':'bt_jalan_payments';
      const resvTbl=isSpk?'reservations':'bt_reservations';
      const fleetTbl=isSpk?'fleet':'bt_fleet';
      const dateCol=isSpk?'lend_date':'start_date';
      const storeFilter=isSpk?'SPK':'TKM';
      const hbTbl=isSpk?'app_settings':'bt_app_settings';
      const gasKeys=isSpk
        ?['heartbeat_spk_gas_email','heartbeat_spk_jalan_links','heartbeat_spk_jalan_payment']
        :['heartbeat_bt_gas_email','heartbeat_bt_jalan_links','heartbeat_bt_jalan_payment'];
      const GAS_ERR_MIN=60; // 60分以上更新なし→停止とみなす
      const [inqR,sqR,hbR]=await Promise.all([
        sb.from('inquiries').select('id',{count:'exact',head:true}).is('replied_at',null).is('blocked_sender_id',null),
        sb.from('sq_terminal_failed').select('id',{count:'exact',head:true}).eq('resolved',false).in('resolved_store',[storeFilter,'UNKNOWN']).neq('resolved_store','EXCLUDED'),
        sb.from(hbTbl).select('key,value').like('key','heartbeat_%'),
      ]);
      // GAS稼働チェック
      const hbMap={};
      (hbR.data||[]).forEach(row=>{try{hbMap[row.key]=JSON.parse(row.value);}catch(e){}});
      const gasDown=gasKeys.filter(k=>{
        const hb=hbMap[k];
        if(!hb||!hb.last_run)return false; // ハートビート未設定はスキップ
        return Math.round((Date.now()-new Date(hb.last_run))/60000)>GAS_ERR_MIN;
      });
      // 未配車: 明日〜7日以内の予約でfleet未登録（直近のみ・要対応分）
      const d7=new Date();d7.setDate(d7.getDate()+7);
      const week=d7.toISOString().slice(0,10);
      let unassigned=0;
      try{
        const rvR=await sb.from(resvTbl).select('id').neq('status','cancelled').gte(dateCol,tomorrow).lte(dateCol,week).neq('ota','direct').limit(300);
        const ids=(rvR.data||[]).map(r=>r.id);
        if(ids.length>0){
          const flR=await sb.from(fleetTbl).select('reservation_id').in('reservation_id',ids);
          const fSet=new Set((flR.data||[]).map(r=>r.reservation_id));
          unassigned=ids.filter(id=>!fSet.has(id)).length;
        }
      }catch(e){}
      setSt({
        inquiry:inqR.count||0,
        sq:sqR.count||0,
        unassigned,
        gasDown:gasDown.length,
        total:(inqR.count||0)+(sqR.count||0)+unassigned+gasDown.length,
        updatedAt:new Date(),
      });
    }catch(e){}
  };
  useEffect(()=>{load();const t=setInterval(load,60000);return()=>clearInterval(t);},[]);
  if(!st)return null;
  const{total,inquiry,sq,unassigned,gasDown=0}=st;
  const ok=total===0;
  const warn=total>0&&total<=5;
  const clr=ok?'#059669':warn?'#d97706':'#dc2626';
  const bg=ok?'#f0fdf4':warn?'#fffbeb':'#fef2f2';
  const bdr=ok?'#bbf7d0':warn?'#fde68a':'#fecaca';
  const timeStr=st.updatedAt?st.updatedAt.toLocaleTimeString('ja-JP',{hour:'2-digit',minute:'2-digit'}):'';
  const items=[];
  if(gasDown>0)items.push(`🤖 GAS停止 ${gasDown}件`);
  if(inquiry>0)items.push(`問い合わせ未対応 ${inquiry}件`);
  if(sq>0)     items.push(`Square失敗 ${sq}件`);
  if(unassigned>0)items.push(`未配車予約 ${unassigned}件（7日以内）`);
  return <a href="monitor.html" style={{display:'block',textDecoration:'none',marginBottom:10}}>
    <div style={{background:bg,border:`1px solid ${bdr}`,borderRadius:10,padding:'10px 14px'}}>
      <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:ok?0:4}}>
        <span style={{fontSize:11,fontWeight:800,color:'#475569'}}>🔍 システム監視</span>
        <span style={{fontSize:9,color:'#94a3b8'}}>{timeStr} · 詳細 →</span>
      </div>
      {ok
        ?<div style={{fontSize:11,fontWeight:700,color:'#059669'}}>✅ 正常</div>
        :<>
          <div style={{fontSize:11,fontWeight:700,color:clr,marginBottom:2}}>⚠️ システムパトロールしてください</div>
          <div style={{fontSize:10,color:'#64748b',lineHeight:1.5,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{items.join(' · ')}</div>
        </>
      }
    </div>
  </a>;
}

function TopSectionTitle({icon,title,sub}){
  return <div style={{display:"flex",alignItems:"center",gap:6,padding:"8px 4px 6px",marginTop:4}}>
    <span style={{fontSize:14}}>{icon}</span>
    <span style={{fontSize:11,fontWeight:800,color:"#475569",letterSpacing:0.3}}>{title}</span>
    {sub&&<span style={{fontSize:9,color:"#94a3b8",fontWeight:600}}>{sub}</span>}
    <div style={{flex:1,height:1,background:"linear-gradient(to right,#e2e8f0,transparent)",marginLeft:6}}/>
  </div>;
}
function TopIcon({icon,label,badge,amount,subText,color,alert,active,onClick}){
  // alert=赤強調 / active=展開中
  const bg=alert?"linear-gradient(135deg,#fef2f2,#fee2e2)":(active?"linear-gradient(135deg,#eff6ff,#dbeafe)":"#fff");
  const border=alert?"1.5px solid #fca5a5":(active?"1.5px solid #93c5fd":"1px solid #e5e7eb");
  return <div onClick={onClick} style={{
    background:bg,border:border,borderRadius:18,padding:"10px 4px",cursor:"pointer",
    boxShadow:active?"0 4px 12px rgba(59,130,246,.15)":"0 2px 5px rgba(0,0,0,.05)",
    textAlign:"center",position:"relative",minHeight:88,
    transition:"all .15s",userSelect:"none"
  }}>
    <div style={{fontSize:26,lineHeight:1.1}}>{icon}</div>
    <div style={{fontSize:10,fontWeight:700,marginTop:5,color:"#374151",lineHeight:1.2,padding:"0 2px"}}>{label}</div>
    {amount>0&&<div style={{fontSize:9,color:alert?"#991b1b":"#6b7280",marginTop:2,fontWeight:700}}>¥{amount.toLocaleString()}</div>}
    {subText&&!amount&&<div style={{fontSize:9,color:"#9ca3af",marginTop:2}}>{subText}</div>}
    {badge>0&&<div style={{
      position:"absolute",top:3,right:3,background:color||"#dc2626",color:"#fff",borderRadius:999,
      minWidth:18,height:18,padding:"0 5px",fontSize:9,fontWeight:800,
      display:"flex",alignItems:"center",justifyContent:"center",boxShadow:"0 1px 3px rgba(0,0,0,.25)"
    }}>{badge>99?"99+":badge}</div>}
  </div>;
}
function PaymentSection({sqfRefreshKey,onOpenSqFailed,setTab}){
  const[counts,setCounts]=useState({sqfCount:0,sqfTotal:0,extCount:0,extTotal:0,jalCount:0,jalUnpaid:0,sqiUnpaid:0,sqiUnpaidAmt:0});
  const[expanded,setExpanded]=useState(null);// 'extra'|'square'|'jalan'|null
  const load=async()=>{
    if(!sb)return;
    try{
      const[sqf,ext,sqi]=await Promise.all([
        sb.from("sq_terminal_failed").select("amount,note,item_name,reason,raw_data").eq("resolved",false),
        sb.from("bt_accounting").select("amount").eq("type","extra_sales").eq("paid",false),
        sb.from("bt_accounting").select("amount,resv_no,paid").not("url","is",null).neq("url","")
      ]);
      let jpd=[];try{jpd=await DB.fetchNhaJalanPayments();}catch(e){}
      const jalanResIds=new Set();
      const jalActive=(jpd||[]).filter(p=>["new","link_created","email_sent"].includes(p.status));
      const sqiData=(sqi.data||[]).filter(r=>!jalanResIds.has(r.resv_no));
      const sqiUnpaidArr=sqiData.filter(r=>!r.paid);
      // ★ TKM APP は札幌店レコードを集計から除外
      const sqfNha=(sqf.data||[]).filter(r=>_guessStore(r)!=="SPK");
      setCounts({
        sqfCount:sqfNha.length,
        sqfTotal:sqfNha.reduce((s,r)=>s+(+r.amount||0),0),
        extCount:(ext.data||[]).length,
        extTotal:(ext.data||[]).reduce((s,r)=>s+(+r.amount||0),0),
        jalCount:jalActive.length,
        jalUnpaid:jalActive.reduce((s,p)=>s+(+p.amount||0),0),
        sqiUnpaid:sqiUnpaidArr.length,
        sqiUnpaidAmt:sqiUnpaidArr.reduce((s,r)=>s+(+r.amount||0),0)
      });
    }catch(e){}
  };
  useEffect(()=>{load();},[sqfRefreshKey]);
  useEffect(()=>{const t=setInterval(load,60000);const onVis=()=>{if(document.visibilityState==="visible")load();};document.addEventListener("visibilitychange",onVis);return()=>{clearInterval(t);document.removeEventListener("visibilitychange",onVis);};},[]);
  const toggle=(k)=>setExpanded(e=>e===k?null:k);
  return <div style={{marginBottom:8}}>
    <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:6}}>
      <TopIcon icon="⚠️" label="Square起票仕訳" badge={counts.sqfCount} amount={counts.sqfTotal} color="#dc2626" alert={counts.sqfCount>0} subText={counts.sqfCount===0?"OK":""} onClick={onOpenSqFailed}/>
      <TopIcon icon="📝" label="予約外未収" badge={counts.extCount} amount={counts.extTotal} color="#f97316" alert={counts.extCount>0} subText={counts.extCount===0?"OK":""} active={expanded==="extra"} onClick={()=>toggle("extra")}/>
      <TopIcon icon="💳" label="Square請求" badge={counts.sqiUnpaid} amount={counts.sqiUnpaidAmt} color="#3b82f6" alert={counts.sqiUnpaid>0} subText={counts.sqiUnpaid===0?"全入金":""} active={expanded==="square"} onClick={()=>toggle("square")}/>
      <TopIcon icon="🟡" label="じゃらん事前" badge={counts.jalCount} amount={counts.jalUnpaid} color="#8b5cf6" alert={counts.jalCount>0} subText={counts.jalCount===0?"OK":""} active={expanded==="jalan"} onClick={()=>toggle("jalan")}/>
    </div>
    {expanded==="extra"&&<div style={{marginTop:6}}><ExtraUnpaidWidget/></div>}
    {expanded==="square"&&<div style={{marginTop:6}}><SquareInvoiceWidget/></div>}
    {expanded==="jalan"&&<div style={{marginTop:6}}><NhaJalanPaymentWidget onGoJalan={()=>setTab&&setTab("jalanpay")}/></div>}
  </div>;
}
function BusinessSection({data,vehicles,fleet,maintenance,onOpenBus,onOpenOil,onOpenIntake}){
  const[expanded,setExpanded]=useState(null);
  const[oilAlertCnt,setOilAlertCnt]=useState(0);
  useEffect(()=>{
    if(!sb||!(vehicles||[]).length)return;
    const OIL_WARN_DAYS=120,OIL_DANGER_DAYS=180;
    (async()=>{
      try{
        const[oilRes,twRes]=await Promise.all([
          sb.from("bt_vehicle_maintenance").select("vehicle_code,completed_date,odometer_km").eq("type","オイル交換").order("completed_date",{ascending:false}),
          sb.from("vehicle_twins").select("id,odometer").eq("store","takamatsu")
        ]);
        const oilMap={};(oilRes.data||[]).forEach(r=>{if(!oilMap[r.vehicle_code])oilMap[r.vehicle_code]=r;});
        const twMap={};(twRes.data||[]).forEach(t=>{if(t.odometer)twMap[t.id]=t.odometer;});
        let cnt=0;
        (vehicles||[]).forEach(v=>{
          const oil=oilMap[v.code];
          if(!oil){cnt++;return;} // 未記録
          const lastKm=Number(oil.odometer_km)||0;
          const curKm=twMap[v.code]||0;
          const days=oil.completed_date?Math.floor((new Date()-new Date(oil.completed_date))/(1000*60*60*24)):999;
          if(curKm>0&&curKm>lastKm&&(curKm-lastKm)>=9000){cnt++;return;}
          if(days>=OIL_WARN_DAYS)cnt++;
        });
        setOilAlertCnt(cnt);
      }catch(e){}
    })();
  },[vehicles]);
  // ざっくり集計（リードタイム件数 / 直近24h新規件数）
  const[ltCount,setLtCount]=useState(0);
  const[recCount,setRecCount]=useState({n:0,c:0});
  const[cxlCount,setCxlCount]=useState(0);// キャンセル総数
  useEffect(()=>{
    if(!data)return;
    // 配車待ち=fleetに無い未来予約
    const today=new Date();today.setHours(0,0,0,0);
    let waiting=0;
    (data||[]).forEach(r=>{
      if(r.status==="cancelled")return;
      const ld=new Date((r.lendDate||"")+"T00:00:00");
      if(isNaN(ld.getTime()))return;
      if(ld<today)return;
      if(!fleet||!fleet[r.id])waiting++;
    });
    setLtCount(waiting);
  },[data,fleet]);
  useEffect(()=>{
    if(!sb)return;
    (async()=>{
      try{
        const cutoff=new Date(Date.now()-24*3600000).toISOString();
        const[{data:n},{data:c}]=await Promise.all([
          sb.from("bt_reservations").select("id").gte("created_at",cutoff).neq("status","cancelled"),
          sb.from("bt_reservations").select("id").gte("created_at",cutoff).in("status",["cancelled","キャンセル","cancel"])
        ]);
        setRecCount({n:(n||[]).length,c:(c||[]).length});
      }catch(e){}
    })();
  },[]);
  useEffect(()=>{
    if(!sb)return;
    (async()=>{
      try{
        const{data}=await sb.from("bt_reservations").select("id").in("status",["cancelled","キャンセル","cancel"]);
        setCxlCount((data||[]).length);
      }catch(e){}
    })();
  },[]);
  const toggle=(k)=>setExpanded(e=>e===k?null:k);
  return <div style={{marginBottom:8}}>
    <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8}}>
      <TopIcon icon="📡" label="直近24h" badge={recCount.n} subText={"CXL "+recCount.c} color="#0891b2" active={expanded==="rec"} onClick={()=>toggle("rec")}/>
      <TopIcon icon="❌" label="キャンセル一覧" badge={cxlCount} subText="一覧/復元" color="#dc2626" active={expanded==="cxl"} onClick={()=>toggle("cxl")}/>
      <a href="inquiry.html" target="_blank" rel="noopener" style={{textDecoration:"none"}}>
        <TopIcon icon="📬" label="問い合わせ" subText="↗ 開く" color="#0ea5e9" onClick={()=>{}}/>
      </a>
      <a href="https://buddica-touring.github.io/damage/" target="_blank" rel="noopener" style={{textDecoration:"none"}}>
        <TopIcon icon="🚗" label="車両チェック" subText="↗ 開く" color="#dc2626" onClick={()=>{}}/>
      </a>
      {/* ★ バス運用廃止: バス運行表アイコン削除（ハイエース運用一本） */}
      <TopIcon icon="🔧" label="OIL交換" badge={oilAlertCnt} subText={oilAlertCnt>0?"要確認":"正常"} color="#ea580c" alert={oilAlertCnt>0} onClick={()=>onOpenOil&&onOpenOil()}/>
      {(()=>{const today=new Date().toISOString().slice(0,10);const pend=(maintenance||[]).filter(m=>(m.status||"pending")!=="approved"&&((m.endDate||m.startDate||"")>=today)).length;
        return <TopIcon icon="🏭" label="入庫" badge={pend} subText={pend>0?"FIX待ち":"OK"} color="#7c3aed" alert={pend>0} onClick={()=>onOpenIntake&&onOpenIntake()}/>;})()}
    </div>
    {expanded==="rec"&&<div style={{marginTop:6}}><TopRecentWidget/></div>}
    {expanded==="cxl"&&<div style={{marginTop:6}}><CancelListWidget onClose={()=>setExpanded(null)}/></div>}
  </div>;
}

function SqFailedWidget({onOpen,refreshKey}){
  const[items,setItems]=useState([]);
  const[lastAuto,setLastAuto]=useState(null);// 直近の自動起票時刻
  const[autoToday,setAutoToday]=useState({count:0,total:0});
  const load=async()=>{
    if(!sb)return;
    try{
      const{data:fails}=await sb.from("sq_terminal_failed").select("id,amount,payment_at,note,item_name,reason,raw_data").eq("resolved",false);
      // ★ TKM関連 + 不明 のみ表示（札幌キーワードを含むものは除外）
      const filtered=(fails||[]).filter(it=>_guessStore(it)!=="SPK");
      setItems(filtered);
      // 直近の自動起票（TKM/SPK 両方の最新）
      const todayJst=(()=>{const d=new Date();const y=d.getFullYear(),m=String(d.getMonth()+1).padStart(2,"0"),dd=String(d.getDate()).padStart(2,"0");return y+"-"+m+"-"+dd;})();
      const{data:tkm}=await sb.from("bt_accounting").select("created_at,amount").eq("input_by","Square自動").gte("date",todayJst).order("created_at",{ascending:false}).limit(50);
      const{data:spk}=await sb.from("spk_accounting").select("created_at,amount").eq("input_by","Square自動").gte("date",todayJst).order("created_at",{ascending:false}).limit(50);
      const all=[...(tkm||[]),...(spk||[])].sort((a,b)=>(b.created_at||"").localeCompare(a.created_at||""));
      setLastAuto(all.length>0?all[0].created_at:null);
      setAutoToday({count:all.length,total:all.reduce((s,r)=>s+(Number(r.amount)||0),0)});
    }catch(e){}
  };
  useEffect(()=>{load();},[refreshKey]);
  useEffect(()=>{const t=setInterval(load,60000);const onVis=()=>{if(document.visibilityState==="visible")load();};document.addEventListener("visibilitychange",onVis);return()=>{clearInterval(t);document.removeEventListener("visibilitychange",onVis);};},[]);
  const failCount=items.length;
  const failTotal=items.reduce((s,r)=>s+(Number(r.amount)||0),0);
  // GAS健全性: 直近自動起票からの経過時間
  const minutesSinceLastAuto=lastAuto?Math.floor((Date.now()-new Date(lastAuto).getTime())/60000):null;
  const stale=minutesSinceLastAuto===null||minutesSinceLastAuto>180;// 3時間以上更新なし
  // 失敗あり → 赤、なし → 緑（健全）or 黄（停滞）
  let bg,border,emoji,title,sub,badgeBg;
  if(failCount>0){
    bg="linear-gradient(135deg,#fef2f2,#fee2e2)";border="2px solid #fca5a5";emoji="⚠️";
    title="Square起票仕訳 （判断必要）";
    sub=failCount+"件 / 合計 ¥"+failTotal.toLocaleString()+" — タップで手動起票";
    badgeBg="#dc2626";
  }else if(stale){
    bg="linear-gradient(135deg,#fffbeb,#fef3c7)";border="2px solid #fcd34d";emoji="🔔";
    title="Square自動取込 — 更新停滞中";
    sub=lastAuto?"最終起票: "+Math.floor(minutesSinceLastAuto/60)+"時間"+(minutesSinceLastAuto%60)+"分前":"本日の自動起票なし";
    badgeBg="#d97706";
  }else{
    bg="linear-gradient(135deg,#ecfdf5,#d1fae5)";border="2px solid #6ee7b7";emoji="✅";
    title="Square自動取込 — 稼働中";
    sub="本日 "+autoToday.count+"件 / ¥"+autoToday.total.toLocaleString()+" 起票済 ／ "+(minutesSinceLastAuto<60?minutesSinceLastAuto+"分前":Math.floor(minutesSinceLastAuto/60)+"時間前")+"に最終起票";
    badgeBg="#059669";
  }
  return <div onClick={onOpen} style={{marginBottom:8,padding:"10px 14px",borderRadius:12,background:bg,border:border,cursor:"pointer",boxShadow:"0 2px 6px rgba(0,0,0,.08)"}}>
    <div style={{display:"flex",alignItems:"center",gap:10}}>
      <span style={{fontSize:20}}>{emoji}</span>
      <div style={{flex:1,minWidth:0}}>
        <div style={{fontSize:13,fontWeight:900,color:failCount>0?"#991b1b":(stale?"#92400e":"#065f46")}}>{title}</div>
        <div style={{fontSize:10,color:failCount>0?"#b91c1c":(stale?"#b45309":"#047857"),marginTop:2}}>{sub}</div>
      </div>
      <span style={{padding:"4px 10px",borderRadius:8,background:badgeBg,color:"#fff",fontSize:10,fontWeight:700,whiteSpace:"nowrap"}}>{failCount>0?failCount+"件":"+ 手動起票"}</span>
    </div>
  </div>;
}

// ★ 店舗推定: note / item_name / raw_data から札幌・香川キーワードで判定
function _guessStore(it){
  const txt=[it.note||"",it.item_name||"",it.reason||"",it.raw_data?(typeof it.raw_data==="string"?it.raw_data:JSON.stringify(it.raw_data)):""].join(" ");
  if(/^(SPK|spk)\s|札幌|さっぽろ|サッポロ/.test(txt))return"SPK";
  if(/^(TKM|tkm)\s|香川|高松|たかまつ|タカマツ/.test(txt))return"BT";
  return"UNKNOWN";
}
function SqFailedModal({onClose,onResolved}){
  const[items,setItems]=useState([]);
  const[loading,setLoading]=useState(true);
  const[sel,setSel]=useState(null);
  const[mode,setMode]=useState("list");// list / edit / manual
  const[form,setForm]=useState({store:"BT",category:"",type:"income",resvNo:"",description:"",staffName:"",memo:"",amount:"",date:"",payMethod:"カード"});
  const[busy,setBusy]=useState(false);
  // ★ Square payment_at は UTC で保存されているため JST に変換して表示
  const fmtJST=(iso)=>{
    if(!iso)return"";
    try{
      const d=new Date(iso);
      if(isNaN(d.getTime()))return String(iso).replace("T"," ").slice(0,16);
      // YYYY-MM-DD HH:mm (JST)
      return d.toLocaleString("sv-SE",{timeZone:"Asia/Tokyo",hour12:false}).slice(0,16);
    }catch(e){return String(iso).replace("T"," ").slice(0,16);}
  };
  const fmtJSTDate=(iso)=>{
    if(!iso)return new Date().toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});
    try{
      const d=new Date(iso);
      if(isNaN(d.getTime()))return String(iso).slice(0,10);
      return d.toLocaleDateString("sv-SE",{timeZone:"Asia/Tokyo"});
    }catch(e){return String(iso).slice(0,10);}
  };
  const load=async()=>{
    setLoading(true);
    try{
      const{data}=await sb.from("sq_terminal_failed").select("*").eq("resolved",false).order("payment_at",{ascending:false});
      // ★ TKM APP は札幌店レコードを完全除外（TKM + 不明 のみ表示）
      const filtered=(data||[]).filter(it=>_guessStore(it)!=="SPK");
      setItems(filtered);
    }catch(e){alert("読込エラー: "+e.message);}
    setLoading(false);
  };
  useEffect(()=>{load();},[]);
  const startManual=()=>{
    const today=new Date();const y=today.getFullYear();const m=String(today.getMonth()+1).padStart(2,"0");const d=String(today.getDate()).padStart(2,"0");
    setSel(null);
    setMode("manual");
    setForm({store:"BT",category:"",type:"income",resvNo:"",description:"",staffName:"",memo:"",amount:"",date:y+"-"+m+"-"+d,payMethod:"カード"});
  };
  const exclude=async(it)=>{
    // 除外（会計起票せず、失敗リストから外す）
    // 用途: テスト決済 / じゃらん現地決済（既に予約に紐付いてる） / その他「立替でも予約外でもない」決済
    const reasons=[
      "テスト決済（捨て打ち）",
      "じゃらん現地決済（予約に既に紐付き済）",
      "通常レンタカー料金（予約と紐付き済）",
      "重複決済（既に他で起票済）",
      "その他（理由を記載）"
    ];
    const choice=window.prompt(
      "¥"+(it.amount||0).toLocaleString()+" を会計起票せずに「除外」しますか？\n\n"
      +"除外理由を選んでください（番号を入力）:\n"
      +reasons.map((r,i)=>(i+1)+". "+r).join("\n")
      +"\n\n（キャンセルで中止）"
    );
    if(!choice)return;
    let reasonText="";
    const num=parseInt(choice,10);
    if(num>=1&&num<=reasons.length){
      reasonText=reasons[num-1];
      if(num===reasons.length){
        const extra=window.prompt("詳細理由を入力してください:");
        if(!extra)return;
        reasonText="その他: "+extra;
      }
    }else{
      reasonText="その他: "+choice;
    }
    const staffName=window.prompt("担当スタッフ名を入力してください（任意）:")||"";
    if(!window.confirm("¥"+(it.amount||0).toLocaleString()+" を「"+reasonText+"」で除外します。\n\n会計には起票されません。よろしいですか？"))return;
    try{
      const{error}=await sb.from("sq_terminal_failed").update({
        resolved:true,
        resolved_at:new Date().toISOString(),
        resolved_by:staffName,
        resolved_store:"EXCLUDED",
        resolved_accounting_id:null,
        resolved_memo:"除外: "+reasonText
      }).eq("id",it.id);
      if(error){alert("除外失敗: "+error.message);return;}
      await load();
      if(onResolved)onResolved();
    }catch(e){alert("エラー: "+e.message);}
  };
  const submitManual=async()=>{
    if(busy)return;
    if(!form.category){alert("科目（立替 / 予約外売上）を選択してください");return;}
    if(!form.description||!form.description.trim()){alert("摘要を入力してください");return;}
    const amt=Number(form.amount)||0;
    if(amt<=0){alert("金額を入力してください");return;}
    if(!form.date){alert("日付を入力してください");return;}
    if(!window.confirm("¥"+amt.toLocaleString()+" を「"+form.store+" / "+form.category+"」で会計に起票しますか？\n\n（手動入力）")){return;}
    setBusy(true);
    try{
      const tbl=form.store==="BT"?"bt_accounting":"spk_accounting";
      const acctId="sq-manual-"+Date.now().toString(36)+"-"+Math.random().toString(36).slice(2,8);
      const row={
        id:acctId,
        date:form.date,
        type:form.type,
        category:form.category,
        sub_category:"",
        description:form.description,
        amount:amt,
        input_by:"Square(手動入力)",
        memo:form.memo||"手動Square端末決済",
        pay_method:form.payMethod||"カード",
        resv_no:form.resvNo||"",
        paid:true,
        staff_name:form.staffName||""
      };
      const{error:e1}=await sb.from(tbl).insert(row);
      if(e1){alert("会計への起票失敗: "+e1.message);setBusy(false);return;}
      alert("✅ 起票完了: ¥"+amt.toLocaleString()+" "+form.store+" / "+form.category);
      setMode("list");
      await load();
      if(onResolved)onResolved();
      setBusy(false);
    }catch(e){alert("エラー: "+e.message);setBusy(false);}
  };
  const pick=(it)=>{
    setSel(it);
    const n=(it.note||"").trim();
    const m=n.match(/^(TKM|SPK|tkm|spk)[\s　]+(\S+)[\s　]+([\s\S]+)$/);
    let resvNo="",desc=n;
    if(m){
      resvNo=(m[2]==="なし"||m[2]==="無し"||m[2]==="-")?"":m[2];
      desc=m[3].replace(/[\s　]+/g," ").trim();
    }
    // ★ TKM APP は店舗を TKM 固定（札幌店は SPK APP で起票）
    setForm({store:"BT",category:"",type:"income",resvNo,description:desc,staffName:"",memo:""});
  };
  const submit=async()=>{
    if(!sel||busy)return;
    if(!form.category){alert("科目（立替 / 予約外売上）を選択してください");return;}
    if(!form.description||!form.description.trim()){alert("摘要を入力してください");return;}
    if(!window.confirm("¥"+sel.amount.toLocaleString()+" を「"+form.store+" / "+form.category+"」で会計に起票しますか？\n\n起票後は失敗リストから外れます。")){return;}
    setBusy(true);
    try{
      const tbl=form.store==="BT"?"bt_accounting":"spk_accounting";
      const acctId="sq-"+String(sel.id).slice(0,16)+"-"+Date.now().toString(36);
      const row={
        id:acctId,
        date:fmtJSTDate(sel.payment_at),
        type:form.type,
        category:form.category,
        sub_category:"",
        description:form.description,
        amount:sel.amount,
        input_by:"Square(手動復旧)",
        memo:"Square payment_id: "+sel.id+(form.memo?" / "+form.memo:""),
        pay_method:"カード",
        resv_no:form.resvNo||"",
        paid:true,
        staff_name:form.staffName||""
      };
      const{error:e1}=await sb.from(tbl).insert(row);
      if(e1){alert("会計への起票失敗: "+e1.message);setBusy(false);return;}
      const{error:e2}=await sb.from("sq_terminal_failed").update({
        resolved:true,
        resolved_at:new Date().toISOString(),
        resolved_by:form.staffName||"",
        resolved_store:form.store,
        resolved_accounting_id:acctId,
        resolved_memo:form.memo||""
      }).eq("id",sel.id);
      if(e2){alert("起票は成功しましたが失敗レコードのクローズに失敗: "+e2.message+"\n(管理者に連絡)");}
      setSel(null);
      await load();
      if(onResolved)onResolved();
      setBusy(false);
    }catch(e){alert("エラー: "+e.message);setBusy(false);}
  };
  return <div className="modal-overlay" onClick={onClose}>
    <div className="modal-box" onClick={e=>e.stopPropagation()} style={{maxWidth:820,maxHeight:"90vh",display:"flex",flexDirection:"column"}}>
      <div style={{padding:"14px 20px",borderBottom:"1px solid #e5e7eb",display:"flex",alignItems:"center",gap:10,flexShrink:0}}>
        <span style={{fontSize:20}}>{mode==="manual"?"📝":"⚠️"}</span>
        <div style={{flex:1}}>
          <div style={{fontWeight:800,fontSize:15,color:mode==="manual"?"#1e40af":"#991b1b"}}>{mode==="manual"?"Square端末決済 — 手動入力":"Square起票仕訳"}</div>
          <div style={{fontSize:10,color:"#6b7280",marginTop:2}}>{mode==="manual"?"GASが拾えなかった/拾い忘れたSquare端末決済を手動で会計起票します。":"お客様の決済は完了済み。会計未起票のリストです。1件ずつ店舗・科目を指定して起票してください。"}</div>
        </div>
        {mode==="list"&&<button onClick={startManual} className="btn-primary" style={{fontSize:11}}>+ 手動入力</button>}
        {mode==="manual"&&<button onClick={()=>setMode("list")} className="btn-ghost" style={{fontSize:11}}>← リスト</button>}
        <button onClick={onClose} className="btn-ghost">閉じる</button>
      </div>
      {/* 店舗切り分け: TKM APP は高松店 + 不明レコードのみ表示。札幌店レコードは完全に非表示。 */}
      <div style={{flex:1,overflow:"auto",padding:"14px 18px"}}>
        {mode==="manual"?<div>
          <div style={{background:"#eff6ff",border:"1px solid #bfdbfe",borderRadius:8,padding:"10px 12px",marginBottom:14,fontSize:11,color:"#1e3a8a"}}>
            ℹ️ Square端末で決済したが自動起票されていない場合に使用。<br/>
            金額・日付・店舗・科目を入力 → 会計に直接起票します。Square自動取込との重複に注意してください。
          </div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(2,1fr)",gap:10}}>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>店舗<input type="text" value="TKM（BUDDICA TOURISM 高松空港店）" disabled className="input-s" style={{marginTop:3,background:"#f3f4f6",color:"#6b7280"}}/></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>科目 <span style={{color:"#dc2626"}}>*</span><select value={form.category} onChange={e=>setForm({...form,category:e.target.value})} className="input-s" style={{marginTop:3,border:form.category?"1px solid #d1d5db":"2px solid #dc2626",background:form.category?"#fff":"#fef2f2"}}>
              <option value="">-- 選択してください --</option>
              <option value="立替">立替</option>
              <option value="予約外売上">予約外売上</option>
            </select></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>金額 <span style={{color:"#dc2626"}}>*</span><input type="number" value={form.amount} onChange={e=>setForm({...form,amount:e.target.value})} placeholder="例: 3500" className="input-s" style={{marginTop:3,border:form.amount?"1px solid #d1d5db":"2px solid #dc2626",background:form.amount?"#fff":"#fef2f2"}}/></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>日付 <span style={{color:"#dc2626"}}>*</span><input type="date" value={form.date} onChange={e=>setForm({...form,date:e.target.value})} className="input-s" style={{marginTop:3}}/></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>区分<select value={form.type} onChange={e=>setForm({...form,type:e.target.value})} className="input-s" style={{marginTop:3}}>
              <option value="income">収入</option>
              <option value="expense">支出</option>
            </select></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>支払方法<select value={form.payMethod} onChange={e=>setForm({...form,payMethod:e.target.value})} className="input-s" style={{marginTop:3}}>
              <option value="カード">カード</option>
              <option value="現金">現金</option>
              <option value="その他">その他</option>
            </select></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>予約番号（任意）<input value={form.resvNo} onChange={e=>setForm({...form,resvNo:e.target.value})} placeholder="例: R0IPN7SD" className="input-s" style={{marginTop:3}}/></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>担当スタッフ<input value={form.staffName} onChange={e=>setForm({...form,staffName:e.target.value})} placeholder="例: 大下" className="input-s" style={{marginTop:3}}/></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151",gridColumn:"span 2"}}>摘要 <span style={{color:"#dc2626"}}>*</span><input value={form.description} onChange={e=>setForm({...form,description:e.target.value})} placeholder="例: ガソリン代 / 延長料金1日分 / オプション追加" className="input-s" style={{marginTop:3,border:form.description?"1px solid #d1d5db":"2px solid #dc2626",background:form.description?"#fff":"#fef2f2"}}/></label>
            <label style={{fontSize:11,fontWeight:700,color:"#374151",gridColumn:"span 2"}}>補足メモ<input value={form.memo} onChange={e=>setForm({...form,memo:e.target.value})} placeholder="（任意）" className="input-s" style={{marginTop:3}}/></label>
          </div>
          <div style={{display:"flex",gap:10,marginTop:16,justifyContent:"flex-end"}}>
            <button onClick={()=>setMode("list")} className="btn-ghost" disabled={busy}>キャンセル</button>
            <button onClick={submitManual} disabled={busy||!form.category||!form.amount||!form.description||!form.date} className="btn-primary" style={{opacity:(busy||!form.category||!form.amount||!form.description||!form.date)?0.5:1}}>{busy?"起票中...":"📝 "+form.store+" / "+(form.category||"科目未選択")+" で起票"}</button>
          </div>
        </div>:
        loading?<div style={{textAlign:"center",padding:40,color:"#94a3b8"}}>読込中...</div>:
         items.length===0?<div style={{textAlign:"center",padding:40}}>
           <div style={{color:"#059669",fontWeight:700,fontSize:14,marginBottom:8}}>✅ 失敗レコードはありません</div>
           <div style={{color:"#64748b",fontSize:11,marginBottom:16}}>Square自動取込は正常に動作しています。<br/>もし自動で拾えなかった決済があれば、上の「+ 手動入力」から登録してください。</div>
           <button onClick={startManual} className="btn-primary" style={{fontSize:12}}>+ 手動入力で起票</button>
         </div>:
         !sel?<div>
           <div style={{fontSize:11,color:"#64748b",marginBottom:8}}>起票する行を選んでください（{items.length}件）</div>
           <div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:12,minWidth:680}}>
             <thead style={{background:"#f8fafc"}}><tr>
               <th style={{padding:"6px 8px",textAlign:"left",borderBottom:"1px solid #e5e7eb",fontSize:10}}>決済日時</th>
               <th style={{padding:"6px 8px",textAlign:"right",borderBottom:"1px solid #e5e7eb",fontSize:10}}>金額</th>
               <th style={{padding:"6px 8px",textAlign:"left",borderBottom:"1px solid #e5e7eb",fontSize:10}}>商品</th>
               <th style={{padding:"6px 8px",textAlign:"left",borderBottom:"1px solid #e5e7eb",fontSize:10}}>メモ</th>
               <th style={{padding:"6px 8px",textAlign:"left",borderBottom:"1px solid #e5e7eb",fontSize:10}}>理由</th>
               <th style={{padding:"6px 8px",borderBottom:"1px solid #e5e7eb"}}></th>
             </tr></thead>
             <tbody>
               {items.map(it=><tr key={it.id} style={{borderBottom:"1px solid #f1f5f9"}}>
                 <td style={{padding:"6px 8px",fontSize:10,color:"#374151",whiteSpace:"nowrap"}}>{fmtJST(it.payment_at)}</td>
                 <td style={{padding:"6px 8px",textAlign:"right",fontWeight:700,color:"#991b1b"}}>¥{(it.amount||0).toLocaleString()}</td>
                 <td style={{padding:"6px 8px",fontSize:11}}>{it.item_name||"-"}</td>
                 <td style={{padding:"6px 8px",fontSize:10,maxWidth:220,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{it.note||<span style={{color:"#dc2626",fontWeight:700}}>空</span>}</td>
                 <td style={{padding:"6px 8px",fontSize:10,color:"#b91c1c",maxWidth:180,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{it.reason||"-"}</td>
                 <td style={{padding:"6px 8px",whiteSpace:"nowrap"}}>
                   <div style={{display:"flex",gap:4,justifyContent:"flex-end"}}>
                     <button className="btn-primary" style={{padding:"4px 10px",fontSize:11}} onClick={()=>pick(it)}>起票へ</button>
                     <button style={{padding:"4px 10px",fontSize:11,background:"#fff",border:"1px solid #cbd5e1",borderRadius:8,color:"#64748b",cursor:"pointer",fontWeight:600}} onClick={()=>exclude(it)} title="会計起票せず除外（テスト決済・じゃらん現地決済等）">除外</button>
                   </div>
                 </td>
               </tr>)}
             </tbody>
           </table></div>
         </div>:
         <div>
           <button onClick={()=>setSel(null)} className="btn-ghost" style={{marginBottom:10,fontSize:11}}>← リストに戻る</button>
           <div style={{background:"#fef2f2",border:"1px solid #fca5a5",borderRadius:8,padding:"10px 12px",marginBottom:14}}>
             <div style={{fontSize:10,color:"#6b7280"}}>Square決済</div>
             <div style={{display:"flex",gap:16,alignItems:"center",marginTop:4,flexWrap:"wrap"}}>
               <div style={{fontSize:18,fontWeight:900,color:"#991b1b"}}>¥{(sel.amount||0).toLocaleString()}</div>
               <div style={{fontSize:11,color:"#374151"}}>{fmtJST(sel.payment_at)}</div>
               <div style={{fontSize:11,color:"#374151"}}>商品: <b>{sel.item_name||"-"}</b></div>
             </div>
             <div style={{fontSize:11,color:"#374151",marginTop:4}}>メモ: {sel.note?<span style={{fontFamily:"monospace"}}>{sel.note}</span>:<span style={{color:"#dc2626",fontWeight:700}}>空</span>}</div>
             <div style={{fontSize:10,color:"#9ca3af",marginTop:2,fontFamily:"monospace"}}>payment_id: {sel.id}</div>
             <div style={{fontSize:10,color:"#b91c1c",marginTop:2}}>失敗理由: {sel.reason||"-"}</div>
           </div>
           <div style={{display:"grid",gridTemplateColumns:"repeat(2,1fr)",gap:10}}>
             <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>店舗<input type="text" value="TKM（BUDDICA TOURISM 高松空港店）" disabled className="input-s" style={{marginTop:3,background:"#f3f4f6",color:"#6b7280"}}/></label>
             <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>科目 <span style={{color:"#dc2626"}}>*</span><select value={form.category} onChange={e=>setForm({...form,category:e.target.value})} className="input-s" style={{marginTop:3,border:form.category?"1px solid #d1d5db":"2px solid #dc2626",background:form.category?"#fff":"#fef2f2"}}>
               <option value="">-- 選択してください --</option>
               <option value="立替">立替</option>
               <option value="予約外売上">予約外売上</option>
             </select></label>
             <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>区分<select value={form.type} onChange={e=>setForm({...form,type:e.target.value})} className="input-s" style={{marginTop:3}}>
               <option value="income">収入</option>
               <option value="expense">支出</option>
             </select></label>
             <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>予約番号（任意）<input value={form.resvNo} onChange={e=>setForm({...form,resvNo:e.target.value})} placeholder="例: R0IPN7SD（なしで空白）" className="input-s" style={{marginTop:3}}/></label>
             <label style={{fontSize:11,fontWeight:700,color:"#374151",gridColumn:"span 2"}}>摘要 <span style={{color:"#dc2626"}}>*</span><input value={form.description} onChange={e=>setForm({...form,description:e.target.value})} placeholder="ガソリン代 / 延長料金1日分 など" className="input-s" style={{marginTop:3}}/></label>
             <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>担当スタッフ<input value={form.staffName} onChange={e=>setForm({...form,staffName:e.target.value})} placeholder="例: 大下" className="input-s" style={{marginTop:3}}/></label>
             <label style={{fontSize:11,fontWeight:700,color:"#374151"}}>補足メモ<input value={form.memo} onChange={e=>setForm({...form,memo:e.target.value})} placeholder="（任意）" className="input-s" style={{marginTop:3}}/></label>
           </div>
           <div style={{display:"flex",gap:10,marginTop:16,justifyContent:"space-between",alignItems:"center"}}>
             <button onClick={()=>{exclude(sel);setSel(null);}} disabled={busy} style={{padding:"6px 14px",fontSize:12,background:"#fff",border:"1px solid #cbd5e1",borderRadius:8,color:"#64748b",cursor:"pointer",fontWeight:600}} title="会計起票せず除外（テスト決済・じゃらん現地決済等）">🚫 除外</button>
             <div style={{display:"flex",gap:10}}>
               <button onClick={()=>setSel(null)} className="btn-ghost" disabled={busy}>キャンセル</button>
               <button onClick={submit} disabled={busy||!form.category} className="btn-primary" style={{opacity:busy||!form.category?0.5:1}}>{busy?"起票中...":form.category?"📝 "+form.store+" / "+form.category+" で起票":"科目を選択してください"}</button>
             </div>
           </div>
         </div>}
      </div>
    </div>
  </div>;
}

/* ==========================================
   じゃらん決済確認
   ========================================== */
/* ==========================================
   じゃらん事前決済ウィジェット（TOP用）
   ========================================== */
function NhaJalanPaymentWidget({onGoJalan}){
  const[jpNew,setJpNew]=useState([]);
  useEffect(()=>{(async()=>{try{const d=await DB.fetchNhaJalanPayments();setJpNew(d);}catch(e){}})();},[]);
  const counts={};jpNew.forEach(p=>{counts[p.status]=(counts[p.status]||0)+1;});
  const total=jpNew.length;
  const needAction=(counts.new||0)+(counts.link_created||0)+(counts.email_sent||0);
  // 未入金金額合計（new/link_created/email_sent の amount 合算）
  const unpaidTotal=jpNew.filter(p=>["new","link_created","email_sent"].includes(p.status)).reduce((s,p)=>s+(Number(p.amount)||0),0);
  const paidTotal=jpNew.filter(p=>p.status==="paid").reduce((s,p)=>s+(Number(p.amount)||0),0);
  // 出発3日前未決済アラート
  const todayMs=(()=>{const d=new Date();return new Date(d.getFullYear(),d.getMonth(),d.getDate()).getTime();})();
  const alerts=jpNew.filter(p=>{
    if(!p.lend_date)return false;
    if(!["new","link_created","email_sent"].includes(p.status))return false;
    const ld=new Date(p.lend_date+"T00:00:00").getTime();
    return Math.ceil((ld-todayMs)/86400000)<=3;
  }).sort((a,b)=>(a.lend_date||"").localeCompare(b.lend_date||""));
  return <>
    {alerts.length>0&&<div onClick={onGoJalan} style={{marginBottom:8,padding:"10px 14px",borderRadius:12,background:"linear-gradient(135deg,#fef2f2,#fee2e2)",border:"2px solid #fca5a5",cursor:"pointer",boxShadow:"0 2px 6px rgba(220,38,38,.15)"}}>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6}}>
        <span style={{fontSize:16}}>🚨</span>
        <div style={{fontSize:12,fontWeight:800,color:"#991b1b",flex:1}}>じゃらん事前決済 出発3日前 未決済</div>
        <span style={{padding:"2px 8px",borderRadius:8,background:"#dc2626",color:"#fff",fontSize:10,fontWeight:700}}>{alerts.length}件</span>
      </div>
      <div style={{display:"flex",flexDirection:"column",gap:3}}>
        {alerts.map(p=>{
          const ld=new Date(p.lend_date+"T00:00:00").getTime();
          const days=Math.ceil((ld-todayMs)/86400000);
          const dayLabel=days<=0?"🚨当日/超過":"あと"+days+"日";
          return <div key={p.id} style={{display:"flex",gap:8,alignItems:"center",fontSize:11,padding:"4px 8px",background:"#fff",borderRadius:6,flexWrap:"wrap"}}>
            <span style={{fontFamily:"monospace",fontSize:10,fontWeight:700,color:"#991b1b"}}>{p.reservation_id}</span>
            <span style={{fontWeight:700,color:"#1e293b"}}>{p.customer_name||"-"}</span>
            <span style={{color:"#64748b",fontSize:10}}>{p.lend_date}</span>
            <span style={{marginLeft:"auto",fontSize:10,fontWeight:700,color:days<=0?"#991b1b":"#b45309",whiteSpace:"nowrap"}}>{dayLabel}</span>
          </div>;
        })}
      </div>
    </div>}
    <div onClick={onGoJalan} style={{marginBottom:8,padding:"10px 14px",borderRadius:12,background:"linear-gradient(135deg,#fdf2f8,#fce7f3)",border:"1px solid #fbcfe8",cursor:"pointer",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
      <div style={{display:"flex",alignItems:"center",gap:8}}>
        <span style={{fontSize:16}}>💳</span>
        <div style={{flex:1}}>
          <div style={{fontSize:12,fontWeight:800,color:"#9d174d"}}>じゃらん事前決済</div>
          <div style={{fontSize:10,color:"#be185d"}}>{total===0?"じゃらん予約が来ると自動で表示されます":total+"件 / 入金済"+(counts.paid||0)+"件"}</div>
          {total>0&&<div style={{display:"flex",gap:10,marginTop:4,flexWrap:"wrap"}}>
            {unpaidTotal>0&&<span style={{fontSize:11,fontWeight:800,color:"#dc2626"}}>未入金 ¥{unpaidTotal.toLocaleString()}</span>}
            {paidTotal>0&&<span style={{fontSize:11,fontWeight:700,color:"#059669"}}>入金済 ¥{paidTotal.toLocaleString()}</span>}
          </div>}
        </div>
        {needAction>0&&<span style={{padding:"4px 10px",borderRadius:8,background:"#dc2626",color:"#fff",fontSize:10,fontWeight:700}}>{needAction}件 要対応</span>}
      </div>
    </div>
  </>;
}

/* ==========================================
   じゃらん事前決済（新システム）
   ========================================== */
function NhaJalanPaymentNew(){
  const[payments,setPayments]=useState([]);
  const[loading,setLoading]=useState(true);
  const[filter,setFilter]=useState("all");
  const[editMemoId,setEditMemoId]=useState(null);
  const[memoText,setMemoText]=useState("");
  const[sortKey,setSortKey]=useState("lend_date");
  const[sortAsc,setSortAsc]=useState(true);
  const toggleSort=(k)=>{if(sortKey===k)setSortAsc(a=>!a);else{setSortKey(k);setSortAsc(true);}};
  const sIcon=(k)=>sortKey===k?(sortAsc?"▲":"▼"):"↕";
  const STATUS_ORD={new:0,link_created:1,email_sent:2,paid:3,cancelled:4,refund:5,refunded:6};
  const load=async()=>{const d=await DB.fetchNhaJalanPayments();setPayments(d);setLoading(false);};
  useEffect(()=>{load();},[]);
  useEffect(()=>{
    const onVis=()=>{if(document.visibilityState==="visible")load();};
    document.addEventListener("visibilitychange",onVis);
    const timer=setInterval(()=>{if(document.visibilityState==="visible")load();},30000);
    return()=>{document.removeEventListener("visibilitychange",onVis);clearInterval(timer);};
  },[]);
  const statusMeta={
    new:{label:"新規",bg:"#f1f5f9",c:"#475569"},
    link_created:{label:"リンク作成済",bg:"#dbeafe",c:"#1d4ed8"},
    email_sent:{label:"メール送信済",bg:"#fef3c7",c:"#92400e"},
    paid:{label:"入金済",bg:"#dcfce7",c:"#166534"},
    cancelled:{label:"キャンセル",bg:"#fef2f2",c:"#dc2626"},
    refund:{label:"返金待ち",bg:"#ffedd5",c:"#c2410c"},
    refunded:{label:"返金済",bg:"#f3e8ff",c:"#7c3aed"}
  };
  const filtered=useMemo(()=>{
    const base=filter==="all"?payments:payments.filter(p=>p.status===filter);
    return [...base].sort((a,b)=>{
      let va,vb;
      if(sortKey==="amount"){va=a.amount||0;vb=b.amount||0;}
      else if(sortKey==="status"){va=STATUS_ORD[a.status]??99;vb=STATUS_ORD[b.status]??99;}
      else if(sortKey==="lend_date"){va=a.lend_date||"";vb=b.lend_date||"";}
      else if(sortKey==="created_at"){va=a.created_at||"";vb=b.created_at||"";}
      else return 0;
      if(va<vb)return sortAsc?-1:1;if(va>vb)return sortAsc?1:-1;return 0;
    });
  },[payments,filter,sortKey,sortAsc]);
  const counts={};payments.forEach(p=>{counts[p.status]=(counts[p.status]||0)+1;});
  const saveMemo=async(id)=>{await DB.updateNhaJalanPaymentMemo(id,memoText);setEditMemoId(null);load();};
  const cardS={background:"#fff",borderRadius:14,border:"1px solid #e2e8f0",boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const thS=(k,sortable)=>({padding:"6px 8px",textAlign:"left",fontWeight:700,fontSize:10,color:sortable?"#1e40af":"#475569",borderBottom:"2px solid #e2e8f0",whiteSpace:"nowrap",cursor:sortable?"pointer":"default",userSelect:"none",background:sortKey===k?"#eff6ff":"transparent"});
  if(loading)return <div style={{textAlign:"center",padding:40,color:"#94a3b8"}}>読込中...</div>;
  return <div>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>じゃらん事前決済</h3>
      <div style={{display:"flex",gap:6,fontSize:10,fontWeight:700}}>
        <span style={{padding:"2px 8px",borderRadius:8,background:"#dcfce7",color:"#166534"}}>入金済 {counts.paid||0}</span>
        <span style={{padding:"2px 8px",borderRadius:8,background:"#fef3c7",color:"#92400e"}}>処理中 {(counts.new||0)+(counts.link_created||0)+(counts.email_sent||0)}</span>
        <span style={{padding:"2px 8px",borderRadius:8,background:"#fef2f2",color:"#dc2626"}}>CXL {(counts.cancelled||0)+(counts.refund||0)+(counts.refunded||0)}</span>
      </div>
    </div>
    <div style={{display:"flex",gap:4,marginBottom:10,flexWrap:"wrap"}}>
      {[{k:"all",l:"全て("+payments.length+")"},...Object.entries(statusMeta).map(([k,v])=>({k,l:v.label+"("+(counts[k]||0)+")"}))].map(f=>
        <button key={f.k} onClick={()=>setFilter(f.k)} style={{padding:"3px 10px",borderRadius:6,border:filter===f.k?"2px solid #2563eb":"1px solid #d1d5db",background:filter===f.k?"#eff6ff":"#fff",fontSize:10,fontWeight:600,cursor:"pointer",color:filter===f.k?"#1d4ed8":"#64748b"}}>{f.l}</button>
      )}
    </div>
    {filtered.length===0?<div style={{...cardS,padding:24,textAlign:"center",color:"#94a3b8",fontSize:13}}>該当データなし</div>:
    <div style={{...cardS,overflow:"hidden"}}><div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
      <thead><tr style={{background:"#f8fafc"}}>
        <th style={thS(null,false)}>予約番号</th>
        <th style={thS(null,false)}>顧客名</th>
        <th style={thS("amount",true)} onClick={()=>toggleSort("amount")}>金額 {sIcon("amount")}</th>
        <th style={thS("status",true)} onClick={()=>toggleSort("status")}>ステータス {sIcon("status")}</th>
        <th style={thS(null,false)}>Squareリンク</th>
        <th style={thS("lend_date",true)} onClick={()=>toggleSort("lend_date")}>利用期間 {sIcon("lend_date")}</th>
        <th style={thS("created_at",true)} onClick={()=>toggleSort("created_at")}>作成日 {sIcon("created_at")}</th>
        <th style={thS(null,false)}>メモ</th>
      </tr></thead>
      <tbody>{filtered.map(p=>{
        const sm=statusMeta[p.status]||statusMeta.new;
        return <tr key={p.id} style={{borderBottom:"1px solid #f1f5f9"}}>
          <td style={{padding:"4px 8px",fontFamily:"monospace",fontSize:10,fontWeight:600}}>{p.reservation_id}</td>
          <td style={{padding:"4px 8px",fontWeight:600}}>{p.customer_name||"-"}</td>
          <td style={{padding:"4px 8px",fontWeight:700,color:"#1e40af"}}>{"\u00A5"}{(p.amount||0).toLocaleString()}</td>
          <td style={{padding:"4px 8px"}}><span style={{fontSize:9,fontWeight:700,padding:"2px 8px",borderRadius:4,background:sm.bg,color:sm.c}}>{sm.label}</span></td>
          <td style={{padding:"4px 8px",fontSize:10}}>{p.square_payment_url?<a href={p.square_payment_url} target="_blank" rel="noreferrer" style={{color:"#2563eb"}}>リンク</a>:"-"}</td>
          <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.lend_date||"-"}{p.lend_date&&p.return_date?" ~ ":""}{p.return_date||""}{(()=>{
            if(!p.lend_date||["paid","cancelled","refund","refunded"].includes(p.status))return null;
            const ld=new Date(p.lend_date+"T00:00:00");const now=new Date();
            const days=Math.ceil((ld-new Date(now.getFullYear(),now.getMonth(),now.getDate()))/86400000);
            const c=days<=3?"#dc2626":days<=7?"#d97706":"#64748b";
            const bg=days<=3?"#fee2e2":days<=7?"#fef3c7":"#f1f5f9";
            return <span style={{marginLeft:4,fontSize:8,fontWeight:700,color:c,background:bg,padding:"1px 5px",borderRadius:4}}>{days<=0?"当日/超過":"あと"+days+"日"}</span>;
          })()}</td>
          <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.created_at?new Date(p.created_at).toLocaleDateString("ja-JP"):"-"}</td>
          <td style={{padding:"4px 8px",fontSize:10}}>{editMemoId===p.id?<div style={{display:"flex",gap:4}}><input value={memoText} onChange={e=>setMemoText(e.target.value)} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:100}}/><button onClick={()=>saveMemo(p.id)} style={{fontSize:9,padding:"2px 6px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",cursor:"pointer"}}>保存</button><button onClick={()=>setEditMemoId(null)} style={{fontSize:9,padding:"2px 6px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer"}}>x</button></div>:<span onClick={()=>{setEditMemoId(p.id);setMemoText(p.memo||"");}} style={{cursor:"pointer",color:p.memo?"#1e293b":"#94a3b8"}}>{p.memo||"クリックで入力"}</span>}</td>
        </tr>;
      })}</tbody>
    </table></div></div>}
  </div>;
}

/* ==========================================
   じゃらん決済（タブ切替: 新システム + 旧データ）
   ========================================== */
function JalanPayment({data,jalanPay,onJalanPayChange}){
  const[viewTab,setViewTab]=useState("new");
  return <div style={{maxWidth:900,margin:"0 auto"}}>
    <div style={{display:"flex",gap:8,marginBottom:12}}>
      <button onClick={()=>setViewTab("new")} style={{padding:"6px 16px",borderRadius:8,border:viewTab==="new"?"2px solid #2563eb":"1px solid #d1d5db",background:viewTab==="new"?"#eff6ff":"#fff",color:viewTab==="new"?"#1d4ed8":"#64748b",fontSize:12,fontWeight:700,cursor:"pointer"}}>新システム（自動）</button>
      <button onClick={()=>setViewTab("legacy")} style={{padding:"6px 16px",borderRadius:8,border:viewTab==="legacy"?"2px solid #f59e0b":"1px solid #d1d5db",background:viewTab==="legacy"?"#fffbeb":"#fff",color:viewTab==="legacy"?"#92400e":"#64748b",fontSize:12,fontWeight:700,cursor:"pointer"}}>旧データ（手動消し込み）</button>
    </div>
    {viewTab==="new"?<NhaJalanPaymentNew/>:<JalanPaymentLegacy data={data} jalanPay={jalanPay} onJalanPayChange={onJalanPayChange}/>}
  </div>;
}

function JalanPaymentLegacy({data,jalanPay,onJalanPayChange}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({});
  const[sheetLoading,setSheetLoading]=useState(false);
  const jData=useMemo(()=>data.filter(r=>r.ota==="J"&&r.status!=="cancelled").sort((a,b)=>(b.lendDate||"").localeCompare(a.lendDate||"")),[data]);
  const startEdit=(id)=>{const existing=jalanPay[id]||{};const res=jData.find(r=>r.id===id);setEditId(id);setForm({category:existing.category||"売上",payStatus:existing.payStatus||"未完了",sendDate:existing.sendDate||"",refundDate:existing.refundDate||"",content:existing.content||"",linkUrl:existing.linkUrl||"",adjustedPrice:existing.adjustedPrice||(res?String(res.finalPrice||res.price||""):"")});};
  const saveEdit=()=>{if(!editId)return;onJalanPayChange(editId,form);setEditId(null);};
  const cancelEdit=()=>{setEditId(null);setForm({});};
  const summary=useMemo(()=>{const done=jData.filter(r=>(jalanPay[r.id]?.payStatus)==="完了").length;return{total:jData.length,done,undone:jData.length-done};},[jData,jalanPay]);
  const cardS={background:"#fff",borderRadius:14,border:"1px solid #e2e8f0",boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const fetchFromSheet=async()=>{
    const resIds=jData.map(r=>r.id);
    if(!resIds.length){alert("じゃらん予約がありません");return;}
    setSheetLoading(true);
    try{
      const payMap=await fetchJalanPaySheetData(resIds);
      const matched=Object.keys(payMap).length;
      if(!matched){setSheetLoading(false);alert("該当する予約番号がスプレッドシートに見つかりませんでした");return;}
      let updated=0;
      Object.entries(payMap).forEach(([rid,pd])=>{
        const existing=jalanPay[rid]||{};
        onJalanPayChange(rid,{...existing,adjustedPrice:pd.adjustedPrice,payStatus:pd.payStatus});
        updated++;
      });
      alert(`${matched}件中 ${updated}件の支払データを反映しました`);
    }catch(e){alert("取得エラー: "+e.message);}
    setSheetLoading(false);
  };

  return <div style={{maxWidth:800,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>じゃらん決済確認（旧）</h3>
      <div style={{display:"flex",gap:8,fontSize:11,fontWeight:700,alignItems:"center"}}>
        <button onClick={fetchFromSheet} disabled={sheetLoading} style={{padding:"4px 12px",borderRadius:8,background:sheetLoading?"#94a3b8":"#7c3aed",color:"#fff",border:"none",fontSize:11,fontWeight:700,cursor:sheetLoading?"not-allowed":"pointer"}}>{sheetLoading?"取得中...":"📊 スプレッドシート取得"}</button>
        <span style={{padding:"2px 10px",borderRadius:10,background:"#f0fdf4",color:"#059669"}}>完了 {summary.done}</span>
        <span style={{padding:"2px 10px",borderRadius:10,background:"#fef2f2",color:"#dc2626"}}>未完了 {summary.undone}</span>
      </div>
    </div>
    {jData.length===0&&<div style={{...cardS,padding:24,textAlign:"center",color:"#94a3b8",fontSize:13}}>じゃらんの予約データがありません</div>}
    {jData.length>0&&<div style={{...cardS,overflow:"hidden"}}>
      <div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
        <thead><tr style={{background:"#fdf2f8"}}>
          {["予約番号","予約者","貸出日","請求金額","差引請求金額","分類","支払確認","送付日","返金日","予約内容","リンク","操作"].map(h=><th key={h} style={{padding:"6px 8px",textAlign:"left",fontWeight:700,fontSize:10,color:"#9d174d",borderBottom:"2px solid #fbcfe8",whiteSpace:"nowrap"}}>{h}</th>)}
        </tr></thead>
        <tbody>{jData.map((r,ri)=>{
          const p=jalanPay[r.id]||{};
          const isDone=p.payStatus==="完了";
          const isEdit=editId===r.id;
          return <tr key={r.id} style={{background:isDone?"#f0fdf4":ri%2===0?"#fff":"#fafbfc",borderBottom:"1px solid #f1f5f9"}}>
            <td style={{padding:"4px 8px",fontFamily:"monospace",fontSize:9,fontWeight:600}}>{r.id}</td>
            <td style={{padding:"4px 8px",fontWeight:600}}>{r.name}</td>
            <td style={{padding:"4px 8px",fontSize:10,color:"#475569"}}>{r.lendDate||"-"}</td>
            <td style={{padding:"4px 8px",fontWeight:700,color:"#1e40af"}}>¥{(r.price||0).toLocaleString()}</td>
            {isEdit?<>
              <td style={{padding:"2px 4px"}}><input type="number" value={form.adjustedPrice||""} onChange={e=>setForm(f=>({...f,adjustedPrice:e.target.value}))} placeholder="金額" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:80}}/></td>
              <td style={{padding:"2px 4px"}}><select value={form.category||"売上"} onChange={e=>setForm(f=>({...f,category:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db"}}><option>売上</option><option>立替</option></select></td>
              <td style={{padding:"2px 4px"}}><select value={form.payStatus||"未完了"} onChange={e=>setForm(f=>({...f,payStatus:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db"}}><option>完了</option><option>未完了</option></select></td>
              <td style={{padding:"2px 4px"}}><input type="date" value={form.sendDate||""} onChange={e=>setForm(f=>({...f,sendDate:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:110}}/></td>
              <td style={{padding:"2px 4px"}}><input type="date" value={form.refundDate||""} onChange={e=>setForm(f=>({...f,refundDate:e.target.value}))} style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:110}}/></td>
              <td style={{padding:"2px 4px"}}><input value={form.content||""} onChange={e=>setForm(f=>({...f,content:e.target.value}))} placeholder="予約内容" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:100}}/></td>
              <td style={{padding:"2px 4px"}}><input value={form.linkUrl||""} onChange={e=>setForm(f=>({...f,linkUrl:e.target.value}))} placeholder="URL" style={{fontSize:10,padding:"2px 4px",borderRadius:4,border:"1px solid #d1d5db",width:80}}/></td>
              <td style={{padding:"2px 4px",whiteSpace:"nowrap"}}><button onClick={saveEdit} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer",marginRight:4}}>保存</button><button onClick={cancelEdit} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer"}}>取消</button></td>
            </>:<>
              <td style={{padding:"4px 8px",fontWeight:700,color:(p.adjustedPrice||r.finalPrice||r.price)?"#7c3aed":"#94a3b8"}}>{(()=>{const fp=Number(p.adjustedPrice)||r.finalPrice||r.price||0;return fp?("¥"+fp.toLocaleString()):"-";})()}</td>
              <td style={{padding:"4px 8px"}}><span style={{fontSize:10,fontWeight:600,padding:"1px 6px",borderRadius:4,background:p.category==="立替"?"#fef3c7":"#dbeafe",color:p.category==="立替"?"#92400e":"#1d4ed8"}}>{p.category||"売上"}</span></td>
              <td style={{padding:"4px 8px"}}><span style={{fontSize:10,fontWeight:700,padding:"1px 6px",borderRadius:4,background:isDone?"#dcfce7":"#fef2f2",color:isDone?"#166534":"#dc2626"}}>{isDone?"完了":"未完了"}</span></td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.sendDate||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b"}}>{p.refundDate||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10,color:"#64748b",maxWidth:100,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p.content||"-"}</td>
              <td style={{padding:"4px 8px",fontSize:10}}>{p.linkUrl?<a href={p.linkUrl} target="_blank" rel="noreferrer" style={{color:"#2563eb"}}>🔗</a>:"-"}</td>
              <td style={{padding:"4px 8px"}}><button onClick={()=>startEdit(r.id)} style={{fontSize:10,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",fontWeight:600}}>編集</button></td>
            </>}
          </tr>;
        })}</tbody>
      </table></div>
    </div>}
  </div>;
}

/* ==========================================
   スタッフ管理
   ========================================== */
function StaffManager({staff,onStaffChange,onDeleteStaff}){
  const[editId,setEditId]=useState(null);
  const[form,setForm]=useState({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});
  const[adding,setAdding]=useState(false);
  const[editOrigName,setEditOrigName]=useState("");
  const[wageHistory,setWageHistory]=useState([]);
  const[showWageHistory,setShowWageHistory]=useState(null); // staff name or null
  const[wageForm,setWageForm]=useState({effective_date:"",hourly_wage:""});
  React.useEffect(()=>{DB.fetchWageHistory().then(d=>setWageHistory(d||[]));},[]);
  const addWageEntry=async(staffName)=>{
    if(!wageForm.effective_date||!wageForm.hourly_wage){alert("適用開始日と時給を入力してください");return;}
    const rec={id:"wh_"+Date.now()+"_"+Math.random().toString(36).slice(2,5),staff_name:staffName,effective_date:wageForm.effective_date,hourly_wage:Number(wageForm.hourly_wage)||0};
    await DB.saveWageHistory(rec);
    setWageHistory(prev=>[...prev,rec].sort((a,b)=>a.effective_date.localeCompare(b.effective_date)));
    setWageForm({effective_date:"",hourly_wage:""});
  };
  const deleteWageEntry=async(id)=>{
    if(!confirm("この時給履歴を削除しますか？"))return;
    await DB.deleteWageHistory(id);
    setWageHistory(prev=>prev.filter(w=>w.id!==id));
  };

  const save=()=>{
    if(!form.name.trim())return;
    if(!window.confirm(adding?"新規登録を実行しますか？":"変更を保存しますか？"))return;
    const entry={name:form.name.trim(),type:form.type,memo:form.memo,hourlyWage:Number(form.hourlyWage)||0,transportCost:Number(form.transportCost)||0,monthlySalary:Number(form.monthlySalary)||0};
    if(adding){
      onStaffChange([...staff,entry]);setAdding(false);
    }else if(editId!==null){
      const oldName=editOrigName;
      const updated=[...staff];updated[editId]=entry;
      onStaffChange(updated);
      if(oldName&&oldName!==entry.name&&onDeleteStaff)onDeleteStaff(oldName);
      setEditId(null);setEditOrigName("");
    }
    setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});
  };

  const startEdit=(i)=>{setEditId(i);setEditOrigName(staff[i].name);setForm({...staff[i]});setAdding(false);};
  const startAdd=()=>{setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});setAdding(true);setEditId(null);};
  const remove=(i)=>{if(window.confirm(`${staff[i].name} を削除しますか？`)){const name=staff[i].name;onStaffChange(staff.filter((_,j)=>j!==i));if(onDeleteStaff)onDeleteStaff(name);}};
  const cancel=()=>{setAdding(false);setEditId(null);setForm({name:"",type:"アルバイト",memo:"",hourlyWage:1100,transportCost:500,monthlySalary:0});};

  const showModal=adding||editId!==null;
  const cardS={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:10,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const fmtCur=n=>n?("¥"+Number(n).toLocaleString()):"¥0";

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>スタッフ ({staff.length})</h3>
      <button onClick={startAdd} style={{padding:"6px 14px",borderRadius:8,background:"#2563eb",color:"#fff",border:"none",fontSize:12,fontWeight:700,cursor:"pointer"}}>＋ 追加</button>
    </div>

    {staff.map((s,i)=>{
      const isP=s.type==="アルバイト";const isR=s.type==="正社員";
      return <div key={i} style={cardS}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontSize:15,fontWeight:800}}>{s.name}</span>
            <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
          </div>
          <div style={{display:"flex",gap:8}}>
            <span onClick={()=>startEdit(i)} style={{fontSize:12,color:"#2563eb",fontWeight:600,cursor:"pointer"}}>編集</span>
            <span onClick={()=>remove(i)} style={{fontSize:12,color:"#dc2626",fontWeight:600,cursor:"pointer"}}>削除</span>
          </div>
        </div>
        {isP&&<div style={{fontSize:13,color:"#374151"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"4px 0",borderBottom:"1px solid #f1f5f9"}}>
            <span style={{color:"#64748b"}}>時給</span>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontWeight:700}}>{fmtCur(s.hourlyWage)}</span>
              <button onClick={()=>setShowWageHistory(showWageHistory===s.name?null:s.name)} style={{fontSize:9,padding:"2px 8px",borderRadius:4,border:"1px solid #d1d5db",background:showWageHistory===s.name?"#2563eb":"#fff",color:showWageHistory===s.name?"#fff":"#2563eb",cursor:"pointer",fontWeight:600}}>履歴</button>
            </div>
          </div>
          {showWageHistory===s.name&&<div style={{background:"#f8fafc",borderRadius:8,padding:10,marginTop:6,marginBottom:6}}>
            <div style={{fontSize:11,fontWeight:700,color:"#1e293b",marginBottom:6}}>時給変更履歴</div>
            {wageHistory.filter(w=>w.staff_name===s.name).length===0&&<div style={{fontSize:10,color:"#94a3b8",marginBottom:6}}>履歴なし（デフォルト時給 {fmtCur(s.hourlyWage)} が適用されます）</div>}
            {wageHistory.filter(w=>w.staff_name===s.name).map(w=><div key={w.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"3px 0",borderBottom:"1px solid #e2e8f0"}}>
              <span style={{fontSize:11}}>{w.effective_date}〜</span>
              <div style={{display:"flex",alignItems:"center",gap:6}}>
                <span style={{fontSize:11,fontWeight:700}}>¥{(w.hourly_wage||0).toLocaleString()}</span>
                <button onClick={()=>deleteWageEntry(w.id)} style={{fontSize:8,padding:"1px 4px",borderRadius:3,border:"1px solid #fecaca",background:"#fff",color:"#dc2626",cursor:"pointer"}}>✕</button>
              </div>
            </div>)}
            <div style={{display:"flex",gap:6,marginTop:8,alignItems:"center"}}>
              <input type="date" value={wageForm.effective_date} onChange={e=>setWageForm(p=>({...p,effective_date:e.target.value}))} style={{fontSize:10,padding:"4px 6px",borderRadius:4,border:"1px solid #d1d5db",flex:1}}/>
              <input type="number" value={wageForm.hourly_wage} onChange={e=>setWageForm(p=>({...p,hourly_wage:e.target.value}))} placeholder="時給" style={{fontSize:10,padding:"4px 6px",borderRadius:4,border:"1px solid #d1d5db",width:70}}/>
              <button onClick={()=>addWageEntry(s.name)} style={{fontSize:10,padding:"4px 10px",borderRadius:4,border:"none",background:"#2563eb",color:"#fff",fontWeight:700,cursor:"pointer"}}>追加</button>
            </div>
          </div>}
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0"}}>
            <span style={{color:"#64748b"}}>交通費 / 回</span><span style={{fontWeight:700}}>{fmtCur(s.transportCost)}</span>
          </div>
        </div>}
        {isR&&<div style={{fontSize:13,color:"#374151"}}>
          <div style={{display:"flex",justifyContent:"space-between",padding:"4px 0"}}>
            <span style={{color:"#64748b"}}>交通費 / 回</span><span style={{fontWeight:700}}>{fmtCur(s.transportCost)}</span>
          </div>
        </div>}
      </div>;
    })}

    {/* 編集・追加モーダル */}
    {showModal&&<div className="modal-overlay" onClick={cancel}><div className="modal-box" style={{maxWidth:380,padding:24}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <h4 style={{fontSize:16,fontWeight:800,margin:0}}>{adding?"スタッフ追加":"スタッフ編集"}</h4>
        <button onClick={cancel} style={{background:"none",border:"none",fontSize:18,color:"#94a3b8",cursor:"pointer"}}>✕</button>
      </div>
      <div style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>氏名</label>
        <input value={form.name} onChange={e=>setForm(p=>({...p,name:e.target.value}))} placeholder="名前を入力" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}} autoFocus/>
      </div>
      <div style={{marginBottom:12}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>雇用形態</label>
        <select value={form.type} onChange={e=>setForm(p=>({...p,type:e.target.value}))} style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,background:"#fff"}}>
          <option>アルバイト</option><option>正社員</option>
        </select>
      </div>
      {form.type==="アルバイト"&&<>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>時給(¥)</label>
          <input type="number" value={form.hourlyWage||""} onChange={e=>setForm(p=>({...p,hourlyWage:e.target.value}))} placeholder="1100" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>交通費/回(¥)</label>
          <input type="number" value={form.transportCost||""} onChange={e=>setForm(p=>({...p,transportCost:e.target.value}))} placeholder="500" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      {form.type==="正社員"&&<>
        <div style={{marginBottom:12}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>交通費/回(¥)</label>
          <input type="number" value={form.transportCost||""} onChange={e=>setForm(p=>({...p,transportCost:e.target.value}))} placeholder="0" style={{width:"100%",padding:"10px 12px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      {/* 削除ボタン（編集時のみ） */}
      {editId!==null&&<button onClick={()=>{remove(editId);cancel();}} style={{width:"100%",padding:"10px",borderRadius:10,border:"none",background:"#fef2f2",color:"#dc2626",fontSize:13,fontWeight:700,cursor:"pointer",marginBottom:12}}>この登録を削除</button>}
      <div style={{display:"flex",gap:8}}>
        <button onClick={cancel} style={{flex:"0 0 auto",padding:"10px 16px",borderRadius:10,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        <button onClick={save} disabled={!form.name.trim()} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:form.name.trim()?"#2563eb":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:form.name.trim()?"pointer":"not-allowed"}}>保存</button>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   申し送りBOX
   ========================================== */
function MemoBox({today}){
  const tomorrow=dOff(today,1);
  const[memos,setMemos]=React.useState([]);
  const[refundPending,setRefundPending]=React.useState([]);// 返金待ち（入金済キャンセル・未返金）
  const[text,setText]=React.useState("");
  const[posting,setPosting]=React.useState(false);
  const[open,setOpen]=React.useState(false);
  const[listOpen,setListOpen]=React.useState(false);
  const[editId,setEditId]=React.useState(null);
  const[editText,setEditText]=React.useState("");
  const[imgPreview,setImgPreview]=React.useState("");
  const[imgFile,setImgFile]=React.useState(null);
  const[imgUploading,setImgUploading]=React.useState(false);
  const[lightbox,setLightbox]=React.useState("");
  const fileRef=React.useRef(null);
  const chRef=React.useRef(null);
  const load=()=>DB.fetchMemos(today).then(d=>setMemos(d||[])).catch(()=>{});
  // ★ 2026-05-10: 返金待ちアラート — paid_at有 + cancelled_at有 + status≠refunded = 要Square返金
  React.useEffect(()=>{
    if(!sb)return;
    let alive=true;
    const loadRefund=async()=>{
      try{
        const{data,error}=await sb.from("bt_jalan_payments")
          .select("reservation_id,customer_name,amount,status,paid_at,cancelled_at,square_payment_url,lend_date,return_date")
          .not("paid_at","is",null)
          .not("cancelled_at","is",null)
          .neq("status","refunded")
          .order("cancelled_at",{ascending:false});
        if(error){dbLog&&dbLog("refundPending",false,error.message);return;}
        if(alive)setRefundPending(data||[]);
      }catch(e){/* silent */}
    };
    loadRefund();
    const iv=setInterval(loadRefund,60000);
    return()=>{alive=false;clearInterval(iv);};
  },[]);
  React.useEffect(()=>{
    load();
    if(sb){chRef.current=sb.channel("tkm-memos-top").on("postgres_changes",{event:"*",schema:"public",table:"bt_memos"},load).subscribe();}
    const iv=setInterval(load,30000);
    return()=>{clearInterval(iv);if(chRef.current)sb.removeChannel(chRef.current);};
  },[today]);
  const selectImg=(e)=>{
    const f=e.target.files[0];if(!f)return;
    setImgFile(f);
    const r=new FileReader();r.onload=(ev)=>setImgPreview(ev.target.result);r.readAsDataURL(f);
    e.target.value="";
  };
  const clearImg=()=>{setImgFile(null);setImgPreview("");};
  const post=async()=>{
    if(!text.trim()&&!imgFile)return;
    setPosting(true);
    let uploadedUrl="";
    if(imgFile){
      setImgUploading(true);
      try{uploadedUrl=await DB.uploadMemoImage(imgFile);}
      catch(e){alert("画像アップロード失敗: "+e.message);setImgUploading(false);setPosting(false);return;}
      setImgUploading(false);
    }
    await DB.postMemo(text.trim(),tomorrow,uploadedUrl).catch(()=>{});
    setText("");clearImg();setPosting(false);load();
  };
  const toggle=(id,done)=>DB.toggleMemoDone(id,done).then(load).catch(()=>{});
  const del=(id)=>{if(!window.confirm("削除しますか？"))return;DB.deleteMemo(id).then(load).catch(()=>{});};
  const startEdit=(m)=>{setEditId(m.id);setEditText(m.content);};
  const saveEdit=async(id)=>{if(!editText.trim())return;await sb.from("bt_memos").update({content:editText.trim()}).eq("id",id).catch(()=>{});setEditId(null);setEditText("");load();};
  const cancelEdit=()=>{setEditId(null);setEditText("");};
  const todayList=memos.filter(m=>m.target_date===today);
  const tomList=memos.filter(m=>m.target_date===tomorrow);
  const todayUndone=todayList.filter(m=>!m.done);
  const tomUndone=tomList.filter(m=>!m.done);
  const MemoRow=({m,redStyle})=>{
    const isEditing=editId===m.id;
    if(isEditing)return(
      <div style={{marginBottom:4,padding:"7px 10px",borderRadius:8,background:"#fffbeb",border:"2px solid #f59e0b"}}>
        <textarea value={editText} onChange={e=>setEditText(e.target.value)} rows={3}
          style={{width:"100%",border:"1px solid #fde68a",borderRadius:6,padding:"6px 8px",fontSize:12,background:"#fff",outline:"none",resize:"vertical",boxSizing:"border-box"}}/>
        <div style={{display:"flex",gap:6,marginTop:5,justifyContent:"flex-end"}}>
          <button onClick={cancelEdit} style={{fontSize:10,padding:"3px 10px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280"}}>キャンセル</button>
          <button onClick={()=>saveEdit(m.id)} disabled={!editText.trim()} style={{fontSize:10,padding:"3px 10px",borderRadius:6,border:"none",background:"#f59e0b",color:"#fff",fontWeight:700,cursor:"pointer"}}>保存</button>
        </div>
      </div>
    );
    return(
      <div style={{display:"flex",gap:6,alignItems:"flex-start",padding:"6px 10px",borderRadius:8,
        background:m.done?"#f9fafb":redStyle?"#fef2f2":"#fffbeb",
        border:"1px solid "+(m.done?"#e5e7eb":redStyle?"#fecaca":"#fde68a"),
        marginBottom:4,opacity:m.done?0.5:1}}>
        <span style={{fontSize:12,flexShrink:0,marginTop:1}}>{m.done?"✅":redStyle?"🔴":"📌"}</span>
        <div style={{flex:1,minWidth:0}}>
          <div style={{fontSize:12,fontWeight:m.done?400:600,color:m.done?"#9ca3af":redStyle?"#7f1d1d":"#1c1917",
            lineHeight:1.4,wordBreak:"break-all",textDecoration:m.done?"line-through":"none",whiteSpace:"pre-wrap"}}>{m.content}</div>
          {m.image_url&&<img src={m.image_url} onClick={()=>setLightbox(m.image_url)}
            style={{marginTop:5,maxWidth:"100%",maxHeight:120,borderRadius:6,cursor:"pointer",objectFit:"cover",opacity:m.done?0.5:1}}
            alt="添付画像"/>}
        </div>
        <div style={{display:"flex",gap:3,flexShrink:0,alignSelf:"flex-start"}}>
          {!m.done&&<button onClick={()=>startEdit(m)} style={{fontSize:9,padding:"2px 6px",borderRadius:6,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280"}}>✏️</button>}
          <button onClick={()=>toggle(m.id,m.done)} style={{fontSize:9,padding:"2px 7px",borderRadius:6,
            border:"1px solid "+(m.done?"#d1d5db":redStyle?"#fecaca":"#fde68a"),
            background:"#fff",cursor:"pointer",color:m.done?"#6b7280":redStyle?"#dc2626":"#92400e",whiteSpace:"nowrap"}}>
            {m.done?"戻す":"済み"}
          </button>
          <button onClick={()=>del(m.id)} style={{fontSize:9,padding:"2px 5px",borderRadius:6,border:"1px solid #e5e7eb",background:"#f9fafb",cursor:"pointer",color:"#9ca3af"}}>✕</button>
        </div>
      </div>
    );
  };
  return(
    <div style={{marginBottom:16}}>
      {/* ライトボックス */}
      {lightbox&&<div onClick={()=>setLightbox("")} style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
        <img src={lightbox} style={{maxWidth:"100%",maxHeight:"90vh",borderRadius:8,objectFit:"contain"}} alt="拡大"/>
        <button onClick={()=>setLightbox("")} style={{position:"absolute",top:16,right:16,background:"rgba(255,255,255,.2)",border:"none",color:"#fff",borderRadius:99,width:32,height:32,fontSize:16,cursor:"pointer"}}>✕</button>
      </div>}
      {refundPending.length>0&&(
        <div style={{marginBottom:8,padding:"10px 12px",borderRadius:12,background:"#faf5ff",border:"2px solid #d8b4fe"}}>
          <div style={{fontSize:10,fontWeight:800,color:"#7c3aed",marginBottom:6,display:"flex",alignItems:"center",gap:6}}>
            💸 返金待ち Handover（入金済キャンセル → 要Square返金）
            <span style={{background:"#7c3aed",color:"#fff",borderRadius:99,fontSize:9,fontWeight:700,padding:"1px 7px"}}>{refundPending.length}件</span>
          </div>
          {refundPending.map((r,i)=>{
            const cancelDays=r.cancelled_at?Math.floor((new Date()-new Date(r.cancelled_at))/86400000):null;
            return <div key={"rf"+i} style={{display:"flex",alignItems:"center",gap:8,marginBottom:4,padding:"7px 10px",borderRadius:8,background:"#fff",border:"1px solid #e9d5ff"}}>
              <span style={{fontSize:12,flexShrink:0}}>💸</span>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontSize:12,fontWeight:700,color:"#581c87",lineHeight:1.4}}>
                  {r.customer_name||"—"} 様　<span style={{fontFamily:"monospace",fontSize:11}}>{r.reservation_id}</span>
                </div>
                <div style={{fontSize:10,color:"#6b21a8",marginTop:2}}>
                  ¥{(r.amount||0).toLocaleString()} / 利用予定 {r.lend_date}〜{r.return_date}
                  {cancelDays!==null&&<span style={{marginLeft:6,fontWeight:800,color:cancelDays>=3?"#dc2626":"#7c3aed"}}>
                    {cancelDays===0?"本日キャンセル":"キャンセル"+cancelDays+"日経過"}
                  </span>}
                </div>
              </div>
              {r.square_payment_url&&<a href={r.square_payment_url} target="_blank" rel="noopener" style={{fontSize:10,fontWeight:700,color:"#fff",background:"#7c3aed",padding:"4px 10px",borderRadius:6,textDecoration:"none",whiteSpace:"nowrap"}}>🔗 Square</a>}
            </div>;
          })}
          <div style={{fontSize:9,color:"#7c3aed",marginTop:6,paddingTop:6,borderTop:"1px dashed #d8b4fe"}}>
            ⚠️ <b>自動返金は廃止（2026-05-10）</b>。手動で対応してください:
            ① Square Dashboard で該当決済を選択 → 「払い戻し」実行
            ② APP 会計タブ で キャンセル料 / 返金額 を手動起票
            ③ APP データタブ で 予約 status を cancelled に変更
          </div>
        </div>
      )}
      {todayUndone.length>0&&(
        <div style={{marginBottom:8,padding:"10px 12px",borderRadius:12,background:"#fef2f2",border:"2px solid #fecaca"}}>
          <div style={{fontSize:10,fontWeight:800,color:"#dc2626",marginBottom:6}}>🔴 本日の Handover（未対応）</div>
          {todayUndone.map(m=><MemoRow key={m.id} m={m} redStyle={true}/>)}
        </div>
      )}
      <div style={{marginBottom:8,borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
        <div onClick={()=>setOpen(o=>!o)} style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:8,cursor:"pointer",userSelect:"none"}}>
          <span style={{fontSize:16}}>✏️</span>
          <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>Handover を書く</span>
          <span style={{marginLeft:"auto",fontSize:11,color:"#94a3b8",fontWeight:700}}>{open?"▲":"▼"}</span>
        </div>
        {open&&<div style={{padding:"10px 12px",borderTop:"1px solid #e2e8f0"}}>
          <textarea value={text} onChange={e=>setText(e.target.value)} rows={3}
            placeholder={"例：216決済必要\n明日コーナン買い出し\n山田さん10時出勤変更"}
            style={{width:"100%",border:"1px solid #e2e8f0",borderRadius:8,padding:"8px 10px",fontSize:12,background:"#fff",outline:"none",resize:"vertical",boxSizing:"border-box",marginBottom:6}}/>
          {/* 画像プレビュー */}
          {imgPreview&&<div style={{position:"relative",display:"inline-block",marginBottom:8}}>
            <img src={imgPreview} style={{maxHeight:100,maxWidth:"100%",borderRadius:6,objectFit:"cover"}} alt="preview"/>
            <button onClick={clearImg} style={{position:"absolute",top:-6,right:-6,width:18,height:18,borderRadius:99,background:"#ef4444",border:"none",color:"#fff",fontSize:10,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",lineHeight:1}}>✕</button>
          </div>}
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div>
              <input ref={fileRef} type="file" accept="image/*" onChange={selectImg} style={{display:"none"}}/>
              <button onClick={()=>fileRef.current.click()} style={{fontSize:11,padding:"5px 10px",borderRadius:8,border:"1px solid #d1d5db",background:"#fff",cursor:"pointer",color:"#6b7280",display:"flex",alignItems:"center",gap:4}}>
                📷 {imgFile?"変更":"写真を添付"}
              </button>
            </div>
            <button onClick={post} disabled={(!text.trim()&&!imgFile)||posting}
              style={{padding:"7px 18px",borderRadius:8,border:"none",
                background:(text.trim()||imgFile)?"#f59e0b":"#d1d5db",
                color:"#fff",fontWeight:700,fontSize:12,cursor:(text.trim()||imgFile)?"pointer":"default"}}>
              {imgUploading?"アップロード中...":posting?"投稿中...":"投稿"}
            </button>
          </div>
        </div>}
      </div>
      {tomList.length>0&&<div style={{marginBottom:8,borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",overflow:"hidden",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
        <div onClick={()=>setListOpen(o=>!o)} style={{background:"#f8fafc",padding:"10px 14px",display:"flex",alignItems:"center",gap:8,cursor:"pointer",userSelect:"none"}}>
          <span style={{fontSize:14}}>📌</span>
          <span style={{fontSize:13,fontWeight:700,color:"#1e293b"}}>明日の Handover</span>
          <span style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:6}}>
            <span style={{background:"#f59e0b",color:"#fff",borderRadius:99,fontSize:9,fontWeight:700,padding:"2px 8px"}}>{tomList.length}件</span>
            <span style={{fontSize:11,color:"#94a3b8",fontWeight:700}}>{listOpen?"▲":"▼"}</span>
          </span>
        </div>
        {listOpen&&<div style={{padding:"8px 12px",borderTop:"1px solid #e2e8f0"}}>
          {tomList.map(m=><MemoRow key={m.id} m={m} redStyle={false}/>)}
        </div>}
      </div>}
    </div>
  );
}
/* ==========================================
   勤怠管理
   ========================================== */
function AttendanceManager({shifts,staff,today,attendance,onAttendanceChange}){
  const WK=["日","月","火","水","木","金","土"];
  const todayYM=toYM(today);
  const[viewYM,setViewYM]=useState(todayYM);
  const[selStaff,setSelStaff]=useState(staff[0]?.name||"");
  const[subTab,setSubTab]=useState("budget"); // "budget" | "actual" | "detail" | "overtime" | "holiday_work"
  const[editDay,setEditDay]=useState(null);
  const[staffFilter,setStaffFilter]=useState("all"); // "all"|"part"|"full"
  const dim=daysInMonth(viewYM);
  const[vy,vmo]=viewYM.split("-").map(Number);
  const[overtimeEvents,setOvertimeEvents]=useState([]);
  const[overtimeSel,setOvertimeSel]=useState("");

  const[syncing,setSyncing]=useState(false);
  const[lastSync,setLastSync]=useState(null);
  const[wageHistory,setWageHistory]=useState([]);

  // マウント時＋手動同期: DBから最新のシフト＋勤怠＋時給履歴を再取得
  const forceSync=React.useCallback(async()=>{
    setSyncing(true);
    try{
      const[shDB,attDB,whDB]=await Promise.all([DB.fetchShifts(),DB.fetchAttendance(),DB.fetchWageHistory()]);
      if(shDB){
        // 親のshiftsを直接更新（setShiftsSync相当）
        window.__spkForceShifts&&window.__spkForceShifts(shDB);
      }
      if(attDB)onAttendanceChange(attDB);
      if(whDB)setWageHistory(whDB);
      setLastSync(new Date());
    }catch(e){console.error("[forceSync]",e);}
    setSyncing(false);
  },[onAttendanceChange]);

  React.useEffect(()=>{forceSync();},[]);

  React.useEffect(()=>{
    if(!sb)return;
    const from=viewYM+"-01";const to=viewYM+"-31";
    sb.from('store_events').select('*').in('category',['overtime','holiday_work'])
      .gte('event_date',from).lte('event_date',to)
      .order('event_date',{ascending:true})
      .then(({data:rows})=>{
        setOvertimeEvents(rows||[]);
        if(rows&&rows.length>0&&!overtimeSel&&(subTab==='overtime'||subTab==='holiday_work')){
          const targetCat=subTab;
          const names=Array.from(new Set(rows.filter(r=>r.category===targetCat).flatMap(r=>r.assignees||[])));
          if(names.length>0)setOvertimeSel(names[0]);
        }
      });
  },[viewYM]);

  // 実働時間計算ヘルパー
  const calcHours=(start,end)=>{
    if(!start||!end)return 0;
    const[sh,sm]=start.split(":").map(Number);
    const[eh,em]=end.split(":").map(Number);
    const diff=(eh*60+em)-(sh*60+sm);
    return diff>0?Math.round(diff/60*10)/10:0;
  };

  // 全スタッフの月間データ生成
  const allStaffData=useMemo(()=>{
    const result={};
    // 残業/休日出勤の集計（スタッフ別）+ イベント詳細
    const calcOTHours=(s,e)=>{if(!s||!e)return 0;const[sh,sm]=s.split(":").map(Number);const[eh,em]=e.split(":").map(Number);const d=(eh*60+em)-(sh*60+sm);return d>0?Math.round(d/60*10)/10:0;};
    const otHByStaff={},hwHByStaff={},otEvByStaff={},hwEvByStaff={};
    (overtimeEvents||[]).forEach(r=>{
      const h=calcOTHours(r.start_time,r.end_time);
      if(h<=0)return;
      const enriched={...r,_h:h};
      (r.assignees||[]).forEach(n=>{
        if(r.category==='overtime'){
          otHByStaff[n]=(otHByStaff[n]||0)+h;
          if(!otEvByStaff[n])otEvByStaff[n]=[];otEvByStaff[n].push(enriched);
        }else if(r.category==='holiday_work'){
          hwHByStaff[n]=(hwHByStaff[n]||0)+h;
          if(!hwEvByStaff[n])hwEvByStaff[n]=[];hwEvByStaff[n].push(enriched);
        }
      });
    });
    staff.forEach(s=>{
      const days=[];
      for(let d=1;d<=dim;d++){
        const ds=viewYM+"-"+String(d).padStart(2,"0");
        const dow=new Date(vy,vmo-1,d).getDay();
        const sh=(shifts[ds]||[]).find(x=>x.name===s.name);
        const attKey=ds+"_"+s.name;
        const att=attendance[attKey]||null;
        days.push({date:ds,day:d,dow,shift:sh,att});
      }
      // 予算（シフトベース）
      let budgetDays=0,budgetHours=0;
      days.forEach(d=>{
        if(d.shift&&d.shift.symbol!=="公"&&d.shift.symbol!=="希"&&d.shift.symbol!=="有"){
          budgetDays++;budgetHours+=calcHours(d.shift.start||"09:00",d.shift.end||"18:00");
        }
      });
      const isP=s.type==="アルバイト";
      // 予算: 日ごとの時給を参照して計算
      let budgetWage=0;
      if(isP){
        days.forEach(d=>{
          if(d.shift&&d.shift.symbol!=="公"&&d.shift.symbol!=="希"&&d.shift.symbol!=="有"){
            const h=calcHours(d.shift.start||"09:00",d.shift.end||"18:00");
            const w=DB.getWageForDate(wageHistory,s.name,d.date)||(s.hourlyWage||0);
            budgetWage+=w*h;
            d._wage=w; // 日ごとの時給を保持
          }
        });
      }else{budgetWage=s.monthlySalary||0;}
      const budgetTransport=(s.transportCost||0)*budgetDays;
      // 実績（勤怠承認ベース）— 欠勤は出勤0扱い
      let actualDays=0,actualHours=0,absentDays=0,actualWage=0;
      days.forEach(d=>{
        if(d.att&&d.att.approved){
          if(d.att.absent){absentDays++;return;}
          if(d.att.memo&&d.att.memo.startsWith("協議中"))return;
          actualDays++;
          const h=calcHours(d.att.start,d.att.end);
          actualHours+=h;
          if(isP){
            const w=DB.getWageForDate(wageHistory,s.name,d.date)||(s.hourlyWage||0);
            actualWage+=w*h;
            d._wage=w;
          }
        }
      });
      if(!isP)actualWage=s.monthlySalary||0;
      const actualTransport=(s.transportCost||0)*actualDays;
      // 残業/休日出勤 ログのみ（実態確認フェーズ・金額計算なし）
      const otHours=otHByStaff[s.name]||0;
      const hwHours=hwHByStaff[s.name]||0;
      const otEvents=(otEvByStaff[s.name]||[]).slice().sort((a,b)=>(a.event_date||'').localeCompare(b.event_date||''));
      const hwEvents=(hwEvByStaff[s.name]||[]).slice().sort((a,b)=>(a.event_date||'').localeCompare(b.event_date||''));
      const hwDays=new Set(hwEvents.map(r=>r.event_date)).size;
      result[s.name]={days,budgetDays,budgetHours,budgetWage:Math.round(budgetWage),budgetTransport,budgetTotal:Math.round(budgetWage)+budgetTransport,
        actualDays,actualHours,actualWage:Math.round(actualWage),actualTransport,
        otHours,hwHours,hwDays,otEvents,hwEvents,
        actualTotal:Math.round(actualWage)+actualTransport,isP,absentDays};
    });
    return result;
  },[staff,shifts,attendance,viewYM,dim,vy,vmo,wageHistory,overtimeEvents]);

  // シフトから勤怠レコード自動生成（シフト変更時にも反映）
  // 注意: attendanceをrefで参照し、依存配列に入れないことで無限ループを防止
  const genAttFromShifts=React.useCallback((curAtt)=>{
    const toCreate=[];
    const toUpdate=[];
    staff.forEach(s=>{
      for(let d=1;d<=dim;d++){
        const ds=viewYM+"-"+String(d).padStart(2,"0");
        const sh=(shifts[ds]||[]).find(x=>x.name===s.name);
        const attKey=ds+"_"+s.name;
        const att=curAtt[attKey]||null;
        if(sh&&!att){
          toCreate.push({date:ds,name:s.name,start:sh.start||"09:00",end:sh.end||"18:00",approved:false,memo:""});
        }else if(sh&&att&&!att.approved){
          const newStart=sh.start||"09:00";const newEnd=sh.end||"18:00";
          if(att.start!==newStart||att.end!==newEnd){
            toUpdate.push({...att,start:newStart,end:newEnd});
          }
        }
      }
    });
    if(toCreate.length>0||toUpdate.length>0){
      const next={...curAtt};
      toCreate.forEach(r=>{next[r.date+"_"+r.name]=r;});
      toUpdate.forEach(r=>{next[r.date+"_"+r.name]=r;});
      onAttendanceChange(next);
      if(toCreate.length>0)DB.saveAttendanceBatch(toCreate);
      if(toUpdate.length>0)DB.saveAttendanceBatch(toUpdate);
    }
  },[shifts,staff,viewYM,dim,onAttendanceChange]);
  // shiftsが変わったら最新のattendanceで自動生成を実行
  React.useEffect(()=>{genAttFromShifts(attendance);},[shifts,viewYM]);

  const approve=(date,name)=>{
    if(!window.confirm("承認を実行しますか？"))return;
    const key=date+"_"+name;const cur=attendance[key];if(!cur)return;
    const updated={...cur,approved:true};
    onAttendanceChange({...attendance,[key]:updated});
    DB.saveAttendance(updated);
  };
  const approveAll=(name)=>{
    if(!window.confirm("全承認を実行しますか？"))return;
    const d=allStaffData[name];if(!d)return;
    const next={...attendance};const batch=[];
    d.days.forEach(day=>{
      if(day.att&&!day.att.approved){
        const key=day.date+"_"+name;
        const updated={...day.att,approved:true};
        next[key]=updated;batch.push(updated);
      }
    });
    onAttendanceChange(next);if(batch.length)DB.saveAttendanceBatch(batch);
  };
  const saveEdit=()=>{
    if(!editDay)return;
    if(!window.confirm("保存を実行しますか？"))return;
    const key=editDay.date+"_"+editDay.name;
    const origMemo=attendance[key]?.memo||"";
    const isKyogi=origMemo.startsWith("協議中");
    // 協議中の場合は解決→memo="打刻" approved=true
    const memo=isKyogi?"打刻":(editDay.memo||"");
    const approved=isKyogi?true:(attendance[key]?.approved||false);
    const updated={date:editDay.date,name:editDay.name,start:editDay.start,end:editDay.end,approved,memo,absent:!!editDay.absent};
    onAttendanceChange({...attendance,[key]:updated});
    DB.saveAttendance(updated);setEditDay(null);
  };

  // 予算総額（フィルター連動）
  const filteredStaff=useMemo(()=>staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員"),[staff,staffFilter]);
  const budgetGrandTotal=useMemo(()=>{
    let payTotal=0,transTotal=0,actualRef=0;
    filteredStaff.forEach(s=>{const d=allStaffData[s.name];if(d){payTotal+=d.budgetWage;transTotal+=d.budgetTransport;actualRef+=d.actualTotal;}});
    return{payTotal,transTotal,grandTotal:payTotal+transTotal,actualRef};
  },[allStaffData,filteredStaff]);

  const cardS={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:12,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
  const boxS=(bg)=>({background:bg||"#f0f9ff",borderRadius:10,padding:"10px 14px",textAlign:"center",flex:1});

  // 給与カラム不在チェック
  const wageColsMissing=DB._staffHasWageCols===false;

  return <div style={{maxWidth:640,margin:"0 auto"}}>
    {/* 給与カラム不在の警告 */}
    {wageColsMissing&&<div style={{background:"#fef2f2",border:"2px solid #dc2626",borderRadius:10,padding:12,marginBottom:12}}>
      <div style={{fontSize:13,fontWeight:800,color:"#dc2626",marginBottom:4}}>⚠️ 給与データがDBに未設定</div>
      <div style={{fontSize:11,color:"#991b1b",lineHeight:1.6}}>
        Supabase staffテーブルに給与カラムがありません。<br/>
        Supabase &gt; SQL Editor で以下を実行してください：
      </div>
      <div style={{background:"#1e293b",color:"#22d3ee",padding:8,borderRadius:6,fontSize:10,fontFamily:"monospace",marginTop:6,lineHeight:1.8,overflowX:"auto",whiteSpace:"pre"}}>
{`ALTER TABLE bt_staff ADD COLUMN IF NOT EXISTS hourly_wage INTEGER DEFAULT 0;
ALTER TABLE bt_staff ADD COLUMN IF NOT EXISTS transport_cost INTEGER DEFAULT 0;
ALTER TABLE bt_staff ADD COLUMN IF NOT EXISTS monthly_salary INTEGER DEFAULT 0;`}
      </div>
      <div style={{fontSize:10,color:"#991b1b",marginTop:6}}>実行後にアプリをリロードすると給与データが自動同期されます。</div>
    </div>}
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
      <h3 style={{fontSize:16,fontWeight:800,margin:0}}>給与計算</h3>
      <button onClick={forceSync} disabled={syncing} style={{padding:"4px 12px",borderRadius:8,fontSize:11,fontWeight:700,border:"1px solid #e2e8f0",background:syncing?"#f1f5f9":"#fff",color:syncing?"#94a3b8":"#2563eb",cursor:syncing?"wait":"pointer"}}>
        {syncing?"同期中...":"🔄 同期"}
      </button>
    </div>
    {lastSync&&<div style={{fontSize:9,color:"#94a3b8",textAlign:"right",marginTop:-10,marginBottom:6}}>最終同期: {lastSync.toLocaleTimeString()}</div>}
    {/* 月選択 */}
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}>
      <button onClick={()=>setViewYM(ymOff(viewYM,-1))} style={{padding:"4px 10px",fontSize:16,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",fontWeight:700,color:"#2563eb"}}>&lt;</button>
      <div style={{fontSize:16,fontWeight:900,color:"#1e293b"}}>{ymLabel(viewYM)}</div>
      <button onClick={()=>setViewYM(ymOff(viewYM,1))} style={{padding:"4px 10px",fontSize:16,background:"#f1f5f9",border:"1px solid #e2e8f0",borderRadius:6,cursor:"pointer",fontWeight:700,color:"#2563eb"}}>&gt;</button>
    </div>
    {/* サブタブ */}
    <div style={{display:"flex",gap:0,marginBottom:14,background:"#f1f5f9",borderRadius:10,padding:3}}>
      {[{id:"budget",l:"予算（シフト）"},{id:"actual",l:"実績（勤怠）"},{id:"detail",l:"給与明細"},{id:"overtime",l:"🟠🟣 残業・休日出勤"}].map(t=>
        <button key={t.id} onClick={()=>setSubTab(t.id)} style={{flex:1,padding:"7px 0",borderRadius:8,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",
          background:subTab===t.id?"#fff":"transparent",color:subTab===t.id?"#1e293b":"#94a3b8",
          boxShadow:subTab===t.id?"0 1px 3px rgba(0,0,0,.1)":"none"}}>{t.l}</button>
      )}
    </div>

    {/* スタッフ種別フィルター */}
    <div style={{display:"flex",gap:4,marginBottom:10}}>
      {[{id:"all",l:"全員"},{id:"part",l:"アルバイト"},{id:"full",l:"正社員"}].map(f=>
        <button key={f.id} onClick={()=>setStaffFilter(f.id)} style={{padding:"4px 12px",borderRadius:16,fontSize:11,fontWeight:700,border:"none",cursor:"pointer",
          background:staffFilter===f.id?"#1e293b":"#f1f5f9",color:staffFilter===f.id?"#fff":"#64748b"}}>{f.l}</button>)}
    </div>

    {/* ====== 予算（シフト）タブ ====== */}
    {subTab==="budget"&&<div>
      {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=>{
        const d=allStaffData[s.name];if(!d)return null;
        const isP=d.isP;
        return <div key={s.name} style={cardS}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800}}>{s.name}</span>
              <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
            </div>
            <span style={{fontSize:11,color:"#64748b"}}>{d.budgetDays}日 / {d.budgetHours.toFixed(1)}h</span>
          </div>
          <div style={{display:"flex",gap:8}}>
            <div style={boxS("#f0f9ff")}>
              <div style={{fontSize:18,fontWeight:900,color:"#1e40af"}}>¥{d.budgetWage.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>支給</div>
              {isP&&<div style={{fontSize:9,color:"#94a3b8"}}>¥{(s.hourlyWage||0).toLocaleString()}×{d.budgetHours.toFixed(1)}h</div>}
            </div>
            <div style={boxS("#fffbeb")}>
              <div style={{fontSize:18,fontWeight:900,color:"#d97706"}}>¥{d.budgetTransport.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>交通費</div>
              <div style={{fontSize:9,color:"#94a3b8"}}>¥{(s.transportCost||0).toLocaleString()}×{d.budgetDays}日</div>
            </div>
            <div style={boxS("#f8fafc")}>
              <div style={{fontSize:18,fontWeight:900,color:"#1e293b"}}>¥{d.budgetTotal.toLocaleString()}</div>
              <div style={{fontSize:10,color:"#64748b",fontWeight:600}}>合計</div>
            </div>
          </div>
        </div>;
      })}
      {/* 予算総額 */}
      <div style={{...cardS,background:"#f0f4ff",border:"2px solid #bfdbfe"}}>
        <div style={{display:"flex",alignItems:"baseline",justifyContent:"space-between",marginBottom:8}}>
          <span style={{fontSize:14,fontWeight:900}}>予算 総額</span>
          <span style={{fontSize:24,fontWeight:900,color:"#dc2626"}}>¥{budgetGrandTotal.grandTotal.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#475569",marginBottom:2}}>
          <span>支給計</span><span style={{fontWeight:700}}>¥{budgetGrandTotal.payTotal.toLocaleString()}</span>
          <span>交通費計</span><span style={{fontWeight:700,color:"#d97706"}}>¥{budgetGrandTotal.transTotal.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12,color:"#475569",borderTop:"1px solid #dbeafe",paddingTop:4,marginTop:4}}>
          <span>実績 参考</span><span style={{fontWeight:700}}>¥{budgetGrandTotal.actualRef.toLocaleString()}</span>
        </div>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:12}}>
          <span style={{color:"#475569"}}>差異</span>
          <span style={{fontWeight:900,color:budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef>=0?"#dc2626":"#059669"}}>¥{(budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef>=0?"-":"")}{Math.abs(budgetGrandTotal.grandTotal-budgetGrandTotal.actualRef).toLocaleString()}</span>
        </div>
      </div>
    </div>}

    {/* ====== 実績（勤怠）タブ ====== */}
    {subTab==="actual"&&<div>
      {/* スタッフ選択 */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12}}>
        {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=><button key={s.name} onClick={()=>setSelStaff(s.name)} style={{
          padding:"6px 14px",borderRadius:20,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",transition:"all .15s",
          background:selStaff===s.name?"#1e293b":"#f1f5f9",color:selStaff===s.name?"#fff":"#64748b"
        }}>{s.name}</button>)}
      </div>
      {(()=>{
        const sd=allStaffData[selStaff];if(!sd)return null;
        const unapproved=sd.days.filter(d=>d.shift&&d.att&&!d.att.approved).length;
        return <>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{fontSize:13,fontWeight:700}}>{selStaff} ー {ymLabel(viewYM)}</div>
            {unapproved>0?
              <button onClick={()=>approveAll(selStaff)} style={{padding:"5px 14px",borderRadius:8,background:"#059669",color:"#fff",border:"none",fontSize:11,fontWeight:700,cursor:"pointer"}}>全承認 ({sd.days.filter(d=>d.shift).length}件)</button>:
              <span style={{padding:"5px 14px",borderRadius:8,background:"#f0fdf4",color:"#059669",fontSize:11,fontWeight:700}}>全承認済 ✅</span>
            }
          </div>
          {sd.days.map(d=>{
            const isHoliday=d.dow===0;const isSat=d.dow===6;
            const rowBg=isHoliday?"#fef2f2":isSat?"#eff6ff":"#fff";
            const dayColor=isHoliday?"#dc2626":isSat?"#2563eb":"#374151";
            const hasShift=!!d.shift;const att=d.att;const isApproved=att&&att.approved;const isAbsent=att&&att.absent;
            const isKyogi=att&&att.memo&&att.memo.startsWith("協議中");
            const kyogiDetail=isKyogi?att.memo.replace(/^協議中:/,""):"";
            const timeStr=isAbsent?"欠勤":att?(att.start+"〜"+att.end):(hasShift?(d.shift.start+"〜"+d.shift.end):"ー");
            return <div key={d.date} style={{borderBottom:"1px solid #f1f5f9",background:isKyogi?"#fffbeb":isAbsent?"#fef2f2":rowBg}}>
              <div style={{display:"flex",alignItems:"center",padding:"8px 12px",gap:8}}>
                <div style={{width:30,textAlign:"center"}}>
                  <div style={{fontSize:14,fontWeight:800,color:dayColor}}>{d.day}</div>
                  <div style={{fontSize:9,color:dayColor,fontWeight:600}}>{WK[d.dow]}</div>
                </div>
                <div style={{flex:1,fontSize:13,color:isKyogi?"#92400e":isAbsent?"#dc2626":hasShift?"#374151":"#d1d5db",fontWeight:hasShift?600:400}}>{timeStr}</div>
                {hasShift&&<div style={{display:"flex",gap:6}}>
                  {isKyogi&&<span style={{padding:"4px 8px",borderRadius:6,background:"#f59e0b",color:"#fff",fontSize:10,fontWeight:700}}>協議中</span>}
                  {!isKyogi&&isAbsent&&<span style={{padding:"4px 8px",borderRadius:6,background:"#dc2626",color:"#fff",fontSize:10,fontWeight:700}}>欠勤</span>}
                  {!isKyogi&&!isAbsent&&(isApproved?
                    <span style={{padding:"4px 10px",borderRadius:6,background:"#059669",color:"#fff",fontSize:10,fontWeight:700}}>承認</span>:
                    <button onClick={()=>approve(d.date,selStaff)} style={{padding:"4px 10px",borderRadius:6,background:"#dcfce7",color:"#059669",border:"1px solid #bbf7d0",fontSize:10,fontWeight:700,cursor:"pointer"}}>承認</button>
                  )}
                  <button onClick={()=>setEditDay({date:d.date,name:selStaff,start:att?.start||d.shift.start||"09:00",end:att?.end||d.shift.end||"18:00",memo:att?.memo||"",absent:att?.absent||false})} style={{padding:"4px 10px",borderRadius:6,background:isKyogi?"#f59e0b":"#f1f5f9",color:isKyogi?"#fff":"#64748b",border:isKyogi?"none":"1px solid #e2e8f0",fontSize:10,fontWeight:700,cursor:"pointer"}}>{isKyogi?"解決":"編集"}</button>
                </div>}
              </div>
              {isKyogi&&<div style={{padding:"4px 12px 8px 52px",fontSize:11,color:"#92400e",fontWeight:600}}>📝 {kyogiDetail}</div>}
            </div>;
          })}
        </>;
      })()}
    </div>}

    {/* ====== 給与明細タブ ====== */}
    {subTab==="detail"&&<div>
      {staff.filter(s=>staffFilter==="all"?true:staffFilter==="part"?s.type==="アルバイト":s.type==="正社員").map(s=>{
        const d=allStaffData[s.name];if(!d)return null;
        const si=s;const isP=d.isP;
        return <div key={s.name} style={cardS}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:800}}>{s.name}</span>
              <span style={{fontSize:10,fontWeight:700,padding:"2px 10px",borderRadius:12,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8"}}>{s.type}</span>
            </div>
            <span style={{fontSize:11,color:"#64748b"}}>{d.actualDays}日 / {d.actualHours.toFixed(1)}h{d.absentDays>0?<span style={{color:"#dc2626",fontWeight:700}}> (欠勤{d.absentDays})</span>:""}</span>
          </div>
          <div style={{fontSize:13}}>
            {isP?<>
              {(()=>{
                // 日ごとの時給を集計して表示
                const wageBreakdown={};
                d.days.forEach(dy=>{if(dy.att&&dy.att.approved&&!dy.att.absent&&!(dy.att.memo&&dy.att.memo.startsWith("協議中"))){const w=dy._wage||(si.hourlyWage||0);const h=calcHours(dy.att.start,dy.att.end);if(!wageBreakdown[w])wageBreakdown[w]={hours:0,total:0};wageBreakdown[w].hours+=h;wageBreakdown[w].total+=w*h;}});
                const rates=Object.keys(wageBreakdown).map(Number).sort((a,b)=>a-b);
                if(rates.length<=1){
                  return <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                    <span style={{color:"#64748b"}}>時給</span><span style={{fontWeight:600}}>¥{(rates[0]||si.hourlyWage||0).toLocaleString()} × {d.actualHours.toFixed(1)}h</span>
                  </div>;
                }
                return rates.map(w=><div key={w} style={{display:"flex",justifyContent:"space-between",padding:"4px 0",borderBottom:"1px solid #f1f5f9"}}>
                  <span style={{color:"#64748b",fontSize:12}}>時給 ¥{w.toLocaleString()}</span>
                  <span style={{fontWeight:600,fontSize:12}}>{wageBreakdown[w].hours.toFixed(1)}h = ¥{Math.round(wageBreakdown[w].total).toLocaleString()}</span>
                </div>);
              })()}
              <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
                <span style={{color:"#64748b"}}>基本給</span><span style={{fontWeight:700}}>¥{d.actualWage.toLocaleString()}</span>
              </div>
            </>:null}
            {d.otHours>0&&<div style={{display:"flex",justifyContent:"space-between",borderBottom:"1px solid #fed7aa",background:"#fff7ed",margin:"4px -8px",padding:"7px 10px",borderRadius:6}}>
              <span style={{color:"#92400e",fontWeight:700,fontSize:12}}>🟠 残業（ログ）</span>
              <span style={{fontWeight:800,color:"#f97316"}}>{d.otEvents.length}件 / {d.otHours.toFixed(1)}h</span>
            </div>}
            {d.hwHours>0&&<div style={{display:"flex",justifyContent:"space-between",borderBottom:"1px solid #ddd6fe",background:"#f5f3ff",margin:"4px -8px",padding:"7px 10px",borderRadius:6}}>
              <span style={{color:"#5b21b6",fontWeight:700,fontSize:12}}>🟣 休日出勤（ログ）</span>
              <span style={{fontWeight:800,color:"#7c3aed"}}>{d.hwDays}日 / {d.hwEvents.length}件 / {d.hwHours.toFixed(1)}h</span>
            </div>}
            <div style={{display:"flex",justifyContent:"space-between",padding:"6px 0",borderBottom:"1px solid #f1f5f9"}}>
              <span style={{color:"#64748b"}}>交通費 (¥{(si.transportCost||0).toLocaleString()}×{d.actualDays}日)</span>
              <span style={{fontWeight:600,color:"#d97706"}}>¥{d.actualTransport.toLocaleString()}</span>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",padding:"8px 0",marginTop:4,borderTop:"2px solid #e2e8f0"}}>
              <span style={{fontWeight:900,fontSize:14}}>支給額</span>
              <span style={{fontWeight:900,fontSize:18,color:"#1e40af"}}>¥{d.actualTotal.toLocaleString()}</span>
            </div>
            {/* 日別勤怠内訳 */}
            {(()=>{
              const WK=["日","月","火","水","木","金","土"];
              const dayRows=d.days.filter(dy=>dy.att&&dy.att.approved&&!dy.att.absent&&!(dy.att.memo&&dy.att.memo.startsWith("協議中")));
              if(!dayRows.length)return null;
              return <div style={{marginTop:10,borderTop:"1px dashed #e2e8f0",paddingTop:8}}>
                <div style={{fontSize:11,fontWeight:700,color:"#64748b",marginBottom:6}}>📋 日別勤怠内訳</div>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                  <thead>
                    <tr style={{background:"#f8fafc"}}>
                      <th style={{padding:"4px 6px",textAlign:"center",color:"#94a3b8",fontWeight:600,borderBottom:"1px solid #f1f5f9",width:32}}>日</th>
                      <th style={{padding:"4px 6px",textAlign:"center",color:"#94a3b8",fontWeight:600,borderBottom:"1px solid #f1f5f9",width:24}}>曜</th>
                      <th style={{padding:"4px 6px",textAlign:"center",color:"#94a3b8",fontWeight:600,borderBottom:"1px solid #f1f5f9"}}>時間帯</th>
                      <th style={{padding:"4px 6px",textAlign:"right",color:"#94a3b8",fontWeight:600,borderBottom:"1px solid #f1f5f9",width:44}}>時間数</th>
                      {isP&&<th style={{padding:"4px 6px",textAlign:"right",color:"#94a3b8",fontWeight:600,borderBottom:"1px solid #f1f5f9",width:60}}>賃金</th>}
                    </tr>
                  </thead>
                  <tbody>
                    {dayRows.map(dy=>{
                      const h=calcHours(dy.att.start,dy.att.end);
                      const w=dy._wage||(si.hourlyWage||0);
                      const wage=isP?Math.round(w*h):null;
                      const isSun=dy.dow===0;const isSat=dy.dow===6;
                      const dc=isSun?"#dc2626":isSat?"#2563eb":"#374151";
                      return <tr key={dy.date} style={{borderBottom:"1px solid #f8fafc"}}>
                        <td style={{padding:"3px 6px",textAlign:"center",fontWeight:600,color:dc}}>{dy.day}</td>
                        <td style={{padding:"3px 6px",textAlign:"center",color:dc}}>{WK[dy.dow]}</td>
                        <td style={{padding:"3px 6px",textAlign:"center",color:"#475569"}}>{dy.att.start}〜{dy.att.end}</td>
                        <td style={{padding:"3px 6px",textAlign:"right",fontWeight:700,color:"#059669"}}>{h}h</td>
                        {isP&&<td style={{padding:"3px 6px",textAlign:"right",color:"#64748b"}}>¥{wage.toLocaleString()}</td>}
                      </tr>;
                    })}
                    <tr style={{background:"#f0fdf4",borderTop:"1px solid #bbf7d0"}}>
                      <td colSpan={2} style={{padding:"4px 6px",textAlign:"right",fontWeight:700,fontSize:11,color:"#374151"}}>合計</td>
                      <td style={{padding:"4px 6px",textAlign:"center",fontSize:11,color:"#64748b"}}>{dayRows.length}日</td>
                      <td style={{padding:"4px 6px",textAlign:"right",fontWeight:900,color:"#059669"}}>{d.actualHours.toFixed(1)}h</td>
                      {isP&&<td style={{padding:"4px 6px",textAlign:"right",fontWeight:700,color:"#1e40af"}}>¥{d.actualWage.toLocaleString()}</td>}
                    </tr>
                  </tbody>
                </table>
              </div>;
            })()}
            {/* 🟠 残業ログ（実態確認・金額計算なし） */}
            {d.otEvents&&d.otEvents.length>0&&(()=>{
              const WK=["日","月","火","水","木","金","土"];
              return <div style={{marginTop:10,borderTop:"1px dashed #fed7aa",background:"#fffbf5",margin:"10px -8px 0",padding:"10px 12px",borderRadius:6}}>
                <div style={{fontSize:11,fontWeight:800,color:"#92400e",marginBottom:6}}>🟠 残業ログ <span style={{fontWeight:600,color:"#94a3b8",marginLeft:6}}>{d.otEvents.length}件 / 合計 {d.otHours.toFixed(1)}h</span></div>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                  <thead><tr style={{background:"#fef3c7"}}>
                    <th style={{padding:"4px 6px",textAlign:"center",color:"#92400e",fontWeight:700,borderBottom:"1px solid #fed7aa",width:50}}>日付</th>
                    <th style={{padding:"4px 6px",textAlign:"center",color:"#92400e",fontWeight:700,borderBottom:"1px solid #fed7aa"}}>時間帯</th>
                    <th style={{padding:"4px 6px",textAlign:"right",color:"#92400e",fontWeight:700,borderBottom:"1px solid #fed7aa",width:44}}>時間</th>
                    <th style={{padding:"4px 6px",textAlign:"left",color:"#92400e",fontWeight:700,borderBottom:"1px solid #fed7aa"}}>理由</th>
                  </tr></thead>
                  <tbody>{d.otEvents.map(ev=>{
                    const dt=new Date(ev.event_date+"T00:00:00");
                    const dlabel=(dt.getMonth()+1)+"/"+dt.getDate()+"("+WK[dt.getDay()]+")";
                    const tlabel=ev.start_time&&ev.end_time?(ev.start_time+"〜"+ev.end_time):"—";
                    return <tr key={ev.id} style={{borderBottom:"1px solid #fef3c7"}}>
                      <td style={{padding:"3px 6px",textAlign:"center",fontWeight:600,color:"#374151"}}>{dlabel}</td>
                      <td style={{padding:"3px 6px",textAlign:"center",color:"#475569"}}>{tlabel}</td>
                      <td style={{padding:"3px 6px",textAlign:"right",fontWeight:700,color:"#f97316"}}>{ev._h}h</td>
                      <td style={{padding:"3px 6px",color:"#374151"}}>{ev.description||ev.title||<span style={{color:"#dc2626"}}>未入力</span>}</td>
                    </tr>;
                  })}
                  <tr style={{background:"#fff7ed",borderTop:"1px solid #fed7aa"}}>
                    <td colSpan={2} style={{padding:"4px 6px",textAlign:"right",fontWeight:800,fontSize:11,color:"#92400e"}}>残業 月間合計</td>
                    <td style={{padding:"4px 6px",textAlign:"right",fontWeight:900,color:"#f97316"}}>{d.otHours.toFixed(1)}h</td>
                    <td style={{padding:"4px 6px",fontSize:10,color:"#94a3b8"}}>{d.otEvents.length}件</td>
                  </tr></tbody>
                </table>
              </div>;
            })()}
            {/* 🟣 休日出勤ログ（実態確認・金額計算なし） */}
            {d.hwEvents&&d.hwEvents.length>0&&(()=>{
              const WK=["日","月","火","水","木","金","土"];
              return <div style={{marginTop:10,borderTop:"1px dashed #ddd6fe",background:"#faf5ff",margin:"10px -8px 0",padding:"10px 12px",borderRadius:6}}>
                <div style={{fontSize:11,fontWeight:800,color:"#5b21b6",marginBottom:6}}>🟣 休日出勤ログ <span style={{fontWeight:600,color:"#94a3b8",marginLeft:6}}>{d.hwDays}日 / {d.hwEvents.length}件 / 合計 {d.hwHours.toFixed(1)}h</span></div>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                  <thead><tr style={{background:"#ede9fe"}}>
                    <th style={{padding:"4px 6px",textAlign:"center",color:"#5b21b6",fontWeight:700,borderBottom:"1px solid #ddd6fe",width:50}}>日付</th>
                    <th style={{padding:"4px 6px",textAlign:"center",color:"#5b21b6",fontWeight:700,borderBottom:"1px solid #ddd6fe"}}>時間帯</th>
                    <th style={{padding:"4px 6px",textAlign:"right",color:"#5b21b6",fontWeight:700,borderBottom:"1px solid #ddd6fe",width:44}}>時間</th>
                    <th style={{padding:"4px 6px",textAlign:"left",color:"#5b21b6",fontWeight:700,borderBottom:"1px solid #ddd6fe"}}>理由</th>
                  </tr></thead>
                  <tbody>{d.hwEvents.map(ev=>{
                    const dt=new Date(ev.event_date+"T00:00:00");
                    const dlabel=(dt.getMonth()+1)+"/"+dt.getDate()+"("+WK[dt.getDay()]+")";
                    const tlabel=ev.start_time&&ev.end_time?(ev.start_time+"〜"+ev.end_time):"—";
                    return <tr key={ev.id} style={{borderBottom:"1px solid #ede9fe"}}>
                      <td style={{padding:"3px 6px",textAlign:"center",fontWeight:600,color:"#374151"}}>{dlabel}</td>
                      <td style={{padding:"3px 6px",textAlign:"center",color:"#475569"}}>{tlabel}</td>
                      <td style={{padding:"3px 6px",textAlign:"right",fontWeight:700,color:"#7c3aed"}}>{ev._h}h</td>
                      <td style={{padding:"3px 6px",color:"#374151"}}>{ev.description||ev.title||<span style={{color:"#dc2626"}}>未入力</span>}</td>
                    </tr>;
                  })}
                  <tr style={{background:"#f5f3ff",borderTop:"1px solid #ddd6fe"}}>
                    <td colSpan={2} style={{padding:"4px 6px",textAlign:"right",fontWeight:800,fontSize:11,color:"#5b21b6"}}>休日出勤 月間合計</td>
                    <td style={{padding:"4px 6px",textAlign:"right",fontWeight:900,color:"#7c3aed"}}>{d.hwHours.toFixed(1)}h</td>
                    <td style={{padding:"4px 6px",fontSize:10,color:"#94a3b8"}}>{d.hwDays}日 / {d.hwEvents.length}件</td>
                  </tr></tbody>
                </table>
              </div>;
            })()}
          </div>
        </div>;
      })}
    </div>}

    {/* ====== 残業・休日出勤 統合タブ ====== */}
    {subTab==="overtime"&&(()=>{
      const calcOTHours=(s,e)=>{if(!s||!e)return 0;const[sh,sm]=s.split(":").map(Number);const[eh,em]=e.split(":").map(Number);const d=(eh*60+em)-(sh*60+sm);return d>0?Math.round(d/60*10)/10:0;};
      const cardS2={background:"#fff",borderRadius:14,padding:16,border:"1px solid #e2e8f0",marginBottom:12,boxShadow:"0 1px 3px rgba(0,0,0,.05)"};
      const renderSection=(isHW)=>{
        const catLabel=isHW?"休日出勤":"残業";
        const catIcon=isHW?"🟣":"🟠";
        const accent=isHW?"#7c3aed":"#f97316";
        const accentBg=isHW?"#f5f3ff":"#fff7ed";
        const accentBorder=isHW?"#ddd6fe":"#fed7aa";
        const accentLight=isHW?"#ede9fe":"#fef3c7";
        const accentSel=isHW?"#ddd6fe":"#ffedd5";
        const targetEvs=overtimeEvents.filter(r=>r.category===(isHW?"holiday_work":"overtime"));
        const eligibleStaff=isHW?staff.filter(s=>s.type==="正社員"):staff;
        const eligibleSet=new Set(eligibleStaff.map(s=>s.name));
        const allNames=Array.from(new Set(targetEvs.flatMap(r=>r.assignees||[]).filter(n=>!isHW||eligibleSet.has(n)))).sort();
        const dispNames=allNames.length>0?allNames:eligibleStaff.map(s=>s.name);
        const selName=overtimeSel&&dispNames.includes(overtimeSel)?overtimeSel:(dispNames[0]||"");
        const myEvents=targetEvs.filter(r=>(r.assignees||[]).includes(selName));
        const totalH=myEvents.reduce((a,r)=>a+calcOTHours(r.start_time,r.end_time),0);
        const summary={};
        dispNames.forEach(n=>{
          const evs=targetEvs.filter(r=>(r.assignees||[]).includes(n));
          summary[n]={cnt:evs.length,hours:evs.reduce((a,r)=>a+calcOTHours(r.start_time,r.end_time),0)};
        });
        return <div key={isHW?"hw":"ot"} style={{marginBottom:24}}>
          <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:10,padding:"8px 14px",borderRadius:10,background:accentBg,border:"2px solid "+accentBorder}}>
            <span style={{fontSize:18}}>{catIcon}</span>
            <span style={{fontSize:15,fontWeight:900,color:accent}}>{catLabel}</span>
            {isHW&&<span style={{fontSize:10,color:"#5b21b6",background:"#fff",padding:"2px 8px",borderRadius:8,fontWeight:700}}>※ 正社員のみ</span>}
          </div>
          <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12}}>
            {dispNames.map(n=><button key={n} onClick={()=>setOvertimeSel(n)} style={{
              padding:"6px 14px",borderRadius:20,fontSize:12,fontWeight:700,border:"none",cursor:"pointer",
              background:selName===n?accent:"#f1f5f9",color:selName===n?"#fff":"#64748b"
            }}>{n}{summary[n]?.cnt>0?` (${summary[n].hours}h)`:""}</button>)}
          </div>
          <div style={cardS2}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
              <span style={{fontSize:14,fontWeight:800,color:"#1e293b"}}>{selName} の{catLabel}記録</span>
              <span style={{fontSize:12,fontWeight:700,color:accent,background:accentBg,padding:"3px 10px",borderRadius:8}}>合計 {totalH}h</span>
            </div>
            {myEvents.length===0?<div style={{fontSize:12,color:"#94a3b8",textAlign:"center",padding:"16px 0"}}>{catLabel}記録なし</div>
            :<table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
              <thead><tr style={{background:"#f8fafc"}}>
                <th style={{padding:"6px 8px",textAlign:"left",color:"#64748b",fontWeight:700,borderBottom:"1px solid #e2e8f0"}}>日付</th>
                <th style={{padding:"6px 8px",textAlign:"center",color:"#64748b",fontWeight:700,borderBottom:"1px solid #e2e8f0"}}>時間</th>
                <th style={{padding:"6px 8px",textAlign:"center",color:"#64748b",fontWeight:700,borderBottom:"1px solid #e2e8f0"}}>時間数</th>
                <th style={{padding:"6px 8px",textAlign:"left",color:"#64748b",fontWeight:700,borderBottom:"1px solid #e2e8f0"}}>タイトル</th>
                <th style={{padding:"6px 8px",textAlign:"left",color:"#dc2626",fontWeight:700,borderBottom:"1px solid #e2e8f0"}}>理由</th>
              </tr></thead>
              <tbody>{myEvents.map(r=>{
                const h=calcOTHours(r.start_time,r.end_time);
                const dt=new Date(r.event_date+"T00:00:00");
                const JDOW=["日","月","火","水","木","金","土"];
                const dateLabel=`${dt.getMonth()+1}/${dt.getDate()}（${JDOW[dt.getDay()]}）`;
                const timeLabel=r.start_time&&r.end_time?`${r.start_time}〜${r.end_time}`:r.start_time||"—";
                return <tr key={r.id} style={{borderBottom:"1px solid #f1f5f9"}}>
                  <td style={{padding:"8px 8px",fontWeight:600,color:"#1e293b"}}>{dateLabel}</td>
                  <td style={{padding:"8px 8px",textAlign:"center",color:"#475569"}}>{timeLabel}</td>
                  <td style={{padding:"8px 8px",textAlign:"center",fontWeight:700,color:accent}}>{h>0?h+"h":"—"}</td>
                  <td style={{padding:"8px 8px",color:"#374151"}}>{r.title||""}</td>
                  <td style={{padding:"8px 8px",color:"#374151",fontWeight:600}}>{r.description||<span style={{color:"#dc2626",fontSize:10}}>未入力</span>}</td>
                </tr>;
              })}</tbody>
              <tfoot><tr style={{background:accentBg}}>
                <td colSpan={2} style={{padding:"8px 8px",fontWeight:800,color:"#1e293b"}}>月間合計</td>
                <td style={{padding:"8px 8px",textAlign:"center",fontWeight:900,fontSize:14,color:accent}}>{totalH}h</td>
                <td colSpan={2} style={{padding:"8px 8px",fontSize:10,color:"#94a3b8"}}>{myEvents.length}件</td>
              </tr></tfoot>
            </table>}
          </div>
          <div style={{...cardS2,background:accentBg,border:"2px solid "+accentBorder}}>
            <div style={{fontSize:13,fontWeight:800,color:"#1e293b",marginBottom:8}}>📊 {viewYM.replace("-","年")}月 {catLabel}サマリー</div>
            {dispNames.filter(n=>summary[n]?.cnt>0).length===0
              ?<div style={{fontSize:12,color:"#94a3b8"}}>この月の{catLabel}記録はありません</div>
              :<table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                <thead><tr style={{background:accentLight}}>
                  <th style={{padding:"5px 8px",textAlign:"left",color:"#64748b",fontWeight:700}}>スタッフ</th>
                  <th style={{padding:"5px 8px",textAlign:"center",color:"#64748b",fontWeight:700}}>件数</th>
                  <th style={{padding:"5px 8px",textAlign:"center",color:"#64748b",fontWeight:700}}>合計時間</th>
                </tr></thead>
                <tbody>{dispNames.filter(n=>summary[n]?.cnt>0).map(n=><tr key={n} style={{borderBottom:"1px solid "+accentBorder,background:n===selName?accentSel:"transparent"}}>
                  <td style={{padding:"6px 8px",fontWeight:700,color:"#1e293b"}}>{n}</td>
                  <td style={{padding:"6px 8px",textAlign:"center",color:"#475569"}}>{summary[n].cnt}件</td>
                  <td style={{padding:"6px 8px",textAlign:"center",fontWeight:700,color:accent}}>{summary[n].hours}h</td>
                </tr>)}</tbody>
              </table>}
          </div>
        </div>;
      };
      return <div>
        {renderSection(false)}
        <div style={{borderTop:"2px dashed #cbd5e1",margin:"8px 0 24px"}}/>
        {renderSection(true)}
        <div style={{fontSize:11,color:"#94a3b8",textAlign:"center",padding:"8px 0"}}>
          ※ チームカレンダーで「🟠 残業」「🟣 休日出勤」カテゴリのイベントを登録すると自動集計されます（理由必須）
        </div>
      </div>;
    })()}

    {/* 編集モーダル */}
    {editDay&&<div className="modal-overlay" onClick={()=>setEditDay(null)}><div className="modal-box" style={{maxWidth:320,padding:20}} onClick={e=>e.stopPropagation()}>
      <h4 style={{fontSize:14,fontWeight:800,margin:"0 0 14px"}}>{editDay.name} — {fmtD(editDay.date)}</h4>
      {editDay.memo&&editDay.memo.startsWith("協議中")&&<div style={{background:"#fffbeb",border:"1px solid #f59e0b",borderRadius:10,padding:"10px 12px",marginBottom:14}}>
        <div style={{fontSize:11,fontWeight:700,color:"#b45309",marginBottom:4}}>📝 スタッフからの修正リクエスト</div>
        <div style={{fontSize:12,color:"#92400e"}}>{editDay.memo.replace(/^協議中:/,"")}</div>
        <div style={{fontSize:10,color:"#b45309",marginTop:6}}>↓ 時間を修正して「解決・保存」すると承認済みになります</div>
      </div>}
      {/* 欠勤チェック */}
      <div style={{marginBottom:14}}>
        <label style={{display:"flex",alignItems:"center",gap:8,cursor:"pointer",padding:"10px 12px",borderRadius:10,border:editDay.absent?"2px solid #dc2626":"1px solid #e2e8f0",background:editDay.absent?"#fef2f2":"#fff"}}>
          <input type="checkbox" checked={!!editDay.absent} onChange={e=>setEditDay(p=>({...p,absent:e.target.checked}))} style={{width:18,height:18,accentColor:"#dc2626"}}/>
          <div>
            <div style={{fontSize:13,fontWeight:700,color:editDay.absent?"#dc2626":"#374151"}}>欠勤</div>
            <div style={{fontSize:10,color:"#94a3b8"}}>出勤カウント0・時間0扱い</div>
          </div>
        </label>
      </div>
      {/* 時間入力（欠勤でない場合のみ） */}
      {!editDay.absent&&<>
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>開始時間</label>
          <input type="time" value={editDay.start} onChange={e=>setEditDay(p=>({...p,start:e.target.value}))} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
        <div style={{marginBottom:10}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>終了時間</label>
          <input type="time" value={editDay.end} onChange={e=>setEditDay(p=>({...p,end:e.target.value}))} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14,boxSizing:"border-box"}}/>
        </div>
      </>}
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>メモ</label>
        <input value={editDay.memo||""} onChange={e=>setEditDay(p=>({...p,memo:e.target.value}))} placeholder="備考" style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:13,boxSizing:"border-box"}}/>
      </div>
      <div style={{display:"flex",gap:8}}>
        <button onClick={()=>setEditDay(null)} style={{flex:"0 0 auto",padding:"8px 14px",borderRadius:8,border:"1px solid #e2e8f0",background:"#fff",fontSize:12,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        <button onClick={saveEdit} style={{flex:1,padding:"8px 14px",borderRadius:8,border:"none",background:editDay.memo&&editDay.memo.startsWith("協議中")?"#f59e0b":"#2563eb",fontSize:12,fontWeight:700,color:"#fff",cursor:"pointer"}}>{editDay.memo&&editDay.memo.startsWith("協議中")?"✅ 解決・保存":"保存"}</button>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   出勤簿（月次カレンダー+ CSV取込）
   ========================================== */
function ShiftCalendar({shifts,onShiftsChange,today,staff,sbSaveShift,reservations,fleet,vehicles}){
  const todayYM=toYM(today);const[viewYM,setViewYM]=useState(todayYM);const WK=["日","月","火","水","木","金","土"];
  const SYMBOLS=["●","希","公","有","出",""];
  const SHIFT_OPTIONS=[
    {s:"●",label:"出勤",color:"#2563eb",bg:"#D4EBFA"},
    {s:"公",label:"公休",color:"#64748b",bg:"#E8E8E8"},
    {s:"希",label:"希望休",color:"#f59e0b",bg:"#FFF3CD"},
    {s:"有",label:"有給",color:"#059669",bg:"#D1FAE5"},
    {s:"出",label:"出張",color:"#7c3aed",bg:"#D4EDDA"},
  ];
  const maxYM='2026-12';const dim=daysInMonth(viewYM);const[y,mo]=viewYM.split("-").map(Number);
  const getShift=(date)=>shifts[date]||[];
  const regularStaff=staff.filter(s=>s.type==="正社員");const partTimeStaff=staff.filter(s=>s.type==="アルバイト");
  const[cellEdit,setCellEdit]=useState(null); // {dateStr,name,type,symbol,start,end,isNew}

  // 日本の祝日判定（簡易版）
  const jpHolidays=useMemo(()=>{
    const hSet=new Set();
    const addH=(m,d)=>hSet.add(`${viewYM.split("-")[0]}-${String(m).padStart(2,"0")}-${String(d).padStart(2,"0")}`);
    const yr=Number(viewYM.split("-")[0]);
    addH(1,1);addH(1,13);addH(2,11);addH(2,23);addH(3,20);addH(4,29);addH(5,3);addH(5,4);addH(5,5);addH(5,6);
    addH(7,21);addH(8,11);addH(9,15);addH(9,23);addH(10,13);addH(11,3);addH(11,23);
    // 振替休日: 祝日が日曜なら翌月曜
    const all=[...hSet];all.forEach(ds=>{if(new Date(ds).getDay()===0){
      const nd=new Date(ds);nd.setDate(nd.getDate()+1);hSet.add(nd.toISOString().slice(0,10));
    }});
    return hSet;
  },[viewYM]);
  const isHoliday=(ds)=>jpHolidays.has(ds);

  // Supabase同期付きシフト更新
  const updateShifts=(next)=>{onShiftsChange(next);if(sbSaveShift){Object.entries(next).forEach(([date,arr])=>{if(arr!==shifts[date]){
    const newNames=new Set(arr.map(s=>s.name));
    const prev=shifts[date]||[];
    prev.forEach(s=>{if(!newNames.has(s.name))DB.deleteShift(date,s.name);});
    arr.forEach(s=>sbSaveShift(date,s.name,s));
  }});}};
  const _onSC=updateShifts;

  // セルタップ → 編集モーダル表示
  const handleCellClick=(dateStr,name,type)=>{
    const cur=getShift(dateStr);const existing=cur.find(s=>s.name===name);
    if(existing){
      setCellEdit({dateStr,name,type,symbol:existing.symbol||"●",start:existing.start||"09:00",end:existing.end||"18:00",status:existing.status||"確定",isNew:false});
    }else{
      setCellEdit({dateStr,name,type,symbol:type==="正社員"?"●":"",start:"09:00",end:"18:00",status:type==="アルバイト"?"申請":"確定",isNew:true});
    }
  };

  // セル編集保存
  const saveCellEdit=()=>{
    if(!cellEdit)return;
    if(!window.confirm("保存を実行しますか？"))return;
    const{dateStr,name,type,symbol,start,end,status,isNew}=cellEdit;
    const cur=getShift(dateStr);
    const entry={name,type,symbol:type==="正社員"?symbol:"",start,end,status:type==="アルバイト"?(status||"確定"):"確定"};
    if(isNew){
      _onSC({...shifts,[dateStr]:[...cur,entry]});
    }else{
      _onSC({...shifts,[dateStr]:cur.map(s=>s.name===name?entry:s)});
    }
    setCellEdit(null);
  };

  // セル削除
  const deleteCellEdit=()=>{
    if(!cellEdit)return;
    if(!window.confirm("削除を実行しますか？"))return;
    const{dateStr,name}=cellEdit;
    const cur=getShift(dateStr);
    _onSC({...shifts,[dateStr]:cur.filter(s=>s.name!==name)});
    DB.deleteShift(dateStr,name);
    setCellEdit(null);
  };

  const[bulkMode,setBulkMode]=useState(false);
  const[bulkNames,setBulkNames]=useState([]);
  const[bulkDows,setBulkDows]=useState([1,2,3,4,5]);
  const[bulkStart,setBulkStart]=useState("09:00");
  const[bulkEnd,setBulkEnd]=useState("18:00");
  const[bulkOverwrite,setBulkOverwrite]=useState(false);
  const[bulkSymbol,setBulkSymbol]=useState("●");
  const bulkTargetDays=useMemo(()=>{
    let count=0;
    for(let d=1;d<=dim;d++){const dow=new Date(y,mo-1,d).getDay();if(bulkDows.includes(dow))count++;}
    return count;
  },[dim,y,mo,bulkDows]);
  const applyBulk=()=>{
    if(bulkNames.length===0){alert("スタッフを選択してください");return;}
    const dowLabels=bulkDows.map(d=>WK[d]).join("・");
    if(!window.confirm(`${bulkNames.join("・")} の ${dowLabels} に一括登録します。\n時間: ${bulkStart}〜${bulkEnd}\nよろしいですか？`))return;
    const next={...shifts};
    let registered=0,skipped=0;
    bulkNames.forEach(bulkName=>{
      for(let d=1;d<=dim;d++){
        const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
        const dow=new Date(y,mo-1,d).getDay();
        if(bulkDows.includes(dow)){
          const cur=next[ds]||[];
          const existing=cur.find(s=>s.name===bulkName);
          if(existing&&!bulkOverwrite){skipped++;continue;}
          const type=staff.find(s=>s.name===bulkName)?.type||"正社員";
          const entry={name:bulkName,type,symbol:type==="正社員"?bulkSymbol:"",start:bulkStart,end:bulkEnd,status:type==="アルバイト"?"申請":"確定"};
          if(existing&&bulkOverwrite){
            next[ds]=cur.map(s=>s.name===bulkName?entry:s);registered++;
          }else if(!existing){
            next[ds]=[...cur,entry];registered++;
          }
        }
      }
    });
    _onSC(next);setBulkMode(false);
    alert(`✅ 一括登録完了\n登録: ${registered}件${skipped>0?`\nスキップ（既存）: ${skipped}件`:""}`);
  };
  const applyBulkDelete=async()=>{
    if(bulkNames.length===0){alert("スタッフを選択してください");return;}
    const dowLabels=bulkDows.map(d=>WK[d]).join("・");
    if(!window.confirm(`${bulkNames.join("・")} の ${dowLabels} のシフトを削除します。よろしいですか？`))return;
    const next={...shifts};
    let delCount=0;
    const delPromises=[];
    bulkNames.forEach(bulkName=>{
      for(let d=1;d<=dim;d++){
        const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
        const dow=new Date(y,mo-1,d).getDay();
        if(bulkDows.includes(dow)){
          const cur=next[ds]||[];
          const had=cur.some(s=>s.name===bulkName);
          next[ds]=cur.filter(s=>s.name!==bulkName);
          if(had){delPromises.push(DB.deleteShift(ds,bulkName));delCount++;}
        }
      }
    });
    onShiftsChange(next);setBulkMode(false);
    try{await Promise.all(delPromises);}catch(e){console.error("bulkDelete error",e);}
    alert(`✅ 一括削除完了（${delCount}件削除）`);
  };

  // ③ 全スタッフ全シフト一括削除（月単位）
  const clearAllShifts=async()=>{
    if(!window.confirm(`⚠️ ${ymLabel(viewYM)}の全スタッフのシフトを全て削除します。\nこの操作は取り消せません。よろしいですか？`))return;
    if(!window.confirm(`本当に削除しますか？（2回目の確認）`))return;
    // まずローカル状態を即座にクリア
    const next={...shifts};
    let delCount=0;
    for(let d=1;d<=dim;d++){
      const ds=`${viewYM}-${String(d).padStart(2,"0")}`;
      const cur=next[ds]||[];
      delCount+=cur.length;
      next[ds]=[];
    }
    onShiftsChange(next);
    // DBから一括削除（完了を待つ）
    try{
      await DB.deleteShiftsMonth(viewYM);
    }catch(e){console.error("deleteShiftsMonth error",e);}
    alert(`✅ ${ymLabel(viewYM)}の全シフトを削除しました（${delCount}件）`);
  };

  const canPrev=viewYM>todayYM;const canNext=viewYM<maxYM;

  // CSV取込
  const handleCSVUpload=(e)=>{
    const f=e.target.files?.[0];if(!f)return;
    readFile(f,text=>{
      const rows=parseCSV(text);
      if(rows.length<2){alert("CSVフォーマットが無効です");return;}
      const headerRow=rows[0];const dateOffset={};
      for(let i=1;i<headerRow.length;i++){
        const h=headerRow[i];const m=h.match(/(\d+)\/(\d+)/);
        if(m){const ymd=`${y}-${String(m[1]).padStart(2,"0")}-${String(m[2]).padStart(2,"0")}`;dateOffset[i]=ymd;}
      }
      const next={...shifts};
      for(let ri=1;ri<rows.length;ri++){
        const row=rows[ri];
        if(!row[0]||row[0]==="人員")continue;
        const staffName=row[0];const staffItem=staff.find(s=>s.name===staffName);if(!staffItem)continue;
        for(let ci=1;ci<row.length;ci++){
          const val=row[ci]?.trim()||"";if(!val)continue;const dateStr=dateOffset[ci];if(!dateStr)continue;
          const cur=next[dateStr]||[];if(cur.find(s=>s.name===staffName))continue;
          let start="09:00",end="18:00",symbol="";
          const timeMatch=val.match(/(\d{1,2}):(\d{2})-(\d{1,2}):(\d{2})/);
          if(timeMatch){start=`${String(timeMatch[1]).padStart(2,"0")}:${timeMatch[2]}`;end=`${String(timeMatch[3]).padStart(2,"0")}:${timeMatch[4]}`;}
          if(staffItem.type==="正社員"){symbol=val==="●"||val===""?"●":val;}
          next[dateStr]=[...cur,{name:staffName,type:staffItem.type,symbol,start,end,status:staffItem.type==="アルバイト"?"申請":"確定"}];
        }
      }
      _onSC(next);alert("シフトCSVを取込みました");
    });
  };

  const staffTypeMap=useMemo(()=>{const m={};staff.forEach(s=>{m[s.name]=s.type;});return m;},[staff]);
  const calcHeadcount=(dateStr)=>{
    const shfts=getShift(dateStr);
    return shfts.filter(s=>{
      const sType=staffTypeMap[s.name]||"";
      // 正社員: ●（出勤）のみカウント。公/希/有/出はカウントしない
      if(sType==="正社員")return s.symbol==="●";
      // アルバイト: 確定シフトのみカウント
      return!!(s.start&&s.end&&s.status==="確定");
    }).length;
  };

  const dates=[];for(let d=1;d<=dim;d++)dates.push(`${viewYM}-${String(d).padStart(2,"0")}`);

  // タスク数取得（予約データから算出 — 年間通して表示可能）
  const monthTasks=useMemo(()=>{
    if(!reservations||!reservations.length)return{};
    const byDate={};
    // ★ バス廃止: PUB/BDB は集計しない（互換のためキーは残すが常に0）
    const ensure=(d)=>{if(!byDate[d])byDate[d]={洗車:0,PU:0,BD:0,PUB:0,BDB:0,DEL:0,COL:0,来店:0,返却:0,total:0};};
    const NO_BUS=/^(来店|店舗|店頭|ヤード|営業所|ー+|-+|なし|無し|FALSE|false|0)$/;
    reservations.forEach(r=>{
      if(r.status==="cancelled")return;
      // 出発日のタスク
      if(r.lendDate){
        ensure(r.lendDate);
        const dpOk=r.delPlace&&r.delPlace.trim()&&!NO_BUS.test(r.delPlace.trim());
        const lendType=(r.visitType==="DEL"||dpOk)?"DEL":"PU";
        if(lendType==="DEL"){byDate[r.lendDate].DEL++;}
        else{byDate[r.lendDate].PU++;}  // ★ ハイエース運用一本化（バス廃止）
        byDate[r.lendDate].total++;
      }
      // 返却日のタスク
      if(r.returnDate){
        ensure(r.returnDate);
        const cpOk=r.colPlace&&r.colPlace.trim()&&!NO_BUS.test(r.colPlace.trim());
        const retType=(r.returnType==="COL"||cpOk)?"COL":"BD";
        if(retType==="COL"){byDate[r.returnDate].COL++;}
        else{byDate[r.returnDate].BD++;}  // ★ ハイエース運用一本化（バス廃止）
        byDate[r.returnDate].total++;
      }
      // 洗車（出発前日）
      if(r.lendDate){
        const prev=new Date(r.lendDate);prev.setDate(prev.getDate()-1);
        const prevDs=prev.toISOString().slice(0,10);
        ensure(prevDs);byDate[prevDs].洗車++;byDate[prevDs].total++;
      }
    });
    return byDate;
  },[reservations]);

  // セル表示内容を取得
  const SHIFT_STATUS_STYLE={"申請":{color:"#f59e0b",bg:"#fffbeb",border:"#fcd34d",label:"申"},"調整中":{color:"#6366f1",bg:"#eef2ff",border:"#a5b4fc",label:"調"},"確定":{color:"#059669",bg:"#ecfdf5",border:"#6ee7b7",label:"✓"}};
  const getCellDisplay=(shift,type)=>{
    if(!shift)return null;
    if(type==="正社員"){
      return shift.symbol||"";
    }
    // アルバイト: 時間＋ステータスバッジ
    const st=SHIFT_STATUS_STYLE[shift.status]||SHIFT_STATUS_STYLE["確定"];
    if(shift.start&&shift.end){
      const s=shift.start.replace(/^0/,"");const e=shift.end.replace(/^0/,"");
      return <div style={{lineHeight:"1.1",position:"relative"}}>
        <span style={{fontSize:7}}>{s}<br/>{e}</span>
        <div style={{fontSize:7,fontWeight:800,color:st.color,marginTop:1}}>{st.label}</div>
      </div>;
    }
    return "";
  };

  // セル背景色 — 平日:白 土曜:青 日曜:赤 祝日:薄黄
  const getBaseBg=(dow,ds)=>{
    if(isHoliday(ds))return "#FFFDE7"; // 祝日=薄黄
    if(dow===0)return "#FFEBEE"; // 日曜=薄赤
    if(dow===6)return "#E3F2FD"; // 土曜=薄青
    return "#FFFFFF"; // 平日=白
  };
  // 背景色は常に曜日ベース（平日=白、土曜=青、日曜=赤、祝日=薄黄色）
  const getCellBg=(shift,dow,ds)=>getBaseBg(dow,ds);

  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div className="px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2" style={{background:"#D2B48C"}}>
      <div className="flex items-center gap-2">
        <button onClick={()=>canPrev&&setViewYM(ymOff(viewYM,-1))} className="px-2 py-1 bg-white border border-gray-300 rounded text-sm hover:bg-gray-50" style={{opacity:canPrev?1:.4}}>◀</button>
        <h3 className="text-base font-bold" style={{margin:0}}>{ymLabel(viewYM)}</h3>
        <button onClick={()=>canNext&&setViewYM(ymOff(viewYM,1))} className="px-2 py-1 bg-white border border-gray-300 rounded text-sm hover:bg-gray-50" style={{opacity:canNext?1:.4}}>▶</button>
        {viewYM!==todayYM&&<button onClick={()=>setViewYM(todayYM)} className="px-2 py-1 bg-blue-50 border border-blue-200 rounded text-xs font-semibold text-blue-700">今月</button>}
      </div>
      <div className="flex items-center gap-2">
        <button onClick={clearAllShifts} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#991b1b",color:"#fff"}}>全削除</button>
        <button onClick={()=>{setBulkNames([]);setBulkDows([1,2,3,4,5]);setBulkMode("delete");}} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#dc2626",color:"#fff"}}>一括削除</button>
        <button onClick={()=>{setBulkNames([]);setBulkDows([1,2,3,4,5]);setBulkSymbol("●");setBulkStart("09:00");setBulkEnd("18:00");setBulkOverwrite(false);setBulkMode("set");}} className="px-3 py-1 rounded-lg text-xs font-semibold border" style={{background:"#2563eb",color:"#fff"}}>一括設定</button>
        <label className="px-3 py-1 rounded-lg text-xs font-semibold border border-blue-300 bg-blue-50 text-blue-700 cursor-pointer hover:bg-blue-100"><span>CSV</span><input type="file" accept=".csv,.txt" className="hidden" onChange={handleCSVUpload}/></label>
      </div>
    </div>
    {/* 一括モーダル */}
    {bulkMode&&<div className="modal-overlay" onClick={()=>setBulkMode(false)}><div className="modal-box" style={{maxWidth:380,padding:24}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <h4 style={{fontSize:16,fontWeight:800,margin:0}}>{bulkMode==="delete"?"一括削除":"一括設定"}</h4>
        <button onClick={()=>setBulkMode(false)} style={{background:"none",border:"none",fontSize:18,color:"#94a3b8",cursor:"pointer"}}>✕</button>
      </div>
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>スタッフ（複数選択可）</label>
        <div style={{display:"flex",gap:4,flexWrap:"wrap",marginBottom:6}}>
          <button onClick={()=>setBulkNames(staff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:700,border:"1px solid #e2e8f0",background:bulkNames.length===staff.length?"#2563eb":"#f8fafc",color:bulkNames.length===staff.length?"#fff":"#64748b",cursor:"pointer"}}>全員</button>
          <button onClick={()=>setBulkNames(regularStaff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#1d4ed8",cursor:"pointer"}}>正社員</button>
          <button onClick={()=>setBulkNames(partTimeStaff.map(s=>s.name))} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#92400e",cursor:"pointer"}}>アルバイト</button>
          <button onClick={()=>setBulkNames([])} style={{padding:"4px 10px",borderRadius:6,fontSize:11,fontWeight:600,border:"1px solid #e2e8f0",background:"#f8fafc",color:"#94a3b8",cursor:"pointer"}}>解除</button>
        </div>
        <div style={{maxHeight:120,overflowY:"auto",border:"1px solid #e2e8f0",borderRadius:8,padding:4}}>
          {staff.map(s=>{const sel=bulkNames.includes(s.name);return <label key={s.name} style={{display:"flex",alignItems:"center",gap:6,padding:"4px 6px",cursor:"pointer",borderRadius:4,background:sel?"#eff6ff":"transparent"}}>
            <input type="checkbox" checked={sel} onChange={()=>setBulkNames(p=>p.includes(s.name)?p.filter(n=>n!==s.name):[...p,s.name])} style={{width:14,height:14}}/>
            <span style={{fontSize:12,fontWeight:sel?700:400}}>{s.name}</span>
            <span style={{fontSize:9,color:s.type==="正社員"?"#1d4ed8":"#92400e",fontWeight:600}}>({s.type})</span>
          </label>;})}
        </div>
        {bulkNames.length>0&&<div style={{fontSize:11,color:"#2563eb",fontWeight:600,marginTop:4}}>{bulkNames.length}名選択中</div>}
      </div>
      <div style={{marginBottom:14}}>
        <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>曜日</label>
        <div style={{display:"flex",gap:6}}>
          {WK.map((w,i)=>{const isSun=i===0;const isSat=i===6;return <button key={i} onClick={()=>setBulkDows(p=>p.includes(i)?p.filter(x=>x!==i):[...p,i])} style={{
            width:38,height:38,borderRadius:8,fontSize:13,fontWeight:700,border:"none",cursor:"pointer",transition:"all .15s",
            background:bulkDows.includes(i)?"#2563eb":"#f1f5f9",color:bulkDows.includes(i)?"#fff":isSun?"#dc2626":isSat?"#2563eb":"#94a3b8"
          }}>{w}</button>;})}
        </div>
      </div>
      {bulkMode==="set"&&<>
        {bulkNames.length>0&&bulkNames.some(bn=>staff.find(s=>s.name===bn)?.type==="正社員")&&<div style={{marginBottom:14}}>
          <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:6}}>シフト種別（正社員）</label>
          <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
            {SHIFT_OPTIONS.map(o=><button key={o.s} onClick={()=>setBulkSymbol(o.s)} style={{
              padding:"6px 10px",borderRadius:8,fontSize:11,fontWeight:700,border:"2px solid",cursor:"pointer",
              background:bulkSymbol===o.s?o.color:"#fff",color:bulkSymbol===o.s?"#fff":o.color,borderColor:bulkSymbol===o.s?o.color:"#e2e8f0"
            }}>{o.s} {o.label}</button>)}
          </div>
        </div>}
        <div style={{display:"flex",gap:12,marginBottom:14}}>
          <div style={{flex:1}}>
            <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>開始</label>
            <input type="time" value={bulkStart} onChange={e=>setBulkStart(e.target.value)} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
          </div>
          <div style={{flex:1}}>
            <label style={{fontSize:12,color:"#64748b",fontWeight:600,display:"block",marginBottom:4}}>終了</label>
            <input type="time" value={bulkEnd} onChange={e=>setBulkEnd(e.target.value)} style={{width:"100%",padding:"8px 10px",borderRadius:8,border:"1px solid #e2e8f0",fontSize:14}}/>
          </div>
        </div>
        <label style={{display:"flex",alignItems:"center",gap:8,fontSize:12,color:"#374151",marginBottom:16,cursor:"pointer"}}>
          <input type="checkbox" checked={bulkOverwrite} onChange={e=>setBulkOverwrite(e.target.checked)} style={{width:16,height:16}}/>
          既存シフトを上書き
        </label>
      </>}
      <div style={{textAlign:"center",padding:"8px 0",background:bulkMode==="delete"?"#fef2f2":"#f8fafc",borderRadius:8,marginBottom:14,fontSize:13,color:"#64748b"}}>
        対象: <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkNames.length}</span> 名 × <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkTargetDays}</span> 日 = <span style={{fontWeight:900,color:bulkMode==="delete"?"#dc2626":"#1e293b",fontSize:16}}>{bulkNames.length*bulkTargetDays}</span> 件
      </div>
      <div style={{display:"flex",gap:8}}>
        <button onClick={()=>setBulkMode(false)} style={{flex:"0 0 auto",padding:"10px 16px",borderRadius:10,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>キャンセル</button>
        {bulkMode==="delete"?
          <button onClick={applyBulkDelete} disabled={bulkNames.length===0} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:bulkNames.length>0?"#dc2626":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:bulkNames.length>0?"pointer":"not-allowed"}}>一括削除 ({bulkTargetDays}日)</button>:
          <button onClick={applyBulk} disabled={bulkNames.length===0} style={{flex:1,padding:"10px 16px",borderRadius:10,border:"none",background:bulkNames.length>0?"#2563eb":"#94a3b8",fontSize:13,fontWeight:700,color:"#fff",cursor:bulkNames.length>0?"pointer":"not-allowed"}}>一括設定 ({bulkTargetDays}件)</button>
        }
      </div>
    </div></div>}

    {/* シフト表（改良版） */}
    <div style={{maxHeight:600,overflowX:"auto",overflowY:"auto",position:"relative",WebkitOverflowScrolling:"touch"}}>
      <table style={{borderCollapse:"collapse",fontSize:10,minWidth:"100%"}}>
        <thead>
          <tr style={{background:"#D2B48C",position:"sticky",top:0,zIndex:3}}>
            <th style={{position:"sticky",left:0,zIndex:5,width:72,minWidth:72,padding:"6px 4px",textAlign:"center",fontWeight:700,borderRight:"2px solid #b8976a",background:"#D2B48C",fontSize:10}}>名前</th>
            {dates.map(ds=>{const dt=new Date(ds);const dow=dt.getDay();const day=dt.getDate();const isToday=ds===today;const hol=isHoliday(ds);
            const bgc=isToday?"#FFFF99":hol?"#FFFDE7":dow===0?"#FFCDD2":dow===6?"#BBDEFB":"#D2B48C";
            const txtC=hol?"#e65100":dow===0?"#c62828":dow===6?"#1565c0":"#78716c";
            return <th key={ds} style={{minWidth:42,width:42,padding:"4px 1px",textAlign:"center",fontWeight:700,fontSize:9,background:bgc,borderRight:"1px solid #b8976a",borderBottom:"1px solid #b8976a",boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none"}}>
              <div style={{lineHeight:1.2}}>{day}</div>
              <div style={{fontSize:8,color:txtC}}>{WK[dow]}{hol?"*":""}</div>
            </th>;})}
          </tr>
        </thead>
        <tbody>
          {/* 正社員 */}
          {regularStaff.length>0&&<tr><td colSpan={dates.length+1} style={{background:"#eff6ff",padding:"3px 8px",fontSize:9,fontWeight:700,color:"#1d4ed8",borderBottom:"1px solid #bfdbfe"}}>正社員</td></tr>}
          {regularStaff.map(st=><tr key={st.name}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontWeight:600,fontSize:10,background:"#fff",borderRight:"2px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",whiteSpace:"nowrap"}}>
              <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:"#dbeafe",color:"#1d4ed8",marginRight:2}}>社</span>{st.name}
            </td>
            {dates.map(ds=>{
              const shift=getShift(ds).find(s=>s.name===st.name);const dow=new Date(ds).getDay();
              const bg=getCellBg(shift,dow,ds);const isToday=ds===today;
              return <td key={ds} onClick={()=>handleCellClick(ds,st.name,"正社員")} style={{
                minWidth:42,width:42,padding:"2px",textAlign:"center",fontSize:11,fontWeight:700,background:bg,
                borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",cursor:"pointer",
                boxShadow:isToday?"inset 0 0 0 2px #f59e0b":"none",
                color:shift?.symbol==="●"?"#1d4ed8":shift?.symbol==="公"?"#64748b":shift?.symbol==="希"?"#d97706":shift?.symbol==="有"?"#059669":shift?.symbol==="出"?"#7c3aed":"#d1d5db",
                height:36,verticalAlign:"middle"
              }}>{shift?shift.symbol:<span style={{color:"#e5e7eb",fontSize:14}}>+</span>}</td>;
            })}
          </tr>)}

          {/* アルバイト */}
          {partTimeStaff.length>0&&<tr><td colSpan={dates.length+1} style={{background:"#fffbeb",padding:"3px 8px",fontSize:9,fontWeight:700,color:"#92400e",borderBottom:"1px solid #fde68a"}}>アルバイト</td></tr>}
          {partTimeStaff.map(st=><tr key={st.name}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontWeight:600,fontSize:10,background:"#fff",borderRight:"2px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",whiteSpace:"nowrap"}}>
              <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:"#fef3c7",color:"#92400e",marginRight:2}}>ア</span>{st.name}
            </td>
            {dates.map(ds=>{
              const shift=getShift(ds).find(s=>s.name===st.name);const dow=new Date(ds).getDay();
              const bg=getCellBg(shift,dow,ds);const isToday=ds===today;
              const stStatus=shift?.status;const stStyle=stStatus?SHIFT_STATUS_STYLE[stStatus]:null;
              const cellBorder=stStyle?`2px solid ${stStyle.border}`:"";
              return <td key={ds} onClick={()=>handleCellClick(ds,st.name,"アルバイト")} style={{
                minWidth:42,width:42,padding:"1px",textAlign:"center",background:bg,
                borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",cursor:"pointer",
                boxShadow:isToday?"inset 0 0 0 2px #f59e0b":cellBorder?`inset 0 0 0 1px ${stStyle.border}`:"none",
                height:36,verticalAlign:"middle"
              }}>{shift?getCellDisplay(shift,"アルバイト"):<span style={{color:"#e5e7eb",fontSize:14}}>+</span>}</td>;
            })}
          </tr>)}

          {/* 人員合計行 */}
          <tr style={{fontWeight:700,background:"#D2B48C"}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontSize:10,fontWeight:700,background:"#D2B48C",borderRight:"2px solid #b8976a",borderBottom:"1px solid #b8976a"}}>人員</td>
            {dates.map(ds=>{const hc=calcHeadcount(ds);return <td key={ds} style={{minWidth:42,width:42,padding:"3px 1px",textAlign:"center",fontSize:11,fontWeight:800,background:"#D2B48C",borderRight:"1px solid #b8976a",borderBottom:"1px solid #b8976a",color:hc===0?"#b8976a":"#1e293b"}}>{hc}</td>;})}
          </tr>
          {/* タスク数合計行 */}
          <tr style={{fontWeight:700,background:"#f0fdf4"}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"4px 6px",fontSize:10,fontWeight:700,background:"#f0fdf4",borderRight:"2px solid #d1d5db",borderBottom:"1px solid #d1d5db"}}>タスク</td>
            {dates.map(ds=>{const tc=monthTasks[ds];const total=tc?tc.total:0;const hc=calcHeadcount(ds);
              const ratio=hc>0?total/hc:0;const rBg=total===0?"#f0fdf4":ratio>3?"#fecaca":ratio>2?"#fed7aa":"#f0fdf4";
              return <td key={ds} style={{minWidth:42,width:42,padding:"2px 1px",textAlign:"center",fontSize:10,fontWeight:800,background:rBg,borderRight:"1px solid #d1d5db",borderBottom:"1px solid #d1d5db",color:total===0?"#d1d5db":"#1e293b"}}>{total||""}</td>;})}
          </tr>
          {/* タスク内訳行 ★ バス廃止：PU/BD/DEL/COL のみ */}
          {[{key:"洗車",label:"洗車",color:"#795548",bg:"#FFFDE7"},{key:"PU",label:"PU",color:"#2563eb",bg:"#eff6ff"},{key:"BD",label:"BD",color:"#dc2626",bg:"#fef2f2"},{key:"DEL",label:"DEL",color:"#0891b2",bg:"#ecfeff"},{key:"COL",label:"COL",color:"#0d9488",bg:"#f0fdfa"}].map(cat=>
          <tr key={cat.key} style={{background:cat.bg}}>
            <td style={{position:"sticky",left:0,zIndex:2,width:72,minWidth:72,padding:"3px 6px",fontSize:8,fontWeight:700,background:cat.bg,borderRight:"2px solid #d1d5db",borderBottom:"1px solid #e5e7eb",color:cat.color}}>{cat.label}</td>
            {dates.map(ds=>{const tc=monthTasks[ds];const cnt=tc?tc[cat.key]:0;
              return <td key={ds} style={{minWidth:42,width:42,padding:"1px",textAlign:"center",fontSize:9,fontWeight:700,background:cat.bg,borderRight:"1px solid #e5e7eb",borderBottom:"1px solid #e5e7eb",color:cnt?cat.color:"#e5e7eb"}}>{cnt||""}</td>;})}
          </tr>)}
        </tbody>
      </table>
    </div>

    {/* サマリーテーブル */}
    <div className="px-4 py-3 border-t border-gray-200 bg-gray-50 overflow-x-auto">
      <div style={{fontSize:11,fontWeight:700,color:"#374151",marginBottom:6}}>月間サマリー</div>
      <table style={{fontSize:10,borderCollapse:"collapse",width:"100%"}}>
        <thead><tr style={{background:"#e5e7eb"}}>
          <th style={{padding:"5px 8px",textAlign:"left",fontWeight:700,border:"1px solid #d1d5db",minWidth:80}}>名前</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#2563eb"}}>出勤</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#64748b"}}>公休</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#d97706"}}>希望休</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#059669"}}>有給</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40,color:"#7c3aed"}}>出張</th>
          <th style={{padding:"5px 6px",textAlign:"center",fontWeight:700,border:"1px solid #d1d5db",minWidth:40}}>合計</th>
        </tr></thead>
        <tbody>
          {staff.map(s=>{
            const staffSymCounts={};let workDays=0;
            const isP=s.type==="アルバイト";
            dates.forEach(ds=>{
              const sShift=getShift(ds).find(sh=>sh.name===s.name);
              if(!sShift)return;
              if(sShift.symbol){
                staffSymCounts[sShift.symbol]=(staffSymCounts[sShift.symbol]||0)+1;
              }else if(isP&&sShift.start&&sShift.end){
                workDays++;
              }
            });
            const symWork=staffSymCounts["●"]||0;
            const totalWork=symWork+workDays;
            const total=totalWork+(staffSymCounts["公"]||0)+(staffSymCounts["希"]||0)+(staffSymCounts["有"]||0)+(staffSymCounts["出"]||0);
            return <tr key={s.name} style={{background:isP?"#fffbeb":"#fff",borderBottom:"1px solid #d1d5db"}}>
              <td style={{padding:"4px 8px",border:"1px solid #d1d5db",fontWeight:600,fontSize:10}}>
                <span style={{fontSize:8,fontWeight:700,padding:"1px 4px",borderRadius:3,background:isP?"#fef3c7":"#dbeafe",color:isP?"#92400e":"#1d4ed8",marginRight:4}}>{isP?"ア":"社"}</span>{s.name}
              </td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",fontWeight:totalWork>0?700:400,color:totalWork>0?"#1d4ed8":"#d1d5db"}}>{totalWork}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["公"]||0)>0?"#64748b":"#d1d5db"}}>{staffSymCounts["公"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["希"]||0)>0?"#d97706":"#d1d5db"}}>{staffSymCounts["希"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["有"]||0)>0?"#059669":"#d1d5db"}}>{staffSymCounts["有"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",color:(staffSymCounts["出"]||0)>0?"#7c3aed":"#d1d5db"}}>{staffSymCounts["出"]||0}</td>
              <td style={{padding:"4px 6px",border:"1px solid #d1d5db",textAlign:"center",fontWeight:700}}>{total}</td>
            </tr>;
          })}
        </tbody>
      </table>
    </div>

    {/* セル編集モーダル（日毎のシフト内容設定） */}
    {cellEdit&&<div className="modal-overlay" onClick={()=>setCellEdit(null)}><div className="modal-box" style={{maxWidth:340,padding:0,borderRadius:16,overflow:"hidden"}} onClick={e=>e.stopPropagation()}>
      {/* ヘッダー */}
      <div style={{background:"#D2B48C",padding:"14px 20px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <div>
          <div style={{fontSize:14,fontWeight:800,color:"#1e293b"}}>{cellEdit.name}</div>
          <div style={{fontSize:12,color:"#78716c"}}>{fmtD(cellEdit.dateStr)} ({WK[new Date(cellEdit.dateStr).getDay()]})</div>
        </div>
        <button onClick={()=>setCellEdit(null)} style={{background:"none",border:"none",fontSize:18,color:"#78716c",cursor:"pointer",padding:4}}>✕</button>
      </div>
      <div style={{padding:"16px 20px"}}>
        {/* シフト種別選択（正社員のみ） */}
        {cellEdit.type==="正社員"&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>出勤内容</label>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
            {SHIFT_OPTIONS.map(o=>{
              const sel=cellEdit.symbol===o.s;
              return <button key={o.s} onClick={()=>setCellEdit({...cellEdit,symbol:o.s})} style={{
                padding:"10px 8px",borderRadius:10,fontSize:12,fontWeight:700,border:"2px solid",cursor:"pointer",transition:"all .15s",
                background:sel?o.color:"#fff",color:sel?"#fff":o.color,borderColor:sel?o.color:"#e2e8f0",
                display:"flex",alignItems:"center",justifyContent:"center",gap:6
              }}><span style={{fontSize:16}}>{o.s}</span> {o.label}</button>;
            })}
          </div>
        </div>}
        {/* ステータス選択（アルバイトのみ） */}
        {cellEdit.type==="アルバイト"&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>ステータス</label>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:6}}>
            {[{s:"申請",c:"#f59e0b",bg:"#fffbeb"},{s:"調整中",c:"#6366f1",bg:"#eef2ff"},{s:"確定",c:"#059669",bg:"#ecfdf5"}].map(o=>{
              const sel=cellEdit.status===o.s;
              return <button key={o.s} onClick={()=>setCellEdit({...cellEdit,status:o.s})} style={{
                padding:"10px 6px",borderRadius:10,fontSize:12,fontWeight:700,border:"2px solid",cursor:"pointer",transition:"all .15s",
                background:sel?o.c:"#fff",color:sel?"#fff":o.c,borderColor:sel?o.c:"#e2e8f0",
                textAlign:"center"
              }}>{o.s}</button>;
            })}
          </div>
        </div>}
        {/* 時間設定（出勤・出張の場合、またはアルバイト） */}
        {(cellEdit.type==="アルバイト"||cellEdit.symbol==="●"||cellEdit.symbol==="出")&&<div style={{marginBottom:16}}>
          <label style={{fontSize:11,color:"#64748b",fontWeight:700,display:"block",marginBottom:8}}>勤務時間</label>
          <div style={{display:"flex",gap:10,alignItems:"center"}}>
            <input type="time" value={cellEdit.start} onChange={e=>setCellEdit({...cellEdit,start:e.target.value})} style={{flex:1,padding:"10px 10px",borderRadius:10,border:"1px solid #e2e8f0",fontSize:15,textAlign:"center"}}/>
            <span style={{color:"#94a3b8",fontWeight:700,fontSize:14}}>〜</span>
            <input type="time" value={cellEdit.end} onChange={e=>setCellEdit({...cellEdit,end:e.target.value})} style={{flex:1,padding:"10px 10px",borderRadius:10,border:"1px solid #e2e8f0",fontSize:15,textAlign:"center"}}/>
          </div>
        </div>}
        {/* ボタン */}
        <div style={{display:"flex",gap:8,marginTop:8}}>
          <button onClick={saveCellEdit} style={{flex:1,padding:"12px 16px",borderRadius:12,border:"none",background:"#2563eb",fontSize:13,fontWeight:700,color:"#fff",cursor:"pointer"}}>
            {cellEdit.isNew?"登録":"保存"}
          </button>
          {!cellEdit.isNew&&<button onClick={deleteCellEdit} style={{padding:"12px 16px",borderRadius:12,border:"1px solid #fecaca",background:"#fef2f2",fontSize:13,fontWeight:700,color:"#dc2626",cursor:"pointer"}}>削除</button>}
          <button onClick={()=>setCellEdit(null)} style={{padding:"12px 16px",borderRadius:12,border:"1px solid #e2e8f0",background:"#fff",fontSize:13,fontWeight:600,color:"#64748b",cursor:"pointer"}}>戻る</button>
        </div>
      </div>
    </div></div>}
  </div>;
}

/* ==========================================
   新規予約登録フォーム（手動 + CSV自動配車）
   ========================================== */
function ReservationForm({onAdd,onBulkAdd,vehicles,vehicleClasses,onClose,prefill,data,fleet,maintenance}){
  // SP予約番号の自動採番: SP-YYYYMMDD-NNNN
  const genSpId=()=>{
    const today=new Date();const ds=today.getFullYear()+String(today.getMonth()+1).padStart(2,"0")+String(today.getDate()).padStart(2,"0");
    const prefix="SP-"+ds+"-";
    const existing=data.filter(r=>r.id&&r.id.startsWith(prefix));
    const maxN=existing.reduce((mx,r)=>{const n=parseInt(r.id.replace(prefix,""),10);return isNaN(n)?mx:Math.max(mx,n);},0);
    return prefix+String(maxN+1).padStart(4,"0");
  };
  const init=prefill||{name:"",people:1,delPlace:"",colPlace:"",vehicle:"A",vehicleCode:"",insurance:"免責",lendDate:"",returnDate:"",lendTime:"09:00",returnTime:"18:00",id:genSpId(),ota:"SP",flight:"",tel:"",mail:"",basePrice:0,optionPrice:0,discount:0};
  const[f,setF]=useState(init);
  const[mode,setMode]=useState("manual"); // manual / csv
  const[csvResult,setCsvResult]=useState(null);
  const[csvLogs,setCsvLogs]=useState([]);
  const[submitResult,setSubmitResult]=useState(null);

  const upF=(k,v)=>setF(p=>({...p,[k]:v}));
  const calcTotal=()=>Math.max(0,(Number(f.basePrice)||0)+(Number(f.optionPrice)||0)-(Number(f.discount)||0));

  // CSV取込（配車は手動）
  const handleCSV=(e)=>{
    const file=e.target.files?.[0];if(!file)return;
    readFile(file,text=>{
      const rows=parseCSV(text);
      const res=detectParse(rows);
      if(!res){setCsvLogs([{t:"err",m:"CSV形式を検出できません"}]);return;}
      const skipMsg=res.skippedOther>0?` (他店舗${res.skippedOther}件除外)`:"";
      setCsvLogs([{t:"ok",m:`${OTA[res.ota].name} 高松${res.data.length}件${skipMsg}`}]);
      setCsvResult({data:res.data,fleet:{},ota:res.ota});
    });
  };
  const commitCSV=()=>{if(csvResult)onBulkAdd(csvResult.data,csvResult.fleet);};

  const submit=()=>{
    if(!f.name||!f.lendDate||!f.returnDate){alert("予約者名・貸出日・返却日は必須です");return;}
    if(f.vehicleCode&&f.lendDate&&f.returnDate){
      const tmpRes={id:f.id||"_tmp",lendDate:f.lendDate,returnDate:f.returnDate,status:"confirmed"};
      const conflict=data.find(r=>r.id!==tmpRes.id&&r.status!=="cancelled"&&fleet[r.id]===f.vehicleCode&&norm(r.lendDate)<=norm(tmpRes.returnDate)&&norm(r.returnDate)>=norm(tmpRes.lendDate));
      if(conflict){const cv=vehicles.find(x=>x.code===f.vehicleCode);alert((cv?cv.name:f.vehicleCode)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の予約が入っているため配車できません。\n配車表で手動配車してください。");return;}
    }
    const total=calcTotal();
    const r={...f,id:f.id||genSpId(),ota:f.ota||"SP",status:"confirmed",visitType:f.delPlace&&!/来店|店舗|店頭|ヤード|営業所/.test(f.delPlace)?"DEL":"来店",returnType:f.colPlace&&!/来店|店舗|店頭|ヤード|営業所/.test(f.colPlace)?"COL":"返却",delTime:f.lendTime,colTime:f.returnTime,delPlace:f.delPlace||"",colPlace:f.colPlace||"",price:total,basePrice:Number(f.basePrice)||0,optionPrice:Number(f.optionPrice)||0,discount:Number(f.discount)||0,tel:f.tel||"",mail:f.mail||""};
    onAdd(r,f.vehicleCode);
    // 配車結果フィードバック
    if(f.vehicleCode){
      const cv=vehicles.find(x=>x.code===f.vehicleCode);
      setSubmitResult({ok:true,msg:`${r.name} 様の予約を登録し、${cv?cv.name:f.vehicleCode} に配車しました`});
    }else{
      // 自動配車の結果を確認
      setTimeout(()=>{
        setSubmitResult({ok:true,msg:`${r.name} 様の予約を登録しました（配車は配車表で確認してください）`});
      },500);
    }
  };

  return <div className="modal-overlay" onClick={onClose}><div className="modal-box" style={{maxWidth:580,maxHeight:"90vh"}} onClick={e=>e.stopPropagation()}>
    <div style={{padding:"16px 20px",borderBottom:"1px solid #e5e7eb"}}>
      <div className="flex items-center justify-between">
        <h3 className="font-bold text-base">新規予約登録</h3>
        <button onClick={onClose} className="text-gray-400 hover:text-gray-600 text-lg">✕</button>
      </div>
      <div className="flex gap-2 mt-2">
        <button onClick={()=>setMode("manual")} className="px-3 py-1 rounded-lg text-xs font-bold" style={{background:mode==="manual"?"#2563eb":"#f1f5f9",color:mode==="manual"?"#fff":"#374151"}}>手動入力</button>
        <button onClick={()=>setMode("csv")} className="px-3 py-1 rounded-lg text-xs font-bold" style={{background:mode==="csv"?"#2563eb":"#f1f5f9",color:mode==="csv"?"#fff":"#374151"}}>CSV一括取込</button>
      </div>
    </div>

    <div style={{padding:"12px 20px",overflowY:"auto",maxHeight:"calc(90vh - 120px)"}}>
      {submitResult&&<div className="mb-3 px-3 py-2 rounded-lg text-sm font-bold" style={{background:submitResult.ok?"#f0fdf4":"#fef2f2",color:submitResult.ok?"#15803d":"#b91c1c"}}>{submitResult.ok?"✓":"✗"} {submitResult.msg}<button onClick={onClose} className="ml-3 text-xs underline">閉じる</button></div>}
      {mode==="csv"?<div>
        <p className="text-xs text-gray-500 mb-2">CSVをアップロードして予約を一括登録します（配車は配車表から手動で行います）</p>
        <label className="flex flex-col items-center p-6 rounded-xl border-2 border-dashed border-blue-300 bg-blue-50 cursor-pointer hover:bg-blue-100 transition mb-3">
          <span style={{fontSize:28}}>📄</span>
          <span className="text-sm font-semibold text-blue-700 mt-1">CSVファイルを選択</span>
          <input type="file" accept=".csv,.txt" className="hidden" onChange={handleCSV}/>
        </label>
        {csvLogs.map((l,i)=><div key={i} className="text-xs px-2 py-1 rounded mb-1" style={{background:l.t==="err"?"#fef2f2":"#f0fdf4",color:l.t==="err"?"#b91c1c":"#15803d"}}>{l.t==="err"?"✗":"✓"} {l.m}</div>)}
        {csvResult&&<div className="mt-3">
          <div className="text-sm font-bold mb-2">配車プレビュー（{csvResult.data.length}件）</div>
          <div style={{maxHeight:300,overflowY:"auto"}} className="border rounded-lg">
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}><thead><tr style={{background:"#f1f5f9"}}>
              <th className="px-2 py-1 text-left border-b">予約者</th><th className="px-2 py-1 text-left border-b">クラス</th><th className="px-2 py-1 text-left border-b">貸出</th><th className="px-2 py-1 text-left border-b">返却</th><th className="px-2 py-1 text-left border-b">状態</th>
            </tr></thead><tbody>
              {csvResult.data.map((r,i)=><tr key={i} className="border-b border-gray-100">
                <td className="px-2 py-1 font-semibold">{r.name}</td>
                <td className="px-2 py-1">{r.vehicle}</td>
                <td className="px-2 py-1">{fmtD(r.lendDate)} {r.lendTime}</td>
                <td className="px-2 py-1">{fmtD(r.returnDate)} {r.returnTime}</td>
                <td className="px-2 py-1"><span style={{color:"#f59e0b",fontWeight:700}}>未配車</span></td>
              </tr>)}
            </tbody></table>
          </div>
          <button onClick={commitCSV} className="btn-primary mt-3 w-full" style={{padding:10}}>この内容で一括登録（配車は配車表で手動）</button>
        </div>}
      </div>:
      <div className="space-y-3">
        <div style={{display:"grid",gridTemplateColumns:"1fr 80px",gap:8}}>
          <div><label className="text-xs text-gray-500">予約者名</label><input value={f.name} onChange={e=>upF("name",e.target.value)} className="input-s" placeholder="タケモト ショウタ"/></div>
          <div><label className="text-xs text-gray-500">人数</label><input type="number" value={f.people} onChange={e=>upF("people",+e.target.value)} className="input-s"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">電話番号</label><input value={f.tel||""} onChange={e=>upF("tel",e.target.value)} className="input-s" placeholder="090-1234-5678"/></div>
          <div><label className="text-xs text-gray-500">メールアドレス</label><input value={f.mail||""} onChange={e=>upF("mail",e.target.value)} className="input-s" placeholder="example@mail.com"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">貸出日</label><input type="date" value={f.lendDate} onChange={e=>upF("lendDate",e.target.value)} className="input-s"/></div>
          <div><label className="text-xs text-gray-500">貸出時間</label><input value={f.lendTime} onChange={e=>upF("lendTime",e.target.value)} className="input-s" placeholder="09:00"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">返却日</label><input type="date" value={f.returnDate} onChange={e=>upF("returnDate",e.target.value)} className="input-s"/></div>
          <div><label className="text-xs text-gray-500">返却時間</label><input value={f.returnTime} onChange={e=>upF("returnTime",e.target.value)} className="input-s" placeholder="18:00"/></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">予約車種（クラス）</label><select value={f.vehicle} onChange={e=>upF("vehicle",e.target.value)} className="input-s">{vehicleClasses.map(c=><option key={c.type} value={c.type}>{c.type}クラス — {c.label}</option>)}</select></div>
          <div><label className="text-xs text-gray-500">車両（ナンバー）</label><select value={f.vehicleCode} onChange={e=>upF("vehicleCode",e.target.value)} className="input-s"><option value="">未定（自動配車）</option>{vehicles.filter(v=>v.type===f.vehicle&&!v.insuranceVeh).map(v=><option key={v.id} value={v.code}>{v.name} ({v.no}) {v.seats}名</option>)}</select></div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">補償プラン</label><select value={f.insurance} onChange={e=>upF("insurance",e.target.value)} className="input-s"><option>免責</option><option>NOC</option><option>安心パック</option><option>フル</option><option>なし</option></select></div>
          <div><label className="text-xs text-gray-500">OTA（予約経路）</label><select value={f.ota} onChange={e=>upF("ota",e.target.value)} className="input-s">{Object.entries(OTA).map(([k,o])=><option key={k} value={k}>{o.name}</option>)}</select></div>
        </div>
        <div><label className="text-xs text-gray-500">予約番号</label><input value={f.id} onChange={e=>upF("id",e.target.value)} className="input-s"/></div>
        {/* 料金内訳セクション */}
        <div style={{background:"#f8fafc",borderRadius:8,padding:"10px 12px",border:"1px solid #e2e8f0"}}>
          <div className="text-xs font-bold text-gray-600 mb-2">料金内訳</div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
            <div><label className="text-xs text-gray-500">基本料金</label><input type="number" value={f.basePrice||""} onChange={e=>upF("basePrice",e.target.value)} className="input-s" placeholder="0"/></div>
            <div><label className="text-xs text-gray-500">オプション・補償</label><input type="number" value={f.optionPrice||""} onChange={e=>upF("optionPrice",e.target.value)} className="input-s" placeholder="0"/></div>
            <div><label className="text-xs text-gray-500">割引</label><input type="number" value={f.discount||""} onChange={e=>upF("discount",e.target.value)} className="input-s" placeholder="0"/></div>
          </div>
          <div className="text-right mt-1" style={{fontSize:13,fontWeight:700,color:"#1e40af"}}>合計: ¥{calcTotal().toLocaleString()}</div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <div><label className="text-xs text-gray-500">お届け場所</label><input value={f.delPlace} onChange={e=>upF("delPlace",e.target.value)} className="input-s" placeholder="高松空港 etc."/></div>
          <div><label className="text-xs text-gray-500">回収場所</label><input value={f.colPlace} onChange={e=>upF("colPlace",e.target.value)} className="input-s" placeholder="高松空港 etc."/></div>
        </div>
        <div><label className="text-xs text-gray-500">到着便名</label><input value={f.flight||""} onChange={e=>upF("flight",e.target.value)} className="input-s" placeholder="ANA123"/></div>
        <button onClick={submit} disabled={!!submitResult} className="btn-primary w-full" style={{padding:10,marginTop:8,opacity:submitResult?0.5:1}}>予約を登録（マスター + 配車 + 売上）</button>
      </div>}
    </div>
  </div></div>;
}

/* ==========================================
   タイムテーブル
   ========================================== */
function TimeTable({tasks,staffCount}){
  // ★ バス廃止：PUB/BDB は集計に含めない（旧データ互換のため type 比較自体は残さない）
  const lend=tasks.filter(t=>["DEL","PU","来店"].includes(t.type));const ret=tasks.filter(t=>["COL","BD","返却"].includes(t.type));
  const rows=[{l:"人員",bg:"#e0e7ff",fg:"#4338ca",b:true,data:SLOTS.map(()=>staffCount),total:staffCount},{l:"貸出計",bg:"#dbeafe",fg:"#1e40af",b:true,w:true,data:SLOTS.map(s=>lend.filter(t=>t.time===s).length),total:lend.length},{l:"┗DEL",bg:"#eff6ff",fg:"#2563eb",data:SLOTS.map(s=>tasks.filter(t=>t.type==="DEL"&&t.time===s).length),total:tasks.filter(t=>t.type==="DEL").length},{l:"┗PU/来店",bg:"#f5f3ff",fg:"#6d28d9",data:SLOTS.map(s=>tasks.filter(t=>(t.type==="PU"||t.type==="来店")&&t.time===s).length),total:tasks.filter(t=>t.type==="PU"||t.type==="来店").length},{l:"返却計",bg:"#ffedd5",fg:"#c2410c",b:true,w:true,data:SLOTS.map(s=>ret.filter(t=>t.time===s).length),total:ret.length},{l:"┗COL",bg:"#fff7ed",fg:"#ea580c",data:SLOTS.map(s=>tasks.filter(t=>t.type==="COL"&&t.time===s).length),total:tasks.filter(t=>t.type==="COL").length},{l:"┗返却/BD",bg:"#fffbeb",fg:"#b45309",data:SLOTS.map(s=>tasks.filter(t=>(t.type==="返却"||t.type==="BD")&&t.time===s).length),total:tasks.filter(t=>t.type==="返却"||t.type==="BD").length},{l:"洗車/他",bg:"#f8fafc",fg:"#64748b",data:SLOTS.map(s=>tasks.filter(t=>!["DEL","PU","来店","COL","BD","返却"].includes(t.type)&&t.time===s).length),total:tasks.filter(t=>!["DEL","PU","来店","COL","BD","返却"].includes(t.type)).length}];
  return <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"><div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:10,whiteSpace:"nowrap"}}><thead><tr style={{background:"#f1f5f9"}}><th style={{position:"sticky",left:0,zIndex:2,background:"#f1f5f9",padding:"4px 5px",textAlign:"left",fontWeight:600,minWidth:60,borderBottom:"1px solid #e2e8f0",fontSize:9}}>TT</th><th style={{padding:"4px 2px",textAlign:"center",fontWeight:600,borderBottom:"1px solid #e2e8f0",fontSize:9}}>計</th>{SLOTS.map(s=><th key={s} style={{padding:"4px 2px",textAlign:"center",fontWeight:500,color:"#64748b",borderBottom:"1px solid #e2e8f0",minWidth:26,fontSize:8}}>{s}</th>)}</tr></thead><tbody>{rows.map((r,i)=><tr key={i}><td style={{position:"sticky",left:0,zIndex:2,background:r.bg,color:r.fg,padding:"2px 5px",fontWeight:r.b?700:500,fontSize:9}}>{r.l}</td><td style={{background:r.bg,color:r.fg,padding:"2px 2px",textAlign:"center",fontWeight:700,fontSize:9}}>{r.total||""}</td>{r.data.map((v,ci)=>{const over=r.w&&v>staffCount;return <td key={ci} style={{background:over?"#fecaca":r.bg,color:over?"#dc2626":v>0?r.fg:"#e2e8f0",padding:"2px",textAlign:"center",fontWeight:over||v>0?700:400,fontSize:9}}>{v||""}</td>;})}</tr>)}</tbody></table></div></div>;
}

/* ==========================================
   配車管理タイムライン（ガントチャート）
   ========================================== */
function FleetTimeline({data,fleet,onFleetChange,today,maintenance,onMaintenanceChange,vehicles,vehicleClasses,onAddReservation,onBulkAddReservation,onCancelReservation,onDeleteReservation,onReassignVehicle,unassignedReasons,hmReload,onVehiclesChange}){
  const scrollRef=useRef(null);const[tooltip,setTooltip]=useState(null);const[viewMode,setViewMode]=useState("month");const[baseDate,setBaseDate]=useState(today);const[collapsed,setCollapsed]=useState(()=>window.innerWidth<=768?{unassignedAlert:true}:{});const[showMaintForm,setShowMaintForm]=useState(null);const[showResForm,setShowResForm]=useState(null);const[maintSaving,setMaintSaving]=useState(false);
  const[dragInfo,setDragInfo]=useState(null);const[dropTarget,setDropTarget]=useState(null);const dropTargetRef=useRef(null);
  // ★ 月別稼働フラグ
  const[kpiFlags,setKpiFlags]=useState({});
  const kpiYM=useMemo(()=>{const d=new Date(baseDate+"T00:00:00");return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0");},[baseDate]);
  useEffect(()=>{
    if(!sb)return;
    (async()=>{
      const{data:rows}=await sb.from("bt_vehicle_monthly_kpi").select("*").eq("year_month",kpiYM);
      const f={};(rows||[]).forEach(r=>f[r.vehicle_code]=r.active);
      setKpiFlags(f);
    })();
  },[kpiYM]);
  const toggleKpi=(code)=>{
    const cur=kpiFlags[code]!==undefined?kpiFlags[code]:(vehicles.find(v=>v.code===code)?.active!==false);
    const next=!cur;
    setKpiFlags(prev=>({...prev,[code]:next}));
    if(sb)sb.from("bt_vehicle_monthly_kpi").upsert({vehicle_code:code,year_month:kpiYM,active:next},{onConflict:"vehicle_code,year_month"}).then(({error})=>{if(error)console.error("[KPI]",error.message);});
  };
  const isKpiActive=(code)=>kpiFlags[code]!==undefined?kpiFlags[code]:(vehicles.find(v=>v.code===code)?.active!==false);
  const kpiCount=vehicles.filter(v=>isKpiActive(v.code)).length;
  const[searchQuery,setSearchQuery]=useState("");const[searchResult,setSearchResult]=useState(null);const searchInputRef=useRef(null);const vehicleRowRefs=useRef({});
  // 検索実行: 予約番号(部分一致) or 予約者名で検索
  const doSearch=(q)=>{if(!q.trim()){setSearchResult(null);return;}const ql=q.trim().toLowerCase();const hits=data.filter(r=>r.status!=="cancelled"&&((r.id&&r.id.toLowerCase().includes(ql))||(r.name&&r.name.toLowerCase().includes(ql))));if(hits.length===0){setSearchResult({found:false,hitSet:null,info:""});return;}const firstHit=hits[0];const vc=fleet[firstHit.id];const vn=vc?vehicles.find(x=>x.code===vc):null;const info=firstHit.name+" / "+(vn?vn.name+"("+vn.no+")":"未配車")+" / "+firstHit.lendDate+"〜"+firstHit.returnDate;const hitSet=new Set(hits.map(r=>r.id));setSearchResult({found:true,hitSet,info,vc});if(firstHit.lendDate){const dt=new Date(firstHit.lendDate+"T00:00:00");const newBase=toLD(new Date(dt.getFullYear(),dt.getMonth(),1));if(newBase!==baseDate){setBaseDate(newBase);setTimeout(()=>{scrollToVehicle_(vc);},300);return;}}scrollToVehicle_(vc);};
  const scrollToVehicle_=(vc)=>{if(!vc||!vehicleRowRefs.current[vc]||!scrollRef.current)return;const el=vehicleRowRefs.current[vc];const container=scrollRef.current;const elTop=el.offsetTop;container.scrollTop=Math.max(0,elTop-80);};
  const clearSearch=()=>{setSearchQuery("");setSearchResult(null);if(searchInputRef.current)searchInputRef.current.value="";};
  useEffect(()=>{const handler=(e)=>{if(e.key==="Escape"&&searchResult)clearSearch();};window.addEventListener("keydown",handler);return()=>window.removeEventListener("keydown",handler);},[searchResult]);
  const WK=["日","月","火","水","木","金","土"];

  const dates=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month"){const y=dt.getFullYear(),m=dt.getMonth();const days=new Date(y,m+1,0).getDate();return Array.from({length:days},(_,i)=>toLD(new Date(y,m,i+1)));}else if(viewMode==="week"){const d=new Date(baseDate+"T00:00:00");d.setDate(d.getDate()-d.getDay());return Array.from({length:7},(_,i)=>dOff(toLD(d),i));}else return[baseDate];},[baseDate,viewMode]);

  const[isMobile,setIsMobile]=useState(window.innerWidth<=768);
  useEffect(()=>{const h=()=>setIsMobile(window.innerWidth<=768);window.addEventListener("resize",h);return()=>window.removeEventListener("resize",h);},[]);
  const COL_W=viewMode==="month"?(isMobile?60:80):viewMode==="week"?(isMobile?100:140):600;const LEFT_W=isMobile?100:260;const ROW_H=30;const CLASS_H=28;
  const monthLabel=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");return`${dt.getFullYear()}年${dt.getMonth()+1}月`;},[baseDate]);
  const monthStats=useMemo(()=>{const dt=new Date(baseDate+"T00:00:00");const y=dt.getFullYear(),m=dt.getMonth();const mStart=`${y}-${String(m+1).padStart(2,"0")}-01`;const mEnd=`${y}-${String(m+1).padStart(2,"0")}-${new Date(y,m+1,0).getDate()}`;const active=data.filter(r=>r.status!=="cancelled");const dep=active.filter(r=>r.lendDate>=mStart&&r.lendDate<=mEnd).length;const ret=active.filter(r=>r.returnDate>=mStart&&r.returnDate<=mEnd).length;return{dep,ret};},[data,baseDate]);

  useEffect(()=>{if(scrollRef.current){const ti=dates.indexOf(today);if(ti>=0)scrollRef.current.scrollLeft=Math.max(0,(ti-2)*COL_W);}},[dates,today]);
  const goToday=()=>setBaseDate(today);
  const goPrev=()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month")dt.setMonth(dt.getMonth()-1);else if(viewMode==="week")dt.setDate(dt.getDate()-7);else dt.setDate(dt.getDate()-1);setBaseDate(toLD(dt));};
  const goNext=()=>{const dt=new Date(baseDate+"T00:00:00");if(viewMode==="month")dt.setMonth(dt.getMonth()+1);else if(viewMode==="week")dt.setDate(dt.getDate()+7);else dt.setDate(dt.getDate()+1);setBaseDate(toLD(dt));};
  const toggleClass=(t)=>setCollapsed(p=>({...p,[t]:!p[t]}));

  const vehicleBars=useMemo(()=>{
    const bars={};vehicles.forEach(v=>{bars[v.code]=[];});
    const dFirst=dates[0],dLast=dates[dates.length-1];data.forEach(r=>{if(r.status==="cancelled")return;const vc=fleet[r.id];if(!vc||!bars[vc])return;const ld=norm(r.lendDate),rd=norm(r.returnDate);if(rd<dFirst||ld>dLast)return;const si=dates.indexOf(ld),ei=dates.indexOf(rd);const s=si>=0?si:0;const e=ei>=0?ei:dates.length-1;bars[vc].push({type:"reservation",r,startI:s,endI:e,left:s*COL_W,width:(e-s+1)*COL_W-2});});
    (maintenance||[]).forEach(m=>{if(!bars[m.vehicleCode])return;const dFirst=dates[0],dLast=dates[dates.length-1];if(m.endDate<dFirst||m.startDate>dLast)return;const si=dates.indexOf(m.startDate),ei=dates.indexOf(m.endDate);const s=si>=0?si:0;const e=ei>=0?ei:dates.length-1;bars[m.vehicleCode].push({type:"maintenance",m,startI:s,endI:e,left:s*COL_W,width:(e-s+1)*COL_W-2});});
    return bars;
  },[data,fleet,dates,maintenance,vehicles]);

  // ★ 車両別売上 (2026-05-26 オーナー指示・返却日起算 確定):
  //   集計範囲: returnDate が表示中の月内の予約のみ (TOPサマリー / forecast.html と整合)
  const vehicleRevenue=useMemo(()=>{
    const map={};
    const _bd=baseDate||"";
    const _ym=_bd.slice(0,7);
    const _y=parseInt(_bd.slice(0,4))||(new Date().getFullYear());
    const _m=parseInt(_bd.slice(5,7))||(new Date().getMonth()+1);
    const _monthStart=_ym+"-01";
    const _monthEnd=_ym+"-"+String(new Date(_y,_m,0).getDate()).padStart(2,"0");
    Object.keys(vehicleBars).forEach(code=>{
      map[code]=(vehicleBars[code]||[]).reduce((s,b)=>{
        if(b.type==="reservation"&&b.r&&b.r.status!=="cancelled"){
          const rd=norm(b.r.returnDate);
          if(!rd||rd<_monthStart||rd>_monthEnd)return s;
          const bp=+(b.r.base_price||b.r.basePrice||0);
          const op=+(b.r.option_price||b.r.optionPrice||0);
          const disc=+(b.r.discount||0);
          const rev=(bp>0||op>0)?Math.max(0,bp+op-disc):+(b.r.price||0);
          return s+rev;
        }
        return s;
      },0);
    });
    return map;
  },[vehicleBars,baseDate]);
  const classRevenue=useMemo(()=>{
    const map={};
    vehicles.forEach(v=>{
      if(!map[v.type])map[v.type]=0;
      map[v.type]+=vehicleRevenue[v.code]||0;
    });
    return map;
  },[vehicles,vehicleRevenue]);
  const fmtRev=(n)=>{
    if(!n||n<=0)return "¥0";
    if(n>=10000000)return "¥"+(n/10000).toFixed(0)+"万";
    if(n>=10000)return "¥"+(n/10000).toFixed(1)+"万";
    return "¥"+Math.round(n).toLocaleString();
  };
  // ★ 配車表ヘッダー集計 (2026-05-26 オーナー要望): 売上総額 / 台あたり / 進捗
  //   BT 月別目標 (暫定・要オーナー確定): 各月 300万円
  const BT_MONTHLY_TARGETS={1:3000000,2:3000000,3:3000000,4:3000000,5:3000000,6:3000000,7:4000000,8:5000000,9:4000000,10:4000000,11:3000000,12:3000000};
  const totalRevenue=useMemo(()=>Object.values(vehicleRevenue).reduce((s,v)=>s+v,0),[vehicleRevenue]);

  // 車両ごとの月別稼働率（表示期間の月の1日〜末日で計算）
  const utilRates=useMemo(()=>{
    const bd=new Date(baseDate+"T00:00:00");const y=bd.getFullYear(),m=bd.getMonth();
    const dim=new Date(y,m+1,0).getDate();
    const rates={};
    vehicles.forEach(v=>{
      // ★ 日単位のSetで重複カウントを防止
      const rentalDays=new Set();
      const maintDays=new Set();
      const ms=new Date(y,m,1),me=new Date(y,m,dim);
      // 予約による稼働日
      data.forEach(r=>{if(r.status==="cancelled")return;if(fleet[r.id]!==v.code)return;
        const ld=new Date(norm(r.lendDate)+"T00:00:00"),rd=new Date(norm(r.returnDate)+"T00:00:00");
        const s=ld>ms?ld:ms;const e=rd<me?rd:me;
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){rentalDays.add(toLD(d));}
      });
      // メンテナンス日数 → 最大稼働日数から減算
      (maintenance||[]).forEach(mt=>{if(mt.vehicleCode!==v.code)return;
        const ld=new Date(norm(mt.startDate)+"T00:00:00"),rd=new Date(norm(mt.endDate)+"T00:00:00");
        const s=ld>ms?ld:ms;const e=rd<me?rd:me;
        for(let d=new Date(s);d<=e;d.setDate(d.getDate()+1)){maintDays.add(toLD(d));}
      });
      const days=rentalDays.size;
      rates[v.code]={days,total:dim,maintDays:maintDays.size,pct:dim>0?Math.min(Math.round(days/dim*100),100):0};
    });
    return rates;
  },[data,fleet,vehicles,maintenance,baseDate]);

  // ★ 稼働フラグON車両の合算稼働率
  const totalUtil=useMemo(()=>{
    const bd=new Date(baseDate+"T00:00:00");const dim=new Date(bd.getFullYear(),bd.getMonth()+1,0).getDate();
    let totalDays=0,activeCount=0;
    vehicles.forEach(v=>{
      if(!isKpiActive(v.code))return;
      activeCount++;
      const u=utilRates[v.code];
      if(u)totalDays+=u.days;
    });
    const maxDays=activeCount*dim;
    return{totalDays,activeCount,maxDays,pct:maxDays>0?Math.round(totalDays/maxDays*100):0};
  },[utilRates,vehicles,kpiFlags,baseDate]);

  // セルクリック → アクション選択
  const[cellAction,setCellAction]=useState(null);
  const handleCellClick=(vehicleCode,dateStr)=>{
    const existing=data.find(r=>fleet[r.id]===vehicleCode&&norm(r.lendDate)<=dateStr&&norm(r.returnDate)>=dateStr);
    if(existing){setTooltip({type:"reservation",...existing,vc:vehicleCode});return;}
    setCellAction({vehicleCode,date:dateStr});
  };
  const handleBarClick=(e,b)=>{e.stopPropagation();if(b.type==="reservation")setTooltip({type:"reservation",...b.r,vc:fleet[b.r.id]});else setTooltip({type:"maintenance",...b.m});};

  const addMaint=async(vc,start,end,label,cost,workshop,invoiceNo,maintNotes,status,startTime,endTime,editId)=>{
    if(maintSaving)return;
    setMaintSaving(true);
    const m={id:editId||("m"+Date.now()),vehicleCode:vc,startDate:start,endDate:end,label,cost:Number(cost)||0,workshop:workshop||"",invoiceNo:invoiceNo||"",maintNotes:maintNotes||"",status:status||"pending",startTime:startTime||"",endTime:endTime||""};
    const next=editId?(maintenance||[]).map(x=>x.id===editId?m:x):[...(maintenance||[]),m];
    onMaintenanceChange(next);
    DB._maintLsSave(next);
    try{
      await DB.saveMaintenance([m]);
    }catch(e){
      setMaintSaving(false);
      alert("保存に失敗しました。再度お試しください。\n"+String(e));
      return;
    }
    // ★ 入庫アクション通知キュー（intake.html と同経路・BT通知チャンネルは将来設定）
    try{const act=editId?"intake_edited":"intake_created";if(sb)sb.from("bt_intake_actions").insert({action_type:act,vehicle_code:vc,user_email:(sbCurrentUser&&sbCurrentUser.email)||"",target_date_from:start||null,target_date_to:end||null,notified_slack:false,payload:{action:act,id:m.id,label:label,vehicle:((vehicles.find(x=>x.code===vc)||{}).name)||vc,start:start,end:end,start_time:startTime||"",end_time:endTime||"",workshop:workshop||"",status:m.status}}).then(()=>{});}catch(e){}
    const n=Number(cost)||0;
    if(n>0&&sb){const col=label==="車検"?"shaken_cost":label==="半年点検"?"tenken_cost":null;if(col)sb.from("bt_vehicles").update({[col]:n}).eq("code",vc).then(({error})=>{if(!error){const upd=vehicles.map(v=>v.code===vc?{...v,[label==="車検"?"shakenCost":"tenkenCost"]:n}:v);if(typeof onVehiclesChange==="function")try{onVehiclesChange(upd);}catch(e){}}});}
    setMaintSaving(false);
    setShowMaintForm(null);
    // ★ 双方向連動: メンテナンスブロック追加 → HM車両ステータスも更新（未来のメンテも含む）
    try{var today2=new Date().toISOString().slice(0,10);if(end>=today2){
      var cars=JSON.parse(localStorage.getItem("bt_hm_cars")||"[]");
      var car=cars.find(function(c){return c.id===vc});
      if(car&&car.status==="active"){car.status="repair";localStorage.setItem("bt_hm_cars",JSON.stringify(cars));
        DB.hm.saveCar(car).then(function(){if(hmReload)return hmReload();}).catch(function(){});
      }
    }}catch(e){}
  };
  const removeMaint=(id)=>{const removed=(maintenance||[]).find(m=>m.id===id);const next=(maintenance||[]).filter(m=>m.id!==id);onMaintenanceChange(next);DB._maintLsSave(next);DB.deleteMaintenance(id);setTooltip(null);
    // ★ 双方向連動: メンテナンス削除 → 他にメンテが無ければHMステータスを稼働に戻す
    if(removed){try{var vc=removed.vehicleCode;var today=new Date().toISOString().slice(0,10);
      var hasOther=next.some(function(m){return m.vehicleCode===vc&&m.startDate<=today&&m.endDate>=today});
      if(!hasOther){var cars=JSON.parse(localStorage.getItem("bt_hm_cars")||"[]");
        var car=cars.find(function(c){return c.id===vc});
        if(car&&car.status!=="active"){car.status="active";localStorage.setItem("bt_hm_cars",JSON.stringify(cars));
          DB.hm.saveCar(car).then(function(){if(hmReload)return hmReload();}).catch(function(){});
        }
        // HM連動メンテも削除
        var ls=JSON.parse(localStorage.getItem("bt_maintenance")||"[]");
        ls=ls.filter(function(m){return m.id!=="hm_"+vc});
        localStorage.setItem("bt_maintenance",JSON.stringify(ls));
      }
    }catch(e){}}
  };

  // ドラッグ&ドロップで車両変更（スロットル付き）
  const handleDragStart=(e,resId)=>{e.dataTransfer.setData("text/plain",resId);e.dataTransfer.effectAllowed="move";setDragInfo(resId);};
  const handleDragEnd=()=>{setDragInfo(null);setDropTarget(null);dropTargetRef.current=null;lastDragOverRef.current={vc:"",t:0};};
  const lastDragOverRef=useRef({vc:"",t:0});
  const handleDragOver=(e,vehicleCode)=>{
    if(!dragInfo)return;e.preventDefault();e.dataTransfer.dropEffect="move";
    // ★ 同じ車両なら完全スキップ（state更新なし=再レンダリングなし）
    if(lastDragOverRef.current.vc===vehicleCode)return;
    lastDragOverRef.current={vc:vehicleCode,t:Date.now()};
    const curVc=fleet[dragInfo];if(curVc===vehicleCode){if(dropTargetRef.current){dropTargetRef.current=null;setDropTarget(null);}return;}
    const conflict=checkVehicleConflict(vehicleCode,dragInfo,data,fleet,maintenance);
    const dt={vc:vehicleCode,ok:!conflict,conflict};
    dropTargetRef.current=dt;
    setDropTarget(dt);
  };
  const handleDrop=(e,vehicleCode)=>{
    e.preventDefault();const resId=e.dataTransfer.getData("text/plain");if(!resId)return;
    setDragInfo(null);setDropTarget(null);
    const res=data.find(r=>r.id===resId);if(!res)return;
    const curVc=fleet[resId];if(curVc===vehicleCode)return;
    const curV=vehicles.find(v=>v.code===curVc);const targetV=vehicles.find(v=>v.code===vehicleCode);
    const conflict=checkVehicleConflict(vehicleCode,resId,data,fleet,maintenance);
    if(conflict){alert((targetV?targetV.name:vehicleCode)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の予約が入っているため変更できません。");return;}
    if(!window.confirm(res.name+" 様の配車を\n「"+(curV?curV.name:"未割当")+"」→「"+(targetV?targetV.name:vehicleCode)+"」\nに変更しますか？\n\n※OPシートの車両情報も同時に更新されます"))return;
    if(onReassignVehicle)onReassignVehicle(resId,vehicleCode);
    else onFleetChange({...fleet,[resId]:vehicleCode});
  };

  // ★ 車両折りたたみ機能 (2026-05-26 オーナー要望): 個別車両を一時的に配車表から非表示
  //    保存先: localStorage (端末別) / value: vehicle_code 配列
  const[hiddenVeh,setHiddenVeh]=useState(()=>{try{return JSON.parse(localStorage.getItem("bt_fleet_hidden_v")||"[]");}catch(e){return [];}});
  const toggleHideVeh=React.useCallback((code)=>{
    setHiddenVeh(prev=>{
      const next=prev.includes(code)?prev.filter(c=>c!==code):[...prev,code];
      try{localStorage.setItem("bt_fleet_hidden_v",JSON.stringify(next));}catch(e){}
      return next;
    });
  },[]);
  const restoreAllInClass=React.useCallback((classType)=>{
    setHiddenVeh(prev=>{
      const next=prev.filter(code=>{const v=vehicles.find(x=>x.code===code);return !v||v.type!==classType;});
      try{localStorage.setItem("bt_fleet_hidden_v",JSON.stringify(next));}catch(e){}
      return next;
    });
  },[vehicles]);
  const groups=useMemo(()=>vehicleClasses.map(vc=>{
    const allItems=vehicles.filter(v=>v.type===vc.type);
    const items=allItems.filter(v=>!hiddenVeh.includes(v.code));
    const hiddenCount=allItems.length-items.length;
    return{...vc,items,hiddenCount,allItemsCount:allItems.length};
  }).filter(g=>g.allItemsCount>0),[vehicles,vehicleClasses,hiddenVeh]);

  return <div style={{display:"flex",flexDirection:"column",background:"#fff",borderRadius:12,boxShadow:"0 1px 3px rgba(0,0,0,.06)",border:"1px solid #e5e7eb",overflow:"hidden",height:"100%",minHeight:0}}>
    <div style={{padding:isMobile?"4px 6px":"8px 12px",background:"#f8fafc",borderBottom:"1px solid #e5e7eb",display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:isMobile?4:8,flexShrink:0,position:"sticky",top:0,zIndex:20}}>
      <div style={{display:"flex",alignItems:"center",gap:isMobile?2:8}}>
        <button onClick={goToday} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?9:12,fontWeight:600,cursor:"pointer"}}>今日</button>
        <button onClick={goPrev} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?10:14,cursor:"pointer"}}>◀</button>
        <button onClick={goNext} style={{padding:isMobile?"2px 4px":"4px 8px",background:"#fff",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?10:14,cursor:"pointer"}}>▶</button>
        <span style={{fontSize:isMobile?11:14,fontWeight:700,color:"#1e293b",marginLeft:2}}>{monthLabel}</span>
        {viewMode==="month"&&<span style={{display:"inline-flex",gap:isMobile?4:8,marginLeft:isMobile?4:12,fontSize:isMobile?8:11,fontWeight:600}}>
          <span style={{background:"#dbeafe",color:"#1e40af",padding:"2px 6px",borderRadius:4}}>出発 {monthStats.dep}</span>
          <span style={{background:"#fef3c7",color:"#92400e",padding:"2px 6px",borderRadius:4}}>返却 {monthStats.ret}</span>
          <span style={{background:"#dcfce7",color:"#166534",padding:"2px 6px",borderRadius:4}}>洗車 {monthStats.dep}</span>
          <span style={{background:"#f0fdf4",color:"#059669",padding:"2px 6px",borderRadius:4,border:"1px solid #86efac"}}>📊稼働 {kpiCount}台 {totalUtil.pct}%（{totalUtil.totalDays}/{totalUtil.maxDays}日）</span>
          {(()=>{const baseMonth=parseInt((baseDate||"").split("-")[1])||(new Date().getMonth()+1);const monthTarget=BT_MONTHLY_TARGETS[baseMonth]||3000000;const revPerVeh=kpiCount>0?totalRevenue/kpiCount:0;const progressPct=monthTarget>0?(totalRevenue/monthTarget*100):0;const pBg=progressPct>=90?"#dcfce7":progressPct>=60?"#fef3c7":"#fee2e2";const pFg=progressPct>=90?"#15803d":progressPct>=60?"#92400e":"#b91c1c";const pBd=progressPct>=90?"#86efac":progressPct>=60?"#fcd34d":"#fca5a5";return <React.Fragment>
            <span title={"配車表表示期間内の予約グロス売上合計 ¥"+Math.round(totalRevenue).toLocaleString()} style={{background:"#fff7ed",color:"#c2410c",padding:"2px 6px",borderRadius:4,border:"1px solid #fdba74"}}>💰 売上 {fmtRev(totalRevenue)}</span>
            <span title={"1台あたり売上 ¥"+Math.round(revPerVeh).toLocaleString()+" (= 合計売上 ÷ 稼働台数"+kpiCount+"台)"} style={{background:"#eff6ff",color:"#1e40af",padding:"2px 6px",borderRadius:4,border:"1px solid #93c5fd"}}>🚗 台/{fmtRev(revPerVeh)}</span>
            <span title={baseMonth+"月目標¥"+Math.round(monthTarget).toLocaleString()+" 達成率 "+progressPct.toFixed(1)+"% (※BT目標は暫定値)"} style={{background:pBg,color:pFg,padding:"2px 6px",borderRadius:4,border:"1px solid "+pBd}}>📊 進捗 {progressPct.toFixed(0)}%</span>
          </React.Fragment>;})()}
        </span>}
      </div>
      <div style={{display:"flex",alignItems:"center",gap:isMobile?2:8}}>
        <div style={{position:"relative",display:"flex",alignItems:"center"}}>
          <input ref={searchInputRef} type="text" placeholder="予約番号/名前" value={searchQuery} onChange={e=>setSearchQuery(e.target.value)} onKeyDown={e=>{if(e.key==="Enter")doSearch(searchQuery);if(e.key==="Escape")clearSearch();}} style={{width:isMobile?90:130,padding:isMobile?"2px 20px 2px 4px":"3px 24px 3px 6px",fontSize:isMobile?9:11,border:"1px solid #d1d5db",borderRadius:4,background:"#fff",outline:"none"}}/>
          {searchQuery&&<button onClick={clearSearch} style={{position:"absolute",right:isMobile?2:4,top:"50%",transform:"translateY(-50%)",background:"none",border:"none",cursor:"pointer",color:"#94a3b8",fontSize:isMobile?10:12,lineHeight:1,padding:0}}>✕</button>}
          {searchResult&&!searchResult.found&&<span style={{fontSize:9,color:"#dc2626",fontWeight:600,whiteSpace:"nowrap",marginLeft:4}}>✕</span>}
        </div>
        <button onClick={()=>doSearch(searchQuery)} style={{padding:isMobile?"2px 4px":"3px 6px",background:"#e2e8f0",border:"1px solid #d1d5db",borderRadius:4,fontSize:isMobile?9:11,fontWeight:600,cursor:"pointer",color:"#475569"}}>検索</button>
        {searchResult&&searchResult.found&&<span style={{fontSize:isMobile?8:10,color:"#1e40af",fontWeight:700,whiteSpace:"nowrap",background:"#dbeafe",padding:"2px 6px",borderRadius:4}}>📍{searchResult.info}</span>}
        <button onClick={()=>setShowResForm({})} style={{padding:isMobile?"2px 6px":"4px 8px",background:"#16a34a",color:"#fff",border:"none",borderRadius:4,fontSize:isMobile?9:12,fontWeight:700,cursor:"pointer"}}>＋予約</button>
        <div style={{display:"flex",border:"1px solid #d1d5db",borderRadius:4,overflow:"hidden"}}>{["day","week","month"].map(m=><button key={m} onClick={()=>setViewMode(m)} style={{padding:isMobile?"2px 4px":"4px 8px",fontSize:isMobile?9:12,fontWeight:600,background:viewMode===m?"#1e40af":"#fff",color:viewMode===m?"#fff":"#374151",border:"none",cursor:"pointer"}}>{m}</button>)}</div>
      </div>
    </div>

    {((unassigned)=>{const allUa=data.filter(r=>r.status!=="cancelled"&&!fleet[r.id]&&r.returnDate&&r.returnDate>=today);
      const[hiddenIds,setHiddenIds]=React.useState(()=>{try{return JSON.parse(localStorage.getItem("bt_hidden_unassigned")||"[]");}catch(e){return[];}});
      const hideId=(id)=>{const next=[...hiddenIds,id];setHiddenIds(next);try{localStorage.setItem("bt_hidden_unassigned",JSON.stringify(next));}catch(e){}};
      const showAll=()=>{setHiddenIds([]);try{localStorage.removeItem("bt_hidden_unassigned");}catch(e){}};
      const ua=allUa.filter(r=>!hiddenIds.includes(r.id));
      const hiddenCount=allUa.length-ua.length;
      return allUa.length>0?<div style={{borderBottom:"1px solid #fca5a5",background:"#fef2f2",padding:isMobile?"4px 8px":"12px 16px",flexShrink:0,maxHeight:collapsed.unassignedAlert?36:isMobile?"30vh":"25vh",overflow:collapsed.unassignedAlert?"hidden":"auto"}}>
      <div style={{display:"flex",alignItems:"center",gap:6,fontSize:isMobile?10:12,fontWeight:700,color:"#dc2626"}}>
        <span>⚠</span>
        <span>未配車 {ua.length}件</span>
        <button onClick={()=>setCollapsed(p=>({...p,unassignedAlert:!p.unassignedAlert}))} style={{marginLeft:"auto",background:"none",border:"none",cursor:"pointer",color:"#dc2626",fontSize:12,fontWeight:600}}>{collapsed.unassignedAlert?"▶":"▼"}</button>
      </div>
      {!collapsed.unassignedAlert&&<div style={{overflowX:"auto",marginTop:4}}>
        <table style={{fontSize:10,borderCollapse:"collapse",width:"100%"}}>
          <thead><tr style={{background:"#fee2e2"}}>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>OTA</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>予約番号</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>予約者名</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>クラス</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>貸出日</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>返却日</th>
            <th style={{padding:"4px 6px",textAlign:"left",fontWeight:700,border:"1px solid #fca5a5"}}>未配車理由</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5"}}>手動配車</th>
            <th style={{padding:"4px 6px",textAlign:"center",fontWeight:700,border:"1px solid #fca5a5",width:36}}></th>
          </tr></thead>
          <tbody>
            {ua.map(r=>{
              const reason=(unassignedReasons||{})[r.id]||"";
              const rL=norm(r.lendDate),rR=norm(r.returnDate);
              // ★ 空き車両を先頭に表示（同クラス優先 + 期間重複チェック）
              const isHP=r.ota==="HP";
              const modelName=(r.preferVc||"").trim();
              const isModelMatch_=(vName,model)=>{if(!model)return false;const idx=vName.indexOf(model);if(idx<0)return false;const after=vName.charAt(idx+model.length);if(!after)return true;if(/[0-9①-⑳\s\/]/.test(after))return true;return false;};
              const sameClass=vehicles.filter(v=>v.type===r.vehicle);
              const otherClass=vehicles.filter(v=>v.type!==r.vehicle);
              const checkAvail=(v)=>{
                const conflict=data.find(o=>o.id!==r.id&&o.status!=="cancelled"&&fleet[o.id]===v.code&&norm(o.lendDate)<=rR&&norm(o.returnDate)>=rL);
                const inMaint=(maintenance||[]).some(m=>m.vehicleCode===v.code&&norm(m.startDate)<=rR&&norm(m.endDate)>=rL);
                return !conflict&&!inMaint;
              };
              const availSame=sameClass.filter(checkAvail);
              const hpMatched=isHP&&modelName?availSame.filter(v=>isModelMatch_(v.name,modelName)):[];
              const availOther=isHP?[]:otherClass.filter(checkAvail);
              return <tr key={r.id} style={{background:"#fff5f5",borderBottom:"1px solid #fca5a5"}}>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5"}}><OBadge ota={r.ota}/></td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",fontFamily:"monospace",fontSize:9}}>{r.id}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5"}}>{r.name}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center"}}>{r.vehicle}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",fontSize:9}}>{fmtD(r.lendDate)}<br/>{r.lendTime}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",fontSize:9}}>{fmtD(r.returnDate)}<br/>{r.returnTime}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",fontSize:8,color:"#b91c1c",maxWidth:180}}>{reason||"不明"}</td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center",whiteSpace:"nowrap"}}>
                {(()=>{const selId="ua_sel_"+r.id;const totalAvail=(isHP&&modelName?hpMatched.length:availSame.length)+availOther.length;return <><select id={selId} style={{fontSize:9,border:"1px solid #d1d5db",borderRadius:4,padding:"2px 4px",background:totalAvail>0?"#dcfce7":"#fee2e2"}}>
                  <option value="">{totalAvail>0?"車両選択 (空き"+totalAvail+"台)":"空車なし"}</option>
                  {isHP&&modelName&&hpMatched.length>0&&<optgroup label={"★ "+modelName+" 指定 ("+hpMatched.length+"台)"}>
                    {hpMatched.map(v=><option key={v.code} value={v.code}>🎯 {v.name} ({v.no})</option>)}
                  </optgroup>}
                  {!(isHP&&modelName)&&availSame.length>0&&<optgroup label={"★ "+r.vehicle+"クラス 空き ("+availSame.length+"台)"}>
                    {availSame.map(v=><option key={v.code} value={v.code}>✅ {v.name} ({v.no})</option>)}
                  </optgroup>}
                  {isHP&&modelName&&availSame.filter(v=>!isModelMatch_(v.name,modelName)).length>0&&<optgroup label={r.vehicle+"クラス 他車種（非推奨）"}>
                    {availSame.filter(v=>!isModelMatch_(v.name,modelName)).map(v=><option key={v.code} value={v.code}>⚠️ {v.name} ({v.no})</option>)}
                  </optgroup>}
                  {availOther.length>0&&<optgroup label="他クラス 空き">
                    {availOther.map(v=><option key={v.code} value={v.code}>{v.name} ({v.no}) [{v.type}]</option>)}
                  </optgroup>}
                </select>{" "}<button onClick={()=>{const sel=document.getElementById(selId);const vc=sel?sel.value:"";if(!vc){alert("車両を選択してください");return;}const conflict=checkVehicleConflict(vc,r.id,data,fleet,maintenance);if(conflict){const cv=vehicles.find(x=>x.code===vc);alert((cv?cv.name:vc)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の"+(conflict._isMaint?"メンテナンス":"予約")+"が入っているため配車できません。");return;}const targetV=vehicles.find(x=>x.code===vc);if(!window.confirm(r.name+" 様を「"+(targetV?targetV.name:vc)+"」に配車しますか？"))return;if(onReassignVehicle)onReassignVehicle(r.id,vc);else onFleetChange({...fleet,[r.id]:vc});}} style={{fontSize:9,fontWeight:700,background:"#2563eb",color:"#fff",border:"none",borderRadius:4,padding:"3px 10px",cursor:"pointer"}}>配車</button></>})()}
              </td>
              <td style={{padding:"4px 6px",border:"1px solid #fca5a5",textAlign:"center"}}>
                <button onClick={()=>{if(window.confirm(r.name+" 様を未配車リストから非表示にしますか？\n\n※データは変更しません\n※「全て再表示」で戻せます"))hideId(r.id);}} title="リストから非表示（データは変更しません）" style={{background:"#f1f5f9",color:"#64748b",border:"1px solid #d1d5db",borderRadius:4,fontSize:9,fontWeight:700,padding:"2px 5px",cursor:"pointer",lineHeight:1}}>✕</button>
              </td>
            </tr>;})}
          </tbody>
        </table>
        {/* ★ 非表示にした予約BOX */}
        {hiddenCount>0&&<details style={{marginTop:6,background:"#f8fafc",borderRadius:6,border:"1px solid #e2e8f0"}}>
          <summary style={{padding:"6px 10px",cursor:"pointer",fontSize:10,fontWeight:700,color:"#64748b",userSelect:"none",listStyle:"none",display:"flex",alignItems:"center",gap:6}}>
            <span style={{fontSize:9,color:"#94a3b8"}}>▶</span>
            <span>非表示 {hiddenCount}件</span>
            <button onClick={e=>{e.stopPropagation();e.preventDefault();if(window.confirm("非表示を全てリストに戻しますか？"))showAll();}} style={{marginLeft:"auto",background:"#fbbf24",color:"#78350f",border:"none",borderRadius:4,fontSize:8,fontWeight:700,padding:"2px 8px",cursor:"pointer"}}>全て再表示</button>
          </summary>
          <div style={{padding:"4px 8px 8px",overflowX:"auto"}}>
            <table style={{fontSize:9,borderCollapse:"collapse",width:"100%"}}>
              <tbody>
                {allUa.filter(r=>hiddenIds.includes(r.id)).map(r=>
                  <tr key={r.id} style={{background:"#f1f5f9",borderBottom:"1px solid #e2e8f0",opacity:0.6}}>
                    <td style={{padding:"3px 6px"}}><OBadge ota={r.ota}/></td>
                    <td style={{padding:"3px 6px"}}>{r.name}</td>
                    <td style={{padding:"3px 6px",textAlign:"center"}}>{r.vehicle}</td>
                    <td style={{padding:"3px 6px",fontSize:8}}>{fmtD(r.lendDate)}〜{fmtD(r.returnDate)}</td>
                    <td style={{padding:"3px 6px",textAlign:"center"}}>
                      <button onClick={()=>{const next=hiddenIds.filter(x=>x!==r.id);setHiddenIds(next);try{localStorage.setItem("bt_hidden_unassigned",JSON.stringify(next));}catch(e){}}} style={{background:"#dbeafe",color:"#1d4ed8",border:"none",borderRadius:4,fontSize:8,fontWeight:700,padding:"2px 6px",cursor:"pointer"}}>戻す</button>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </details>}
      </div>}
    </div>:null;})()}

    <div ref={scrollRef} style={{flex:1,overflow:"auto",position:"relative"}}>
      <table style={{borderCollapse:"collapse",minWidth:LEFT_W+dates.length*COL_W}}>
        <thead><tr style={{position:"sticky",top:0,zIndex:10}}>
          <th style={{position:"sticky",left:0,zIndex:11,width:LEFT_W,minWidth:LEFT_W,height:44,background:"#f1f5f9",borderBottom:"2px solid #94a3b8",borderRight:"2px solid #94a3b8",padding:"0 8px",textAlign:"left",fontSize:11,fontWeight:700,color:"#1e293b"}}>車両</th>
          {dates.map(d=>{const dt=new Date(d);const dow=dt.getDay();const isToday=d===today;return <th key={d} style={{width:COL_W,minWidth:COL_W,height:44,textAlign:"center",borderRight:"1px solid #cbd5e1",background:isToday?"#dbeafe":"#f1f5f9",borderBottom:"2px solid #94a3b8",padding:0}}><div style={{fontSize:isMobile?9:11,fontWeight:600,color:isToday?"#1d4ed8":"#334155"}}>{dt.getDate()}<span style={{fontSize:isMobile?8:9,fontWeight:dow===0||dow===6?700:400,color:dow===0?"#dc2626":dow===6?"#2563eb":"#64748b",marginLeft:1}}>{WK[dow]}</span></div></th>;})}
        </tr></thead>
        <tbody>
          {groups.map(g=><React.Fragment key={g.type}>
            <tr onClick={()=>toggleClass(g.type)} style={{cursor:"pointer",userSelect:"none"}}>
              <td style={{position:"sticky",left:0,zIndex:5,height:CLASS_H,background:"#dbe3ec",borderTop:"3px solid #475569",borderBottom:"1px solid #e2e8f0",borderRight:"2px solid #94a3b8",padding:"0 6px"}}><span style={{fontSize:10,color:"#64748b",marginRight:3}}>{collapsed[g.type]?"▶":"▼"}</span><span style={{fontSize:isMobile?9:10,fontWeight:700,color:"#334155"}}>{isMobile?g.type:g.type+"クラス（"+g.label+"）"}</span>{!isMobile&&<span style={{fontSize:8,color:"#64748b",marginLeft:4}}>稼働{g.items.filter(v=>isKpiActive(v.code)).length}/{g.items.length}台</span>}{classRevenue[g.type]>0&&<span title={"クラス売上 ¥"+Math.round(classRevenue[g.type]).toLocaleString()+" (配車表 表示期間内)"} style={{fontSize:isMobile?8:9,fontWeight:800,marginLeft:5,padding:"1px 6px",borderRadius:4,background:"linear-gradient(135deg,#dcfce7,#bbf7d0)",color:"#15803d",border:"1px solid #86efac"}}>💰 {fmtRev(classRevenue[g.type])}</span>}{g.hiddenCount>0&&<span onClick={e=>{e.stopPropagation();if(window.confirm(g.type+"クラスの折りたたみ中"+g.hiddenCount+"台を全て表示しますか？"))restoreAllInClass(g.type);}} title={"折りたたみ中 "+g.hiddenCount+"台 / クリックで全て表示に戻す"} style={{fontSize:8,fontWeight:700,marginLeft:4,padding:"1px 5px",borderRadius:3,cursor:"pointer",background:"#fef3c7",color:"#92400e",border:"1px solid #fbbf24"}}>👁 {g.hiddenCount}台折りたたみ中</span>}</td>
              {dates.map(d=><td key={d} style={{height:CLASS_H,borderTop:"3px solid #475569",borderBottom:"1px solid #e2e8f0",background:"#dbe3ec",borderRight:"1px solid #e2e8f0"}}/>)}
            </tr>
            {!collapsed[g.type]&&g.items.map(v=>{const bars=vehicleBars[v.code]||[];const isDT=dropTarget&&dropTarget.vc===v.code;const rowHL=isDT?(dropTarget.ok?"rgba(34,197,94,.15)":"rgba(239,68,68,.1)"):"transparent";const hasSearchHit=searchResult&&searchResult.found&&bars.some(b=>b.type==="reservation"&&searchResult.hitSet.has(b.r.id));return <tr key={v.id} ref={el=>{vehicleRowRefs.current[v.code]=el;}} onDragOver={e=>handleDragOver(e,v.code)} onDragLeave={()=>{if(dropTargetRef.current){dropTargetRef.current=null;setDropTarget(null);}}} onDrop={e=>handleDrop(e,v.code)} style={{outline:isDT?(dropTarget.ok?"2px solid #22c55e":"2px dashed #ef4444"):"none",background:hasSearchHit?"#fefce8":"transparent"}}>
              <td style={{position:"sticky",left:0,zIndex:5,height:ROW_H,background:hasSearchHit?"#fef08a":(isDT?(dropTarget.ok?"#dcfce7":"#fef2f2"):"#fff"),borderBottom:"1px solid #f1f5f9",borderRight:hasSearchHit?"3px solid #f59e0b":"2px solid #94a3b8",padding:isMobile?"0 4px":"0 10px",overflow:"hidden",whiteSpace:"nowrap",transition:"background .15s"}}>
                {hasSearchHit&&<span style={{fontSize:9,marginRight:3}}>📍</span>}
                <span style={{fontSize:isMobile?9:10,fontWeight:700,color:hasSearchHit?"#b45309":"#2563eb"}}>{v.no}<span style={{fontSize:8,color:hasSearchHit?"#92400e":"#94a3b8",fontWeight:500}}>({v.seats})</span></span>
                {!isMobile&&<span style={{fontSize:9,color:"#64748b",marginLeft:4}}>{v.name}</span>}
                <span onClick={e=>{e.stopPropagation();toggleKpi(v.code);}} style={{fontSize:8,fontWeight:700,marginLeft:3,padding:"0 3px",borderRadius:3,cursor:"pointer",background:isKpiActive(v.code)?"#dcfce7":"#fee2e2",color:isKpiActive(v.code)?"#059669":"#dc2626",border:"1px solid "+(isKpiActive(v.code)?"#86efac":"#fca5a5")}} title={isKpiActive(v.code)?"稼働中（クリックで除外）":"除外中（クリックで稼働に変更）"}>{isKpiActive(v.code)?"稼働":"除外"}</span>
                <span onClick={e=>{e.stopPropagation();toggleHideVeh(v.code);}} style={{fontSize:8,fontWeight:700,marginLeft:3,padding:"0 3px",borderRadius:3,cursor:"pointer",background:"#f1f5f9",color:"#64748b",border:"1px solid #cbd5e1"}} title="折りたたみ（一時的に非表示・クラス見出しから戻せます）">👁 隠す</span>
                {vehicleRevenue[v.code]>0&&<span title={"車両売上 ¥"+Math.round(vehicleRevenue[v.code]).toLocaleString()+" (配車表 表示期間内)"} style={{fontSize:8,fontWeight:700,marginLeft:3,padding:"0 3px",borderRadius:3,background:"#f0fdf4",color:"#15803d",border:"1px solid #86efac"}}>💰 {fmtRev(vehicleRevenue[v.code])}</span>}
                {(()=>{const u=utilRates[v.code];if(!u)return null;const pc=u.pct;const cl=pc>=80?"#dc2626":pc>=50?"#f59e0b":"#22c55e";return <span style={{fontSize:8,fontWeight:700,color:cl,marginLeft:4,background:pc>=80?"#fef2f2":pc>=50?"#fffbeb":"#f0fdf4",padding:"0 3px",borderRadius:3}}>{u.days}日{!isMobile&&" "+pc+"%"}</span>;})()}
              </td>
              {dates.map((d,di)=>{const isToday=d===today;return <td key={d} style={{position:"relative",height:ROW_H,borderBottom:"1px solid #f1f5f9",borderRight:"1px solid #e2e8f0",cursor:dragInfo?"copy":"pointer",background:isDT?rowHL:(isToday?"#eff6ff":"transparent"),padding:0,transition:"background .15s"}} onClick={()=>{if(!dragInfo)handleCellClick(v.code,d);}}>
                {di===0&&bars.map((b,bi)=>{const isRes=b.type==="reservation";const isMaint=b.type==="maintenance";const isDragging=dragInfo===b.r?.id;const isSearchHit=isRes&&searchResult&&searchResult.found&&searchResult.hitSet.has(b.r.id);return <div key={bi} className={isMaint?"":(isSearchHit?"tl-bar tl-bar-hit":"tl-bar")} draggable={isRes} onDragStart={isRes?e=>handleDragStart(e,b.r.id):undefined} onDragEnd={handleDragEnd} onClick={e=>handleBarClick(e,b)} style={{left:b.left,width:Math.max(b.width,20),background:isMaint?(b.m?.status==="approved"?"repeating-linear-gradient(135deg,#15803d,#15803d 3px,#16a34a 3px,#16a34a 6px)":"repeating-linear-gradient(135deg,#d97706,#d97706 3px,#f59e0b 3px,#f59e0b 6px)"):(isRes?(isDragging?"#f87171":(b.r.ota==="O"?"#fef9c3":(b.r.ota==="HP"?"#dbeafe":"#dc2626"))):"#2563eb"),color:isRes&&!isDragging&&(b.r.ota==="O"||b.r.ota==="HP")?(b.r.ota==="HP"?"#1e40af":"#92400e"):"#fff",fontSize:isMaint?9.5:9,fontWeight:isMaint?800:600,boxShadow:isSearchHit?"0 0 8px 3px rgba(250,204,21,.8),0 0 16px 6px rgba(250,204,21,.4)":(isDragging?"0 4px 12px rgba(0,0,0,.3)":(isMaint?"none":"0 1px 3px rgba(0,0,0,.2)")),outline:isSearchHit?"3px solid #facc15":"none",position:"absolute",top:isMaint?0:3,height:isMaint?17:undefined,bottom:isMaint?undefined:3,zIndex:isMaint?3:(isSearchHit?15:(isDragging?10:2)),opacity:isDragging?0.7:(isMaint?0.9:1),cursor:isRes?"grab":"pointer",transition:"opacity .15s, box-shadow .15s",borderRadius:isMaint?0:4,display:"flex",alignItems:"center",padding:"0 4px",overflow:"hidden",whiteSpace:"nowrap"}}><span style={{overflow:"hidden",textOverflow:"ellipsis"}}>{isRes?`${b.r.lendTime}-${b.r.returnTime} ${b.r.name} 様`:("🔧"+b.m.label+(b.m.status==="approved"?"〔FIX〕":"〔仮〕"))}</span></div>;})}
              </td>;})}
            </tr>;})}
          </React.Fragment>)}
        </tbody>
      </table>
    </div>

    {cellAction&&<div className="modal-overlay" onClick={()=>setCellAction(null)}><div className="modal-box" style={{maxWidth:280,padding:20}} onClick={e=>e.stopPropagation()}>
      <h4 className="font-bold text-sm mb-3">{cellAction.vehicleCode} — {fmtD(cellAction.date)}</h4>
      <div className="space-y-2">
        <button onClick={()=>{const v=vehicles.find(x=>x.code===cellAction.vehicleCode);setShowResForm({vehicleCode:cellAction.vehicleCode,lendDate:cellAction.date,vehicle:v?.type||"A"});setCellAction(null);}} className="w-full py-2 bg-green-600 text-white rounded-lg text-sm font-bold hover:bg-green-700">新規予約を登録</button>
        <button onClick={()=>{setShowMaintForm(cellAction);setCellAction(null);}} className="w-full py-2 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700">メンテナンス登録</button>
        <button onClick={()=>setCellAction(null)} className="w-full py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-semibold">キャンセル</button>
      </div>
    </div></div>}

    {tooltip&&<div className="modal-overlay" style={{background:"rgba(0,0,0,.15)"}} onClick={()=>setTooltip(null)}><div className="modal-box" style={{maxWidth:340,padding:20}} onClick={e=>e.stopPropagation()}>
      <div className="flex items-center justify-between mb-2"><span className="font-bold text-sm">{tooltip.type==="reservation"?tooltip.name:tooltip.label}</span><button onClick={()=>setTooltip(null)} className="text-gray-400 hover:text-gray-600">✕</button></div>
      {tooltip.type==="reservation"?<div className="text-xs space-y-1 text-gray-600">
        <div><OBadge ota={tooltip.ota}/> <span className="font-mono">{tooltip.id}</span></div>
        <div>貸出: {fmtD(tooltip.lendDate)} {tooltip.lendTime} / 返却: {fmtD(tooltip.returnDate)} {tooltip.returnTime}</div>
        <div>クラス: {tooltip.vehicle} / 補償: {tooltip.insurance}</div>
        <div style={{display:"flex",alignItems:"center",gap:6,marginTop:4}}>
          <span style={{fontWeight:700,color:"#1e293b"}}>配車:</span>
          <select value={tooltip.vc||""} onChange={e=>{const newVc=e.target.value;if(!newVc){if(!window.confirm("配車を解除しますか？"))return;const nf={...fleet};delete nf[tooltip.id];onFleetChange(nf);DB.deleteFleetOne(tooltip.id);setTooltip({...tooltip,vc:""});/* 配車解除→OPシートタスクもクリア */try{const r=data.find(x=>x.id===tooltip.id);if(r){const _clr=async(d)=>{if(!d)return;const tks=await DB.fetchTasks(d);if(!tks)return;const upd=tks.map(tk=>tk.reservationId===tooltip.id?{...tk,assignedVehicle:"",plateNo:""}:tk);if(JSON.stringify(upd)!==JSON.stringify(tks))DB.upsertTasks(upd,d);};const ld=norm(r.lendDate),rd=norm(r.returnDate);_clr(ld);if(rd!==ld)_clr(rd);_clr(dOff(ld,-1));}}catch(e){console.error("[fleet clear tasks]",e);}return;}const conflict=checkVehicleConflict(newVc,tooltip.id,data,fleet,maintenance);if(conflict){const cv=vehicles.find(x=>x.code===newVc);alert((cv?cv.name:newVc)+" は "+fmtD(conflict.lendDate)+"〜"+fmtD(conflict.returnDate)+" に「"+conflict.name+"」様の"+(conflict._isMaint?"メンテナンス":"予約")+"が入っているため変更できません。");return;}const targetV=vehicles.find(x=>x.code===newVc);if(!window.confirm("配車を「"+(targetV?targetV.name:newVc)+"」に変更しますか？"))return;if(onReassignVehicle){onReassignVehicle(tooltip.id,newVc);}else{onFleetChange({...fleet,[tooltip.id]:newVc});}setTooltip({...tooltip,vc:newVc});}} style={{border:"1px solid #d1d5db",borderRadius:6,padding:"3px 6px",fontSize:11,fontWeight:600,color:"#1d4ed8",flex:1}}>
            <option value="">— 未割当 —</option>
            {vehicleClasses.map(cls=><optgroup key={cls.type} label={cls.type+"クラス"}>{vehicles.filter(v=>v.type===cls.type).map(v=><option key={v.code} value={v.code}>{v.name} ({v.no}) {v.seats}名</option>)}</optgroup>)}
          </select>
        </div>
        <div style={{marginTop:8,display:"flex",gap:6}}>
          {onCancelReservation&&tooltip.status!=="cancelled"&&<button onClick={()=>{
            // ★ 2026-05-11: 誤キャンセル防止 2段階確認（SP-20260507-0004/0005 障害対策）
            const msg=tooltip.name+" 様の予約をキャンセルしますか？\n\n予約番号: "+tooltip.id+"\n貸出: "+fmtD(tooltip.lendDate)+" "+tooltip.lendTime+"\n返却: "+fmtD(tooltip.returnDate)+" "+tooltip.returnTime+"\n\n※OPシートはCXL表示、配車表から除外されます";
            if(!window.confirm(msg))return;
            const conf=window.prompt('確認のため、予約番号「'+tooltip.id+'」を入力してください\n(誤キャンセル防止)');
            if(conf===tooltip.id){onCancelReservation(tooltip.id);setTooltip(null);}
            else if(conf!==null){alert('予約番号が一致しないため、キャンセル操作を中止しました');}
          }} style={{flex:1,background:"#fee2e2",color:"#dc2626",border:"none",borderRadius:6,fontSize:11,fontWeight:800,padding:"6px 8px",cursor:"pointer"}}>キャンセル</button>}
          {onDeleteReservation&&<button onClick={()=>{const msg="⚠️ 物理削除（復元不可）\n\n"+tooltip.name+" 様の予約をDBから完全削除しますか？\n\n予約番号: "+tooltip.id+"\n貸出: "+fmtD(tooltip.lendDate)+" "+tooltip.lendTime+"\n返却: "+fmtD(tooltip.returnDate)+" "+tooltip.returnTime+"\n\n※この操作は取り消せません。配車・タスクも削除されます。";if(!window.confirm(msg))return;const conf=window.prompt('本当に削除する場合、"削除"と入力してください');if(conf==='削除'){onDeleteReservation(tooltip.id);setTooltip(null);}else if(conf!==null){alert('入力が一致しないため、削除をキャンセルしました');}}} style={{flex:1,background:"#7f1d1d",color:"#fff",border:"none",borderRadius:6,fontSize:11,fontWeight:800,padding:"6px 8px",cursor:"pointer"}}>削除</button>}
        </div>
      </div>:<div className="text-xs space-y-1 text-gray-600">
        <div>車両: {tooltip.vehicleCode}</div><div>期間: {fmtD(tooltip.startDate)} 〜 {fmtD(tooltip.endDate)}{(tooltip.startTime||tooltip.endTime)?(" 🕐"+(tooltip.startTime||"?")+"〜"+(tooltip.endTime||"?")):""}</div>
        <div>ステータス: <span style={{fontWeight:800,padding:"1px 8px",borderRadius:4,color:"#fff",background:tooltip.status==="approved"?"#16a34a":"#f59e0b"}}>{tooltip.status==="approved"?"🟢 FIX":"🟠 仮予定"}</span></div>
        {tooltip.workshop&&<div>🏭 {tooltip.workshop}</div>}
        <div style={{display:"flex",gap:6,marginTop:8}}>
          <button onClick={()=>{const m=(maintenance||[]).find(x=>x.id===tooltip.id)||tooltip;setShowMaintForm({vehicleCode:m.vehicleCode,date:m.startDate,edit:m});setTooltip(null);}} style={{flex:1,background:"#eff6ff",color:"#1d4ed8",border:"none",borderRadius:8,fontSize:11,fontWeight:800,padding:"6px 8px",cursor:"pointer"}}>✏️ 編集</button>
          <button onClick={()=>removeMaint(tooltip.id)} style={{flex:1,background:"#fef2f2",color:"#dc2626",border:"none",borderRadius:8,fontSize:11,fontWeight:800,padding:"6px 8px",cursor:"pointer"}}>🗑 削除</button>
        </div>
      </div>}
    </div></div>}

    {showMaintForm&&<div className="modal-overlay" onClick={()=>{if(!maintSaving)setShowMaintForm(null);}}><div className="modal-box" style={{maxWidth:320,padding:20}} onClick={e=>e.stopPropagation()}><h4 className="font-bold text-sm mb-3">{showMaintForm.edit?"メンテナンス編集":"メンテナンス登録"}</h4><MaintForm vehicleCode={showMaintForm.vehicleCode} startDate={showMaintForm.date} edit={showMaintForm.edit} onAdd={addMaint} onClose={()=>{if(!maintSaving)setShowMaintForm(null);}} vehicles={vehicles} saving={maintSaving}/></div></div>}

    {showResForm&&<ReservationForm prefill={showResForm} onAdd={(r,vc)=>{onAddReservation(r,vc);setShowResForm(null);}} onBulkAdd={(rArr,fl)=>{onBulkAddReservation(rArr,fl);setShowResForm(null);}} vehicles={vehicles} vehicleClasses={vehicleClasses} onClose={()=>setShowResForm(null)} data={data} fleet={fleet} maintenance={maintenance}/>}
  </div>;
}

function MaintForm({vehicleCode,startDate,onAdd,onClose,vehicles,saving,edit}){
  const[start,setStart]=useState(edit?(edit.startDate||startDate):startDate);const[end,setEnd]=useState(edit?(edit.endDate||startDate):startDate);const[label,setLabel]=useState(edit?(edit.label||"メンテナンス"):"メンテナンス");
  const[cost,setCost]=useState(edit&&edit.cost?String(edit.cost):"");const[workshop,setWorkshop]=useState(edit?(edit.workshop||""):"");const[invoiceNo,setInvoiceNo]=useState(edit?(edit.invoiceNo||""):"");const[maintNotes,setMaintNotes]=useState(edit?(edit.maintNotes||""):"");
  const[status,setStatus]=useState(edit?(edit.status||"pending"):"pending");const[startTime,setStartTime]=useState(edit?(edit.startTime||""):"");const[endTime,setEndTime]=useState(edit?(edit.endTime||""):"");
  const v=vehicles.find(x=>x.code===vehicleCode);
  const isDetail=label==="車検"||label==="半年点検";
  const isRepair=label==="修理";
  const iS={padding:"5px 8px",fontSize:12,border:"1px solid #d1d5db",borderRadius:6,width:"100%"};
  const lS={fontSize:10,color:"#64748b",fontWeight:700,display:"block",marginBottom:2};
  return <div style={{display:"flex",flexDirection:"column",gap:10}}>
    <div style={{fontSize:11,color:"#64748b"}}>車両: <strong>{v?v.name:vehicleCode}</strong> ({v?v.no:""}) {v?v.seats+"名":""}</div>
    <div><label style={lS}>ラベル</label><select value={label} onChange={e=>setLabel(e.target.value)} style={iS}><option>メンテナンス</option><option>車検</option><option>半年点検</option><option>修理</option><option>清掃</option><option>その他</option></select></div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
      <div><label style={lS}>{isDetail?"入庫日（開始）":"開始日"}</label><input type="date" value={start} onChange={e=>setStart(e.target.value)} style={iS}/></div>
      <div><label style={lS}>{isDetail?"出庫日（終了）":"終了日"}</label><input type="date" value={end} onChange={e=>setEnd(e.target.value)} style={iS}/></div>
    </div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
      <div><label style={lS}>入庫時刻（任意）</label><input type="time" value={startTime} onChange={e=>setStartTime(e.target.value)} style={iS}/></div>
      <div><label style={lS}>出庫時刻（任意）</label><input type="time" value={endTime} onChange={e=>setEndTime(e.target.value)} style={iS}/></div>
    </div>
    <div><label style={lS}>ステータス</label>
      <div style={{display:"flex",gap:6}}>
        <button type="button" onClick={()=>setStatus("pending")} style={{flex:1,padding:"7px 4px",fontSize:12,fontWeight:800,borderRadius:7,cursor:"pointer",border:status==="pending"?"2px solid #d97706":"1px solid #e2e8f0",background:status==="pending"?"#f59e0b":"#fff",color:status==="pending"?"#fff":"#92400e"}}>🟠 仮予定（FIX待ち）</button>
        <button type="button" onClick={()=>setStatus("approved")} style={{flex:1,padding:"7px 4px",fontSize:12,fontWeight:800,borderRadius:7,cursor:"pointer",border:status==="approved"?"2px solid #15803d":"1px solid #e2e8f0",background:status==="approved"?"#16a34a":"#fff",color:status==="approved"?"#fff":"#166534"}}>🟢 FIX（確定）</button>
      </div>
    </div>
    {isDetail&&<div style={{padding:"10px 12px",background:"#eff6ff",borderRadius:8,border:"1px solid #dbeafe",display:"flex",flexDirection:"column",gap:8}}>
      <div style={{fontSize:10,fontWeight:800,color:"#1e40af",marginBottom:2}}>{label} 詳細情報</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
        <div><label style={lS}>概算予算（円）</label><input type="number" value={cost} onChange={e=>setCost(e.target.value)} style={iS} placeholder="0"/><div style={{fontSize:9,color:"#2563eb",marginTop:2}}>→ 車両のランニングコストに自動登録</div></div>
        <div><label style={lS}>請求書番号</label><input value={invoiceNo} onChange={e=>setInvoiceNo(e.target.value)} style={iS} placeholder="INV-001"/></div>
      </div>
      <div><label style={lS}>業者名</label><input value={workshop} onChange={e=>setWorkshop(e.target.value)} style={iS} placeholder="〇〇自動車"/></div>
      <div><label style={lS}>メモ</label><input value={maintNotes} onChange={e=>setMaintNotes(e.target.value)} style={iS}/></div>
    </div>}
    {isRepair&&<div style={{padding:"10px 12px",background:"#fef2f2",borderRadius:8,border:"1px solid #fecaca",display:"flex",flexDirection:"column",gap:8}}>
      <div style={{fontSize:10,fontWeight:800,color:"#991b1b",marginBottom:2}}>修理 詳細情報</div>
      <div><label style={lS}>修理予算（円）</label><input type="number" value={cost} onChange={e=>setCost(e.target.value)} style={iS} placeholder="0"/><div style={{fontSize:9,color:"#dc2626",marginTop:2}}>→ 予算スケジュールに自動反映</div></div>
      <div><label style={lS}>業者名</label><input value={workshop} onChange={e=>setWorkshop(e.target.value)} style={iS} placeholder="〇〇自動車"/></div>
      <div><label style={lS}>メモ</label><input value={maintNotes} onChange={e=>setMaintNotes(e.target.value)} style={iS}/></div>
    </div>}
    <div style={{display:"flex",justifyContent:"flex-end",gap:8}}><button onClick={onClose} disabled={saving} className="btn-ghost">キャンセル</button><button onClick={()=>onAdd(vehicleCode,start,end,label,cost,workshop,invoiceNo,maintNotes,status,startTime,endTime,edit?edit.id:null)} disabled={saving} className="btn-primary" style={saving?{opacity:0.6,cursor:"not-allowed"}:{}}>{saving?"保存中...":(edit?"更新":"登録")}</button></div>
  </div>;
}

/* ==========================================
   OPシート（独立フルスクリーン）
   ========================================== */
function OPScreen({reservations,today,shifts,fleet,onFleetChange,onClose,onGoFleet,vehicles,staff,resOpts,sheetPlaces,onUpdateSheetPlaces,repeaterMap,jalanPay,onReservationUpdate,maintenance,openIntent,onOpenIntentConsumed,initialView}){
  const[dayOff,setDayOff]=useState(0);const selDate=dOff(today,dayOff);const[tasks,setTasks]=useState([]);
  const[opView,setOpView]=useState(initialView||"summary"); // ★ 表示切替: "summary" | "hia" | "tasks" | "wash" | "raiten" | "other" | "master" | "edit" | "guide" (バスタブは廃止)
  // ★ 2026-07-16 ご利用ガイド送信: 締結状況(サイン数)を bt_mypage_list から取得
  const[guideSignMap,setGuideSignMap]=useState({});
  React.useEffect(()=>{if(!sb)return;let go=true;const load=()=>sb.rpc("bt_mypage_list").then(({data})=>{if(!go||!Array.isArray(data))return;const m={};data.forEach(x=>{if(x&&x.id)m[x.id]=x.signs||0;});setGuideSignMap(m);}).catch(()=>{});load();const iv=setInterval(load,60000);return()=>{go=false;clearInterval(iv);};},[]);
  const[washAddCat,setWashAddCat]=useState("");const[washAddVc,setWashAddVc]=useState("");const[washAddTime,setWashAddTime]=useState("");const[washAddMemo,setWashAddMemo]=useState("");
  // ★ その他タブ用 state (SPK v4.6.5 から完全コピー)
  const[otherAddType,setOtherAddType]=useState("");const[otherAddName,setOtherAddName]=useState("");const[otherAddTime,setOtherAddTime]=useState("");const[otherAddPlace,setOtherAddPlace]=useState("");const[otherAddVc,setOtherAddVc]=useState("");const[otherAddMemo,setOtherAddMemo]=useState("");const[otherEditId,setOtherEditId]=useState(null);
  const[editResId,setEditResId]=useState(null); // ★ 編集対象の予約ID（マスターからの遷移用）
  const[editBlock,setEditBlock]=useState(null); // ★ 編集ブロック: null(入口選択) | "dep"(出発) | "ret"(返却) | "common"(共通)
  const[suppressDayOffReset,setSuppressDayOffReset]=useState(false); // ★ openIntent処理中はdayOff変更時のリセットを抑止
  // ★ 日付変更時に編集状態をリセット（openIntent処理中は除く）
  useEffect(()=>{if(suppressDayOffReset){setSuppressDayOffReset(false);return;}setEditResId(null);setEditBlock(null);},[dayOff]);
  // ★ 外部から「この予約を開いて」の指示を受けたら、日付ジャンプ＋編集モード起動
  useEffect(()=>{
    if(!openIntent||!openIntent.resId)return;
    const lendDate=openIntent.lendDate;
    if(lendDate){
      try{
        const t=new Date(today+"T00:00:00");
        const l=new Date(lendDate+"T00:00:00");
        const diff=Math.round((l-t)/(1000*60*60*24));
        if(diff!==dayOff){setSuppressDayOffReset(true);setDayOff(diff);}
      }catch(e){}
    }
    setOpView("master");
    setEditResId(openIntent.resId);
    setEditBlock(null);
    if(onOpenIntentConsumed)onOpenIntentConsumed();
  },[openIntent,today]);
  const[analysisPeriod,setAnalysisPeriod]=useState("day"); // ★ 分析期間: "day" | "month" | "year"
  const[analysisData,setAnalysisData]=useState(null); // ★ 月間/年間分析データ
  const[resDetailPopup,setResDetailPopup]=useState(null); // ★ 予約詳細ポップアップ {task}
  const[chipMenu,setChipMenu]=useState(null); // ★ バス便チップ操作メニュー {taskId, x, y}
  const[busTimeMenu,setBusTimeMenu]=useState(null); // ★ バス便時間変更メニュー {taskId, type, currentHour}
  const[busDrivers,setBusDrivers]=useState(()=>{try{return JSON.parse(localStorage.getItem("bt_bus_drivers_"+selDate)||"{}");} catch(e){return{};}}); // ★ バス便ごとの運転手・補助 {hourKey: {driver:"", assistant:""}}
  useEffect(()=>{try{localStorage.setItem("bt_bus_drivers_"+selDate,JSON.stringify(busDrivers));}catch(e){}},[busDrivers,selDate]);
  useEffect(()=>{try{setBusDrivers(JSON.parse(localStorage.getItem("bt_bus_drivers_"+selDate)||"{}"));}catch(e){setBusDrivers({});}},[selDate]);
  const[busVehicles,setBusVehicles]=useState({}); // ★ バス便ごとの車両ナンバー {hourKey: plateNo}
  const[busTab,setBusTab]=useState("all"); // ★ バスタブ内切替: "all" | "pu" | "bd"
  const[chipAction,setChipAction]=useState(null); // ★ チップ操作メニュー
  const[dragTask,setDragTask]=useState(null); // ★ ドラッグ中のタスク {taskId, fromSlot, fromLeg}
  const[nhaJpMap,setNhaJpMap]=useState({}); // ★ bt_jalan_payments決済ステータス
  useEffect(()=>{(async()=>{try{const d=await DB.fetchNhaJalanPayments();const m={};(d||[]).forEach(p=>{m[p.reservation_id]=p;});setNhaJpMap(m);}catch(e){}})();},[]);
  const[editLogs,setEditLogs]=useState([]); // ★ 編集ログ
  const[showLogTaskId,setShowLogTaskId]=useState(null); // ★ ログ表示対象タスクID
  const[showAllLogs,setShowAllLogs]=useState(false); // ★ 全ログ表示
  const[editorName,setEditorName]=useState(()=>localStorage.getItem("bt_editor_name")||""); // ★ 操作者名
  const[patrolIncomplete,setPatrolIncomplete]=useState([]); // ★ 2026-04-24 パトロールSS記入漏れ（予約者名あり・予約番号なし）
  // ★ シート在庫管理
  const SEAT_STOCK_KEY="seat_stock_nha";
  const[seatStock,setSeatStock]=useState({b:5,c:5,j:3});
  const[showSeatCfg,setShowSeatCfg]=useState(false);
  const[seatEdit,setSeatEdit]=useState({b:5,c:5,j:3});
  useEffect(()=>{if(!sb)return;sb.from("bt_app_settings").select("value").eq("key",SEAT_STOCK_KEY).single().then(({data})=>{if(!data||data.value==null)return;try{const raw=data.value;const v=typeof raw==="string"?JSON.parse(raw):raw;if(v&&typeof v==="object"&&("b" in v||"c" in v||"j" in v)){setSeatStock(v);setSeatEdit(v);}}catch(e){console.error("[seatStock load]",e);}});},[]);
  const saveSeatStock=async(s)=>{setSeatStock(s);setShowSeatCfg(false);if(sb)await sb.from("bt_app_settings").upsert({key:SEAT_STOCK_KEY,value:JSON.stringify(s)},{onConflict:"key"});};
  // 選択日のシート需要
  // 「今日シートが必要」= 今日アクティブ + 翌日出発準備（洗車で積み込む分）
  // 返却日当日は在庫に戻る（同日返却→同日貸出で使い回し可）
  const seatDemand=useMemo(()=>{
    const tomorrow=dOff(selDate,1);
    const act=reservations.filter(r=>r.status!=="cancelled"&&norm(r.lendDate)<=tomorrow&&(norm(r.returnDate)>selDate||norm(r.lendDate)>=selDate));
    return{b:act.reduce((s,r)=>s+(+(r.optB||0)),0),c:act.reduce((s,r)=>s+(+(r.optC||0)),0),j:act.reduce((s,r)=>s+(+(r.optJ||0)),0)};
  },[reservations,selDate]);
  // ★ 編集ログ取得
  useEffect(()=>{DB.fetchEditLogs(selDate).then(l=>setEditLogs(l||[]));},[selDate]);
  // ★ 編集ログ記録ヘルパー
  const logEdit=useCallback((t,field,oldVal,newVal)=>{
    const by=editorName||"不明";
    const entry={date:selDate,taskId:t._id,taskName:t.name||"",field,oldValue:String(oldVal||""),newValue:String(newVal||""),editedBy:by};
    DB.addEditLog(entry);
    setEditLogs(prev=>[{...entry,id:"tmp_"+Date.now(),created_at:new Date().toISOString(),task_id:t._id,task_name:t.name,old_value:entry.oldValue,new_value:entry.newValue,edited_by:by},...prev]);
  },[selDate,editorName]);
  // ★ 出勤メンバー: シフト登録者のうち公休・希望休・有休以外の全員
  const staffTypeMapOP=useMemo(()=>{const m={};staff.forEach(s=>{m[s.name]=s.type;});return m;},[staff]);
  const activeMembers=useMemo(()=>{
    const dayShifts=shifts[selDate]||[];
    const offSymbols=new Set(["公","希","有","出"]);
    return dayShifts.filter(s=>{
      const sType=staffTypeMapOP[s.name]||"";
      if(sType==="正社員")return s.symbol==="●";
      return!offSymbols.has(s.symbol)&&!!(s.start&&s.end);
    }).map(s=>s.name);
  },[shifts,selDate,staffTypeMapOP]);
  const fleetRef=React.useRef(fleet);fleetRef.current=fleet;
  // fleet変更時にタスクの車種情報を同期 + LS/DB永続化
  useEffect(()=>{
    setTasks(prev=>{
      let changed=false;
      const next=prev.map(t=>{
        if(!t.reservationId)return t;
        const vc=fleet[t.reservationId];
        const vn=vc?vehicles.find(v=>v.code===vc):null;
        const updates={};
        // fleet変更（配車/解除）
        if(vc&&vc!==t.assignedVehicle){updates.assignedVehicle=vc;updates.plateNo=vn?vn.no:"";updates.vehicleNo=vn?vn.no:"";updates.vehicleName=vn?vn.name:"";}
        if(!vc&&t.assignedVehicle){updates.assignedVehicle="";updates.plateNo="";updates.vehicleNo="";updates.vehicleName="";}
        // 車両マスター変更（type/no/name変更を検出）
        if(vn&&vc===t.assignedVehicle){
          if(vn.type!==t.vehicle)updates.vehicle=vn.type;
          if(vn.no!==t.plateNo){updates.plateNo=vn.no;updates.vehicleNo=vn.no;}
          if(vn.name!==t.vehicleName)updates.vehicleName=vn.name;
        }
        if(vn&&updates.assignedVehicle)updates.vehicle=vn.type;
        if(!Object.keys(updates).length)return t;
        changed=true;
        return{...t,...updates};
      });
      // ★ 変更があればLS/DBに即時保存（タブ移動で元に戻る問題を防止）
      if(changed&&next.length){
        DB._lsSave(next,selDate);
        DB.upsertTasks(next,selDate);
        next.forEach(t=>selfUpdatedIds.current.set(t._id,Date.now()));
      }
      return changed?next:prev;
    });
  },[fleet,vehicles]);
  // ★ 月間/年間分析データロード
  const loadAnalysisData=React.useCallback(async(period)=>{
    if(period==="day"){setAnalysisData(null);return;}
    try{
      let startDate,endDate;
      const d=new Date(selDate);
      if(period==="month"){
        startDate=new Date(d.getFullYear(),d.getMonth(),1).toISOString().slice(0,10);
        endDate=new Date(d.getFullYear(),d.getMonth()+1,0).toISOString().slice(0,10);
      }else{
        startDate=d.getFullYear()+"-01-01";
        endDate=d.getFullYear()+"-12-31";
      }
      if(!sb)return;const{data,error}=await sb.from("bt_tasks").select("type,time,people,date,flight,done").gte("date",startDate).lte("date",endDate);
      if(error)throw error;
      setAnalysisData({tasks:data||[],period,startDate,endDate});
    }catch(e){console.error("Analysis load error:",e);setAnalysisData(null);}
  },[selDate]);

  // タスクロード
  const selfUpdatedIds=React.useRef(new Map()); // _id -> timestamp
  const loadTasks=React.useCallback(async(date,force)=>{
    // 自分の変更直後（3秒以内）はDBリロードをスキップ（自分の変更を上書きしない）
    if(!force&&selfUpdatedIds.current.size>0&&Date.now()-Math.max(...selfUpdatedIds.current.values())<3000){
      console.log("[loadTasks] 自分の変更直後のためスキップ");return;
    }
    // ★ DB取得前にlocalStorageを読む（fetchTasksがLSを上書きする前に保持）
    const lsData=DB._lsLoad(date);
    const lsMap={};
    if(lsData)lsData.forEach(x=>{lsMap[x._id]=x;});
    // 1. DB(+localStorage)から取得
    const saved=await DB.fetchTasks(date);
    // 🛡 2026-06-21 データ消失対策: fetchがエラー由来（DB/RLS/瞬断）で空のときは
    //   絶対に再生成→upsertしない（既存DB行をスタッフ入力ごと丸ごと上書きする事故を防止）。
    if(saved&&saved._fetchError){
      if(saved.length>0){setTasks(saved);console.warn("[loadTasks] fetchエラー→LS表示維持（再生成スキップ）",date,saved.length+"件");}
      else{console.warn("[loadTasks] fetchエラー＆LS空→再生成スキップ（上書き事故防止）",date);}
      return;
    }
    if(saved&&saved.length>0){
      // 日付ズレ修正: DELタスクの予約lendDateがこの日と合わないものを除去
      const removed=[];
      let fixed=saved.filter(t=>{
        if(!t.reservationId||t.manual)return true;
        const r=reservations.find(x=>x.id===t.reservationId);
        // ★ 予約がCSV入替等で消えた場合、対応タスクも除去（幽霊タスク防止）
        if(!r){removed.push(t._id);console.log("[loadTasks] orphan task removed:",t._id,t.reservationId,t.type);return false;}
        // ★ 2026-05-10 fix: 「日付ズレ」自浄ロジックを撤去（札幌実装と統一）
        //   旧コードは予約日付変更時に担当付きタスクごと物理削除して「担当消失」障害を引き起こしていた。
        //   置き去りタスクは GAS の cleanupOrphanTasksNha が日次でクリーンアップする方針に変更。
        //   業務影響: 置き去りタスクは最大1日表示される可能性あり（次回02:00 JST に削除）。
        return true;
      });
      // ★ 日付不整合タスクをDBからも削除（幽霊タスク防止）
      if(removed.length&&sb){
        dbLog("cleanStale",true,"表示除外のみ(★2026-07-04 DB削除なし):"+removed.length);/* 開くだけでDBを書かない: 孤立/キャンセルは表示除外のみ。掃除は日次に委ねる。 */
      }
      // ★2026-07-16 クラス③墓標ガード(SPK/NHA移植・根絶): 削除タスクを生成補完が復活させない。失敗時は空Set=現状維持(fail-safe)。
      let _tomb=new Set();
      try{if(sb){const{data:_dd}=await sb.from("bt_tasks").select("_id").eq("date",date).eq("deleted",true);(_dd||[]).forEach(x=>_tomb.add(x._id));}}catch(_e){}
      // 不足予約を追加
      const gen=generateTasks(reservations,date,fleetRef.current,vehicles);
      const _sd=(ty)=>["BD","BDB","COL","返却"].includes(ty)?"R":(ty==="洗車"?"W":"L");const existIds=new Set(fixed.filter(t=>t.reservationId).map(t=>t.reservationId+":"+_sd(t.type)));
      // ★ 新規生成タスクにsheetPlacesの場所情報を補完
      gen.forEach(g=>{
        if(g.reservationId&&!existIds.has(g.reservationId+":"+_sd(g.type))&&!_tomb.has(g._id)){
          const sp=sheetPlaces[g.reservationId];
          if(sp&&!g.place){if((g.type==="DEL"||g.type==="PU")&&sp.delPlace)g.place=sp.delPlace;if((g.type==="COL"||g.type==="BD")&&sp.colPlace)g.place=sp.colPlace;}
          if(sp&&(g.type==="DEL"||g.type==="PU")&&!g.colPlace&&sp.colPlace)g.colPlace=sp.colPlace;
          fixed.push(g);
        }
      });
      // ★ 洗車タスクの整合性管理（車両コード単位で重複排除 + 孤児削除 + 未配車分追加）
      const tomorrowDate=dOff(date,1);
      const tomorrowResMap=new Map(); // 翌日DEL: 車両コード→予約 / 未配車: "unassigned:"+resId→予約
      reservations.forEach(r=>{
        if(r.status==="cancelled")return;
        if(!sD(r.lendDate,tomorrowDate))return;
        const vc=fleetRef.current[r.id];
        if(vc){if(!tomorrowResMap.has(vc))tomorrowResMap.set(vc,r);}
        else{tomorrowResMap.set("unassigned:"+r.id,r);}
      });
      // 既存の洗車タスクを車両コード単位で重複排除
      const washByVehicle=new Map();const washDupIds=[];
      fixed.forEach(t=>{
        if(t.type!=="洗車")return;
        const key=t.assignedVehicle||("unassigned:"+t.reservationId);
        if(washByVehicle.has(key)){washDupIds.push(t._id);}
        else{washByVehicle.set(key,t);}
      });
      // 翌日DELがない車両の孤児洗車を検出
      washByVehicle.forEach((wt,key)=>{
        if(!tomorrowResMap.has(key)){washDupIds.push(wt._id);washByVehicle.delete(key);}
      });
      if(washDupIds.length){
        fixed=fixed.filter(t=>!washDupIds.includes(t._id));
        dbLog("washClean",true,"表示除外のみ(★2026-07-04 DB削除なし):"+washDupIds.length);/* 開くだけでDBを書かない: 重複洗車は表示除外のみ。 */
        console.log("[loadTasks] wash cleanup:",washDupIds.length,"removed");
      }
      // 不足洗車タスクを追加（翌日DEL予約があるのに洗車がない場合）
      tomorrowResMap.forEach((tRes,key)=>{
        if(washByVehicle.has(key))return;
        if(_tomb.has("w-"+tRes.id))return;/* ★2026-07-16 墓標ガード: 削除した洗車を再生成しない */
        const vc=key.startsWith("unassigned:")?"":(key);
        const veh=vc?vehicles.find(v=>v.code===vc):null;
        fixed.push({_id:"w-"+tRes.id,type:"洗車",time:"",name:`翌日出発: ${tRes.name||""}`,people:0,place:"",vehicle:veh?veh.type:tRes.vehicle,insurance:"",flight:"",reservationId:tRes.id,ota:tRes.ota,tel:"",mail:"",done:false,assignee:"",memo:`${fmtD(tomorrowDate)} DEL ${tRes.lendTime||""} ${tRes.name||""}`,assignedVehicle:vc,plateNo:veh?veh.no:"",insuranceChange:"",opts:{b:+(tRes.optB||0),c:+(tRes.optC||0),j:+(tRes.optJ||0),usb:+(tRes.optUSB||0)},yakkan:false,line:false,payment:false,returnDate:"",returnTime:"",returnType:"",colPlace:""});
        washByVehicle.set(key,true);
      });
      // ★ STEP0: 重複排除（同じ予約ID+同系統タイプの重複を除去）
      const seenResType=new Set();
      const dupIds=[];
      fixed.forEach(t=>{
        if(!t.reservationId||t.manual)return;
        // ★ バス廃止: PU/BD のみで重複判定（旧PUB/BDBデータもグループ統合）
        const baseType=(t.type==="PUB"||t.type==="PU")?"PU_GROUP":(t.type==="BDB"||t.type==="BD")?"BD_GROUP":t.type;
        const key=t.reservationId+":"+baseType;
        if(seenResType.has(key)){dupIds.push(t._id);}
        else{seenResType.add(key);}
      });
      if(dupIds.length>0){
        console.log("[loadTasks] dedup:",dupIds.length,"件の重複タスクを除去");
        fixed=fixed.filter(t=>!dupIds.includes(t._id));
        dbLog("dedup",true,"表示除外のみ(★2026-07-04 DB削除なし):"+dupIds.length);/* 開くだけでDBを書かない: 重複は表示除外のみ。単独書き込み化で今後は生成されない。 */
      }
      // ★ バス運用廃止（高松店はハイエース一本化）: 旧PUB/BDB → PU/BD に自動降格
      let autoDemoted=0;
      fixed=fixed.map(t=>{
        if(t.type==="PUB"){autoDemoted++;return{...t,type:"PU",place:t.place==="高松空港"?"":t.place,_placeSource:"",_changed:{...(t._changed||{}),type:true}};}
        if(t.type==="BDB"){autoDemoted++;return{...t,type:"BD",place:t.place==="高松空港"?"":t.place,_placeSource:"",_changed:{...(t._changed||{}),type:true}};}
        return t;
      });
      if(autoDemoted>0){
        console.log("[loadTasks] バス→ハイエース降格:",autoDemoted,"件");
        DB.upsertTasks(fixed,date);
      }
      // ★ LSにあるmanualタスクがDB結果に欠けていれば復元
      const fixedIds=new Set(fixed.map(t=>t._id));
      Object.values(lsMap).forEach(lst=>{
        if(lst.manual&&!fixedIds.has(lst._id)){
          console.log("[loadTasks] manual task restored from LS:",lst._id,lst.name);
          fixed.push(lst);
        }
      });
      // fleet情報をタスクに反映（DBが古い場合の対策）
      const fl=fleetRef.current;let fleetApplied=false;
      let fixedWithFleet=fixed.map(t=>{
        if(!t.reservationId)return t;
        const vc=fl[t.reservationId];
        if(!vc&&!t.assignedVehicle)return t;
        if(vc===t.assignedVehicle)return t;
        fleetApplied=true;
        if(!vc)return{...t,assignedVehicle:"",plateNo:""};
        const vn=vehicles.find(v=>v.code===vc);
        return{...t,assignedVehicle:vc,plateNo:vn?vn.no:"",vehicle:vn?vn.type:t.vehicle};
      });
      // ★ 手動変更を保護: DB _changedがある場合はDB値が権威（他端末の変更を尊重）
      fixedWithFleet.forEach(t=>{
        const ls=lsMap[t._id];
        const dbChanged=t._changed||{};
        const lsChanged=(ls&&ls._changed)||{};
        // DB _changedを基本とし、DBにないLS独自の変更のみ追加
        const merged={...lsChanged,...dbChanged};
        if(Object.keys(merged).length){
          t._changed=merged;
          // LSにのみ存在する_changedフィールドはLS値を適用（DBに未到達のローカル変更）
          Object.keys(lsChanged).forEach(f=>{
            if(lsChanged[f]&&!dbChanged[f]&&ls[f]!==undefined&&ls[f]!==null&&f!=='_changed'&&f!=='opts'&&typeof ls[f]!=='object'){t[f]=ls[f];}
          });
        }
        if(ls){
          if(ls.place&&!t.place)t.place=ls.place;
          if(ls.colPlace&&!t.colPlace)t.colPlace=ls.colPlace;
        }
      });
      fixedWithFleet=fixedWithFleet.filter(t=>!_tomb.has(t._id));/* ★2026-07-16 墓標ガード: 削除済みは表示/永続化から除外(ゾンビ根絶) */
      if(fixedWithFleet.length!==saved.length||fixedWithFleet.some((t,i)=>t._id!==saved[i]?._id)||fleetApplied||removed.length){
        DB.upsertTasks(fixedWithFleet,date);
      } else {
        // ★ upsertTasksを呼ばない場合でも、マージ結果（_changed/place等）をLSに確実に保存
        DB._lsSave(fixedWithFleet,date);
      }
      setTasks(fixedWithFleet);return;
    }
    // 2. DBにタスクなし→自動生成
    let gen=generateTasks(reservations,date,fleetRef.current,vehicles);
    // ★2026-07-16 クラス③墓標ガード(根絶): DB空(全タスク削除含む)でも削除済みは再生成しない。失敗時は現状維持(fail-safe)。
    try{if(sb){const{data:_dd}=await sb.from("bt_tasks").select("_id").eq("date",date).eq("deleted",true);if(_dd&&_dd.length){const _tb=new Set(_dd.map(x=>x._id));gen=gen.filter(g=>!_tb.has(g._id));}}}catch(_e){}
    // ★ sheetPlacesから場所情報を補完
    gen.forEach(g=>{
      if(!g.reservationId)return;
      const sp=sheetPlaces[g.reservationId];
      if(sp&&!g.place){if(g.type==="DEL"&&sp.delPlace)g.place=sp.delPlace;if(g.type==="COL"&&sp.colPlace)g.place=sp.colPlace;}
      if(sp&&g.type==="DEL"&&!g.colPlace&&sp.colPlace)g.colPlace=sp.colPlace;
    });
    setTasks(gen);
    // 🛡 protect=true: 万一DBに既存行があってもスタッフ入力(担当/場所/時間)を焼き戻して上書き事故を防止
    if(gen.length)DB.upsertTasks(gen,date,{protect:true});
  },[reservations,vehicles]);
  useEffect(()=>{loadTasks(selDate,true);},[selDate]);
  // ★ 予約データ変更時（CSV入替等）にも現在日のタスクをリロード（キャンセル済みタスク除去等）
  // loadTasksはreservationsに依存するuseCallbackなので、reservations変更で自動的に再構築される
  // ただしselDateが変わらないとuseEffect[selDate]はトリガーしないため、別途トリガーが必要
  const prevResCountRef=React.useRef(-1);
  useEffect(()=>{
    const cnt=reservations.length;
    if(prevResCountRef.current>=0&&prevResCountRef.current!==cnt){
      console.log("[OPSheet] reservations changed:",prevResCountRef.current,"→",cnt,"reloading tasks");
      loadTasks(selDate,true);
    }
    prevResCountRef.current=cnt;
  },[reservations.length]);
  // Realtimeでタスク更新を受信（他端末の変更を反映）
  useEffect(()=>{
    if(!sb)return;
    let debounce=null;
    const ch=sb.channel("tasks-"+selDate)
      .on("postgres_changes",{event:"*",schema:"public",table:"bt_tasks",filter:"date=eq."+selDate},(payload)=>{
        const evtId=payload.new&&payload.new._id;
        if(evtId&&selfUpdatedIds.current.has(evtId)&&Date.now()-selfUpdatedIds.current.get(evtId)<3000){return;}
        selfUpdatedIds.current.forEach((ts,k)=>{if(Date.now()-ts>10000)selfUpdatedIds.current.delete(k);});
        clearTimeout(debounce);
        debounce=setTimeout(async()=>{
          // ★ DB取得前にLS読み取り（fetchTasksがLSを上書きする前に保持）
          const lsD=DB._lsLoad(selDate);
          const lm={};if(lsD)lsD.forEach(x=>{lm[x._id]=x;});
          const fresh=await DB.fetchTasks(selDate);
          if(fresh&&fresh.length){
            // ★ 手動変更保護: DB _changedが権威（他端末の変更を尊重）
            fresh.forEach(t=>{
              const ls=lm[t._id];
              const dbChanged=t._changed||{};
              const lsChanged=(ls&&ls._changed)||{};
              // DB優先でマージ（DBにある変更は上書きしない）
              const merged={...lsChanged,...dbChanged};
              if(Object.keys(merged).length){
                t._changed=merged;
                // LSにのみ存在する変更はLS値を適用（DBに未反映のローカル変更）
                Object.keys(lsChanged).forEach(f=>{
                  if(lsChanged[f]&&!dbChanged[f]&&ls[f]!==undefined&&ls[f]!==null&&f!=='_changed'&&f!=='opts'&&typeof ls[f]!=='object'){t[f]=ls[f];}
                });
              }
              if(ls){
                if(ls.place&&!t.place)t.place=ls.place;
                if(ls.colPlace&&!t.colPlace)t.colPlace=ls.colPlace;
              }
            });
            setTasks(fresh);
            DB._lsSave(fresh,selDate);
          }
        },500);
      }).subscribe();
    return()=>{clearTimeout(debounce);sb.removeChannel(ch);};
  },[selDate]);
