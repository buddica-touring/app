      const td2={...td,padding:"6px 10px",fontSize:12};

      // ===== E. 車両別P&L データ計算 =====
      const plFleetMap={};
      dbFleet.forEach(f=>{const rid=f.reservation_id;const vc=f.vehicle_code;if(rid&&vc)plFleetMap[rid]=vc;});
      const plVRevMap={};
