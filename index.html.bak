  const assignVehicle=(taskId,vehicleCode)=>{selfUpdatedIds.current.set(taskId,Date.now());const task=tasks.find(t=>t._id===taskId);if(!task)return;const v=vehicles.find(x=>x.code===vehicleCode);const updated={...task,assignedVehicle:vehicleCode,plateNo:v?v.no:""};setTasks(ts=>ts.map(x=>x._id===taskId?updated:x));DB.updateTask(updated,selDate);if(task.reservationId){onFleetChange(prev=>{const nf={...(typeof prev==="object"?prev:fleetRef.current)};if(vehicleCode)nf[task.reservationId]=vehicleCode;else delete nf[task.reservationId];return nf;});}if(v&&task.reservationId){DB.updateReservationField(task.reservationId,{vehicle:v.type},"配車変更→クラス同期","op_sheet");if(onReservationUpdate)onReservationUpdate(task.reservationId,{vehicle:v.type});}};
  const done=tasks.filter(t=>t.done).length;const staffCount=activeMembers.length;
