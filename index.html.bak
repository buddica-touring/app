  const dayButtons=useMemo(()=>{
    const arr=[];
    const active=reservations.filter(r=>r.status!=="cancelled");
    // 日付別 lend/return インデックス
    const lendByDate={};const retByDate={};
    active.forEach(r=>{
      if(r.lendDate){const k=norm(r.lendDate);(lendByDate[k]=lendByDate[k]||[]).push(r);}
      if(r.returnDate){const k=norm(r.returnDate);(retByDate[k]=retByDate[k]||[]).push(r);}
    });
    const fleetNow=fleetRef.current||{};
    for(let i=0;i<=60;i++){
      const d=dOff(today,i);
      const ds=shifts[d]||[];
      const dk=norm(d);
      const lendList=lendByDate[dk]||[];
      const retList=retByDate[dk]||[];
      // 予約タスク数 = lend(PU/DEL) + return(BD/COL)。同日貸出返却は2件扱い（generateTasksと一致）
      let tc=lendList.length+retList.length;
      // 洗車タスク = 翌日lendDate予約から生成（loadTasksと同じロジック）
      // 配車済み: 車両コード単位でユニーク / 未配車: 予約ID単位
      const tmr=dOff(d,1);
      const tmrList=lendByDate[norm(tmr)]||[];
      const washKeys=new Set();
      tmrList.forEach(r=>{
        const vc=fleetNow[r.id];
        washKeys.add(vc?("v:"+vc):("u:"+r.id));
      });
      tc+=washKeys.size;
      if(ds.length>0||tc>0||i<=2)arr.push({i,d,staff:ds.length,tc});
    }
    return arr;
  },[today,shifts,reservations,fleet]);
  // ★ PCキーボード ←/→ で前日/翌日へ移動（文字入力中・修飾キー時は無効）
  useEffect(()=>{
    const onKey=(e)=>{
      if(e.key!=="ArrowLeft"&&e.key!=="ArrowRight")return;
      if(e.ctrlKey||e.metaKey||e.altKey)return;
      const ae=document.activeElement;
      if(ae){const tn=(ae.tagName||"").toUpperCase();if(tn==="INPUT"||tn==="TEXTAREA"||tn==="SELECT"||ae.isContentEditable)return;}
      const minI=dayButtons.length?dayButtons[0].i:0;
      const maxI=dayButtons.length?dayButtons[dayButtons.length-1].i:60;
      const dir=e.key==="ArrowRight"?1:-1;
      const nx=Math.max(minI,Math.min(maxI,dayOff+dir));
      if(nx!==dayOff){e.preventDefault();setDayOff(nx);}
    };
    window.addEventListener("keydown",onKey);
    return()=>window.removeEventListener("keydown",onKey);
  },[dayButtons,dayOff]);
