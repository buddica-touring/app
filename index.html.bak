        E("div",{style:{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}},
          E("span",{style:{fontSize:12,fontWeight:800,color:"#d97706",flexShrink:0}},"🟡 半年点検未登録（6ヶ月以内） "+tenkenAlert.length+"台"),
          E("div",{style:{display:"flex",gap:4,flexWrap:"wrap"}},
            tenkenAlert.slice(0,8).map(function(v){return E("span",{key:v.code,style:{fontSize:10,padding:"2px 8px",borderRadius:6,background:"#fef9c3",color:"#92400e",fontWeight:600}},
              v.name+(nextTenken[v.code]?"→"+nextTenken[v.code].slice(5):"（未定）"));})
          ),
